---
/**
 * GardenMedallion — the compass reading of the bloom family.
 * The centre bloom uses --poppy-soft (SUCCESSION §19 pastel refinement,
 * 2026-07-07); lavender + blue at the cardinal points, marimekko yellow
 * at the south. Ring stroke uses --canopy at lower opacity for a whisper
 * register. Used as the Lexicon head mark and the Colophon seal near the
 * byline; both surfaces carry the same delicate palette after the fold.
 */
interface Props { size?: number; }
const { size = 120 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 180 180" class="medallion" aria-hidden="true">
  <circle cx="90" cy="90" r="72" fill="#efe8d6" stroke="var(--canopy)" stroke-width="1" opacity="0.9"/>
  <circle cx="90" cy="90" r="58" fill="none" stroke="var(--canopy)" stroke-width="0.5" opacity="0.35" stroke-dasharray="1.5 3"/>
  <g transform="translate(90 90)">
    <g fill="var(--poppy-soft)" opacity="0.92">
      <path d="M0 -18 C 7 -16, 8 -4, 0 3 C -8 -4, -7 -16, 0 -18 Z"/>
      <path d="M17 -8 C 19 1, 11 11, 3 7 C 0 -2, 8 -11, 17 -8 Z"/>
      <path d="M10 14 C 0 19, -8 11, -3 5 C 5 -1, 14 5, 10 14 Z"/>
      <path d="M-12 11 C -19 5, -14 -6, -6 -3 C -3 4, -8 12, -12 11 Z"/>
      <path d="M-15 -6 C -11 -14, -1 -12, -1 -5 C -6 4, -18 3, -15 -6 Z"/>
    </g>
    <path d="M0 -1 C -3 -4, -7 -2, -7 1 C -7 5, 0 8, 0 8 C 0 8, 7 5, 7 1 C 7 -2, 3 -4, 0 -1 Z" fill="#f7f2e7"/>
  </g>
  <g transform="translate(90 42)" opacity="0.82">
    <g fill="#b899c9">
      <ellipse cx="-5" cy="-2" rx="5" ry="8" transform="rotate(-30 -5 -2)"/>
      <ellipse cx="5" cy="-2" rx="5" ry="8" transform="rotate(30 5 -2)"/>
      <ellipse cx="0" cy="6" rx="5" ry="8"/>
    </g>
    <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
  </g>
  <g transform="translate(138 90)" opacity="0.8">
    <g fill="#a4b8c8"><path d="M0 -9 L 2 -3 L 8 -3 L 3 1 L 5 7 L 0 3 L -5 7 L -3 1 L -8 -3 L -2 -3 Z"/></g>
    <circle cx="0" cy="0" r="2.2" fill="#f7f2e7"/>
  </g>
  <g transform="translate(90 138)" opacity="0.8">
    <g fill="#e8c15a">
      <ellipse cx="-4" cy="-2" rx="4" ry="7" transform="rotate(-30 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4" ry="7" transform="rotate(30 4 -2)"/>
      <ellipse cx="0" cy="5" rx="4" ry="7"/>
    </g>
    <circle cx="0" cy="1" r="2.2" fill="#f7f2e7"/>
  </g>
  <g transform="translate(42 90)" opacity="0.82">
    <g fill="#b899c9">
      <ellipse cx="-5" cy="-2" rx="5" ry="8" transform="rotate(-30 -5 -2)"/>
      <ellipse cx="5" cy="-2" rx="5" ry="8" transform="rotate(30 5 -2)"/>
      <ellipse cx="0" cy="6" rx="5" ry="8"/>
    </g>
    <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
  </g>
  <circle cx="55" cy="55" r="1.1" fill="#b899c9" opacity="0.75"/>
  <circle cx="125" cy="55" r="1.1" fill="#e8c15a" opacity="0.75"/>
  <circle cx="125" cy="125" r="1.1" fill="#a4b8c8" opacity="0.75"/>
  <circle cx="55" cy="125" r="1.1" fill="#e8c15a" opacity="0.75"/>
</svg>
<style>
  .medallion { display: block; }
</style>
