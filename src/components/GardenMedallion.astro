---
/**
 * GardenMedallion — the compass reading of the ensō, four cardinal blooms
 * held inside the ring. Used as the Lexicon head mark and the Colophon seal
 * near the byline.
 */
import EnkaMark from "./EnkaMark.astro";
interface Props { size?: number; }
const { size = 120 } = Astro.props;
---
<EnkaMark size={size} ring="closed" hold="compass" />
