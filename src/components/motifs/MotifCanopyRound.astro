---
/**
 * The canopy round — shelter + circle.
 * A soft crown of foliage with dappled light-gaps (cream · yellow · blue);
 * trunk hairline; one poppy-soft bloom sheltered at the foot. Replaces
 * CanopyScene at the colophon foot. Part of the garden's motif set
 * (SUCCESSION §18). Pastel palette.
 */
interface Props { size?: number; }
const { size = 120 } = Astro.props;
const h = Math.round(size * 132 / 120);
---
<svg width={size} height={h} viewBox="0 0 100 110" aria-hidden="true">
  <path d="M50 12 C 22 12, 12 34, 18 52 C 24 68, 44 74, 50 74 C 56 74, 76 68, 82 52 C 88 34, 78 12, 50 12 Z" fill="var(--canopy)" opacity="0.72"/>
  <circle cx="34" cy="32" r="3" fill="var(--paper)" opacity="0.94"/>
  <circle cx="58" cy="28" r="2.4" fill="#e8c15a" opacity="0.78"/>
  <circle cx="46" cy="46" r="2" fill="#a4b8c8" opacity="0.78"/>
  <circle cx="66" cy="52" r="2.6" fill="var(--paper)" opacity="0.94"/>
  <path d="M50 74 L50 96" stroke="var(--canopy)" stroke-width="0.9" stroke-linecap="round" opacity="0.75"/>
  <circle cx="50" cy="98" r="3" fill="var(--poppy-soft)" opacity="0.92"/>
  <circle cx="50" cy="98" r="1" fill="var(--paper)"/>
  <path d="M20 102 C 50 100, 80 102, 90 102" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.45"/>
</svg>
