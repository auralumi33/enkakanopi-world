  <path d="M190 24 C 174 24, 168 42, 174 52 C 180 60, 200 60, 206 52 C 212 42, 206 24, 190 24 Z" fill="var(--canopy)" opacity="0.72"/>
  <circle cx="182" cy="34" r="2" fill="var(--paper)" opacity="0.94"/>
  <circle cx="196" cy="30" r="1.7" fill="#e8c15a" opacity="0.78"/>
  <circle cx="190" cy="44" r="1.7" fill="#a4b8c8" opacity="0.78"/>
