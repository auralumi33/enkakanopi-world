---
/**
 * The two hulls + braided seam — home hero inline doodle.
 * Replaces the clunky phrase "patience between the hulls" in the
 * .keystone paragraph. Softer warm-brown hulls (--ink-faint at whisper
 * opacity), tiny lavender + coral mastheads (feminine notch), calligraphic
 * braided seam between with a soft coral heart at center. Rhymes with
 * MotifBraidedSeam on Versions of Me (the "traffic between the versions"
 * idiom made portable). Part of the garden's motif set (SUCCESSION §20).
 * Pastel palette. Sits inline in prose at ~48px height.
 */
interface Props { size?: number; }
const { size = 72 } = Astro.props;
const h = Math.round(size * 60 / 110);
---
<svg width={size} height={h} viewBox="0 0 110 60" aria-hidden="true">
  <!-- left hull -->
  <path d="M10 26 C 12 34, 22 36, 30 36 C 34 36, 36 34, 36 26 C 32 24, 14 24, 10 26 Z" fill="var(--ink-faint)" opacity="0.55"/>
  <path d="M20 26 L20 12" stroke="var(--ink-faint)" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
  <!-- feminine lavender bud at left masthead -->
  <circle cx="20" cy="10" r="1.6" fill="#b899c9" opacity="0.9"/>
  <!-- right hull -->
  <path d="M74 26 C 76 34, 86 36, 94 36 C 98 36, 100 34, 100 26 C 96 24, 78 24, 74 26 Z" fill="var(--ink-faint)" opacity="0.55"/>
  <path d="M84 26 L84 12" stroke="var(--ink-faint)" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
  <!-- feminine coral bud at right masthead -->
  <circle cx="84" cy="10" r="1.6" fill="var(--poppy-soft)" opacity="0.9"/>
  <!-- braided seam between (calligraphic) -->
  <path d="M38 30 C 46 22, 54 38, 72 30" stroke="var(--ink-faint)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.6"/>
  <path d="M38 30 C 46 38, 54 22, 72 30" stroke="#b899c9" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.55" stroke-dasharray="1.5 2"/>
  <!-- soft coral heart at seam center -->
  <circle cx="55" cy="30" r="1.8" fill="var(--poppy-soft)" opacity="0.85"/>
  <!-- water ripple -->
  <path d="M4 46 C 22 44, 42 48, 66 46 C 88 44, 104 48, 108 46" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.45"/>
</svg>
