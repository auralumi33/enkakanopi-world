---
/**
 * The sheltered bloom — shelter + bloom.
 * Marimekko poppy nestled beneath a soft canopy arc; the one held gesture
 * on the surface it lives on. Part of the garden's motif set
 * (SUCCESSION §18). Pastel-refined palette: canopy-soft leaves, poppy-soft
 * held bloom, bloom-family sprinkles at whisper opacity. House tokens where
 * possible; bloom-family hexes direct per DESIGN-SYSTEM.md §Named idioms.
 */
interface Props { size?: number; }
const { size = 140 } = Astro.props;
const w = size;
const h = Math.round(size * 108 / 140);
---
<svg width={w} height={h} viewBox="0 0 130 100" aria-hidden="true">
  <path d="M12 46 C 30 20, 50 16, 65 22 C 82 15, 102 20, 118 42" stroke="var(--canopy)" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.68"/>
  <path d="M32 26 C 40 20, 48 24, 46 32 C 40 36, 30 32, 32 26 Z" fill="var(--canopy-soft)" opacity="0.88"/>
  <path d="M62 18 C 72 14, 78 20, 74 28 C 66 30, 58 24, 62 18 Z" fill="var(--canopy-soft)" opacity="0.92"/>
  <path d="M90 24 C 98 20, 104 26, 100 34 C 92 36, 84 30, 90 24 Z" fill="var(--canopy-soft)" opacity="0.88"/>
  <circle cx="112" cy="16" r="1.6" fill="#e8c15a" opacity="0.75"/>
  <circle cx="18" cy="18" r="1.6" fill="#b899c9" opacity="0.75"/>
  <circle cx="46" cy="54" r="1.4" fill="#a4b8c8" opacity="0.75"/>
  <path d="M65 78 L65 66" stroke="var(--canopy)" stroke-width="0.9" stroke-linecap="round" opacity="0.68"/>
  <g transform="translate(65 62)">
    <path d="M-9 -3 C -13 -12, -3 -14, 0 -7 C -3 -3, -8 -1, -9 -3 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M9 -4 C 11 -11, 3 -13, 0 -7 C 3 -3, 8 -1, 9 -4 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M-6 5 C -11 3, -11 -3, -5 -3 C -2 -1, -3 4, -6 5 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M6 4 C 11 2, 11 -3, 5 -3 C 2 -1, 3 4, 6 4 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <circle cx="0" cy="-2" r="2" fill="var(--paper)"/>
  </g>
  <path d="M20 82 C 65 80, 110 82, 118 82" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.45"/>
</svg>
