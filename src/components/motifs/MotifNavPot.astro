---
/**
 * MotifNavPot — the little potted plant standing in for the "i" in the
 * kan(ensō)p(pot) lockup. Same trapezoidal pot + single stem + five-petal
 * bloom grammar as `MotifNurseryPot`/`Bloom`/`RowPlanter`, but the bloom is
 * scaled up 1.4× around its own centre and full-opacity — a statement
 * flourish at this scale, not the dainty whisper the same petal shape
 * plays elsewhere. Tight viewBox (little dead space) so it sits flush
 * against the wordmark. Aria-hidden — a companion mark, not a second logo.
 */
interface Props { size?: number }
const { size = 30 } = Astro.props;
---
<svg width={size} height={size} viewBox="16 6 27 54" preserveAspectRatio="xMidYMax meet" aria-hidden="true" class="nav-pot">
  <path d="M20 50 L40 50 L37 58 L23 58 Z" fill="var(--canopy-deep)" opacity="0.85" />
  <path d="M19 50 L41 50" stroke="var(--canopy-deep)" stroke-width="1.2" opacity="0.9" />
  <path d="M30 50 L30 26" stroke="var(--canopy-deep)" stroke-width="1.3" stroke-linecap="round" opacity="0.85" />
  <path d="M30 38 C 25 34, 21 36, 23 42 C 27 44, 30 42, 30 38 Z" fill="var(--canopy-soft)" opacity="0.9" />
  <path d="M30 32 C 35 28, 39 30, 37 36 C 33 38, 30 36, 30 32 Z" fill="var(--canopy-soft)" opacity="0.9" />
  {/* the bloom, scaled 1.4× around its own centre (30,17) — bigger, bolder,
      full opacity so it reads as the statement piece, not a whisper.
      #e46b6b — the bloom-family coral, not var(--poppy)/#cf4a45 (that's
      reserved for the prose register per SUCCESSION §18.3). */}
  <g transform="translate(30 17) scale(1.4) translate(-30 -17)">
    <g fill="#e46b6b" opacity="1">
      <path d="M30 10 C 33 10.8, 33.6 16.6, 30 18.8 C 26.4 16.6, 27 10.8, 30 10 Z" />
      <path d="M35.6 14.4 C 38.8 16.6, 37.4 21.8, 32.8 20.6 C 31.2 17.8, 33 13.4, 35.6 14.4 Z" />
      <path d="M32.6 24.2 C 28.6 27.4, 23.4 25, 25 20.6 C 29.2 18.8, 33.4 20.6, 32.6 24.2 Z" />
      <path d="M24.4 22.6 C 21.2 20.4, 22.6 15.2, 27.2 16.4 C 28.8 19.2, 27 23.6, 24.4 22.6 Z" />
      <path d="M24.8 14.4 C 28.8 13.4, 32 17.4, 30 20.6 C 25.8 21.4, 22.4 17.8, 24.8 14.4 Z" />
    </g>
    <circle cx="30" cy="17" r="2.6" fill="var(--paper)" />
  </g>
</svg>
<style>
  .nav-pot { display: block; }
</style>
