---
/**
 * SceneInsideLife — Marimekko × fine-line hybrid scene.
 * Reisman: "Our outside lives begin on the skin's surface... medical
 * training necessarily centers on the body's inside life." A Marimekko
 * silhouette of a body-like curve — the skin surface hairline-drawn as
 * a diagnostic outline — with a soft bloom scatter INSIDE the silhouette
 * (the inside life). A dragonfly hovers outside brushing the skin, a
 * hairline "diagnosis" tick above.
 * For: field-notes/the-silent-workspace · SUCCESSION §26.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 320" role="img" aria-labelledby="inside-t" preserveAspectRatio="xMidYMid meet">
    <title id="inside-t">A hand-drawn body silhouette with an inside life of soft blooms; a dragonfly hovers outside the skin.</title>

    {/* the body silhouette — Marimekko-scale soft oval, canopy-soft fill */}
    <path d="M320 44 C 400 44, 430 100, 428 160 C 426 220, 410 264, 372 280 C 342 292, 296 292, 268 280 C 230 264, 214 220, 212 160 C 210 100, 240 44, 320 44 Z"
      fill="#a4b8c8" opacity="0.2"/>

    {/* the skin — hairline diagnostic outline */}
    <path d="M320 44 C 400 44, 430 100, 428 160 C 426 220, 410 264, 372 280 C 342 292, 296 292, 268 280 C 230 264, 214 220, 212 160 C 210 100, 240 44, 320 44 Z"
      stroke="var(--ink-soft)" stroke-width="0.7" fill="none" opacity="0.7"/>

    {/* the inside life — soft bloom scatter inside the silhouette */}
    <g transform="translate(280 130)">
      <g fill="#b899c9" opacity="0.72">
        <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
        <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        <ellipse cx="0" cy="4" rx="4" ry="6"/>
      </g>
      <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
    </g>
    <g transform="translate(360 180)">
      <g fill="#e46b6b" opacity="0.75">
        <path d="M0 -8 C 3 -7, 4 -1, 0 1 C -4 -1, -3 -7, 0 -8 Z"/>
        <path d="M8 -3 C 9 2, 4 7, 1 5 C 0 -1, 5 -5, 8 -3 Z"/>
        <path d="M5 7 C 0 9, -4 6, -1 3 C 3 0, 7 2, 5 7 Z"/>
        <path d="M-6 6 C -9 3, -6 -2, -3 -1 C -1 3, -4 7, -6 6 Z"/>
        <path d="M-8 -2 C -5 -7, -1 -6, 0 -2 C -2 2, -8 2, -8 -2 Z"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(302 224)">
      <g fill="#e8c15a" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>

    {/* faint interior ticks — the intermediate signals only sometimes verbalised */}
    <g stroke="var(--ink-soft)" stroke-width="0.35" stroke-linecap="round" opacity="0.5">
      <path d="M340 90 L 342 92"/>
      <path d="M256 160 L 258 162"/>
      <path d="M400 200 L 402 202"/>
      <path d="M330 250 L 332 252"/>
    </g>

    {/* the dragonfly — outside the skin, delicate visitor */}
    <g transform="translate(148 130)">
      <path d="M0 -8 L 0 12" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linecap="round" opacity="0.72"/>
      <ellipse cx="-11" cy="-2" rx="11" ry="3.4" transform="rotate(-22 -11 -2)" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.65"/>
      <ellipse cx="11" cy="-2" rx="11" ry="3.4" transform="rotate(22 11 -2)" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.65"/>
      <ellipse cx="-8" cy="6" rx="8" ry="2.6" transform="rotate(18 -8 6)" stroke="var(--ink-soft)" stroke-width="0.45" fill="none" opacity="0.6"/>
      <ellipse cx="8" cy="6" rx="8" ry="2.6" transform="rotate(-18 8 6)" stroke="var(--ink-soft)" stroke-width="0.45" fill="none" opacity="0.6"/>
      <circle cx="0" cy="0" r="1" fill="var(--poppy-soft)" opacity="0.9"/>
    </g>

    {/* the diagnosis tick — a small fine-line cross-plus above the body */}
    <g transform="translate(530 60)" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.7">
      <path d="M0 -6 L 0 6"/>
      <path d="M-6 0 L 6 0"/>
    </g>
    <circle cx="530" cy="60" r="0.9" fill="#e8c15a" opacity="0.9"/>

    {/* fine-line "reading axis" — from dragonfly toward the middle inside */}
    <path d="M168 128 C 200 128, 240 130, 268 132"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" stroke-dasharray="1.2 2" opacity="0.55"/>

    {/* scatter */}
    <circle cx="90" cy="60" r="0.8" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="560" cy="270" r="0.6" fill="var(--ink-soft)" opacity="0.55"/>
    <circle cx="500" cy="290" r="0.4" fill="var(--ink-soft)" opacity="0.5"/>

    {/* hand captions */}
    <text class="hand-label" x="88" y="152" font-size="15">the outside life</text>
    <text class="hand-label" x="88" y="170" font-size="15" opacity="0.65">begins on the skin</text>
    <text class="hand-label" x="454" y="180" font-size="15">the inside life —</text>
    <text class="hand-label hand-label--accent" x="454" y="200" font-size="15">held long enough to become</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
