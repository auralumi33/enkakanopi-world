---
/**
 * SceneShelfOfImpossible — Marimekko × fine-line hybrid scene.
 * The shelf where the impossible things lived — specifically named:
 * a rolled magic carpet, Neuromancer's console cowboys (a small
 * terminal + a book spine), and the 1980 Brave New World (a small
 * cathode-ray TV silhouette on a stand). All on a tilted hairline
 * shelf. §27 redraw — object-poetry, not sparkle-stars. Each object
 * is drawn once, holds its own meaning, and does not repeat.
 * For: field-notes/a-fiction-we-grew-up-inside.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 300" role="img" aria-labelledby="shelf-t" preserveAspectRatio="xMidYMid meet">
    <title id="shelf-t">A tilted hairline shelf holding four impossible things — a rolled magic carpet, a book spine of Neuromancer, a small cathode-ray television for Brave New World, and a terminal for the console cowboys.</title>

    {/* the shelf plank — hairline calligraphic, tilted right (the metaphor) */}
    <path d="M40 216 L 600 188"
      stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.75"/>
    <path d="M42 220 L 600 192"
      stroke="var(--ink-soft)" stroke-width="0.45" fill="none" stroke-linecap="round" opacity="0.5"/>
    {/* the two shelf brackets — hairline supports */}
    <path d="M76 216 L 82 250" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.55"/>
    <path d="M560 190 L 566 226" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.55"/>

    {/* Object 1 — the rolled magic carpet (Marimekko-patterned roll) */}
    <g transform="translate(112 178) rotate(-2)">
      {/* the roll body — coral silhouette */}
      <rect x="-40" y="-6" width="80" height="16" rx="8" fill="#e46b6b" opacity="0.68"/>
      {/* pattern bands inside — hairline stripes suggesting the woven carpet */}
      <path d="M-32 -3 L 32 -3 M-32 2 L 32 2 M-32 7 L 32 7"
        stroke="#f7f2e7" stroke-width="0.6" fill="none" opacity="0.85"/>
      {/* the ends of the roll — hairline cap-circles */}
      <circle cx="-40" cy="2" r="8" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.65"/>
      <circle cx="40" cy="2" r="8" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.65"/>
      {/* a tiny lavender bloom at the roll's end — the carpet's terminal weave */}
      <circle cx="-40" cy="2" r="2" fill="#b899c9" opacity="0.85"/>
    </g>

    {/* Object 2 — the book spine (Neuromancer) */}
    <g transform="translate(232 166) rotate(-2.2)">
      {/* the spine — slate rectangle */}
      <rect x="-8" y="-30" width="16" height="60" fill="#a4b8c8" opacity="0.72"/>
      {/* the top + bottom rules */}
      <path d="M-8 -24 L 8 -24 M-8 24 L 8 24" stroke="#f7f2e7" stroke-width="0.55" opacity="0.85"/>
      {/* hairline vertical text-block outline (a book's title band) */}
      <rect x="-5" y="-14" width="10" height="30" stroke="#f7f2e7" stroke-width="0.4" fill="none" opacity="0.75"/>
      {/* a tiny gold accent — the spine's foil-stamped tick */}
      <circle cx="0" cy="20" r="1.1" fill="#e8c15a" opacity="0.9"/>
    </g>

    {/* Object 3 — the 1980 cathode-ray TV silhouette (Brave New World) */}
    <g transform="translate(354 156) rotate(-2.5)">
      {/* the TV body — soft-canopy silhouette, rounded */}
      <rect x="-32" y="-24" width="64" height="48" rx="4" fill="#a4b8c8" opacity="0.68"/>
      {/* the screen — inset hairline */}
      <rect x="-24" y="-18" width="48" height="34" rx="2" stroke="var(--ink-soft)" stroke-width="0.55" fill="#f7f2e7" opacity="0.7"/>
      {/* the screen's soft-serious silhouette — a tiny figure inside (the very serious voiceover) */}
      <ellipse cx="0" cy="-2" rx="6" ry="8" fill="#a4b8c8" opacity="0.4"/>
      <circle cx="0" cy="-8" r="2.4" fill="#a4b8c8" opacity="0.55"/>
      {/* the dial + antennae */}
      <circle cx="20" cy="18" r="1.6" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.7"/>
      <path d="M-14 -24 L -18 -34" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.65"/>
      <path d="M14 -24 L 18 -34" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.65"/>
      {/* two small feet */}
      <path d="M-18 24 L -18 30 M18 24 L 18 30" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.65"/>
    </g>

    {/* Object 4 — the terminal (Neuromancer's console cowboys) */}
    <g transform="translate(482 162) rotate(-3)">
      {/* the terminal shell — Marimekko lavender + hairline outline */}
      <rect x="-30" y="-18" width="60" height="36" rx="3" fill="#b899c9" opacity="0.68"/>
      <rect x="-30" y="-18" width="60" height="36" rx="3" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.72"/>
      {/* the screen — inset dark rectangle */}
      <rect x="-24" y="-13" width="48" height="20" fill="#4f5b3f" opacity="0.85"/>
      {/* the cursor blink — a tiny gold rectangle */}
      <rect x="-20" y="-6" width="3" height="1.5" fill="#e8c15a" opacity="0.95"/>
      {/* hairline prompt-line marks */}
      <path d="M-16 -5 L 4 -5 M-16 -1 L 10 -1 M-16 3 L -6 3"
        stroke="#e8c15a" stroke-width="0.5" opacity="0.7"/>
      {/* the base line + tiny keys */}
      <path d="M-22 12 L 22 12" stroke="var(--ink-soft)" stroke-width="0.4" opacity="0.6"/>
      <path d="M-14 15 L -6 15 M-2 15 L 6 15 M10 15 L 18 15"
        stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.65"/>
    </g>

    {/* the shelf-tilt gesture — a fine calligraphic sweep below the plank */}
    <path d="M60 244 C 200 250, 380 236, 540 230 C 580 228, 600 232, 610 236"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.55"/>

    {/* the shelf's tilt-mark — a small chevron indicating the tilt-angle */}
    <path d="M580 262 L 596 258 L 590 268"
      stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.55"/>

    {/* a tiny poppy at the shelf's low-end — where the impossible things now sit */}
    <circle cx="72" cy="240" r="1.2" fill="var(--poppy-soft)" opacity="0.88"/>

    {/* hand captions */}
    <text class="hand-label" x="86" y="98" font-size="16">a shelf where the</text>
    <text class="hand-label" x="86" y="118" font-size="16">impossible things lived —</text>
    <text class="hand-label hand-label--accent" x="440" y="106" font-size="16">tilting.</text>
    <text class="hand-label" x="98" y="272" font-size="14">the carpet · the book · the screen · the console</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
