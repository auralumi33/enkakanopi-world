---
/**
 * The pinned cluster — Volume I · cluster-break motif.
 * A small paper tag held by a hairline pin at top, with a poppy-soft bloom
 * hanging beneath. Sits between theme clusters ("home & the rebuild" · "the
 * machines" · "the selves" · "the hands" · "the body") on the archive wall.
 * Part of the garden's motif set (SUCCESSION §19). Pastel palette.
 */
interface Props { size?: number; }
const { size = 96 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 100" aria-hidden="true">
  <path d="M50 12 L50 22" stroke="var(--ink-soft)" stroke-width="0.9" stroke-linecap="round" opacity="0.6"/>
  <circle cx="50" cy="12" r="1.8" fill="var(--ink-faint)" opacity="0.7"/>
  <path d="M30 22 L70 22 L70 62 L60 72 L30 72 Z" fill="var(--paper-deep)" stroke="var(--ink-faint)" stroke-width="0.7" opacity="0.78"/>
  <path d="M70 62 L60 62 L60 72" stroke="var(--ink-faint)" stroke-width="0.7" fill="none" opacity="0.6"/>
  <path d="M50 72 L50 80" stroke="var(--canopy)" stroke-width="0.8" stroke-linecap="round" opacity="0.7"/>
  <g transform="translate(50 84)">
    <path d="M-5 -2 C -7 -6, -2 -8, 0 -4 C -2 -2, -5 -1, -5 -2 Z" fill="var(--poppy-soft)" opacity="0.9"/>
    <path d="M5 -2 C 7 -6, 2 -8, 0 -4 C 2 -2, 5 -1, 5 -2 Z" fill="var(--poppy-soft)" opacity="0.9"/>
    <path d="M-3 3 C -6 2, -6 -1, -3 -1 C -1 0, -1 2, -3 3 Z" fill="var(--poppy-soft)" opacity="0.9"/>
    <path d="M3 3 C 6 2, 6 -1, 3 -1 C 1 0, 1 2, 3 3 Z" fill="var(--poppy-soft)" opacity="0.9"/>
    <circle cx="0" cy="-1" r="1" fill="var(--paper)"/>
  </g>
</svg>
