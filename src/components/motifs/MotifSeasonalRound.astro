---
/**
 * The seasonal round — circular self-completing cycles.
 * Four cardinal beats on a dashed round: seed (N) · sprout (E) · bloom (S)
 * · seed-pod (W), with 円 kanji hint at centre. Literalises the name-thesis
 * "blooms in circular, self-completing cycles." Part of the garden's motif
 * set (SUCCESSION §18). Pastel palette.
 */
interface Props { size?: number; }
const { size = 130 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 120 120" aria-hidden="true">
  <circle cx="60" cy="60" r="42" stroke="var(--canopy-soft)" stroke-width="0.8" fill="none" stroke-dasharray="1.5 3" opacity="0.7"/>
  <ellipse cx="60" cy="20" rx="3" ry="4" fill="var(--ink-soft)" opacity="0.6"/>
  <path d="M100 60 L100 52" stroke="var(--canopy)" stroke-width="1.1" stroke-linecap="round" opacity="0.85"/>
  <path d="M100 56 C 96 54, 94 55, 96 58 C 98 59, 100 57, 100 56 Z" fill="var(--canopy-soft)" opacity="0.92"/>
  <circle cx="102" cy="50" r="1.4" fill="#b899c9" opacity="0.8"/>
  <g transform="translate(60 100)">
    <path d="M-5 -2 C -7 -6, -2 -8, 0 -4 C -2 -2, -5 -1, -5 -2 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M5 -2 C 7 -6, 2 -8, 0 -4 C 2 -2, 5 -1, 5 -2 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M-3 3 C -6 2, -6 -1, -3 -1 C -1 0, -1 2, -3 3 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M3 3 C 6 2, 6 -1, 3 -1 C 1 0, 1 2, 3 3 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <circle cx="0" cy="-1" r="1" fill="var(--paper)"/>
  </g>
  <ellipse cx="20" cy="60" rx="4" ry="3" fill="#a4b8c8" opacity="0.78"/>
  <path d="M20 60 L14 60" stroke="var(--ink-soft)" stroke-width="0.8" opacity="0.6"/>
  <circle cx="88" cy="32" r="1.2" fill="#e8c15a" opacity="0.8"/>
  <circle cx="32" cy="32" r="1.2" fill="#b899c9" opacity="0.8"/>
  <text x="60" y="65" text-anchor="middle" font-family='"Newsreader", serif' font-size="12" fill="var(--ink-faint)" opacity="0.55">円</text>
</svg>
