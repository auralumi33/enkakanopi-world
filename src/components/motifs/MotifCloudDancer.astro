---
/**
 * The cloud + arms-raised dancer — home hero inline doodle.
 * Replaces the clunky phrase "dancing under the weight of the clouds" in
 * the .sub paragraph. Dainty stick-figure register: simple round head,
 * curved arms up, skirt-drape, small yellow star between the arms,
 * poppy-soft heart. Part of the garden's motif set (SUCCESSION §20 · the
 * mixed pastel register). Pastel palette; sits inline in prose at ~48px
 * height via CSS vertical-align: middle.
 */
interface Props { size?: number; }
const { size = 48 } = Astro.props;
const h = Math.round(size * 120 / 100);
---
<svg width={size} height={h} viewBox="0 0 100 120" aria-hidden="true">
  <!-- cloud outline (fine-line hairline) -->
  <path d="M28 18 C 24 18, 22 14, 26 12 C 28 6, 38 6, 40 12 C 50 8, 58 12, 58 18 C 64 18, 66 24, 58 24 L 28 24 C 22 24, 22 18, 28 18 Z"
    stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.72"/>
  <!-- yellow star between the raised arms -->
  <path d="M50 40 L 52 46 L 58 46 L 53 50 L 55 56 L 50 52 L 45 56 L 47 50 L 42 46 L 48 46 Z"
    fill="#e8c15a" opacity="0.9"/>
  <!-- head -->
  <circle cx="50" cy="66" r="3" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" opacity="0.78"/>
  <!-- body -->
  <path d="M50 70 C 51 78, 49 86, 50 94" stroke="var(--ink-soft)" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.78"/>
  <!-- arms raised -->
  <path d="M50 72 C 44 62, 40 56, 38 50" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.75"/>
  <path d="M50 72 C 56 62, 60 56, 62 50" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.75"/>
  <!-- skirt -->
  <path d="M48 94 C 42 100, 38 106, 36 112" stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.72"/>
  <path d="M52 94 C 58 100, 62 106, 64 112" stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.72"/>
  <path d="M36 112 C 44 114, 56 114, 64 112" stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.68"/>
  <!-- vine flourish to the side -->
  <path d="M64 114 C 72 114, 78 112, 82 106" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.6"/>
  <path d="M76 110 C 78 108, 80 106, 80 104" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.55"/>
  <!-- poppy-soft heart at chest -->
  <circle cx="50" cy="78" r="1.2" fill="var(--poppy-soft)" opacity="0.9"/>
</svg>
