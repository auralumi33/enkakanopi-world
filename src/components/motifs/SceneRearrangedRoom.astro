---
/**
 * SceneRearrangedRoom — Marimekko × fine-line hybrid scene.
 * "Some events do not resolve into opinion. They rearrange the room and
 * leave you standing in it." A floor-plan-like Marimekko rectangle with
 * soft bloom clusters repositioned + a fine-line dashed path that used to
 * lead one way now traced somewhere else + a tiny dragonfly at the new
 * landing point. Marimekko silhouettes (bloom clusters as "furniture")
 * blended with hairline dashed calligraphic wanders.
 * For: field-notes/a-fiction-we-grew-up-inside · SUCCESSION §26.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 320" role="img" aria-labelledby="room-t" preserveAspectRatio="xMidYMid meet">
    <title id="room-t">A hand-drawn floor plan of a rearranged room; a former path and a new one, small bloom clusters as furniture.</title>

    {/* the room outline — hairline calligraphic rectangle, slightly imperfect */}
    <path d="M60 60 L 580 58 L 582 268 L 62 270 Z"
      stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linejoin="round" opacity="0.68"/>

    {/* the door — a small break in the top edge */}
    <path d="M260 58 L 260 40 L 340 40 L 340 58"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.6" stroke-linecap="round"/>
    <path d="M260 40 A 40 40 0 0 1 300 58"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-dasharray="1.2 2" opacity="0.5"/>

    {/* the room's former layout — bloom clusters where they used to sit (faded) */}
    <g opacity="0.35">
      <g transform="translate(140 130)">
        <g fill="#b899c9">
          <ellipse cx="-6" cy="-3" rx="6" ry="9" transform="rotate(-25 -6 -3)"/>
          <ellipse cx="6" cy="-3" rx="6" ry="9" transform="rotate(25 6 -3)"/>
          <ellipse cx="0" cy="6" rx="6" ry="9"/>
        </g>
        <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
      </g>
      <g transform="translate(460 160)">
        <g fill="#e8c15a">
          <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
          <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        </g>
        <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
      </g>
    </g>

    {/* the room's new layout — the same clusters, repositioned */}
    <g transform="translate(200 200)">
      <g fill="#b899c9" opacity="0.72">
        <ellipse cx="-6" cy="-3" rx="6" ry="9" transform="rotate(-25 -6 -3)"/>
        <ellipse cx="6" cy="-3" rx="6" ry="9" transform="rotate(25 6 -3)"/>
        <ellipse cx="0" cy="6" rx="6" ry="9"/>
      </g>
      <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(400 110)">
      <g fill="#e8c15a" opacity="0.72">
        <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
        <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        <ellipse cx="0" cy="4" rx="4" ry="6"/>
      </g>
      <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
    </g>
    <g transform="translate(320 220)">
      <g fill="#e46b6b" opacity="0.75">
        <path d="M0 -8 C 3 -7, 4 -1, 0 1 C -4 -1, -3 -7, 0 -8 Z"/>
        <path d="M8 -3 C 9 2, 4 7, 1 5 C 0 -1, 5 -5, 8 -3 Z"/>
        <path d="M5 7 C 0 9, -4 6, -1 3 C 3 0, 7 2, 5 7 Z"/>
        <path d="M-6 6 C -9 3, -6 -2, -3 -1 C -1 3, -4 7, -6 6 Z"/>
        <path d="M-8 -2 C -5 -7, -1 -6, 0 -2 C -2 2, -8 2, -8 -2 Z"/>
      </g>
      <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
    </g>

    {/* the former path — where the walker used to go (faded dashed) */}
    <path d="M300 58 C 260 90, 200 108, 140 130 C 160 156, 300 158, 460 160"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" stroke-dasharray="1 2" opacity="0.3"/>

    {/* the new path — where the walker now goes (fine-line calligraphic) */}
    <path d="M300 58 C 280 110, 240 160, 200 200 C 260 214, 330 222, 400 110"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" stroke-dasharray="1.4 2.6" opacity="0.65"/>

    {/* the dragonfly — the small delicate visitor at the new landing point */}
    <g transform="translate(400 90)">
      <path d="M0 -6 L 0 8" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.7"/>
      <ellipse cx="-8" cy="-2" rx="8" ry="2.6" transform="rotate(-22 -8 -2)" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.6"/>
      <ellipse cx="8" cy="-2" rx="8" ry="2.6" transform="rotate(22 8 -2)" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.6"/>
      <ellipse cx="-6" cy="4" rx="6" ry="2" transform="rotate(18 -6 4)" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" opacity="0.55"/>
      <ellipse cx="6" cy="4" rx="6" ry="2" transform="rotate(-18 6 4)" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" opacity="0.55"/>
      <circle cx="0" cy="0" r="0.9" fill="var(--poppy-soft)" opacity="0.85"/>
    </g>

    {/* scatter dots */}
    <circle cx="90" cy="80" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
    <circle cx="550" cy="248" r="0.6" fill="var(--ink-soft)" opacity="0.55"/>
    <circle cx="88" cy="248" r="0.8" fill="var(--poppy-soft)" opacity="0.85"/>

    {/* hand captions */}
    <text class="hand-label" x="106" y="146" font-size="15" opacity="0.5">where it used to sit</text>
    <text class="hand-label" x="176" y="230" font-size="15">where it sits now</text>
    <text class="hand-label" x="424" y="88" font-size="15">still standing</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
