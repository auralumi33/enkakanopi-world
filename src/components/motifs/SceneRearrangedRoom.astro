---
/**
 * SceneRearrangedRoom — Marimekko × fine-line hybrid scene.
 * "They rearrange the room and leave you standing in it." A hairline
 * floor-plan with the *actual furniture* Rika keeps in the essay's
 * register — a lamp, a small table, a chair, a bed-shape — each
 * ghosted where they used to sit and drawn crisply where they sit
 * now, with a small hand-drawn figure standing in the doorway,
 * facing the rearrangement. §27 redraw — object-poetry, not
 * dragonfly. Everything is essay-specific.
 * For: field-notes/a-fiction-we-grew-up-inside.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 340" role="img" aria-labelledby="room-t" preserveAspectRatio="xMidYMid meet">
    <title id="room-t">A hand-drawn floor plan of a room where the furniture has been rearranged; ghost outlines of former positions and crisp new positions, with a small figure standing in the doorway.</title>

    {/* the room outline — hairline calligraphic, slightly imperfect */}
    <path d="M60 60 L 580 58 L 582 288 L 62 290 Z"
      stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linejoin="round" opacity="0.7"/>

    {/* the door — a break in the top edge, hinged open */}
    <path d="M260 58 L 260 40 L 340 40 L 340 58"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.6" stroke-linecap="round"/>
    <path d="M260 58 L 296 22"
      stroke="var(--ink-soft)" stroke-width="0.45" fill="none" stroke-linecap="round" opacity="0.55"/>
    <path d="M260 58 A 42 42 0 0 1 300 22"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-dasharray="1.2 2.4" opacity="0.5"/>

    {/* ─── FORMER positions — ghosted (opacity 0.28) ─── */}
    <g opacity="0.28">
      {/* the lamp — was in top-left */}
      <g transform="translate(130 128)">
        <path d="M-8 -14 L 8 -14 L 6 -4 L -6 -4 Z" fill="#e8c15a"/>
        <path d="M0 -4 L 0 22" stroke="var(--ink-soft)" stroke-width="0.7" stroke-linecap="round"/>
        <ellipse cx="0" cy="24" rx="12" ry="2" fill="var(--ink-soft)"/>
      </g>
      {/* the small table — was in top-right */}
      <g transform="translate(460 130)">
        <rect x="-24" y="-6" width="48" height="12" fill="#a4b8c8"/>
        <path d="M-22 6 L -22 22 M22 6 L 22 22" stroke="var(--ink-soft)" stroke-width="0.7"/>
      </g>
      {/* the chair — was in bottom-left */}
      <g transform="translate(140 230)">
        <path d="M-10 -14 L 10 -14 L 10 6 L -10 6 Z" stroke="var(--ink-soft)" stroke-width="0.7" fill="none"/>
        <path d="M-10 -14 L -10 -30 L 10 -30 L 10 -14" stroke="var(--ink-soft)" stroke-width="0.7" fill="none"/>
        <path d="M-8 6 L -8 22 M8 6 L 8 22" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linecap="round"/>
      </g>
      {/* the small bed / cot — was in bottom-right */}
      <g transform="translate(460 236)">
        <rect x="-38" y="-14" width="76" height="30" rx="3" fill="#b899c9"/>
        <ellipse cx="-24" cy="-6" rx="8" ry="4" fill="#f7f2e7"/>
      </g>
    </g>

    {/* ─── NEW positions — crisp (opacity 0.72) ─── */}
    {/* the lamp — moved to bottom-left (closer to the reader) */}
    <g transform="translate(150 250)" opacity="0.85">
      <path d="M-8 -14 L 8 -14 L 6 -4 L -6 -4 Z" fill="#e8c15a" opacity="0.85"/>
      <path d="M0 -4 L 0 22" stroke="var(--ink-soft)" stroke-width="0.8" stroke-linecap="round" opacity="0.72"/>
      <ellipse cx="0" cy="24" rx="12" ry="2.4" fill="var(--ink-soft)" opacity="0.55"/>
      {/* a small glow — the lamp is on */}
      <ellipse cx="0" cy="-10" rx="18" ry="12" fill="#e8c15a" opacity="0.22"/>
    </g>
    {/* the small table — moved to top-centre */}
    <g transform="translate(340 118)" opacity="0.85">
      <rect x="-30" y="-8" width="60" height="14" fill="#a4b8c8" opacity="0.72"/>
      <path d="M-28 6 L -28 26 M28 6 L 28 26" stroke="var(--ink-soft)" stroke-width="0.8" opacity="0.72"/>
      {/* a small poppy on the table — a real object placed */}
      <g transform="translate(0 -12)">
        <g fill="#e46b6b" opacity="0.75">
          <path d="M0 -6 C 2 -5, 3 0, 0 1 C -3 0, -2 -5, 0 -6 Z"/>
          <path d="M5 -2 C 6 2, 3 5, 1 4 C 0 0, 3 -3, 5 -2 Z"/>
          <path d="M4 5 C 0 7, -3 4, 0 2 C 3 0, 5 3, 4 5 Z"/>
          <path d="M-5 4 C -7 1, -5 -2, -2 -1 C 0 2, -3 5, -5 4 Z"/>
        </g>
      </g>
    </g>
    {/* the chair — moved to right, turned to face the doorway */}
    <g transform="translate(480 200)" opacity="0.85">
      <path d="M-10 -14 L 10 -14 L 10 6 L -10 6 Z" stroke="var(--ink-soft)" stroke-width="0.8" fill="#f2ede0" opacity="0.85"/>
      <path d="M-10 -14 L -10 -30 L 10 -30 L 10 -14" stroke="var(--ink-soft)" stroke-width="0.8" fill="none" opacity="0.72"/>
      <path d="M-8 6 L -8 22 M8 6 L 8 22" stroke="var(--ink-soft)" stroke-width="0.7" stroke-linecap="round" opacity="0.72"/>
    </g>
    {/* the small bed — moved to bottom-centre (calmer position) */}
    <g transform="translate(300 244)" opacity="0.85">
      <rect x="-46" y="-14" width="92" height="34" rx="3" fill="#b899c9" opacity="0.72"/>
      <rect x="-46" y="-14" width="92" height="34" rx="3" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.55"/>
      <ellipse cx="-30" cy="-6" rx="10" ry="5" fill="#f7f2e7" opacity="0.9"/>
    </g>

    {/* the figure in the doorway — a small hand-drawn stick person, standing */}
    <g transform="translate(300 40)">
      <circle cx="0" cy="-8" r="4.5" stroke="var(--ink-soft)" stroke-width="0.75" fill="#f7f2e7" opacity="0.85"/>
      <path d="M0 -3 L 0 14" stroke="var(--ink-soft)" stroke-width="0.9" stroke-linecap="round" opacity="0.85"/>
      <path d="M-6 4 L 6 4" stroke="var(--ink-soft)" stroke-width="0.85" stroke-linecap="round" opacity="0.85"/>
      <path d="M0 14 L -5 22 M0 14 L 5 22" stroke="var(--ink-soft)" stroke-width="0.85" stroke-linecap="round" opacity="0.85"/>
      {/* a small poppy at her feet — a held thing she is still holding */}
      <circle cx="8" cy="6" r="1.2" fill="var(--poppy-soft)" opacity="0.9"/>
    </g>

    {/* hand captions */}
    <text class="hand-label" x="86" y="122" font-size="14" opacity="0.6">where they used to sit</text>
    <text class="hand-label" x="112" y="308" font-size="15">where they sit now</text>
    <text class="hand-label hand-label--accent" x="346" y="72" font-size="15">standing in the</text>
    <text class="hand-label hand-label--accent" x="346" y="88" font-size="15">rearranged room</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
