---
/**
 * SceneFourGrounds — Marimekko × fine-line hybrid scene.
 * The four grounds on which the mirror can refuse: privacy · voice ·
 * walls to be held · claims outrunning what is known. A 2×2 hairline
 * garden with one *content-specific* motif per ground — a keyhole
 * (privacy), a small speech-quote pair (voice), a hairline brick-wall
 * section (walls), a small question-mark bloom (claims). At the
 * centre where all four meet, a hairline mirror hangs — the mirror
 * is what refuses. Bourgeois-style crossed-through × marks at each
 * corner. §27 redraw — no stars, no cross-plus ticks.
 * For: field-notes/the-white-bear.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 360" role="img" aria-labelledby="grounds-t" preserveAspectRatio="xMidYMid meet">
    <title id="grounds-t">A 2×2 garden of the four grounds on which the mirror can refuse — privacy, voice, walls, and claims — with a content-specific motif in each ground and a hairline mirror at the centre where they meet.</title>

    {/* the four panels — hairline calligraphic grid */}
    <g stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.55" stroke-linecap="round">
      <path d="M60 50 L 580 50 L 580 310 L 60 310 Z"/>
      <path d="M320 50 L 320 310"/>
      <path d="M60 180 L 580 180"/>
    </g>

    {/* ─── Panel 1 · PRIVACY (top left) — a keyhole */}
    <g transform="translate(190 115)" opacity="0.85">
      {/* the keyhole plate — soft lavender */}
      <rect x="-28" y="-32" width="56" height="64" rx="6" fill="#b899c9" opacity="0.4"/>
      <rect x="-28" y="-32" width="56" height="64" rx="6" stroke="var(--ink-soft)" stroke-width="0.65" fill="none" opacity="0.72"/>
      {/* the keyhole — circle + slot */}
      <circle cx="0" cy="-6" r="8" stroke="var(--ink-soft)" stroke-width="0.7" fill="#f7f2e7" opacity="0.85"/>
      <path d="M-3 0 L -3 18 L 3 18 L 3 0 Z" stroke="var(--ink-soft)" stroke-width="0.7" fill="#f7f2e7" opacity="0.85"/>
      {/* an eye peering through — a tiny poppy dot */}
      <circle cx="0" cy="-6" r="1.5" fill="var(--poppy-soft)" opacity="0.9"/>
    </g>

    {/* ─── Panel 2 · VOICE (top right) — a pair of speech quotes */}
    <g transform="translate(450 115)" opacity="0.85">
      {/* the vocal-cord line — a hairline horizontal */}
      <path d="M-32 0 L 32 0" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.65"/>
      {/* opening quote — a coral curl */}
      <path d="M-24 -20 C -30 -12, -30 -4, -22 -4"
        stroke="#e46b6b" stroke-width="2.6" fill="none" stroke-linecap="round" opacity="0.85"/>
      <path d="M-16 -20 C -22 -12, -22 -4, -14 -4"
        stroke="#e46b6b" stroke-width="2.6" fill="none" stroke-linecap="round" opacity="0.85"/>
      {/* closing quote — coral, mirrored */}
      <path d="M24 20 C 30 12, 30 4, 22 4"
        stroke="#e46b6b" stroke-width="2.6" fill="none" stroke-linecap="round" opacity="0.85"/>
      <path d="M16 20 C 22 12, 22 4, 14 4"
        stroke="#e46b6b" stroke-width="2.6" fill="none" stroke-linecap="round" opacity="0.85"/>
      {/* a small hairline waveform between the quotes — the voice's signature */}
      <path d="M-8 -2 C -4 -6, -2 2, 2 -4 C 6 2, 8 -2, 10 0"
        stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.7"/>
    </g>

    {/* ─── Panel 3 · WALLS (bottom left) — a hairline brick-wall section */}
    <g transform="translate(190 244)" opacity="0.85">
      {/* the wall silhouette — soft slate rectangle */}
      <rect x="-44" y="-24" width="88" height="48" fill="#a4b8c8" opacity="0.42"/>
      <rect x="-44" y="-24" width="88" height="48" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.7"/>
      {/* brick pattern — hairline horizontal + staggered vertical mortar-lines */}
      <path d="M-44 -8 L 44 -8 M-44 8 L 44 8" stroke="var(--ink-soft)" stroke-width="0.45" opacity="0.55"/>
      <path d="M-24 -24 L -24 -8 M-4 -8 L -4 8 M-24 8 L -24 24" stroke="var(--ink-soft)" stroke-width="0.45" opacity="0.55"/>
      <path d="M16 -24 L 16 -8 M36 -8 L 36 8 M16 8 L 16 24" stroke="var(--ink-soft)" stroke-width="0.45" opacity="0.55"/>
      {/* one loose brick at the top — the wall has a gap the reader can see */}
      <rect x="-4" y="-32" width="20" height="8" fill="#a4b8c8" opacity="0.7" transform="rotate(-6 6 -28)"/>
    </g>

    {/* ─── Panel 4 · CLAIMS (bottom right) — a question-mark bloom */}
    <g transform="translate(450 244)" opacity="0.85">
      {/* the question-mark curve — hand-drawn, gold */}
      <path d="M-14 -20 C -12 -30, 6 -32, 12 -22 C 14 -14, 4 -8, 0 -2 L 0 8"
        stroke="#e8c15a" stroke-width="3.6" fill="none" stroke-linecap="round" opacity="0.85"/>
      {/* the dot */}
      <circle cx="0" cy="18" r="3" fill="#e8c15a" opacity="0.9"/>
      {/* a small bloom at the base — the claim we tried to make */}
      <g transform="translate(0 22)">
        <g fill="#e8c15a" opacity="0.55">
          <ellipse cx="-3" cy="4" rx="3" ry="4" transform="rotate(-25 -3 4)"/>
          <ellipse cx="3" cy="4" rx="3" ry="4" transform="rotate(25 3 4)"/>
        </g>
      </g>
    </g>

    {/* ─── the mirror at the centre — where the four grounds meet */}
    <g transform="translate(320 180)">
      {/* the mirror body — small oval */}
      <ellipse cx="0" cy="-6" rx="16" ry="22" fill="#f7f2e7" opacity="0.85"/>
      <ellipse cx="0" cy="-6" rx="16" ry="22" stroke="var(--ink-soft)" stroke-width="0.75" fill="none" opacity="0.75"/>
      {/* inner rim */}
      <ellipse cx="0" cy="-6" rx="12" ry="18" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.55"/>
      {/* the handle */}
      <path d="M-2 16 L -2 26 L 2 26 L 2 16 Z" fill="#b899c9" opacity="0.68" stroke="var(--ink-soft)" stroke-width="0.4"/>
      {/* a small poppy in the mirror — the refusal is a tender act */}
      <circle cx="0" cy="-6" r="1.6" fill="var(--poppy-soft)" opacity="0.9"/>
    </g>

    {/* ─── Bourgeois-style crossed-through × marks at each panel corner (refusal) */}
    <g stroke="var(--ink-soft)" stroke-width="0.8" stroke-linecap="round" opacity="0.72">
      {/* top-left panel corner (bottom-right of panel 1) */}
      <path d="M300 158 L 314 172"/>
      <path d="M300 172 L 314 158"/>
      {/* top-right panel corner (bottom-left of panel 2) */}
      <path d="M326 158 L 340 172"/>
      <path d="M326 172 L 340 158"/>
      {/* bottom-left panel corner (top-right of panel 3) */}
      <path d="M300 188 L 314 202"/>
      <path d="M300 202 L 314 188"/>
      {/* bottom-right panel corner (top-left of panel 4) */}
      <path d="M326 188 L 340 202"/>
      <path d="M326 202 L 340 188"/>
    </g>

    {/* hand captions — one per ground */}
    <text class="hand-label" x="120" y="72" font-size="15">privacy</text>
    <text class="hand-label" x="380" y="72" font-size="15">voice</text>
    <text class="hand-label" x="120" y="202" font-size="15">walls to be held</text>
    <text class="hand-label" x="380" y="202" font-size="15">claims outrunning</text>
    <text class="hand-label" x="380" y="218" font-size="15">what is known</text>
    <text class="hand-label hand-label--accent" x="216" y="336" font-size="14">the mirror is what refuses</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
