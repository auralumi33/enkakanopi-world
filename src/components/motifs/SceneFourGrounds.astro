---
/**
 * SceneFourGrounds — Marimekko × fine-line hybrid scene.
 * The four grounds on which the mirror can refuse: privacy · voice · walls ·
 * claims. A 2×2 soft Marimekko garden layout — four pastel bloom clusters,
 * one per ground — each panel with a tiny fine-line refusal tick (a "damn"
 * mark) at its edge. Marimekko pot-arrangement blended with hairline tattoo-
 * flash refusal marks.
 * For: field-notes/the-white-bear · SUCCESSION §26.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 340" role="img" aria-labelledby="grounds-t" preserveAspectRatio="xMidYMid meet">
    <title id="grounds-t">A 2×2 garden with a bloom cluster in each of four grounds — privacy, voice, walls, claims — each carrying a small refusal tick.</title>

    {/* the four panels — hairline calligraphic grid */}
    <g stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.55" stroke-linecap="round">
      <path d="M60 40 L 580 40 L 580 300 L 60 300 Z"/>
      <path d="M320 40 L 320 300"/>
      <path d="M60 170 L 580 170"/>
    </g>

    {/* Panel 1 — privacy (top left) — lavender bloom cluster */}
    <g transform="translate(190 100)">
      <g fill="#b899c9" opacity="0.72">
        <ellipse cx="-6" cy="-3" rx="6" ry="9" transform="rotate(-25 -6 -3)"/>
        <ellipse cx="6" cy="-3" rx="6" ry="9" transform="rotate(25 6 -3)"/>
        <ellipse cx="0" cy="6" rx="6" ry="9"/>
      </g>
      <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
    </g>
    {/* Panel 2 — voice (top right) — coral poppy */}
    <g transform="translate(450 100)">
      <g fill="#e46b6b" opacity="0.75">
        <path d="M0 -10 C 4 -9, 4.5 -2, 0 1 C -4.5 -2, -4 -9, 0 -10 Z"/>
        <path d="M9 -4 C 10.5 1, 6 7, 1 5 C 0 -1, 6 -6, 9 -4 Z"/>
        <path d="M5 8 C 0 11, -5 7, -1 3 C 4 0, 8 3, 5 8 Z"/>
        <path d="M-7 6 C -11 3, -8 -3, -3 -1 C -1 3, -5 7, -7 6 Z"/>
        <path d="M-9 -3 C -6 -8, -1 -7, -1 -2 C -3 2, -10 1, -9 -3 Z"/>
      </g>
      <circle cx="0" cy="0" r="2.4" fill="#f7f2e7"/>
    </g>
    {/* Panel 3 — walls (bottom left) — slate stars */}
    <g transform="translate(190 234)">
      <g fill="#a4b8c8" opacity="0.72">
        <path d="M0 -12 L 2.6 -3.6 L 12 -3.6 L 4.4 1.6 L 7.2 10 L 0 5 L -7.2 10 L -4.4 1.6 L -12 -3.6 L -2.6 -3.6 Z"/>
      </g>
      <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
    </g>
    {/* Panel 4 — claims (bottom right) — gold bud */}
    <g transform="translate(450 234)">
      <g fill="#e8c15a" opacity="0.75">
        <ellipse cx="-5" cy="-2" rx="5" ry="7.5" transform="rotate(-25 -5 -2)"/>
        <ellipse cx="5" cy="-2" rx="5" ry="7.5" transform="rotate(25 5 -2)"/>
        <ellipse cx="0" cy="6" rx="5" ry="7.5"/>
      </g>
      <circle cx="0" cy="0" r="2.2" fill="#f7f2e7"/>
    </g>

    {/* the refusal ticks — tiny fine-line "damn" marks at each panel edge */}
    <g stroke="var(--ink-soft)" stroke-width="0.55" stroke-linecap="round" opacity="0.7">
      {/* top left refusal — top-right corner */}
      <path d="M300 58 L 306 58 M303 55 L 303 61"/>
      {/* top right refusal — top-left corner */}
      <path d="M334 58 L 340 58 M337 55 L 337 61"/>
      {/* bottom left refusal — bottom-right corner */}
      <path d="M300 288 L 306 288 M303 285 L 303 291"/>
      {/* bottom right refusal — bottom-left corner */}
      <path d="M334 288 L 340 288 M337 285 L 337 291"/>
    </g>
    <circle cx="303" cy="58" r="1" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="337" cy="58" r="1" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="303" cy="288" r="1" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="337" cy="288" r="1" fill="var(--poppy-soft)" opacity="0.85"/>

    {/* scatter */}
    <circle cx="90" cy="322" r="0.5" fill="var(--ink-soft)" opacity="0.55"/>
    <circle cx="556" cy="60" r="0.7" fill="var(--poppy-soft)" opacity="0.85"/>

    {/* hand captions — one per ground */}
    <text class="hand-label" x="122" y="62" font-size="15">privacy</text>
    <text class="hand-label" x="380" y="62" font-size="15">voice</text>
    <text class="hand-label" x="122" y="196" font-size="15">walls to be held</text>
    <text class="hand-label" x="380" y="196" font-size="15">claims outrunning</text>
    <text class="hand-label" x="380" y="212" font-size="15">what is known</text>
    <text class="hand-label hand-label--accent" x="230" y="326" font-size="14">the geometry of our refusals</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
