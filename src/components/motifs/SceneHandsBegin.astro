---
/**
 * SceneHandsBegin — Marimekko × fine-line hybrid scene.
 * "You cannot reason your way into somatic knowledge; you have to get
 * your hands dirty and let them learn ahead of you."
 * Two soft hairline hands cup a small unshaped lump of clay between them
 * — the making before the making. Above the hands, a small brain-shape
 * sits with a dashed hairline "no" line through it (the head, told to
 * wait). Below the hands, a small bloom is beginning to open — what
 * the hands are already learning.
 * §28 · Workbench · Why Start With the Hands.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 280" role="img" aria-labelledby="hands-t" preserveAspectRatio="xMidYMid meet">
    <title id="hands-t">Two hairline hands cup a small unshaped lump of clay between them; above, a brain-shape is asked to wait; below, a small bloom is beginning.</title>

    {/* the head — a soft brain-silhouette above, with a dashed "wait" line through */}
    <g transform="translate(320 60)" opacity="0.55">
      {/* brain silhouette — two soft lobes */}
      <path d="M-20 0 C -24 -14, -8 -18, 0 -14 C 8 -18, 24 -14, 20 0 C 22 6, 18 10, 12 10 C 8 14, -8 14, -12 10 C -18 10, -22 6, -20 0 Z"
        fill="#a4b8c8" opacity="0.4"
        stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
      {/* the central seam */}
      <path d="M0 -12 L 0 12" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.55"/>
      {/* the dashed "wait" line running through */}
      <path d="M-30 0 L 30 0" stroke="var(--ink-soft)" stroke-width="0.5" stroke-dasharray="2 3" stroke-linecap="round" opacity="0.55"/>
    </g>
    <text class="hand-label" x="360" y="66" font-size="13" opacity="0.6">the head, told to wait</text>

    {/* THE LEFT HAND — cupped, reaching toward the centre */}
    <g transform="translate(220 158)">
      <ellipse cx="0" cy="0" rx="34" ry="14" transform="rotate(-14 0 0)"
        fill="#f2e0d0" opacity="0.65"
        stroke="var(--ink-soft)" stroke-width="0.65" stroke-linejoin="round"/>
      {/* thumb */}
      <path d="M22 -8 C 32 -12, 40 -8, 38 0 C 36 4, 28 6, 24 4"
        stroke="var(--ink-soft)" stroke-width="0.55" fill="#f2e0d0" fill-opacity="0.65" opacity="0.72"/>
      {/* fingers — three soft hairline curves */}
      <path d="M28 4 C 40 8, 46 6, 46 0"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.65"/>
      <path d="M26 8 C 36 14, 42 12, 44 6"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.65"/>
      {/* wrist trailing off */}
      <path d="M-30 6 C -38 12, -44 20, -48 32"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.7"/>
    </g>

    {/* THE RIGHT HAND — cupped, mirroring */}
    <g transform="translate(420 158)">
      <ellipse cx="0" cy="0" rx="34" ry="14" transform="rotate(14 0 0)"
        fill="#f2e0d0" opacity="0.65"
        stroke="var(--ink-soft)" stroke-width="0.65" stroke-linejoin="round"/>
      <path d="M-22 -8 C -32 -12, -40 -8, -38 0 C -36 4, -28 6, -24 4"
        stroke="var(--ink-soft)" stroke-width="0.55" fill="#f2e0d0" fill-opacity="0.65" opacity="0.72"/>
      <path d="M-28 4 C -40 8, -46 6, -46 0"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.65"/>
      <path d="M-26 8 C -36 14, -42 12, -44 6"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.65"/>
      <path d="M30 6 C 38 12, 44 20, 48 32"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.7"/>
    </g>

    {/* THE LUMP — an unshaped soft clay in the cradle between the hands */}
    <ellipse cx="320" cy="148" rx="26" ry="18" fill="#e8c15a" opacity="0.68"/>
    <path d="M294 148 C 296 132, 318 128, 328 132 C 340 130, 348 138, 346 148 C 344 158, 330 164, 320 162 C 308 164, 294 158, 294 148 Z"
      stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.72"/>
    {/* small thumbprints in the clay — the hands are already at work */}
    <ellipse cx="308" cy="148" rx="3" ry="2" fill="var(--ink-soft)" opacity="0.4"/>
    <ellipse cx="326" cy="146" rx="2.5" ry="1.8" fill="var(--ink-soft)" opacity="0.4"/>

    {/* BELOW the hands — a small bloom beginning to open (what the hands already know) */}
    <g transform="translate(320 232)">
      <path d="M0 6 L 0 -6" stroke="var(--canopy)" stroke-width="0.7" stroke-linecap="round" opacity="0.75"/>
      <g fill="#e46b6b" opacity="0.75">
        <path d="M0 -12 C 3 -11, 4 -5, 0 -3 C -4 -5, -3 -11, 0 -12 Z"/>
        <path d="M6 -8 C 8 -3, 4 2, 1 0 C 0 -6, 4 -10, 6 -8 Z"/>
        <path d="M4 3 C 0 4, -4 1, -2 -2 C 3 -4, 6 0, 4 3 Z"/>
        <path d="M-6 2 C -8 -1, -5 -6, -2 -4 C 0 -1, -3 3, -6 2 Z"/>
      </g>
      <circle cx="0" cy="-4" r="1.4" fill="#f7f2e7"/>
    </g>

    {/* hand captions */}
    <text class="hand-label hand-label--accent" x="60" y="60" font-size="15">get your hands</text>
    <text class="hand-label hand-label--accent" x="60" y="78" font-size="15">dirty first</text>
    <text class="hand-label" x="60" y="252" font-size="14" opacity="0.75">the making</text>
    <text class="hand-label" x="60" y="268" font-size="14" opacity="0.7">before the making</text>
    <text class="hand-label hand-label--accent" x="480" y="240" font-size="14">a small opening</text>
    <text class="hand-label" x="480" y="256" font-size="13" opacity="0.7">the hands were</text>
    <text class="hand-label" x="480" y="270" font-size="13" opacity="0.7">already learning</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
