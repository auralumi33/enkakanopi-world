---
/**
 * SceneAsymptote — Marimekko × fine-line hybrid scene.
 * Kalanithi: "You can't ever reach perfection, but you can believe in an
 * asymptote toward which you are ceaselessly striving." A soft Marimekko
 * curve rising toward a horizontal line it never touches, with poppy bloom
 * silhouettes trailing along it + a fine-line tangent from below + a tiny
 * gold star ahead as the beckoning perfection.
 * For: field-notes/the-silent-workspace · SUCCESSION §26.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 300" role="img" aria-labelledby="asymptote-t" preserveAspectRatio="xMidYMid meet">
    <title id="asymptote-t">A curve rising toward a line it never touches, with soft blooms trailing along it and a small gold star ahead.</title>

    {/* the horizontal — the unreachable perfection */}
    <path d="M60 60 L 600 60"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" stroke-dasharray="1.5 3" opacity="0.55"/>

    {/* the asymptotic curve — Marimekko-scale soft canopy-green fill under the curve */}
    <path d="M60 268 C 180 268, 280 240, 360 180 C 440 118, 500 84, 600 68 L 600 268 Z"
      fill="#a4b8c8" opacity="0.22"/>

    {/* the curve — hairline calligraphic */}
    <path d="M60 268 C 180 268, 280 240, 360 180 C 440 118, 500 84, 600 68"
      stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.75"/>
    {/* second finer trace, offset — the ceaseless striving mark */}
    <path d="M62 272 C 182 272, 282 244, 362 184 C 442 122, 502 88, 598 72"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.5"/>

    {/* the tangent from below — a fine-line dashed line kissing the curve */}
    <path d="M120 290 L 420 132"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" stroke-dasharray="1.2 2" opacity="0.5"/>
    <circle cx="360" cy="180" r="1.2" fill="var(--poppy-soft)" opacity="0.9"/>

    {/* the trailing blooms along the curve — Marimekko clusters at increasing altitude */}
    <g transform="translate(150 244)">
      <g fill="#b899c9" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.2" fill="#f7f2e7"/>
    </g>
    <g transform="translate(240 220)">
      <g fill="#e8c15a" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
        <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(360 172)">
      <g fill="#e46b6b" opacity="0.75">
        <path d="M0 -8 C 3 -7, 4 -1, 0 1 C -4 -1, -3 -7, 0 -8 Z"/>
        <path d="M8 -3 C 9 2, 4 7, 1 5 C 0 -1, 5 -5, 8 -3 Z"/>
        <path d="M5 7 C 0 9, -4 6, -1 3 C 3 0, 7 2, 5 7 Z"/>
        <path d="M-6 6 C -9 3, -6 -2, -3 -1 C -1 3, -4 7, -6 6 Z"/>
        <path d="M-8 -2 C -5 -7, -1 -6, 0 -2 C -2 2, -8 2, -8 -2 Z"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(470 108)">
      <g fill="#b899c9" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.2" fill="#f7f2e7"/>
    </g>

    {/* the beckoning star — a fine-line star just above the asymptote */}
    <g transform="translate(580 40)">
      <path d="M0 -10 L 2.4 -3 L 10 -3 L 4 1.5 L 6.5 9 L 0 4 L -6.5 9 L -4 1.5 L -10 -3 L -2.4 -3 Z"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linejoin="round" opacity="0.72"/>
      <circle cx="0" cy="-1" r="1" fill="#e8c15a" opacity="0.9"/>
      <g stroke="var(--ink-soft)" stroke-width="0.3" stroke-linecap="round" opacity="0.55">
        <path d="M-18 6 L -16 6 M-17 5 L -17 7"/>
      </g>
    </g>

    {/* scatter */}
    <circle cx="82" cy="94" r="0.8" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="90" cy="290" r="0.5" fill="var(--ink-soft)" opacity="0.55"/>

    {/* hand captions */}
    <text class="hand-label hand-label--accent" x="466" y="52" font-size="15">perfection</text>
    <text class="hand-label" x="72" y="290" font-size="15">ceaselessly striving</text>
    <text class="hand-label" x="356" y="216" font-size="14" opacity="0.7">the tangent kisses,</text>
    <text class="hand-label" x="356" y="232" font-size="14" opacity="0.7">and leaves again</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
