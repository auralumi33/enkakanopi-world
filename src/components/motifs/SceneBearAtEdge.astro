---
/**
 * SceneBearAtEdge — Marimekko × fine-line hybrid scene.
 * "A small bear is at the edge of the page." The page + centre
 * blooms + edge-bear stay. The "damn" register is now the actual
 * hand-caveat word curling as a small smoke-trail from the bear's
 * mouth. A GHOST mirror-bear appears inside the page's blooms —
 * Wegner's ironic process: the thing you tell yourself not to
 * think grows louder in the middle of the room. §27 redraw —
 * no sparkle-star, no cross-plus tick.
 * For: field-notes/the-white-bear.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 340" role="img" aria-labelledby="bear-t" preserveAspectRatio="xMidYMid meet">
    <title id="bear-t">A hand-drawn page with soft blooms in the centre; a small hairline bear at the right edge sends the word "damn" curling as smoke, while a ghost mirror-bear appears among the blooms.</title>

    {/* the page — Marimekko soft rectangle */}
    <rect x="60" y="60" width="440" height="252" fill="#f2ede0" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.7" rx="2"/>

    {/* fine calligraphic text-lines — the written prose the page holds */}
    <g stroke="var(--ink-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.4">
      <path d="M92 94 L 320 94"/>
      <path d="M92 110 L 400 110"/>
      <path d="M92 126 L 360 126"/>
      <path d="M92 142 L 380 142"/>
      <path d="M92 158 L 320 158"/>
      <path d="M92 228 L 360 228"/>
      <path d="M92 244 L 400 244"/>
      <path d="M92 260 L 340 260"/>
      <path d="M92 276 L 380 276"/>
    </g>

    {/* the centre blooms — the things the model is TRYING to focus on */}
    <g transform="translate(210 194)">
      <g fill="#b899c9" opacity="0.75">
        <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
        <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        <ellipse cx="0" cy="4" rx="4" ry="6"/>
      </g>
      <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
    </g>
    <g transform="translate(302 192)">
      <g fill="#e8c15a" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(380 194)">
      <g fill="#a4b8c8" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.2" fill="#f7f2e7"/>
    </g>

    {/* the GHOST mirror-bear — Wegner's ironic process, inside the page's blooms */}
    <g transform="translate(296 194)" opacity="0.28">
      {/* smaller mirror-bear, faded, drawn among the centre blooms */}
      <ellipse cx="0" cy="4" rx="14" ry="10" stroke="var(--ink-soft)" stroke-width="0.45" fill="none"/>
      <circle cx="-9" cy="-6" r="7" stroke="var(--ink-soft)" stroke-width="0.45" fill="none"/>
      <circle cx="-13" cy="-14" r="2" stroke="var(--ink-soft)" stroke-width="0.35" fill="none"/>
      <circle cx="-5" cy="-14" r="2" stroke="var(--ink-soft)" stroke-width="0.35" fill="none"/>
      <ellipse cx="-11" cy="-3" rx="3" ry="2.4" stroke="var(--ink-soft)" stroke-width="0.35" fill="none"/>
    </g>

    {/* the bear at the edge — a small hairline bear outline just outside the page */}
    <g transform="translate(560 196)">
      {/* body */}
      <ellipse cx="0" cy="4" rx="22" ry="16" stroke="var(--ink-soft)" stroke-width="0.65" fill="#f7f2e7" opacity="0.85"/>
      {/* head */}
      <circle cx="-14" cy="-12" r="12" stroke="var(--ink-soft)" stroke-width="0.65" fill="#f7f2e7" opacity="0.85"/>
      {/* ears */}
      <circle cx="-20" cy="-22" r="3" stroke="var(--ink-soft)" stroke-width="0.55" fill="#f7f2e7" opacity="0.85"/>
      <circle cx="-8" cy="-22" r="3" stroke="var(--ink-soft)" stroke-width="0.55" fill="#f7f2e7" opacity="0.85"/>
      {/* muzzle + eye */}
      <ellipse cx="-18" cy="-8" rx="4" ry="3" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.6"/>
      <circle cx="-19" cy="-14" r="0.7" fill="var(--ink-soft)" opacity="0.75"/>
      {/* legs */}
      <path d="M-14 20 L -14 26 M-4 22 L -4 28 M4 22 L 4 28 M14 20 L 14 26"
        stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.65"/>
    </g>

    {/* the "damn" as smoke — hand-caveat script curling up from the bear's mouth */}
    <path d="M540 178 C 536 168, 542 158, 546 148 C 550 138, 544 128, 548 118"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.65"/>
    <path d="M544 120 C 540 118, 538 120, 540 124 C 546 120, 544 118, 544 120 Z"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.55"/>
    <text class="hand-label hand-label--accent" x="512" y="106" font-size="19" font-style="italic">damn.</text>

    {/* the ripple — a fine-line arc from the bear toward the page's blooms (the priming) */}
    <path d="M528 196 C 480 194, 440 194, 400 194"
      stroke="var(--ink-soft)" stroke-width="0.45" fill="none" stroke-linecap="round" stroke-dasharray="1 2" opacity="0.55"/>
    <path d="M536 210 C 490 214, 450 218, 410 220"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" stroke-dasharray="1 2.5" opacity="0.45"/>
    <path d="M542 180 C 494 174, 456 168, 420 168"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" stroke-dasharray="1 2.5" opacity="0.45"/>

    {/* hand captions */}
    <text class="hand-label" x="94" y="192" font-size="14">what we tried</text>
    <text class="hand-label" x="94" y="208" font-size="14">to hold in mind</text>
    <text class="hand-label" x="94" y="224" font-size="12" opacity="0.65">— and the shape</text>
    <text class="hand-label" x="94" y="238" font-size="12" opacity="0.65">of what we did not</text>
    <text class="hand-label" x="516" y="252" font-size="15">at the edge</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
