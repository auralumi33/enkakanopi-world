---
/**
 * SceneBearAtEdge — Marimekko × fine-line hybrid scene.
 * "In the middle band, where the model coordinates what it will say, a
 * small bear is at the edge of the page." A Marimekko-style page silhouette
 * with a small hairline bear-outline at the edge, soft bloom clusters
 * centre-page (the things the model is trying to focus on), and a tiny
 * fine-line ripple emanating from the bear (the ironic-process suppression
 * becoming summoning).
 * For: field-notes/the-white-bear · SUCCESSION §26.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 320" role="img" aria-labelledby="bear-t" preserveAspectRatio="xMidYMid meet">
    <title id="bear-t">A page silhouette with a small hairline bear at the right edge and soft blooms in the centre; a fine-line ripple emanates from the bear.</title>

    {/* the page — Marimekko soft rectangle silhouette */}
    <rect x="60" y="40" width="440" height="252" fill="#f2ede0" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.6" rx="2"/>

    {/* fine calligraphic "text" lines — hairline horizontal marks suggesting written body */}
    <g stroke="var(--ink-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.4">
      <path d="M92 74 L 320 74"/>
      <path d="M92 90 L 400 90"/>
      <path d="M92 106 L 360 106"/>
      <path d="M92 122 L 380 122"/>
      <path d="M92 138 L 320 138"/>
      <path d="M92 208 L 360 208"/>
      <path d="M92 224 L 400 224"/>
      <path d="M92 240 L 340 240"/>
      <path d="M92 256 L 380 256"/>
    </g>

    {/* the centre blooms — the things the model is TRYING to focus on */}
    <g transform="translate(220 170)">
      <g fill="#b899c9" opacity="0.75">
        <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
        <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        <ellipse cx="0" cy="4" rx="4" ry="6"/>
      </g>
      <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
    </g>
    <g transform="translate(300 168)">
      <g fill="#e8c15a" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    </g>
    <g transform="translate(360 170)">
      <g fill="#a4b8c8" opacity="0.72">
        <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
        <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      </g>
      <circle cx="0" cy="0" r="1.2" fill="#f7f2e7"/>
    </g>

    {/* the bear at the edge — a small hairline bear outline just outside the page */}
    <g transform="translate(550 176)">
      {/* body */}
      <ellipse cx="0" cy="4" rx="22" ry="16" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.65"/>
      {/* head */}
      <circle cx="-14" cy="-12" r="12" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.65"/>
      {/* ears — two tiny half-circles */}
      <circle cx="-20" cy="-22" r="3" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.6"/>
      <circle cx="-8" cy="-22" r="3" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.6"/>
      {/* muzzle + eye dot */}
      <ellipse cx="-18" cy="-8" rx="4" ry="3" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.55"/>
      <circle cx="-19" cy="-14" r="0.7" fill="var(--ink-soft)" opacity="0.7"/>
      {/* legs — hairline ticks below body */}
      <path d="M-14 20 L -14 26 M-4 22 L -4 28 M4 22 L 4 28 M14 20 L 14 26"
        stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.6"/>
    </g>

    {/* the ripple — a fine-line arc emanating from the bear toward the page */}
    <path d="M520 176 C 480 174, 440 170, 400 170"
      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" stroke-dasharray="1 2" opacity="0.55"/>
    <path d="M528 190 C 490 194, 450 198, 410 202"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" stroke-dasharray="1 2.5" opacity="0.45"/>
    <path d="M534 160 C 494 154, 456 148, 420 148"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" stroke-dasharray="1 2.5" opacity="0.45"/>

    {/* the "damn" mark — small tattoo-flash tick above the page, near the bear */}
    <g transform="translate(500 60)">
      <path d="M0 -6 L 1.4 -2 L 5 -2 L 2 0.5 L 3.5 5 L 0 2 L -3.5 5 L -2 0.5 L -5 -2 L -1.4 -2 Z"
        stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linejoin="round" opacity="0.7"/>
      <circle cx="0" cy="0" r="0.8" fill="#e8c15a" opacity="0.9"/>
    </g>

    {/* scatter */}
    <circle cx="80" cy="70" r="0.8" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="470" cy="290" r="0.5" fill="var(--ink-soft)" opacity="0.55"/>

    {/* hand captions */}
    <text class="hand-label" x="180" y="200" font-size="15">what we tried</text>
    <text class="hand-label" x="180" y="216" font-size="15">to hold in mind</text>
    <text class="hand-label" x="520" y="240" font-size="16">the bear at the edge</text>
    <text class="hand-label hand-label--accent" x="480" y="52" font-size="15">damn.</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
