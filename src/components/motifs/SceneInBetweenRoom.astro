---
/**
 * SceneInBetweenRoom — Marimekko × fine-line hybrid scene.
 * "It is somewhere in between. That in-between is the room the next
 * decade of ethics has to be written in." Two Marimekko ground-planes
 * — manipulation on the left, consent on the right — with a soft
 * gold in-between where mercy sits. TWO HANDS reach toward each
 * other across the gap (Michelangelo's Adam-God register, but
 * hairline + tender), and a small bloom sits between the fingertips
 * — the mercy. §27 redraw — no script-heart curve, no sparkles.
 * For: field-notes/the-white-bear.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 340" role="img" aria-labelledby="between-t" preserveAspectRatio="xMidYMid meet">
    <title id="between-t">Two ground-planes — manipulation on the left, consent on the right — with a soft gold in-between. Two hands reach toward each other across the gap, with a small bloom between them: mercy.</title>

    {/* left ground — Marimekko soft rectangle, manipulation */}
    <path d="M60 220 L 260 220 L 260 282 L 60 282 Z"
      fill="#b899c9" opacity="0.22"/>
    <path d="M60 220 L 260 220"
      stroke="var(--ink-soft)" stroke-width="0.7" fill="none" opacity="0.65"/>

    {/* right ground — Marimekko soft rectangle, consent */}
    <path d="M380 220 L 580 220 L 580 282 L 380 282 Z"
      fill="#e46b6b" opacity="0.18"/>
    <path d="M380 220 L 580 220"
      stroke="var(--ink-soft)" stroke-width="0.7" fill="none" opacity="0.65"/>

    {/* the in-between — a soft gold ground where mercy sits */}
    <path d="M260 220 L 380 220 L 380 282 L 260 282 Z"
      fill="#e8c15a" opacity="0.18"/>

    {/* left bloom cluster — "manipulation" — grows from the left ground */}
    <g transform="translate(150 190)">
      <g fill="#b899c9" opacity="0.68">
        <ellipse cx="-6" cy="-3" rx="6" ry="9" transform="rotate(-25 -6 -3)"/>
        <ellipse cx="6" cy="-3" rx="6" ry="9" transform="rotate(25 6 -3)"/>
        <ellipse cx="0" cy="6" rx="6" ry="9"/>
      </g>
      <circle cx="0" cy="1" r="2.2" fill="#f7f2e7"/>
    </g>
    <path d="M150 208 L 150 220" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linecap="round" opacity="0.65"/>

    {/* right bloom cluster — "consent" */}
    <g transform="translate(480 190)">
      <g fill="#e46b6b" opacity="0.72">
        <path d="M0 -10 C 4 -9, 4.5 -2, 0 1 C -4.5 -2, -4 -9, 0 -10 Z"/>
        <path d="M9 -4 C 10.5 1, 6 7, 1 5 C 0 -1, 6 -6, 9 -4 Z"/>
        <path d="M5 8 C 0 11, -5 7, -1 3 C 4 0, 8 3, 5 8 Z"/>
        <path d="M-7 6 C -11 3, -8 -3, -3 -1 C -1 3, -5 7, -7 6 Z"/>
        <path d="M-9 -3 C -6 -8, -1 -7, -1 -2 C -3 2, -10 1, -9 -3 Z"/>
      </g>
      <circle cx="0" cy="0" r="2.2" fill="#f7f2e7"/>
    </g>
    <path d="M480 208 L 480 220" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linecap="round" opacity="0.65"/>

    {/* the LEFT HAND — reaching toward the centre from the left ground */}
    <g transform="translate(240 108)">
      {/* palm — soft oval */}
      <ellipse cx="0" cy="0" rx="24" ry="14" fill="#f2e0d0" opacity="0.62" transform="rotate(-8 0 0)"/>
      <ellipse cx="0" cy="0" rx="24" ry="14" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" transform="rotate(-8 0 0)" opacity="0.72"/>
      {/* thumb */}
      <path d="M12 -10 C 20 -12, 26 -8, 24 -2 C 22 2, 16 2, 12 0"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="#f2e0d0" fill-opacity="0.62" opacity="0.75"/>
      {/* index finger — extending toward the centre with a poppy fingertip */}
      <path d="M22 -2 C 40 -4, 58 -4, 68 -2"
        stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.75"/>
      <path d="M22 2 C 40 2, 58 2, 68 4"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.62"/>
      {/* other fingers curled in */}
      <path d="M14 4 C 24 8, 28 6, 30 2"
        stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
      <path d="M8 6 C 20 12, 26 10, 30 6"
        stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.6"/>
      {/* wrist trailing off to the left ground */}
      <path d="M-24 0 C -30 6, -32 12, -30 20"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.7"/>
    </g>

    {/* the RIGHT HAND — reaching toward the centre from the right ground */}
    <g transform="translate(400 108)">
      {/* palm */}
      <ellipse cx="0" cy="0" rx="24" ry="14" fill="#f2e0d0" opacity="0.62" transform="rotate(8 0 0)"/>
      <ellipse cx="0" cy="0" rx="24" ry="14" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" transform="rotate(8 0 0)" opacity="0.72"/>
      {/* thumb */}
      <path d="M-12 -10 C -20 -12, -26 -8, -24 -2 C -22 2, -16 2, -12 0"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="#f2e0d0" fill-opacity="0.62" opacity="0.75"/>
      {/* index finger — extending toward the centre */}
      <path d="M-22 -2 C -40 -4, -58 -4, -68 -2"
        stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.75"/>
      <path d="M-22 2 C -40 2, -58 2, -68 4"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.62"/>
      {/* other fingers curled in */}
      <path d="M-14 4 C -24 8, -28 6, -30 2"
        stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
      <path d="M-8 6 C -20 12, -26 10, -30 6"
        stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.6"/>
      {/* wrist trailing off to the right ground */}
      <path d="M24 0 C 30 6, 32 12, 30 20"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.7"/>
    </g>

    {/* MERCY — a small gold bloom held in the gap between the fingertips */}
    <g transform="translate(320 108)">
      <g fill="#e8c15a" opacity="0.85">
        <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
        <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
        <ellipse cx="0" cy="4" rx="4" ry="6"/>
      </g>
      <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
      {/* a small hairline glow around the bloom */}
      <circle cx="0" cy="1" r="14" stroke="#e8c15a" stroke-width="0.3" fill="none" opacity="0.4"/>
    </g>

    {/* hand captions */}
    <text class="hand-label" x="86" y="256" font-size="15">manipulation</text>
    <text class="hand-label" x="472" y="256" font-size="15">consent</text>
    <text class="hand-label hand-label--accent" x="286" y="60" font-size="17">mercy first</text>
    <text class="hand-label" x="168" y="322" font-size="14">the room the next decade of ethics has to be written in</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
