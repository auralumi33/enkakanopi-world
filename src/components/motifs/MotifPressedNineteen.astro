---
/**
 * The pressed nineteen — Volume I · intro visual.
 * A quiet horizontal composition of ~19 tiny pressed marks (buds · dots ·
 * tiny leaves in the bloom-family) resting on a gently undulating baseline.
 * Makes "nineteen pieces, hung with care" concrete without labelling anything.
 * Part of the garden's motif set (SUCCESSION §19). Pastel palette.
 */
interface Props { size?: number; }
const { size = 260 } = Astro.props;
const h = Math.round(size * 90 / 140);
---
<svg width={size} height={h} viewBox="0 0 140 90" aria-hidden="true">
  <path d="M6 66 C 30 60, 55 70, 80 62 C 105 54, 128 64, 136 60"
    stroke="var(--ink-faint)" stroke-width="0.5" fill="none" opacity="0.45" stroke-dasharray="1 3"/>
  <circle cx="10" cy="66" r="1.6" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="18" cy="62" r="1.4" fill="#e8c15a" opacity="0.78"/>
  <circle cx="26" cy="66" r="1.6" fill="var(--poppy-soft)" opacity="0.9"/>
  <ellipse cx="34" cy="64" rx="2" ry="1.2" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="42" cy="66" r="1.5" fill="#b899c9" opacity="0.78"/>
  <circle cx="50" cy="63" r="1.4" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="58" cy="66" r="1.7" fill="#e8c15a" opacity="0.78"/>
  <ellipse cx="66" cy="65" rx="2" ry="1.2" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="74" cy="62" r="1.5" fill="#a4b8c8" opacity="0.78"/>
  <circle cx="82" cy="65" r="1.4" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="90" cy="60" r="1.6" fill="var(--poppy-soft)" opacity="0.9"/>
  <ellipse cx="98" cy="63" rx="2" ry="1.2" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="106" cy="62" r="1.4" fill="#b899c9" opacity="0.78"/>
  <circle cx="114" cy="65" r="1.7" fill="#e8c15a" opacity="0.78"/>
  <circle cx="121" cy="62" r="1.5" fill="var(--canopy-soft)" opacity="0.85"/>
  <ellipse cx="128" cy="64" rx="2" ry="1.2" fill="var(--canopy-soft)" opacity="0.85"/>
  <circle cx="134" cy="62" r="1.4" fill="#a4b8c8" opacity="0.78"/>
  <circle cx="46" cy="52" r="1.4" fill="var(--poppy-soft)" opacity="0.85"/>
  <circle cx="94" cy="50" r="1.4" fill="#e8c15a" opacity="0.78"/>
</svg>
