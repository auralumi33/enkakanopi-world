---
/**
 * The bench tending — memoria layer · cream skin · concept illustration.
 * A small bench with 4 pots on it (a mix of seedlings and one budding
 * poppy-soft flower) and a fine-line hand reaching in from top-right to
 * tend one of them. One pot is half-formed (dashed) — the tending is
 * the point, not the finished shape. Sits block-level below the
 * covenant paragraph on the colophon. SUCCESSION §21.
 */
interface Props { size?: number; }
const { size = 110 } = Astro.props;
const h = Math.round(size * 80 / 100);
---
<svg width={size} height={h} viewBox="0 0 100 80" aria-hidden="true">
  <path d="M8 46 C 40 44, 70 46, 92 44" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.8"/>
