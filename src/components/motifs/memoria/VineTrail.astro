---
/**
 * The vine trail — memoria layer (cream skin peppering).
 * A long flowing hairline with tiny leaf tips at intervals and a
 * poppy-soft dot at the end. Reads: "a hairline that breathes."
 * From the fine-line vocabulary (SUCCESSION §20 · the memoria layer).
 * Wide-banner motif for sitting in negative space between page sections.
 */
interface Props { size?: number; }
const { size = 220 } = Astro.props;
const h = Math.round(size * 40 / 100);
---
<svg width={size} height={h} viewBox="0 0 100 40" aria-hidden="true">
  <path d="M4 22 C 20 12, 40 30, 58 18 C 74 8, 88 22, 96 20"
    stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.75"/>
  <path d="M22 16 C 20 12, 18 14, 20 18" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
  <path d="M38 22 C 40 26, 42 24, 40 20" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
  <path d="M58 16 C 56 12, 54 14, 56 18" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
  <path d="M76 12 C 78 8, 80 10, 78 14" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.65"/>
  <circle cx="96" cy="20" r="0.9" fill="var(--poppy-soft)" opacity="0.85"/>
  <circle cx="12" cy="24" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
</svg>
