---
/**
 * WhiteBear — memoria layer · cream skin · essay mark for
 * "The White Bear." A nearly-closed circle (like an ensō held tighter,
 * gap at top-right) with a small bear-silhouette inside the negative
 * space: two rounded ears, a soft head/body ellipse, tiny eyes + nose.
 * A small "damn" mark in Caveat script below to the right — the moment
 * consciousness turns and notices its own lapse. SUCCESSION §23.
 */
interface Props { size?: number; }
const { size = 84 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 80 80" aria-hidden="true">
  <path d="M 52 18 C 34 12, 18 22, 14 36 C 12 50, 22 62, 36 66 C 52 68, 66 60, 68 44 C 68 34, 66 26, 60 20"
    stroke="var(--ink-soft)" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.72"/>
  <circle cx="34" cy="34" r="3" stroke="var(--ink-soft)" stroke-width="0.7" fill="var(--paper-deep)" opacity="0.65"/>
  <circle cx="46" cy="34" r="3" stroke="var(--ink-soft)" stroke-width="0.7" fill="var(--paper-deep)" opacity="0.65"/>
  <ellipse cx="40" cy="43" rx="8" ry="7" stroke="var(--ink-soft)" stroke-width="0.85" fill="var(--paper-deep)" opacity="0.65"/>
  <circle cx="37" cy="42" r="0.6" fill="var(--ink-soft)" opacity="0.72"/>
  <circle cx="43" cy="42" r="0.6" fill="var(--ink-soft)" opacity="0.72"/>
  <circle cx="40" cy="45" r="0.5" fill="var(--ink-soft)" opacity="0.7"/>
  <text x="52" y="74" font-family="Caveat, cursive" font-size="10" fill="var(--ink-soft)" opacity="0.7" font-style="italic">damn</text>
</svg>
