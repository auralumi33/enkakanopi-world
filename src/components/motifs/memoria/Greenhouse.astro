---
/**
 * The greenhouse (not the cathedral) — memoria layer · cream skin ·
 * concept illustration for the colophon.
 * A small greenhouse: rounded roof arch + vertical glass panels + three
 * tiny plants inside (one with a poppy-soft bud). Beside it, a small
 * dashed cathedral silhouette with a delicate strike — the choice made
 * visible without extra words. Sits block-level below the opening lede.
 * SUCCESSION §21 · memoria layer per-essay extension pattern.
 */
interface Props { size?: number; }
const { size = 110 } = Astro.props;
const h = Math.round(size * 80 / 100);
---
