---
/**
 * In company (hand + machines) — memoria layer · cream skin · concept
 * illustration. A wide banner: on the left a fine-line hand holding a
 * pen, drawing a flowing curve trail (ending in a poppy-soft dot); a
 * dashed seam in the middle; on the right a small crew of three
 * machine marks (chip outlines with bloom-family accent dots —
 * lavender, yellow, pastel blue). A shared line arcs from the machines
 * back to the same drawn curve. Visualises the co-creation register:
 * words are hers, drawings are made in company. Sits block-level
 * below the co-creation paragraph on the colophon. SUCCESSION §21.
 */
interface Props { size?: number; }
const { size = 300 } = Astro.props;
const h = Math.round(size * 90 / 240);
---
<svg width={size} height={h} viewBox="0 0 240 90" aria-hidden="true">
