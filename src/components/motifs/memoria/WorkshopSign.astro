---
/**
 * The calligraphic sign — memoria layer (night skin variant).
 * A flowing S-curve entry, an ornamental loop center with a tiny gold
 * star nested inside, and a flowing calligraphic exit with tiny leaf
 * tips and drop endings. Reads: "closes the passage · a name laid down."
 * Sits at the workshop foot, after the refusal list. From the fine-line
 * calligraphic vocabulary (SUCCESSION §20 · the memoria layer ·
 * night-skin variant). Wide-banner motif.
 */
interface Props { size?: number; }
const { size = 260 } = Astro.props;
const h = Math.round(size * 80 / 140);
---
<svg width={size} height={h} viewBox="0 0 140 80" aria-hidden="true">
  <path d="M10 44 C 30 34, 44 52, 58 42" stroke="var(--night-ink)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.82"/>
  <path d="M58 42 C 66 34, 78 46, 70 54 C 62 56, 56 46, 62 40" stroke="var(--night-ink)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.72"/>
  <path d="M70 54 C 82 48, 96 62, 110 52 C 124 44, 130 46, 132 48" stroke="var(--night-ink)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.82"/>
  <path d="M67 46 L68 48 L70 48 L68.5 49 L69 51 L67 50 L65 51 L65.5 49 L64 48 L66 48 Z"
    fill="var(--gold)" opacity="0.92"/>
  <path d="M28 40 C 26 36, 24 38, 26 42" stroke="var(--night-ink)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.65"/>
  <path d="M100 54 C 102 50, 104 52, 102 56" stroke="var(--night-ink)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.65"/>
  <circle cx="130" cy="48" r="0.7" fill="var(--night-ink)" opacity="0.7"/>
  <circle cx="12" cy="46" r="0.7" fill="var(--night-ink)" opacity="0.7"/>
</svg>
