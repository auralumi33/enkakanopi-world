---
/**
 * The moon crescent — memoria layer (cream skin peppering).
 * A proper waxing crescent moon — outer arc bulges right, inner arc creates
 * the "bite" from the left (the dark side of the moon). A small hand-inked
 * four-line star sits beside it (the night sky), and one --poppy-soft press
 * marks the dark side. Same restraint discipline as before (stroke 0.85,
 * tapered, --ink-soft at ~0.78); the shape now reads as a moon at a glance
 * rather than as a closed lens/leaf/almond.
 * Reworked 2026-07-09 (Set 3 · slice-2) — the interior mote was dropped
 * (Law 8, "every value earns its place"), the polygon star swapped for a
 * hand-inked four-line spark.
 */
interface Props { size?: number; }
const { size = 44 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 60 60" aria-hidden="true">
  {/* the crescent — outer bulge right, inner concave curve back */}
  <path d="M 22 14 C 40 16, 40 48, 22 50 C 30 40, 30 24, 22 14 Z"
    stroke="var(--ink-soft)" stroke-width="0.85" fill="none"
    stroke-linecap="round" stroke-linejoin="round" opacity="0.78"/>
  {/* a small hand-inked star beside the moon (the night sky, held sparingly) */}
  <g transform="translate(48 18)" stroke="var(--ink-soft)" stroke-width="0.55"
     fill="none" stroke-linecap="round" opacity="0.7">
    <path d="M0 -3 L 0 3"/>
    <path d="M-3 0 L 3 0"/>
    <path d="M-2 -2 L 2 2"/>
    <path d="M-2 2 L 2 -2"/>
  </g>
  {/* one --poppy-soft press near the dark side (Law 6 — one accent, held back) */}
  <circle cx="12" cy="42" r="1.1" fill="var(--poppy-soft)" opacity="0.9"/>
</svg>
