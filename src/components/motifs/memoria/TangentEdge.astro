---
/**
 * TangentEdge — memoria layer · cream skin · essay mark for
 * "The Wobble the Ruler Couldn't Hold." A smooth curve with a dashed
 * tangent line kissing it at one point (poppy-soft dot), then diverging;
 * beyond the tangent-contact, small scatter dots (the edge cases where
 * the linear approximation fails). The garden's epistemology: legibility
 * arrives by loving the curve enough to know where the tangent leaves.
 * SUCCESSION §23.
 */
interface Props { size?: number; }
const { size = 140 } = Astro.props;
const h = Math.round(size * 80 / 140);
---
<svg width={size} height={h} viewBox="0 0 140 80" aria-hidden="true">
  <path d="M 10 60 C 30 55, 60 20, 90 20 C 110 20, 125 30, 135 55"
    stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.78"/>
  <path d="M 60 40 L 130 15"
    stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.6" stroke-dasharray="1.5 2"/>
  <circle cx="90" cy="20" r="1.6" fill="var(--poppy-soft)" opacity="0.9"/>
  <circle cx="118" cy="12" r="0.7" fill="var(--ink-soft)" opacity="0.55"/>
  <circle cx="128" cy="10" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
  <circle cx="122" cy="16" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
  <circle cx="105" cy="42" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
  <circle cx="115" cy="48" r="0.5" fill="var(--ink-soft)" opacity="0.5"/>
</svg>
