---
/**
 * The dragonfly — memoria layer (cream skin peppering).
 * A dainty hairline dragonfly (tattoo-flash discipline): two paired
 * gossamer wings, slim segmented body, tiny antennae, poppy-soft
 * body accent. Reads: "a delicate visitor · the mind that lands
 * briefly." Used as an inter-paragraph breather across the field-notes.
 * SUCCESSION §25 · essay breather (tattoo-flash register).
 */
interface Props { size?: number; }
const { size = 72 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 60 60" aria-hidden="true">
  {/* the body — slim, segmented vertical stroke */}
  <path d="M30 14 L 30 44" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linecap="round" opacity="0.72"/>
  {/* faint segment ticks along the body */}
  <g stroke="var(--ink-soft)" stroke-width="0.35" stroke-linecap="round" opacity="0.55">
    <path d="M28 26 L 32 26"/>
    <path d="M28.5 30 L 31.5 30"/>
    <path d="M28.5 34 L 31.5 34"/>
    <path d="M29 38 L 31 38"/>
  </g>
  {/* the head — a tiny circle at the top */}
  <circle cx="30" cy="13" r="1" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.65"/>
  {/* the antennae — tiny hair-flick */}
  <path d="M29 11 L 27 8" stroke="var(--ink-soft)" stroke-width="0.35" stroke-linecap="round" opacity="0.55"/>
  <path d="M31 11 L 33 8" stroke="var(--ink-soft)" stroke-width="0.35" stroke-linecap="round" opacity="0.55"/>
  {/* the upper wings — two long ovals angled up and out */}
  <ellipse cx="18" cy="20" rx="10" ry="3.4" transform="rotate(-22 18 20)" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.65"/>
  <ellipse cx="42" cy="20" rx="10" ry="3.4" transform="rotate(22 42 20)" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.65"/>
  {/* the lower wings — two shorter ovals angled down and out */}
  <ellipse cx="20" cy="30" rx="7.5" ry="2.6" transform="rotate(18 20 30)" stroke="var(--ink-soft)" stroke-width="0.45" fill="none" opacity="0.6"/>
  <ellipse cx="40" cy="30" rx="7.5" ry="2.6" transform="rotate(-18 40 30)" stroke="var(--ink-soft)" stroke-width="0.45" fill="none" opacity="0.6"/>
  {/* the thorax accent — a small poppy dot */}
  <circle cx="30" cy="22" r="1" fill="var(--poppy-soft)" opacity="0.85"/>
  {/* tail tip whisper */}
  <circle cx="30" cy="45" r="0.6" fill="var(--ink-soft)" opacity="0.55"/>
</svg>
