---
/**
 * SceneWeaveSeam — Marimekko × fine-line hybrid scene (Set 3 · 2026-07-09).
 * "The container beneath the craft, holding the raw human weave."
 *
 * Layered composition: a soft table-line → the hand-brushed ensō container →
 * a --skin fabric panel inside → faint silk-moiré vertical stripes on the
 * fabric → the ruled --ink-soft spine across → the --canopy thread woven
 * over-and-under → three tall-stem-and-bloom botanicals GROWING on the cloth
 * (--lavender bloom + --coral marigold + --slate bell, with --gold centres) →
 * a fern frond at the base → two embroidery needles piercing the cloth from
 * either side with --canopy trailing threads → four cardinal orbit dots
 * around the ensō (lineage from MotifEnkaEnso) → a small bloom below the
 * ensō → a trellis-canopy above the ensō with four hanging blooms (one per
 * canonical pastel) + whisper vine curls.
 *
 * Hand-labels are ALL from Rika's shipped voice: "what looks carved was
 * always soft thread" (kickoff §4A) · "warm surface, rigorous spine" +
 * "— Law 3, made tactile" (design law) · "held long enough to become"
 * (Silent Workspace). Zero prose from the machine.
 *
 * Reads as: designer form × creative-tech rigor × the four grounds ×
 * return to essentials. All in Enka's palette — no lift from PJ refs.
 * Register: middleground · dainty · feminine · hand-drawn organic craft.
 * §33 · Set 3 · slice-2.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 720 420" role="img" aria-labelledby="weaveseam-t" preserveAspectRatio="xMidYMid meet">
    <title id="weaveseam-t">The ensō container holds a fabric panel — a garden being made by two embroidery needles — the container beneath the craft rendered whole.</title>

    {/* — the trellis-canopy above the ensō (theme continuation w/ the silk-on-washi register) — */}
    <path d="M 220 68 C 260 44, 380 32, 500 44 C 520 46, 540 54, 550 60"
      stroke="var(--canopy)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.40"/>
    {/* whisper vine-curls along the arch */}
    <path d="M 274 46 C 278 42, 280 42, 282 46 C 280 50, 276 50, 274 46 Z"
      stroke="var(--canopy-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.55"/>
    <path d="M 396 34 C 404 30, 410 30, 406 38 C 402 40, 398 40, 396 34 Z"
      stroke="var(--canopy-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.5"/>
    <path d="M 470 40 C 474 36, 476 36, 478 40 C 476 44, 472 44, 470 40 Z"
      stroke="var(--canopy-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.55"/>
    {/* end tendrils, softened */}
    <path d="M 258 56 C 254 68, 252 78, 256 86 C 258 90, 260 92, 258 94"
      stroke="var(--canopy)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.42"/>
    <path d="M 512 56 C 516 68, 518 78, 514 86"
      stroke="var(--canopy)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.42"/>
    {/* four hanging blooms · one per canonical pastel */}
    {/* lavender */}
    <path d="M 306 41 L 306 55" stroke="var(--canopy-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.55"/>
    <g transform="translate(306 58)">
      <g fill="#b899c9" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.25" stroke-linejoin="round">
        <path d="M0 -3 C 1.6 -2.6, 2 -0.8, 0 -0.2 C -2 -0.8, -1.6 -2.6, 0 -3 Z"/>
        <path d="M2.4 -1 C 3 0.8, 1.6 2, 0.4 1.2 C 0 -0.2, 1.4 -1.6, 2.4 -1 Z"/>
        <path d="M1.6 2 C 0 2.6, -1.6 1.2, -0.6 0 C 1 -0.8, 2.4 0.6, 1.6 2 Z"/>
        <path d="M-2 1 C -3 -0.6, -2 -1.8, -0.4 -1 C 0 0, -1 1.8, -2 1 Z"/>
      </g>
      <circle cx="0" cy="0" r="0.5" fill="#e8c15a" opacity="0.9"/>
    </g>
    {/* gold */}
    <path d="M 360 35 L 360 50" stroke="var(--canopy-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.55"/>
    <g transform="translate(360 54)">
      <g fill="#e8c15a" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.25" stroke-linejoin="round">
        <path d="M0 -3 C 1.6 -2.6, 2 -0.8, 0 -0.2 C -2 -0.8, -1.6 -2.6, 0 -3 Z"/>
        <path d="M2.4 -1 C 3 0.8, 1.6 2, 0.4 1.2 C 0 -0.2, 1.4 -1.6, 2.4 -1 Z"/>
        <path d="M1.6 2 C 0 2.6, -1.6 1.2, -0.6 0 C 1 -0.8, 2.4 0.6, 1.6 2 Z"/>
        <path d="M-2 1 C -3 -0.6, -2 -1.8, -0.4 -1 C 0 0, -1 1.8, -2 1 Z"/>
      </g>
      <circle cx="0" cy="0" r="0.5" fill="var(--ink-soft)" opacity="0.6"/>
    </g>
    {/* coral */}
    <path d="M 424 33 L 424 46" stroke="var(--canopy-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.55"/>
    <g transform="translate(424 50)">
      <g fill="#e46b6b" opacity="0.78" stroke="var(--ink-soft)" stroke-width="0.25" stroke-linejoin="round">
        <path d="M0 -3 C 1.6 -2.6, 2 -0.8, 0 -0.2 C -2 -0.8, -1.6 -2.6, 0 -3 Z"/>
        <path d="M2.4 -1 C 3 0.8, 1.6 2, 0.4 1.2 C 0 -0.2, 1.4 -1.6, 2.4 -1 Z"/>
        <path d="M1.6 2 C 0 2.6, -1.6 1.2, -0.6 0 C 1 -0.8, 2.4 0.6, 1.6 2 Z"/>
        <path d="M-2 1 C -3 -0.6, -2 -1.8, -0.4 -1 C 0 0, -1 1.8, -2 1 Z"/>
      </g>
      <circle cx="0" cy="0" r="0.5" fill="#e8c15a" opacity="0.9"/>
    </g>
    {/* slate bell */}
    <path d="M 468 37 L 468 51" stroke="var(--canopy-soft)" stroke-width="0.4" stroke-linecap="round" opacity="0.55"/>
    <g transform="translate(468 54)">
      <path d="M -2.5 -1 C -3 3, -2 4, 0 4 C 2 4, 3 3, 2.5 -1 Z" fill="#a4b8c8" opacity="0.78" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round"/>
      <circle cx="0" cy="4" r="0.5" fill="#e8c15a" opacity="0.85"/>
    </g>

    {/* — the ensō container — large, hand-brushed — */}
    <path d="M 450 100 C 350 80, 220 130, 170 200 C 130 280, 200 360, 320 370 C 440 376, 570 336, 610 260 C 636 208, 620 146, 550 114"
      stroke="var(--ink-soft)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.5"/>

    {/* soft table-line */}
    <path d="M 140 342 C 260 340, 500 340, 610 342"
      stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>

    {/* — the --skin fabric panel — */}
    <path d="M 245 218 C 247 216, 320 214, 355 214 C 390 214, 465 216, 469 218 C 471 220, 471 316, 469 318 C 467 320, 390 322, 355 322 C 320 322, 247 320, 245 318 C 243 316, 243 220, 245 218 Z"
      fill="#f2e0d0" fill-opacity="0.62"
      stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round" opacity="0.72"/>

    {/* faint silk-moiré vertical stripes inside the fabric */}
    <g stroke="var(--ink-soft)" stroke-width="0.35" fill="none" opacity="0.22" stroke-linecap="round">
      <path d="M 260 220 Q 263 248, 260 276 T 260 316"/>
      <path d="M 278 220 Q 275 248, 278 276 T 278 316"/>
      <path d="M 296 220 Q 299 248, 296 276 T 296 316"/>
      <path d="M 314 220 Q 311 248, 314 276 T 314 316"/>
      <path d="M 332 220 Q 335 248, 332 276 T 332 316"/>
      <path d="M 350 220 Q 347 248, 350 276 T 350 316"/>
      <path d="M 368 220 Q 371 248, 368 276 T 368 316"/>
      <path d="M 386 220 Q 383 248, 386 276 T 386 316"/>
      <path d="M 404 220 Q 407 248, 404 276 T 404 316"/>
      <path d="M 422 220 Q 419 248, 422 276 T 422 316"/>
      <path d="M 440 220 Q 443 248, 440 276 T 440 316"/>
      <path d="M 458 220 Q 455 248, 458 276 T 458 316"/>
    </g>

    {/* — the ruled --ink-soft spine — */}
    <path d="M 260 268.4 C 310 267.6, 355 268.6, 400 267.8 C 435 268.2, 450 268.0, 452 268.4"
      stroke="var(--ink-soft)" stroke-width="1.0" fill="none" stroke-linecap="round" opacity="0.78"/>

    {/* — the woven --canopy thread over-and-under — */}
    <path d="M 264 268 C 274 268, 280 250, 294 252 C 308 254, 314 268, 328 268 C 342 268, 348 286, 362 284 C 376 282, 382 268, 396 268 C 410 268, 416 250, 430 252 C 442 254, 448 268, 450 268"
      stroke="var(--canopy)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.65"/>

    {/* doubled --poppy-soft press */}
    <circle cx="362" cy="284" r="2.4" fill="var(--poppy-soft)" opacity="0.9"/>
    <circle cx="362" cy="268" r="3.2" fill="var(--poppy-soft)" opacity="0.85"/>
    <circle cx="362" cy="268" r="1.0" fill="var(--paper-washi)"/>

    {/* — three tall-stem-and-bloom botanicals GROWING on the cloth — */}
    {/* LEFT stem · --lavender bloom */}
    <g transform="translate(288 218)">
      <path d="M 0 96 L 0 8" stroke="var(--canopy)" stroke-width="0.8" stroke-linecap="round" opacity="0.72"/>
      <path d="M 0 62 C -8 60, -12 54, -10 48 C -8 52, -4 56, 0 58 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 68 C 8 66, 12 60, 10 54 C 8 58, 4 62, 0 64 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 40 C -7 38, -10 33, -9 28 C -7 32, -3 36, 0 37 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 46 C 7 44, 10 39, 9 34 C 7 38, 3 42, 0 43 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <circle cx="4" cy="18" r="1.8" fill="#b899c9" opacity="0.75"/>
      <g transform="translate(0 8)">
        <g fill="#b899c9" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round">
          <path d="M0 -8 C 4 -7, 5 -3, 0 -1 C -4 -3, -5 -7, 0 -8 Z"/>
          <path d="M6 -4 C 8 1, 5 5, 1 2 C 0 -3, 4 -6, 6 -4 Z"/>
          <path d="M4 5 C 0 6, -4 3, -2 0 C 3 -2, 6 3, 4 5 Z"/>
          <path d="M-6 3 C -8 -2, -5 -6, -1 -3 C 0 -1, -3 4, -6 3 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.2" fill="#e8c15a" opacity="0.9"/>
      </g>
    </g>

    {/* CENTRE-RIGHT stem · --coral marigold */}
    <g transform="translate(408 218)">
      <path d="M 0 92 L 0 4" stroke="var(--canopy)" stroke-width="0.8" stroke-linecap="round" opacity="0.72"/>
      <path d="M 0 78 C -10 76, -14 70, -16 62 C -12 68, -6 74, 0 76 Z" fill="var(--canopy-soft)" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 84 C 10 82, 14 76, 16 68 C 12 74, 6 80, 0 82 Z" fill="var(--canopy-soft)" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 50 C -7 48, -10 43, -9 38 C -7 42, -3 46, 0 47 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 0 56 C 7 54, 10 49, 9 44 C 7 48, 3 52, 0 53 Z" fill="var(--canopy-soft)" opacity="0.6" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <g transform="translate(0 6)">
        <circle cx="0" cy="0" r="5.5" fill="#e46b6b" opacity="0.75"/>
        <circle cx="0" cy="0" r="4" fill="#e46b6b" opacity="0.5"/>
        <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
        <g stroke="#e46b6b" stroke-width="0.55" opacity="0.6" stroke-linecap="round">
          <path d="M 0 -8 L 0 -6"/><path d="M 0 6 L 0 8"/><path d="M -8 0 L -6 0"/><path d="M 6 0 L 8 0"/>
          <path d="M -5.5 -5.5 L -4 -4"/><path d="M 4 4 L 5.5 5.5"/><path d="M 4 -4 L 5.5 -5.5"/><path d="M -5.5 5.5 L -4 4"/>
        </g>
      </g>
    </g>

    {/* RIGHT stem · --slate bell */}
    <g transform="translate(438 220)">
      <path d="M 0 94 L 0 20" stroke="var(--canopy)" stroke-width="0.7" stroke-linecap="round" opacity="0.7"/>
      <path d="M 0 62 C -6 60, -9 55, -8 50 C -6 54, -2 58, 0 59 Z" fill="var(--canopy-soft)" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round"/>
      <path d="M 0 44 C 6 42, 9 37, 8 32 C 6 36, 2 40, 0 41 Z" fill="var(--canopy-soft)" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round"/>
      <g transform="translate(0 22)">
        <path d="M -3 0 C -4 4, -3 6, 0 6 C 3 6, 4 4, 3 0 Z" fill="#a4b8c8" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round"/>
        <circle cx="0" cy="6" r="0.7" fill="#e8c15a" opacity="0.8"/>
      </g>
    </g>

    {/* — fern frond at the base of the cloth — */}
    <g transform="translate(276 316)">
      <path d="M 0 0 C -4 -4, -8 -8, -12 -14 C -16 -20, -20 -26, -22 -32"
        stroke="var(--canopy)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M -6 -6 C -8 -8, -10 -10, -12 -12" stroke="var(--canopy)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M -10 -12 C -12 -14, -14 -16, -16 -18" stroke="var(--canopy)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M -14 -18 C -16 -20, -18 -22, -20 -24" stroke="var(--canopy)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M -18 -24 C -20 -26, -21 -28, -22 -30" stroke="var(--canopy)" stroke-width="0.3" fill="none" stroke-linecap="round" opacity="0.5"/>
    </g>

    {/* — LEFT embroidery needle piercing the cloth · thread trailing off-frame — */}
    <g transform="translate(200 274) rotate(-12)">
      <path d="M -4 0 C -18 -6, -34 4, -50 -4 C -64 -12, -78 0, -90 -8"
        stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.7"/>
      <ellipse cx="-1" cy="0" rx="3.2" ry="1.5" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.85"/>
      <line x1="2" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.3" stroke-linecap="round" opacity="0.85"/>
      <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.8"/>
    </g>

    {/* — RIGHT embroidery needle · mirrored — */}
    <g transform="translate(514 284) rotate(190)">
      <path d="M -4 0 C -18 -6, -34 4, -50 -4 C -64 -12, -78 0, -90 -8"
        stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.7"/>
      <ellipse cx="-1" cy="0" rx="3.2" ry="1.5" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.85"/>
      <line x1="2" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.3" stroke-linecap="round" opacity="0.85"/>
      <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.8"/>
    </g>

    {/* — four cardinal orbit dots around the ensō — */}
    <circle cx="378" cy="82" r="1.6" fill="#b899c9" opacity="0.72"/>
    <circle cx="618" cy="240" r="1.6" fill="#e8c15a" opacity="0.72"/>
    <circle cx="378" cy="378" r="1.6" fill="#a4b8c8" opacity="0.72"/>
    <circle cx="140" cy="240" r="1.6" fill="var(--poppy-soft)" opacity="0.72"/>

    {/* — small bloom below the ensō — */}
    <g transform="translate(355 322)">
      <path d="M 0 6 L 0 -4" stroke="var(--canopy)" stroke-width="0.55" stroke-linecap="round" opacity="0.7"/>
      <g fill="#e46b6b" opacity="0.78">
        <path d="M 0 -10 C 3 -9, 4 -3, 0 -2 C -4 -3, -3 -9, 0 -10 Z"/>
        <path d="M 6 -6 C 8 -1, 4 3, 1 1 C 0 -4, 4 -8, 6 -6 Z"/>
        <path d="M 4 4 C 0 5, -4 2, -2 0 C 3 -3, 6 1, 4 4 Z"/>
        <path d="M -6 2 C -8 -3, -5 -8, -2 -6 C 0 -3, -3 3, -6 2 Z"/>
      </g>
    </g>

    {/* — HAND LABELS · all from Rika's own voice — */}
    <text class="hand-label" x="42" y="112" font-size="17">what looks carved</text>
    <text class="hand-label" x="42" y="132" font-size="17">was always</text>
    <text class="hand-label hand-label--accent" x="42" y="152" font-size="17">soft thread</text>

    <text class="hand-label" x="530" y="112" font-size="15" opacity="0.75">warm surface,</text>
    <text class="hand-label hand-label--accent" x="530" y="132" font-size="15">rigorous spine</text>
    <text class="hand-label" x="530" y="150" font-size="11" opacity="0.65">— Law 3, made tactile</text>

    <text class="hand-label" x="340" y="94" font-size="14" opacity="0.7" text-anchor="middle" font-style="italic">held long enough to become</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
