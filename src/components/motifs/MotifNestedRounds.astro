---
/**
 * The nested rounds — quiet accumulation.
 * Three concentric hand-brushed circles (seed within seedling within
 * bloom) with a poppy-soft heart and bloom-family sprinkles at the four
 * cardinals — a Marimekko compass. Part of the garden's motif set
 * (SUCCESSION §18). Pastel palette.
 */
interface Props { size?: number; }
const { size = 120 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 100" aria-hidden="true">
  <circle cx="50" cy="50" r="42" stroke="var(--canopy)" stroke-width="0.9" fill="none" opacity="0.55"/>
  <circle cx="50.5" cy="49.5" r="28" stroke="var(--canopy-soft)" stroke-width="1.3" fill="none" opacity="0.85"/>
  <circle cx="50" cy="50.4" r="14" stroke="var(--ink-soft)" stroke-width="1.4" fill="none" opacity="0.6"/>
  <circle cx="50" cy="50" r="3" fill="var(--poppy-soft)" opacity="0.92"/>
  <circle cx="50" cy="50" r="0.9" fill="var(--paper)"/>
  <circle cx="50" cy="12" r="1.6" fill="#b899c9" opacity="0.8"/>
  <circle cx="88" cy="50" r="1.6" fill="#e8c15a" opacity="0.8"/>
  <circle cx="50" cy="88" r="1.6" fill="#a4b8c8" opacity="0.8"/>
  <circle cx="12" cy="50" r="1.6" fill="var(--canopy-soft)" opacity="0.85"/>
</svg>
