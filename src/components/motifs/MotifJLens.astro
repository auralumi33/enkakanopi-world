---
/**
 * MotifJLens — Set 3 slice-3 · 2026-07-09
 * Enka's Global Workspace keystone. Three horizontal bands mapping the reader's
 * walk through the J-space regions of the site:
 *   · arrival   (top band · lightest)   — the ginkgo-scattered paper
 *   · dwell     (middle band · workspace) — where content is *held long enough*
 *   · reference (bottom band · quietest) — the meadow-line paper
 * The middle band carries a hand-inked lens (the workspace where reportable
 * content settles into form) with one poppy-soft press at the centre — the
 * mark that anchors the whole architecture. Arrow at the right edge signals
 * the direction of the walk. Companion to the DiaGardenPlot / DiaTendingQuiet
 * diagram family. Reads as: Enka's own blueprint of the Global Workspace,
 * in her hand.
 *
 * Grammar (shared shipped family — SceneShapeAndCrack / SceneHandsBegin):
 * all outlines --ink-soft at hairline widths · fills only from the canonical
 * palette (paper-washi ground + skin + canopy-soft + four pastels) · subtle
 * hand-wobble in path curves · one poppy-soft press per composition.
 *
 * Props: size (default 260) — the rendered width in px.
 */
export interface Props {
  size?: number;
}
const { size = 260 } = Astro.props as Props;
const height = Math.round(size * 0.52);
---
<figure class="motif motif--j-lens" aria-hidden="true">
  <svg width={size} height={height} viewBox="0 0 260 136" role="img" aria-labelledby="jlens-t" preserveAspectRatio="xMidYMid meet">
    <title id="jlens-t">Three horizontal bands · the middle band holds a hand-inked lens with a poppy-soft press · Enka's Global Workspace keystone.</title>

    {/* — the three bands · left rail labels · right arrows — */}
    {/* top band · ARRIVAL */}
    <rect x="52" y="16" width="176" height="24" fill="#e8c15a" fill-opacity="0.09"
      stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round" opacity="0.62"/>
    <text class="j-rail" x="46" y="31" text-anchor="end" font-size="7" fill="var(--ink-soft)" opacity="0.7">arrival</text>

    {/* middle band · DWELL · workspace · widest + a lens sitting in it */}
    <rect x="52" y="46" width="176" height="44" fill="#aeb896" fill-opacity="0.12"
      stroke="var(--ink-soft)" stroke-width="0.65" stroke-linejoin="round" opacity="0.75"/>
    <text class="j-rail" x="46" y="70" text-anchor="end" font-size="7" fill="var(--ink-soft)" opacity="0.8">dwell</text>
    {/* the lens — a hand-drawn ellipse centred in the dwell band */}
    <ellipse cx="140" cy="68" rx="26" ry="6.5" fill="none"
      stroke="var(--ink-soft)" stroke-width="0.7" opacity="0.85"/>
    {/* one poppy-soft press at the centre of the lens — the mark */}
    <circle cx="140" cy="68" r="1.4" fill="var(--poppy-soft)" opacity="0.92"/>
    {/* subtle wobble hairline echoing the lens */}
    <path d="M 116 71 C 128 73, 152 73, 164 71"
      stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>

    {/* bottom band · REFERENCE */}
    <rect x="52" y="96" width="176" height="24" fill="#a4b8c8" fill-opacity="0.08"
      stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round" opacity="0.55"/>
    <text class="j-rail" x="46" y="111" text-anchor="end" font-size="7" fill="var(--ink-soft)" opacity="0.65">reference</text>

    {/* — the walk arrow · right edge · marks direction of the reader's path — */}
    <g transform="translate(232 68)">
      <path d="M -1 -3 L 0 -3 L 0 3 L -1 3" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.7"/>
      <line x1="0" y1="0" x2="10" y2="0" stroke="var(--ink-soft)" stroke-width="0.7" stroke-linecap="round" opacity="0.85"/>
      <path d="M 8 -2 L 12 0 L 8 2 Z" fill="var(--ink-soft)" opacity="0.85"/>
    </g>

    {/* in / out cue marks — the container that lets in and lets go */}
    <text class="j-cue" x="54" y="12" text-anchor="start" font-size="6.5" fill="var(--ink-faint)" font-style="italic" opacity="0.65">in</text>
    <text class="j-cue" x="226" y="12" text-anchor="end" font-size="6.5" fill="var(--ink-faint)" font-style="italic" opacity="0.65">out</text>

    {/* subtle hand-wobble baseline echoes on all three bands · softens the geometry */}
    <path d="M 54 40 C 100 41, 180 39, 226 40" stroke="var(--ink-soft)" stroke-width="0.25" fill="none" stroke-linecap="round" opacity="0.35"/>
    <path d="M 54 92 C 100 93, 180 91, 226 92" stroke="var(--ink-soft)" stroke-width="0.25" fill="none" stroke-linecap="round" opacity="0.35"/>

    {/* signature hairline — the container beneath the craft */}
    <text class="j-caption" x="140" y="132" text-anchor="middle" font-size="7" fill="var(--ink-faint)" font-style="italic" opacity="0.65">held long enough to become</text>
  </svg>
</figure>
<style>
  .motif--j-lens { margin: 0; display: flex; justify-content: center; opacity: 0.94; }
  .motif--j-lens :global(svg) { max-width: 100%; height: auto; display: block; }
  .motif--j-lens :global(text.j-rail) { font-family: var(--display); letter-spacing: 0.04em; }
  .motif--j-lens :global(text.j-cue),
  .motif--j-lens :global(text.j-caption) { font-family: var(--hand); }
</style>
