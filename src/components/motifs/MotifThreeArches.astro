---
/**
 * The three arches — "under something older and greener than itself."
 * Three nested canopy arches; leaf clusters vary in the bloom-family
 * palette (sage · lavender · yellow). Small poppy-soft bloom + seedling
 * sheltered beneath. Part of the garden's motif set (SUCCESSION §18).
 * Pastel palette. Wide-banner motif.
 */
interface Props { size?: number; }
const { size = 340 } = Astro.props;
const h = Math.round(size * 90 / 220);
---
<svg width={size} height={h} viewBox="0 0 220 90" aria-hidden="true">
  <path d="M10 78 C 30 20, 90 20, 110 78" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.48"/>
  <path d="M50 78 C 70 30, 130 30, 150 78" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.62"/>
  <path d="M90 78 C 110 38, 170 38, 190 78" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.78"/>
  <path d="M100 42 C 106 38, 112 42, 108 48 C 102 50, 96 46, 100 42 Z" fill="var(--canopy-soft)" opacity="0.88"/>
  <path d="M140 40 C 148 36, 154 42, 148 48 C 142 50, 134 44, 140 40 Z" fill="#b899c9" opacity="0.68"/>
  <path d="M170 46 C 176 42, 182 46, 178 52 C 172 54, 164 50, 170 46 Z" fill="#e8c15a" opacity="0.68"/>
  <circle cx="120" cy="24" r="1.4" fill="#a4b8c8" opacity="0.8"/>
  <circle cx="80" cy="30" r="1.4" fill="#b899c9" opacity="0.8"/>
  <circle cx="160" cy="34" r="1.4" fill="#e8c15a" opacity="0.8"/>
  <path d="M14 80 C 100 78, 190 80, 200 80" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.45"/>
  <g transform="translate(140 72)">
    <path d="M-4 -1 C -6 -5, -1 -6, 0 -3 C -2 -1, -4 -1, -4 -1 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M4 -1 C 6 -5, 1 -6, 0 -3 C 2 -1, 4 -1, 4 -1 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M-3 3 C -5 1, -5 -1, -2 -1 C -1 0, -1 2, -3 3 Z" fill="var(--poppy-soft)" opacity="0.92"/>
    <path d="M3 3 C 5 1, 5 -1, 2 -1 C 1 0, 1 2, 3 3 Z" fill="var(--poppy-soft)" opacity="0.92"/>
  </g>
  <path d="M60 72 L60 68" stroke="var(--canopy)" stroke-width="0.9" stroke-linecap="round" opacity="0.8"/>
  <path d="M60 70 C 57 68, 55 69, 56 71 C 58 72, 60 71, 60 70 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <circle cx="66" cy="70" r="1.4" fill="#a4b8c8" opacity="0.8"/>
</svg>
