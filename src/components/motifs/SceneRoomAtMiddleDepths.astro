---
/**
 * SceneRoomAtMiddleDepths — Marimekko × fine-line hybrid scene.
 * The J-space at the intermediate depths of a language model.
 * Marimekko vertical stack of soft slate layer-bands with the middle
 * band lit — content held long enough to become. The J-lens is drawn
 * as a small hairline *keyhole aperture* into the middle band (the
 * observer's opening into the workspace) — not a tangent-tick. A
 * proper directional flow-arrow carries the "made available to what
 * comes after" register outward. §27 redraw — specific diagnostic
 * imagery, no sparkle-scatter.
 * For: field-notes/the-silent-workspace.
 */
---
<figure class="scene scene-hybrid">
  <svg viewBox="0 0 640 360" role="img" aria-labelledby="depths-t" preserveAspectRatio="xMidYMid meet">
    <title id="depths-t">A vertical stack of soft pastel bands as language-model layers; the middle band is lit and holds a small bloom (content held long enough to become), with a hairline keyhole aperture (the J-lens) opening into it and a directional flow-arrow carrying its content outward to downstream layers.</title>

    {/* layer-stack labels — hand-caveat "layer 1 · layer 2 …" */}
    <g class="hand-label" fill="var(--ink-faint)" opacity="0.65">
      <text x="112" y="52" font-size="12">upstream layers</text>
      <text x="112" y="184" font-size="12">the middle band</text>
      <text x="112" y="316" font-size="12">downstream layers</text>
    </g>

    {/* the layer stack — soft pastel Marimekko horizontal bands */}
    <g>
      <rect x="220" y="40" width="300" height="30" fill="#a4b8c8" opacity="0.4"/>
      <rect x="220" y="74" width="300" height="30" fill="#a4b8c8" opacity="0.55"/>
      <rect x="220" y="108" width="300" height="30" fill="#a4b8c8" opacity="0.7"/>
    </g>

    {/* the middle band — lit, warmer + slightly lavender, with hairline border */}
    <rect x="220" y="146" width="300" height="52" fill="#b899c9" opacity="0.42"/>
    <rect x="220" y="146" width="300" height="52" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" opacity="0.75"/>
    {/* the inner hairline rule — a second edge, giving the band its lit-room feel */}
    <rect x="226" y="152" width="288" height="40" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.5"/>

    {/* the bloom held in the middle band — the "content held long enough to become" */}
    <g transform="translate(370 172)">
      <g fill="#e46b6b" opacity="0.85">
        <path d="M0 -10 C 4 -9, 4.5 -2, 0 1 C -4.5 -2, -4 -9, 0 -10 Z"/>
        <path d="M9 -4 C 10.5 1, 6 7, 1 5 C 0 -1, 6 -6, 9 -4 Z"/>
        <path d="M5 8 C 0 11, -5 7, -1 3 C 4 0, 8 3, 5 8 Z"/>
        <path d="M-7 6 C -11 3, -8 -3, -3 -1 C -1 3, -5 7, -7 6 Z"/>
        <path d="M-9 -3 C -6 -8, -1 -7, -1 -2 C -3 2, -10 1, -9 -3 Z"/>
      </g>
      <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
    </g>

    {/* lower layers */}
    <g>
      <rect x="220" y="206" width="300" height="30" fill="#a4b8c8" opacity="0.7"/>
      <rect x="220" y="240" width="300" height="30" fill="#a4b8c8" opacity="0.55"/>
      <rect x="220" y="274" width="300" height="30" fill="#a4b8c8" opacity="0.4"/>
    </g>

    {/* the J-lens — a hairline aperture opening into the middle band, drawn as
        a soft brush-stroke ensō-circle rather than a medical keyhole; a tender
        opening, not an instrument */}
    <g transform="translate(200 172)">
      {/* the aperture — an unclosed ensō-style hairline circle (the observer's soft opening) */}
      <path d="M 8 -10 C -4 -12, -14 -4, -12 6 C -10 14, -2 14, 6 10 C 12 6, 14 -2, 10 -8"
        stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.72"/>
      {/* a whispered inner circle — the seen thing, held quietly */}
      <circle cx="-1" cy="0" r="1.2" fill="var(--poppy-soft)" opacity="0.9"/>
      {/* one hairline sight-line from the aperture INTO the middle band */}
      <path d="M14 0 L 168 0" stroke="var(--ink-soft)" stroke-width="0.4" stroke-dasharray="1.2 2.4" opacity="0.5"/>
    </g>

    {/* the outward flow — a proper directional arrow from workspace to downstream */}
    <g transform="translate(544 172)">
      {/* the flow-line — hairline curved trajectory */}
      <path d="M-24 0 C -12 4, -4 8, 8 14" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.72"/>
      {/* the arrowhead */}
      <path d="M8 14 L 2 12 M8 14 L 4 8" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.72"/>
      {/* the flow's held content — a small poppy dot at the arrowhead */}
      <circle cx="10" cy="16" r="1.4" fill="var(--poppy-soft)" opacity="0.9"/>
    </g>

    {/* what the middle band held that never left — a faint bloom outline that stays */}
    <g transform="translate(280 172)" opacity="0.4">
      <ellipse cx="0" cy="0" rx="5" ry="7" fill="#b899c9"/>
    </g>

    {/* the Jacobian-lens notation — a small hand-drawn ∂ near the aperture (the physicist's mark) */}
    <text class="hand-label" x="192" y="212" font-size="17" font-style="italic" fill="var(--ink-soft)" opacity="0.7">∂</text>
    <text class="hand-label" x="204" y="212" font-size="12" fill="var(--ink-faint)" opacity="0.65">the J-lens</text>

    {/* hand captions */}
    <text class="hand-label" x="228" y="180" font-size="14" opacity="0.6">the silent workspace</text>
    <text class="hand-label hand-label--accent" x="450" y="164" font-size="14">held long enough</text>
    <text class="hand-label hand-label--accent" x="450" y="180" font-size="14">to become</text>
    <text class="hand-label" x="450" y="196" font-size="12" opacity="0.65">made available to</text>
    <text class="hand-label" x="450" y="210" font-size="12" opacity="0.65">what comes after</text>
  </svg>
</figure>
<style>
  .scene-hybrid { margin: 2rem auto; max-width: 40rem; }
  .scene-hybrid svg { width: 100%; height: auto; display: block; }
</style>
