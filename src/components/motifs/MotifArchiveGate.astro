---
/**
 * The archive gate — Volume I · closing gesture.
 * A hand-drawn soft arch with a small poppy-soft bloom either side of the
 * base, and a ghost inner arch for depth. Says "you are entering / leaving
 * the archive room." Sits at the page foot. Part of the garden's motif set
 * (SUCCESSION §19). Pastel palette.
 */
interface Props { size?: number; }
const { size = 340 } = Astro.props;
const h = Math.round(size * 90 / 220);
---
<svg width={size} height={h} viewBox="0 0 220 90" aria-hidden="true">
  <path d="M30 82 C 32 34, 60 22, 110 22 C 160 22, 188 34, 190 82"
    stroke="var(--canopy)" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.65"/>
  <path d="M52 82 C 54 46, 78 36, 110 36 C 142 36, 166 46, 168 82"
    stroke="var(--canopy)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.35" stroke-dasharray="1.5 3"/>
  <path d="M30 78 L30 72" stroke="var(--canopy)" stroke-width="0.8" stroke-linecap="round" opacity="0.72"/>
  <path d="M30 74 C 27 72, 25 73, 26 76 C 28 77, 30 75, 30 74 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <circle cx="30" cy="68" r="2" fill="var(--poppy-soft)" opacity="0.92"/>
  <path d="M190 78 L190 72" stroke="var(--canopy)" stroke-width="0.8" stroke-linecap="round" opacity="0.72"/>
  <path d="M190 74 C 193 72, 195 73, 194 76 C 192 77, 190 75, 190 74 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <circle cx="190" cy="68" r="2" fill="var(--poppy-soft)" opacity="0.92"/>
  <path d="M14 84 C 100 82, 190 84, 200 84" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.45"/>
  <circle cx="90" cy="72" r="1.4" fill="#b899c9" opacity="0.75"/>
  <circle cx="130" cy="70" r="1.4" fill="#e8c15a" opacity="0.75"/>
  <circle cx="110" cy="68" r="1.2" fill="#a4b8c8" opacity="0.75"/>
</svg>
