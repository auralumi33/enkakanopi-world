---
/**
 * The ensō 円 — the circle that completes itself.
 * A hand-brushed unclosed circle (the 円 of 円花), gap at ~1 o'clock
 * (openly unfinished), a single seedling inside with a poppy-soft tip at
 * the apex. Refined per Rika's sketch: no pot, cleaner interior. Part of
 * the garden's motif set (SUCCESSION §18). Pastel palette.
 */
interface Props { size?: number; }
const { size = 120 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 100" aria-hidden="true">
  <path d="M 62 14 C 44 8, 24 16, 16 34 C 8 52, 14 74, 32 84 C 50 92, 72 84, 82 66 C 88 54, 88 40, 78 28"
    stroke="var(--ink-soft)" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.62"/>
  <path d="M50 66 L50 44" stroke="var(--canopy)" stroke-width="1.1" stroke-linecap="round" opacity="0.85"/>
  <path d="M50 54 C 44 50, 40 52, 42 58 C 46 60, 50 58, 50 54 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <circle cx="56" cy="52" r="2" fill="#b899c9" opacity="0.72"/>
  <circle cx="44" cy="60" r="1.4" fill="#e8c15a" opacity="0.72"/>
  <circle cx="50" cy="42" r="3" fill="var(--poppy-soft)" opacity="0.92"/>
  <circle cx="50" cy="42" r="1" fill="var(--paper)"/>
</svg>
