---
/**
 * The word-plot — Lexicon · intro visual.
 * A small hand-drawn plot showing four terms as tiny plants at growth
 * stages (seed · seedling · budding · evergreen), each with a tiny name-
 * tag line beneath. Reads: "each term is a plant tended here." Part of the
 * garden's motif set (SUCCESSION §19). Pastel palette.
 */
interface Props { size?: number; }
const { size = 260 } = Astro.props;
const h = Math.round(size * 90 / 140);
---
<svg width={size} height={h} viewBox="0 0 140 90" aria-hidden="true">
  <path d="M10 76 C 40 74, 100 76, 130 74" stroke="var(--ink-faint)" stroke-width="0.6" fill="none" opacity="0.5"/>
  <ellipse cx="24" cy="72" rx="2.5" ry="2" fill="var(--ink-soft)" opacity="0.6"/>
  <path d="M52 72 L52 60" stroke="var(--canopy)" stroke-width="0.9" stroke-linecap="round" opacity="0.85"/>
  <path d="M52 66 C 48 64, 46 65, 47 68 C 50 69, 52 67, 52 66 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <path d="M82 72 L82 48" stroke="var(--canopy)" stroke-width="0.9" stroke-linecap="round" opacity="0.85"/>
  <path d="M82 58 C 78 56, 76 57, 77 60 C 80 61, 82 59, 82 58 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <path d="M82 52 C 86 50, 88 52, 87 55 C 84 56, 82 54, 82 52 Z" fill="var(--canopy-soft)" opacity="0.9"/>
  <circle cx="82" cy="45" r="2" fill="#b899c9" opacity="0.85"/>
  <path d="M116 72 L116 42" stroke="var(--canopy)" stroke-width="1" stroke-linecap="round" opacity="0.85"/>
  <path d="M116 58 C 111 56, 109 57, 110 61 C 113 62, 116 60, 116 58 Z" fill="var(--canopy-soft)" opacity="0.92"/>
  <path d="M116 52 C 121 50, 123 52, 122 56 C 118 57, 116 54, 116 52 Z" fill="var(--canopy-soft)" opacity="0.92"/>
  <path d="M116 46 C 111 44, 109 46, 110 49 C 113 50, 116 48, 116 46 Z" fill="var(--canopy-soft)" opacity="0.92"/>
  <circle cx="116" cy="38" r="2.4" fill="var(--poppy-soft)" opacity="0.92"/>
  <circle cx="116" cy="38" r="0.7" fill="var(--paper)"/>
  <path d="M20 82 L28 82" stroke="var(--ink-faint)" stroke-width="0.5" opacity="0.4"/>
  <path d="M48 82 L56 82" stroke="var(--ink-faint)" stroke-width="0.5" opacity="0.4"/>
  <path d="M78 82 L86 82" stroke="var(--ink-faint)" stroke-width="0.5" opacity="0.4"/>
  <path d="M112 82 L120 82" stroke="var(--ink-faint)" stroke-width="0.5" opacity="0.4"/>
  <circle cx="52" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
  <circle cx="80" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
  <circle cx="84" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
  <circle cx="112" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
  <circle cx="116" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
  <circle cx="120" cy="86" r="0.9" fill="var(--ink-faint)" opacity="0.8"/>
</svg>
