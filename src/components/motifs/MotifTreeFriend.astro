---
/**
 * MotifTreeFriend — Set 3 slice-3 · 2026-07-09
 * Arrival hero motif · looking up from below into a canopy of leaves.
 * A slender trunk rises up the centre · canopy of --canopy + --canopy-soft
 * foliage arches overhead · four canonical pastels scattered through as
 * dappled sun-through-leaves · a small poppy-soft bloom held high on
 * one branch (the mark) · at the base, a tiny --skin figure looks up.
 * The "Is that tree your friend?" register — arrival, awe, invitation,
 * the container reading as shelter. Companion to the CanopyScene, but
 * scoped smaller and portable (essay-callout size).
 *
 * Grammar (shared shipped family): all outlines --ink-soft at hairline
 * widths · fills only from canonical palette · subtle hand-wobble in
 * curves · one poppy-soft press per composition.
 *
 * Props: size (default 220) — the rendered width in px.
 */
export interface Props {
  size?: number;
}
const { size = 220 } = Astro.props as Props;
const height = Math.round(size * 1.05);
---
<figure class="motif motif--tree-friend" aria-hidden="true">
  <svg width={size} height={height} viewBox="0 0 220 230" role="img" aria-labelledby="treefriend-t" preserveAspectRatio="xMidYMid meet">
    <title id="treefriend-t">A slender tree rises overhead; canopy of soft-green leaves and dappled pastel light spreads across the top; a tiny skin-toned figure at the base looks up; a small poppy bloom is held high on one branch.</title>

    {/* — the trunk · slender hairline · a subtle wobble as it rises — */}
    <path d="M 110 210 C 108 168, 112 128, 108 88"
      stroke="var(--ink-soft)" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.75"/>

    {/* — the branches · hairline spread from ~60% up · asymmetric organic — */}
    <path d="M 110 120 C 96 108, 76 96, 58 84"
      stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.65"/>
    <path d="M 110 108 C 128 96, 152 84, 172 74"
      stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.65"/>
    <path d="M 110 96 C 100 78, 92 62, 90 46"
      stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.6"/>
    <path d="M 110 92 C 124 76, 138 58, 148 42"
      stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.6"/>

    {/* — the foliage · seven soft leaf clusters, the pastel register (Rika,
        2026-07-14) — same tones + gentle sway as the canopy hero's leaf-
        masses and the ideas-map's buds, so all three read as one visual
        family. The tree's shape is unchanged; only the ink lightens and
        each cluster gets its own slow, phase-offset rotation. */}
    <ellipse class="tf-leaf" data-sway="0" cx="58" cy="82" rx="22" ry="14" transform="rotate(-14 58 82)" fill="var(--leaf-pastel-2)" opacity="0.6"
      stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="1" cx="88" cy="46" rx="20" ry="13" transform="rotate(-6 88 46)" fill="var(--leaf-pastel-3)" opacity="0.5"
      stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="2" cx="118" cy="34" rx="22" ry="14" transform="rotate(4 118 34)" fill="var(--leaf-pastel-1)" opacity="0.65"
      stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="3" cx="150" cy="46" rx="20" ry="13" transform="rotate(10 150 46)" fill="var(--leaf-pastel-3)" opacity="0.5"
      stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="4" cx="176" cy="76" rx="22" ry="14" transform="rotate(16 176 76)" fill="var(--leaf-pastel-2)" opacity="0.6"
      stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="5" cx="76" cy="112" rx="18" ry="12" transform="rotate(-18 76 112)" fill="var(--leaf-pastel-1)" opacity="0.45"
      stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round"/>
    <ellipse class="tf-leaf" data-sway="6" cx="148" cy="112" rx="18" ry="12" transform="rotate(18 148 112)" fill="var(--leaf-pastel-1)" opacity="0.45"
      stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round"/>

    {/* — dappled sun · four canonical pastels · sun-through-leaves — */}
    <circle cx="72" cy="66" r="2" fill="#e8c15a" opacity="0.55"/>
    <circle cx="102" cy="52" r="1.8" fill="#b899c9" opacity="0.5"/>
    <circle cx="158" cy="58" r="2.2" fill="#e8c15a" opacity="0.55"/>
    <circle cx="184" cy="94" r="1.6" fill="#a4b8c8" opacity="0.5"/>
    <circle cx="58" cy="102" r="1.5" fill="#e46b6b" opacity="0.45"/>
    <circle cx="128" cy="78" r="1.8" fill="#e8c15a" opacity="0.45"/>

    {/* — one poppy bloom held high on a branch · the mark — */}
    <g transform="translate(150 42)">
      <g fill="var(--poppy-soft)" opacity="0.85">
        <path d="M 0 -4 C 3 -3.5, 3.6 -1, 0 -0.2 C -3.6 -1, -3 -3.5, 0 -4 Z"/>
        <path d="M 3.5 -1 C 4.2 1.8, 2 3.4, 0.5 2.4 C 0 -0.2, 1.8 -2.4, 3.5 -1 Z"/>
        <path d="M 2 3.4 C 0 4, -2 2.6, -0.8 1 C 1 -0.4, 3.4 1.4, 2 3.4 Z"/>
        <path d="M -2.8 1.6 C -4.2 -0.7, -2.6 -2.4, -1 -1.4 C 0 0, -1.6 3, -2.8 1.6 Z"/>
      </g>
      <circle cx="0" cy="0" r="1" fill="#e8c15a" opacity="0.9"/>
    </g>

    {/* — the small skin figure · looking up · at the base — */}
    <g transform="translate(110 200)">
      {/* head · a soft skin oval */}
      <ellipse cx="0" cy="-8" rx="3.4" ry="4" fill="#f2e0d0" opacity="0.85"
        stroke="var(--ink-soft)" stroke-width="0.45" stroke-linejoin="round"/>
      {/* body · trapezoid hairline · gently tilted looking up */}
      <path d="M -3 -4 L -4.5 8 L 4.5 8 L 3 -4 Z" fill="#f2e0d0" opacity="0.55"
        stroke="var(--ink-soft)" stroke-width="0.45" stroke-linejoin="round"/>
      {/* one gaze line up into the canopy — a hairline dashed hint */}
      <path d="M 0 -12 L 0 -18" stroke="var(--ink-soft)" stroke-width="0.35" stroke-dasharray="1.5 2" stroke-linecap="round" opacity="0.6"/>
    </g>

    {/* — the ground line · soft hairline — */}
    <path d="M 40 216 C 90 214, 130 214, 180 216"
      stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.5"/>

    {/* — the caption · italic hand register — */}
    <text class="tree-caption" x="110" y="228" text-anchor="middle" font-size="9" fill="var(--ink-faint)" font-style="italic" opacity="0.72">is that tree your friend?</text>
  </svg>
</figure>
<script>
  // the second sanctioned "paper stays still" exception, applied here too
  // (Rika, 2026-07-14) — each leaf cluster gets a slow, gentle, phase-
  // offset sway, matching the canopy hero + the ideas-map's buds. Fully
  // static under prefers-reduced-motion: the loop is never started.
  (function () {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;
    document.querySelectorAll<SVGEllipseElement>(".tf-leaf").forEach((leaf) => {
      const i = Number(leaf.dataset.sway ?? "0");
      const amp = (0.8 + (i % 3) * 0.3).toFixed(2);
      const dur = (8 + i * 1.1).toFixed(1);
      const anim = document.createElementNS("http://www.w3.org/2000/svg", "animateTransform");
      anim.setAttribute("attributeName", "transform");
      anim.setAttribute("type", "rotate");
      anim.setAttribute("additive", "sum");
      anim.setAttribute("values", `0 0 0; ${amp} 0 0; 0 0 0; -${amp} 0 0; 0 0 0`);
      anim.setAttribute("dur", `${dur}s`);
      anim.setAttribute("repeatCount", "indefinite");
      leaf.appendChild(anim);
    });
  })();
</script>
<style>
  .motif--tree-friend { margin: 0; display: flex; justify-content: center; opacity: 0.94; }
  .motif--tree-friend :global(svg) { max-width: 100%; height: auto; display: block; }
  .motif--tree-friend :global(text.tree-caption) { font-family: var(--hand); }
</style>
