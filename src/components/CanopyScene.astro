        <circle cx="0" cy="-1.1" r="0.34" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="0.95" cy="-0.32" r="0.34" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="0.58" cy="0.85" r="0.34" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="-0.58" cy="0.85" r="0.34" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="-0.95" cy="-0.32" r="0.34" fill="var(--ink-soft)" opacity="0.75"/>
