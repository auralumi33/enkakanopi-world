---
/**
 * CanopyScene — the home's single hand-drawn image (slice-3.5 · 円花 lineage
 * pushed to its most elegant form).
 *
 * Vision (Rika 2026-07-09): the 円花 keystone said fully at scene scale.
 * The ensō is the container; three sumi-e cherry-blossom sprigs hang from
 * a simplified three-arch canopy inside; a paintbrush + embroidery needles
 * are visible making the ensō. Retires the busy layers that read as
 * amateur scribble (over-under thread crossings, tiny cascade buds,
 * hidden-joys scattered dots, top-down flower plot).
 *
 * Adopts the wabi-sabi principles of the ensō essay Rika cited:
 *   fukinsei (asymmetry) · kanso (simplicity) · koko (weathered) ·
 *   shizen (natural) · yugen (subtle grace) · datsuzoku (freedom) ·
 *   seijaku (tranquility). One fluid intention.
 *
 * Layers, top-to-bottom:
 *   · Panel-style header (円 · canopy + subtitle)
 *   · The ensō (bold minimalist single-brushstroke circle · encloses all)
 *   · The paintbrush (touches the ensō at its 1 o'clock start)
 *   · Left + right embroidery needles (stitch the ensō from either side)
 *   · Simplified three-arch canopy at top (calligraphic hairline)
 *   · Three leaf ovals · sage soft
 *   · Kernel voice · "held long enough to become"
 *   · Three sumi-e cherry-blossom sprigs hanging DOWN from the canopy
 *     — proper 5-petal sakura clusters with ink stamens, buds along
 *     the branch, tip blossom carrying the paradox smile
 *   · Isson magpie (perched on the rightmost canopy edge)
 *   · Beam (dashed light falling)
 *   · Ground line + poppy port ring · "the light lands here" seal
 *
 * Motion: dapples + petals + hidden joys retired; only the beam remains
 * still. Sumi-e should be swift and unhesitating — not animated.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A minimalist ensō container being drawn by a sumi-e paintbrush at its top and embroidery needles at its edges; inside, a simplified three-arch canopy hangs three delicate sumi-e cherry-blossom sprigs (lavender · coral · gold) as detail around the ensō; at the ground the light lands on a small silk-on-washi cloth holding three dainty Isson-hairline tall-stem flowers (lavender · gold · slate bell).</title>

    {/* — Panel-style header (kanji + subtitle) at top center — */}
    {/* Slice-3.7 · header shifted UP (y 30→24 / 52→44) — pairs with the
        lowered ensō top curve below to give visible breathability between
        text block and drawing. */}
    <text class="hero-kanji" x="412" y="24" text-anchor="middle" font-size="18" letter-spacing="0.5" opacity="0.88">円 · canopy</text>
    <text class="hero-sub" x="412" y="44" text-anchor="middle" font-size="12" font-style="italic" opacity="0.6">the container and the light</text>

    {/* — THE ENSŌ · bold minimalist single-brushstroke circle —
        Slice-3.5: brought UP from whisper (0.20 opacity) to elegant
        presence (0.55 opacity, width 2.6) — reads as the disciplined
        sumi-e stroke Rika's references show. Three tapered dry-brush
        hairlines at the 1 o'clock opening: fukinsei · datsuzoku. */}
    <g class="enso-container" aria-hidden="true">
      <path d="M 700 92 C 540 68, 300 64, 156 106 C 46 152, 24 268, 90 358 C 178 424, 402 438, 590 414 C 710 394, 782 322, 782 236 C 782 178, 748 122, 712 96"
        stroke="var(--ink-soft)" stroke-width="2.6" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 700 92 C 540 68, 300 64, 156 106 C 46 152, 24 268, 90 358 C 178 424, 402 438, 590 414 C 710 394, 782 322, 782 236 C 782 178, 748 122, 712 96"
        stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.32"/>
      <path d="M 712 96 C 720 94, 728 96, 734 100" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.48"/>
      <path d="M 720 92 C 726 91, 730 91, 734 92" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.32"/>
      <path d="M 726 88 C 730 87, 733 87, 736 88" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round" opacity="0.22"/>
    </g>

    {/* — THE PAINTBRUSH · touches the ensō at its 1 o'clock start —
        The maker's tool: bamboo handle rising up-right + tapered brush
        tip touching the ensō starting stroke. Reads as: the container
        is being drawn, not just placed. */}
    <g class="enso-brush" aria-hidden="true">
      <g transform="translate(700 92) rotate(-42)">
        <rect x="8" y="-2" width="46" height="4" rx="1.8" fill="var(--bamboo)" opacity="0.85"
          stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round"/>
        <rect x="6" y="-2.4" width="3" height="4.8" fill="var(--ink-soft)" opacity="0.55"/>
        <path d="M 6 -1.6 C 3.5 -1.2, 1.2 -0.6, 0 0 C 1.2 0.6, 3.5 1.2, 6 1.6 Z" fill="var(--ink-soft)" opacity="0.78"/>
        <path d="M 0 0 C -0.8 -0.2, -1.4 0, -2 0.2" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.68"/>
      </g>
      <circle cx="698" cy="93" r="0.9" fill="var(--ink-soft)" opacity="0.72"/>
    </g>

    {/* — EMBROIDERY NEEDLES stitching the ensō from L and R —
        SceneWeaveSeam grammar. Simplified from slice-3.0 (removed the
        four canopy-arch over-under crossings that read too busy). Just
        the two needles + their trailing threads remain — the paintbrush
        and the needles jointly make the container. */}
    <g class="enso-needles" aria-hidden="true">
      <g transform="translate(60 130) rotate(-18)">
        <path d="M -4 0 C -20 -6, -38 4, -58 -4 C -76 -12, -94 0, -110 -8"
          stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.6"/>
        <ellipse cx="0" cy="0" rx="3.4" ry="1.6" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.75"/>
        <line x1="3" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.2" stroke-linecap="round" opacity="0.75"/>
        <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.72"/>
      </g>
      <g transform="translate(760 130) rotate(198)">
        <path d="M -4 0 C -20 -6, -38 4, -58 -4 C -76 -12, -94 0, -110 -8"
          stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.6"/>
        <ellipse cx="0" cy="0" rx="3.4" ry="1.6" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.75"/>
        <line x1="3" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.2" stroke-linecap="round" opacity="0.75"/>
        <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.72"/>
      </g>
    </g>

    {/* — CANOPY · simplified from 5 strokes to 3 (kanso simplicity) —
        Three gentle calligraphic arches at top. Sumi-e discipline:
        each arch is one confident stroke, no ornamental sub-strokes. */}
    <g class="ink block canopy-strokes">
      <path d="M 108 168 C 168 116, 240 106, 306 148" />
      <path d="M 278 152 C 342 100, 430 96, 496 148" />
      <path d="M 470 148 C 540 100, 620 108, 688 172" />
    </g>

    {/* — Three leaf ovals · sage soft under the canopy — */}
    <g class="leaves">
      <path class="leaf-fill" d="M 174 130 C 194 108, 234 110, 254 132 C 236 152, 194 152, 174 130 Z" />
      <path class="leaf-fill" d="M 358 122 C 380 100, 424 104, 442 128 C 420 148, 378 146, 358 122 Z" />
      <path class="leaf-fill" d="M 552 132 C 574 110, 616 112, 638 132 C 620 152, 574 152, 552 132 Z" />
    </g>

    {/* — Isson magpie · perched on the right canopy edge (retained) — */}
    <g class="isson-magpie" transform="translate(688 168)" opacity="0.42" aria-hidden="true">
      <path d="M -8 0 C -6 -3, -2 -4, 2 -3 C 4 -2, 6 -1, 8 0 C 6 1, 4 1.5, 0 1.5 C -4 1.5, -6 1, -8 0 Z" fill="var(--ink)" stroke="var(--ink)" stroke-width="0.3"/>
      <circle cx="-5" cy="-1.5" r="0.6" fill="var(--paper-washi)"/>
      <circle cx="-5" cy="-1.5" r="0.3" fill="var(--ink)"/>
      <path d="M 8 0 L 18 1" stroke="var(--ink)" stroke-width="0.7" fill="none" stroke-linecap="round"/>
      <path d="M -3 1.5 L -3 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
      <path d="M -1 1.5 L -1 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
    </g>

    {/* — KERNEL VOICE · SceneWeaveSeam's shipped register — */}
    <text class="kernel-voice" x="412" y="228" text-anchor="middle" font-size="13" opacity="0.62" font-style="italic">held long enough to become</text>

    {/* — LIGHT BEAM · dashed hairline falling from canopy → ground — */}
    <path class="ink hair beam" d="M 412 168 C 420 250, 404 330, 412 386" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-dasharray="1.5 7" />

    {/* — SUMI-E CHERRY-BLOSSOM SPRIGS · three hanging clusters —
        Slice-3.5: proper sakura sprigs replacing the amateur cascade-
        bud scribbles. Each sprig has:
          · one confident brushed main branch (--ink-soft width 1.4-1.6
            at 0.72-0.82 opacity — proper sumi-e brush)
          · 4-5 five-petal sakura blossoms in the canonical pastel
            (petals arranged at 72° intervals · slight overlap · with
            a small white centre and 5-7 ink-soft stamen dots)
          · 2 small teardrop buds along the branch length
          · a paradox smile hidden inside the largest blossom
        Reads as: the discipline of sumi-e — each stroke intentional. */}

    {/* Left sprig · 紫 lavender · sakura cluster */}
    <g class="sumie-sprig sprig-left" aria-hidden="true">
      {/* main brushed branch · confident single stroke */}
      <path d="M 194 158 C 190 190, 178 224, 174 258 C 172 274, 174 286, 180 296"
        stroke="var(--ink-soft)" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.78"/>
      {/* small side twig */}
      <path d="M 178 244 C 172 244, 166 248, 162 254"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.62"/>

      {/* Two teardrop buds along the branch */}
      <path d="M 187 202 C 188 199, 191 199, 192 202 C 191 205, 188 205, 187 202 Z" fill="#b899c9" opacity="0.75"/>
      <path d="M 183 226 C 184 223, 187 223, 188 226 C 187 229, 184 229, 183 226 Z" fill="#b899c9" opacity="0.72"/>
      <path d="M 162 254 C 163 251, 166 251, 167 254 C 166 257, 163 257, 162 254 Z" fill="#b899c9" opacity="0.68"/>

      {/* Sakura blossom cluster at the tip — 4 open flowers + 1 turned */}
      {/* main blossom at tip (largest) · carries paradox smile */}
      <g transform="translate(180 300)">
        <g fill="#b899c9" opacity="0.82">
          <path d="M 0 -6 C 2.4 -5.4, 3.2 -2, 1.6 -0.6 C 0.4 0.4, -0.4 0.4, -1.6 -0.6 C -3.2 -2, -2.4 -5.4, 0 -6 Z"/>
          <path d="M 5.7 -1.9 C 6.9 0.4, 5.1 3.6, 2.7 3.2 C 1.4 3, 0.4 1.8, 0.5 0.5 C 1.4 -0.8, 3.6 -2.4, 5.7 -1.9 Z"/>
          <path d="M 3.5 4.9 C 1.4 6.5, -1.4 5.3, -1.7 2.9 C -1.6 1.7, -0.6 0.6, 0.6 0.7 C 2.1 1.5, 4 3, 3.5 4.9 Z"/>
          <path d="M -3.5 4.9 C -5.3 3, -4.6 -0.4, -2.4 -0.8 C -1 -0.8, -0.4 0.4, -0.5 1.6 C -1.2 3.1, -2.7 4.7, -3.5 4.9 Z"/>
          <path d="M -5.7 -1.9 C -4.8 -4.4, -2 -4.8, -1 -3.2 C -0.4 -2, -0.6 -0.6, -1.8 0 C -3.4 0.2, -5.4 -0.8, -5.7 -1.9 Z"/>
        </g>
        {/* white centre + 5 ink stamens · sakura signature */}
        <circle cx="0" cy="0" r="1.3" fill="var(--paper-washi)" opacity="0.92"/>
        <circle cx="0" cy="-0.8" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.75" cy="-0.25" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.45" cy="0.65" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.45" cy="0.65" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.75" cy="-0.25" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        {/* paradox smile hidden between stamens */}
        <path d="M -0.6 0.9 C -0.35 1.2, 0.35 1.2, 0.6 0.9" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round" opacity="0.55"/>
      </g>
      {/* second smaller blossom slightly right and up */}
      <g transform="translate(196 290) scale(0.7)">
        <g fill="#b899c9" opacity="0.68">
          <path d="M 0 -6 C 2.4 -5.4, 3.2 -2, 1.6 -0.6 C 0.4 0.4, -0.4 0.4, -1.6 -0.6 C -3.2 -2, -2.4 -5.4, 0 -6 Z"/>
          <path d="M 5.7 -1.9 C 6.9 0.4, 5.1 3.6, 2.7 3.2 C 1.4 3, 0.4 1.8, 0.5 0.5 C 1.4 -0.8, 3.6 -2.4, 5.7 -1.9 Z"/>
          <path d="M 3.5 4.9 C 1.4 6.5, -1.4 5.3, -1.7 2.9 C -1.6 1.7, -0.6 0.6, 0.6 0.7 C 2.1 1.5, 4 3, 3.5 4.9 Z"/>
          <path d="M -3.5 4.9 C -5.3 3, -4.6 -0.4, -2.4 -0.8 C -1 -0.8, -0.4 0.4, -0.5 1.6 C -1.2 3.1, -2.7 4.7, -3.5 4.9 Z"/>
          <path d="M -5.7 -1.9 C -4.8 -4.4, -2 -4.8, -1 -3.2 C -0.4 -2, -0.6 -0.6, -1.8 0 C -3.4 0.2, -5.4 -0.8, -5.7 -1.9 Z"/>
        </g>
        <circle cx="0" cy="0" r="1" fill="var(--paper-washi)" opacity="0.9"/>
      </g>
      {/* half-turned blossom below (side profile — 3-petal hint) */}
      <g transform="translate(168 308)">
        <path d="M 0 0 C -2 -3, -4 -2, -3.5 0.5 C -3 2, -1 2, 0 0 Z" fill="#b899c9" opacity="0.65"/>
        <path d="M 0 0 C 2 -3, 4 -2, 3.5 0.5 C 3 2, 1 2, 0 0 Z" fill="#b899c9" opacity="0.72"/>
        <circle cx="0" cy="0.5" r="0.35" fill="var(--ink-soft)" opacity="0.62"/>
      </g>
    </g>

    {/* Middle sprig · 珊瑚 coral · most prominent (drops just off centre) */}
    <g class="sumie-sprig sprig-middle" aria-hidden="true">
      <path d="M 350 148 C 352 178, 358 208, 362 240 C 364 258, 360 274, 354 286"
        stroke="var(--ink-soft)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.82"/>
      {/* small side twig */}
      <path d="M 358 224 C 366 226, 372 232, 376 240"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.62"/>

      {/* Buds along the branch */}
      <path d="M 353 190 C 354 187, 357 187, 358 190 C 357 193, 354 193, 353 190 Z" fill="#e46b6b" opacity="0.72"/>
      <path d="M 358 218 C 359 215, 362 215, 363 218 C 362 221, 359 221, 358 218 Z" fill="#e46b6b" opacity="0.75"/>
      <path d="M 376 240 C 377 237, 380 237, 381 240 C 380 243, 377 243, 376 240 Z" fill="#e46b6b" opacity="0.7"/>

      {/* Peony-scale primary blossom at the tip · carries paradox smile */}
      <g transform="translate(354 292)">
        <g fill="#e46b6b" opacity="0.85">
          <path d="M 0 -7 C 2.8 -6.3, 3.7 -2.3, 1.9 -0.7 C 0.5 0.5, -0.5 0.5, -1.9 -0.7 C -3.7 -2.3, -2.8 -6.3, 0 -7 Z"/>
          <path d="M 6.7 -2.3 C 8 0.5, 6 4.2, 3.1 3.7 C 1.6 3.5, 0.4 2, 0.5 0.6 C 1.6 -0.9, 4.2 -2.8, 6.7 -2.3 Z"/>
          <path d="M 4.2 5.6 C 1.6 7.5, -1.6 6.1, -1.9 3.4 C -1.9 2, -0.7 0.7, 0.7 0.8 C 2.5 1.8, 4.7 3.5, 4.2 5.6 Z"/>
          <path d="M -4.2 5.6 C -6.3 3.5, -5.4 -0.5, -2.8 -0.9 C -1.2 -0.9, -0.5 0.5, -0.6 1.9 C -1.4 3.6, -3.2 5.4, -4.2 5.6 Z"/>
          <path d="M -6.7 -2.3 C -5.6 -5.1, -2.3 -5.6, -1.2 -3.7 C -0.5 -2.3, -0.7 -0.7, -2.1 0 C -4 0.2, -6.3 -0.9, -6.7 -2.3 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.5" fill="var(--paper-washi)" opacity="0.94"/>
        {/* 7 stamens · the coral's fuller register */}
        <circle cx="0" cy="-0.95" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.8" cy="-0.55" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.9" cy="0.35" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.35" cy="0.9" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.35" cy="0.9" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.9" cy="0.35" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.8" cy="-0.55" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        {/* paradox smile */}
        <path d="M -0.7 1.15 C -0.4 1.5, 0.4 1.5, 0.7 1.15" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round" opacity="0.58"/>
      </g>
      {/* second smaller blossom to the side */}
      <g transform="translate(376 246) scale(0.7)">
        <g fill="#e46b6b" opacity="0.72">
          <path d="M 0 -7 C 2.8 -6.3, 3.7 -2.3, 1.9 -0.7 C 0.5 0.5, -0.5 0.5, -1.9 -0.7 C -3.7 -2.3, -2.8 -6.3, 0 -7 Z"/>
          <path d="M 6.7 -2.3 C 8 0.5, 6 4.2, 3.1 3.7 C 1.6 3.5, 0.4 2, 0.5 0.6 C 1.6 -0.9, 4.2 -2.8, 6.7 -2.3 Z"/>
          <path d="M 4.2 5.6 C 1.6 7.5, -1.6 6.1, -1.9 3.4 C -1.9 2, -0.7 0.7, 0.7 0.8 C 2.5 1.8, 4.7 3.5, 4.2 5.6 Z"/>
          <path d="M -4.2 5.6 C -6.3 3.5, -5.4 -0.5, -2.8 -0.9 C -1.2 -0.9, -0.5 0.5, -0.6 1.9 C -1.4 3.6, -3.2 5.4, -4.2 5.6 Z"/>
          <path d="M -6.7 -2.3 C -5.6 -5.1, -2.3 -5.6, -1.2 -3.7 C -0.5 -2.3, -0.7 -0.7, -2.1 0 C -4 0.2, -6.3 -0.9, -6.7 -2.3 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.2" fill="var(--paper-washi)" opacity="0.92"/>
      </g>
    </g>

    {/* Right sprig · 金 gold · symmetric to left */}
    <g class="sumie-sprig sprig-right" aria-hidden="true">
      <path d="M 626 158 C 630 190, 642 224, 646 258 C 648 274, 646 286, 640 296"
        stroke="var(--ink-soft)" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.78"/>
      <path d="M 642 244 C 648 244, 654 248, 658 254"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.62"/>

      {/* Buds along the branch */}
      <path d="M 630 202 C 631 199, 634 199, 635 202 C 634 205, 631 205, 630 202 Z" fill="#e8c15a" opacity="0.75"/>
      <path d="M 636 226 C 637 223, 640 223, 641 226 C 640 229, 637 229, 636 226 Z" fill="#e8c15a" opacity="0.72"/>
      <path d="M 656 254 C 657 251, 660 251, 661 254 C 660 257, 657 257, 656 254 Z" fill="#e8c15a" opacity="0.68"/>

      {/* Primary sakura blossom at the tip · carries paradox smile */}
      <g transform="translate(640 300)">
        <g fill="#e8c15a" opacity="0.82">
          <path d="M 0 -5.5 C 2.2 -5, 2.9 -1.8, 1.5 -0.6 C 0.4 0.4, -0.4 0.4, -1.5 -0.6 C -2.9 -1.8, -2.2 -5, 0 -5.5 Z"/>
          <path d="M 5.2 -1.8 C 6.3 0.4, 4.7 3.3, 2.5 2.9 C 1.3 2.7, 0.4 1.6, 0.5 0.4 C 1.3 -0.7, 3.3 -2.2, 5.2 -1.8 Z"/>
          <path d="M 3.2 4.5 C 1.3 6, -1.3 4.8, -1.6 2.6 C -1.5 1.5, -0.5 0.5, 0.6 0.6 C 1.9 1.4, 3.7 2.7, 3.2 4.5 Z"/>
          <path d="M -3.2 4.5 C -4.8 2.7, -4.2 -0.4, -2.2 -0.7 C -0.9 -0.7, -0.4 0.4, -0.5 1.5 C -1.1 2.9, -2.5 4.3, -3.2 4.5 Z"/>
          <path d="M -5.2 -1.8 C -4.4 -4, -1.8 -4.4, -0.9 -2.9 C -0.4 -1.8, -0.5 -0.5, -1.7 0 C -3.1 0.2, -4.9 -0.7, -5.2 -1.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.2" fill="var(--paper-washi)" opacity="0.92"/>
        <circle cx="0" cy="-0.75" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.7" cy="-0.22" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.42" cy="0.6" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.42" cy="0.6" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.7" cy="-0.22" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <path d="M -0.55 0.85 C -0.32 1.15, 0.32 1.15, 0.55 0.85" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round" opacity="0.55"/>
      </g>
