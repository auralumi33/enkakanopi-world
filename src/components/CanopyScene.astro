---
/**
 * CanopyScene — the home's single hand-drawn image (slice-3.8 · 円花
 * keystone made real · wreath composition).
 *
 * Vision (Rika 2026-07-09, tightened): a singular minimalist sumi-e
 * image — bold ensō stroke as the container, cherry-blossom branches
 * hanging DIRECTLY from the ensō (not from a separate canopy inside),
 * larger blossoms per reference, and a small 円花 hanko seal baked
 * into the composition. Wreath-style asymmetry per fukinsei — the
 * left side of the ensō is "carried" by sakura, the right is bare
 * ink stroke.
 *
 * Layers (kept spare · yugen simplicity):
 *   · Panel-style header (円 · canopy + subtitle) at top
 *   · The ensō (bold minimalist single stroke · unchanged from 3.5/3.7)
 *   · Cherry-blossom wreath — one main branch descending from the ensō
 *     top-left, curving around the left side · larger 5-petal sakura
 *     blossoms clustered in 3 groups along the branch (Isson-hairline
 *     branch, blooms in canonical pastels, ink stamens)
 *   · A smaller counter-branch hanging from the top-right of the ensō
 *     for balance
 *   · 円花 hanko seal at bottom-right (poppy square with white 円花
 *     kanji · maker's mark register)
 *   · Isson magpie (small silhouette perched on the ensō right edge)
 *   · Kernel voice · "held long enough to become"
 *   · Light beam (dashed hairline) falling to a small poppy port —
 *     "the light lands here" seal at the bottom centre
 *
 * Retired in this slice: canopy arches + leaf ovals · paintbrush at
 * ensō start · both embroidery needles · previous 3 hanging sprigs +
 * their cascade buds · light-lands flower bed cloth + silk-moiré +
 * 3 tall-stem flowers.
 *
 * Wabi-sabi principles held: fukinsei · kanso · shizen · yugen · seijaku.
 * One fluid intention.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A minimalist sumi-e ensō with a cherry-blossom branch hanging from its top-left curving down around the interior, larger 5-petal sakura blossoms clustered along it; a small counter-branch hangs from the top-right for balance; a red 円花 maker's-seal sits at the bottom-right; a small Isson magpie perches on the ensō; a dashed light beam falls to a small poppy seal at the bottom centre marked "the light lands here".</title>

    {/* — Panel-style header (kanji + subtitle) — */}
    <text class="hero-kanji" x="412" y="24" text-anchor="middle" font-size="18" letter-spacing="0.5" opacity="0.88">円 · canopy</text>
    <text class="hero-sub" x="412" y="44" text-anchor="middle" font-size="12" font-style="italic" opacity="0.6">the container and the light</text>

    {/* — THE ENSŌ · WHISPERED with OPENING INVERTED to 6 o'clock —
        Slice-4.3: opening rotated from 1 o'clock (top-right) to 6 o'clock
        (bottom) per Rika — so the little gap sits where "the light lands
        here" is, and the whole ensō reads accurately (opening at the base
        rather than the top). Path now starts at (280 428) at ~7 o'clock,
        curves CCW up + around + back down, ending at (540 425) at
        ~5 o'clock. Opening spans ~260 units around the light-lands seal. */}
    <g class="enso-container" aria-hidden="true">
      <path d="M 280 428 C 156 420, 40 340, 24 260 C 24 152, 156 68, 320 62 C 540 62, 700 92, 782 178 C 795 236, 782 322, 700 394 C 660 414, 590 422, 540 425"
        stroke="var(--ink-soft)" stroke-width="1.0" fill="none" stroke-linecap="round" opacity="0.20"/>
      <path d="M 280 428 C 156 420, 40 340, 24 260 C 24 152, 156 68, 320 62 C 540 62, 700 92, 782 178 C 795 236, 782 322, 700 394 C 660 414, 590 422, 540 425"
        stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.15"/>
      {/* dry-brush tail near the BOTTOM opening end (5 o'clock) · trails right */}
      <path d="M 540 425 C 528 428, 516 428, 508 425" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.22"/>
      <path d="M 528 430 C 522 430, 518 430, 514 430" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round" opacity="0.18"/>
      <path d="M 516 434 C 520 434, 522 434, 524 434" stroke="var(--ink-soft)" stroke-width="0.22" fill="none" stroke-linecap="round" opacity="0.14"/>
    </g>

    {/* — Slice-4.3 · PAINTBRUSH moved to the 6 o'clock opening —
        Small bamboo fude at refined discreet size (slice-4.2), now
        positioned at the ensō's bottom-right opening end (540, 425)
        where the brush would be lifting off after completing the stroke.
        Rotation -42° preserved so the handle rises up-right from the
        contact point. Reads as: the ensō is being drawn from the bottom,
        the brush trails off just past the light-lands seal. */}
    <g class="enso-brush" aria-hidden="true">
      <g transform="translate(540 425) rotate(-42)">
        {/* bamboo handle · warm --bamboo · shorter + thinner */}
        <rect x="5" y="-1.3" width="30" height="2.6" rx="1.2" fill="var(--bamboo)" opacity="0.82"
          stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round"/>
        {/* ferrule ring · dark band near the brush end */}
        <rect x="3.5" y="-1.55" width="2" height="3.1" fill="var(--ink-soft)" opacity="0.62"/>
        {/* the brush tip · tapered sumi-e brush ink shape */}
        <path d="M 3.5 -1.05 C 2.2 -0.85, 0.75 -0.4, 0 0 C 0.75 0.4, 2.2 0.85, 3.5 1.05 Z" fill="var(--ink-soft)" opacity="0.74"/>
        {/* fine hair-tip at the very end */}
        <path d="M 0 0 C -0.5 -0.15, -0.9 0, -1.3 0.15" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.64"/>
      </g>
      {/* tiny wet ink dot where the brush tip meets the paper */}
      <circle cx="538" cy="426" r="0.6" fill="var(--ink-soft)" opacity="0.68"/>
    </g>

    {/* — 円花 WREATH · MAIN LEFT BRANCH — extended (slice-4.0) to trace
        along the full left arc of the ensō, from top-left curving down
        along the ensō left side to bottom-left. The BRANCH itself now
        forms the shape of the circle here — the ink stroke is only a
        whisper behind it. */}
    <g class="wreath-main" aria-hidden="true">
      {/* Slice-4.1 · main sumi-e branch · extended FURTHER along the
          perimeter (now curves under the bottom of the ensō toward the
          right side too) · opacity dialled lighter (0.75 → 0.55) · width
          slightly reduced (2.0 → 1.7). Reads as: the branches themselves
          trace the whole ensō, not just one arc. */}
      <path d="M 148 108 C 90 138, 46 200, 34 260 C 26 330, 90 396, 200 418 C 290 428, 380 424, 456 412"
        stroke="var(--ink-soft)" stroke-width="1.7" fill="none" stroke-linecap="round" opacity="0.55"/>
      {/* subtle inner shadow · also lightened */}
      <path d="M 148 108 C 90 138, 46 200, 34 260 C 26 330, 90 396, 200 418 C 290 428, 380 424, 456 412"
        stroke="var(--ink)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.20"/>
      {/* small side-twig off the upper-left arc · reaches inward */}
      <path d="M 60 200 C 78 208, 96 214, 112 218"
        stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.64"/>
      {/* second small side-twig on the lower-left arc · reaches inward */}
      <path d="M 62 340 C 82 342, 104 340, 122 336"
        stroke="var(--ink-soft)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.62"/>
      {/* small side-twig near the branch tip at bottom */}
      <path d="M 170 410 C 186 412, 202 412, 218 408"
        stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.58"/>

      {/* — CLUSTER 1 · upper-left arc · densest cluster — 紫 lavender
          repositioned onto the extended arc (slice-4.0). Primary at
          the top curve where the branch enters. */}
      {/* primary large blossom · paradox smile hidden inside */}
      <g transform="translate(128 132)">
        <g fill="#b899c9" opacity="0.82">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
          <path d="M 5 6.7 C 2 8.9, -2 7.2, -2.3 4 C -2.3 2.3, -0.8 0.9, 0.9 1 C 3 2.2, 5.6 4, 5 6.7 Z"/>
          <path d="M -5 6.7 C -7.5 4.2, -6.5 -0.6, -3.4 -1 C -1.4 -1, -0.6 0.5, -0.7 2.2 C -1.7 4.3, -3.8 6.5, -5 6.7 Z"/>
          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.8" fill="var(--paper-washi)" opacity="0.94"/>
        <circle cx="0" cy="-1.15" r="0.35" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="0.9" cy="-0.35" r="0.35" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="0.55" cy="0.9" r="0.35" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="-0.55" cy="0.9" r="0.35" fill="var(--ink-soft)" opacity="0.75"/>
        <circle cx="-0.9" cy="-0.35" r="0.35" fill="var(--ink-soft)" opacity="0.75"/>
        <path d="M -0.8 1.15 C -0.45 1.55, 0.45 1.55, 0.8 1.15" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.6"/>
      </g>
      {/* secondary blossom · upper-right of primary · along arc */}
      <g transform="translate(155 116) scale(0.75)">
        <g fill="#b899c9" opacity="0.75">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
          <path d="M 5 6.7 C 2 8.9, -2 7.2, -2.3 4 C -2.3 2.3, -0.8 0.9, 0.9 1 C 3 2.2, 5.6 4, 5 6.7 Z"/>
          <path d="M -5 6.7 C -7.5 4.2, -6.5 -0.6, -3.4 -1 C -1.4 -1, -0.6 0.5, -0.7 2.2 C -1.7 4.3, -3.8 6.5, -5 6.7 Z"/>
          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.5" fill="var(--paper-washi)" opacity="0.92"/>
      </g>
      {/* tertiary blossom · lower-left of primary · along descending arc */}
      <g transform="translate(108 158) scale(0.68)">
        <g fill="#b899c9" opacity="0.72">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
          <path d="M 5 6.7 C 2 8.9, -2 7.2, -2.3 4 C -2.3 2.3, -0.8 0.9, 0.9 1 C 3 2.2, 5.6 4, 5 6.7 Z"/>
          <path d="M -5 6.7 C -7.5 4.2, -6.5 -0.6, -3.4 -1 C -1.4 -1, -0.6 0.5, -0.7 2.2 C -1.7 4.3, -3.8 6.5, -5 6.7 Z"/>
          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.4" fill="var(--paper-washi)" opacity="0.92"/>
      </g>
      {/* small teardrop buds along the descending branch · repositioned onto the arc */}
      <path d="M 88 180 C 89 176, 93 176, 94 180 C 93 184, 89 184, 88 180 Z" fill="#b899c9" opacity="0.72"/>
      <path d="M 64 220 C 65 216, 69 216, 70 220 C 69 224, 65 224, 64 220 Z" fill="#b899c9" opacity="0.68"/>
      <path d="M 140 118 C 141 114, 145 114, 146 118 C 145 122, 141 122, 140 118 Z" fill="#b899c9" opacity="0.68"/>

      {/* — CLUSTER 2 · mid-left arc · 珊瑚 coral (poppy family) —
          Slice-4.0: repositioned onto the leftmost part of the extended arc
          near y=250. Adds warm colour at the widest curve of the wreath. */}
      <g transform="translate(58 250)">
        <g fill="#e46b6b" opacity="0.8">
          <path d="M 0 -7 C 2.8 -6.3, 3.7 -2.3, 1.9 -0.7 C 0.5 0.5, -0.5 0.5, -1.9 -0.7 C -3.7 -2.3, -2.8 -6.3, 0 -7 Z"/>
          <path d="M 6.7 -2.3 C 8 0.5, 6 4.2, 3.1 3.7 C 1.6 3.5, 0.4 2, 0.5 0.6 C 1.6 -0.9, 4.2 -2.8, 6.7 -2.3 Z"/>
          <path d="M 4.2 5.6 C 1.6 7.5, -1.6 6.1, -1.9 3.4 C -1.9 2, -0.7 0.7, 0.7 0.8 C 2.5 1.8, 4.7 3.5, 4.2 5.6 Z"/>
          <path d="M -4.2 5.6 C -6.3 3.5, -5.4 -0.5, -2.8 -0.9 C -1.2 -0.9, -0.5 0.5, -0.6 1.9 C -1.4 3.6, -3.2 5.4, -4.2 5.6 Z"/>
          <path d="M -6.7 -2.3 C -5.6 -5.1, -2.3 -5.6, -1.2 -3.7 C -0.5 -2.3, -0.7 -0.7, -2.1 0 C -4 0.2, -6.3 -0.9, -6.7 -2.3 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.5" fill="var(--paper-washi)" opacity="0.94"/>
        <circle cx="0" cy="-0.95" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.9" cy="-0.3" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.55" cy="0.85" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.55" cy="0.85" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.9" cy="-0.3" r="0.3" fill="var(--ink-soft)" opacity="0.72"/>
        <path d="M -0.7 1.15 C -0.4 1.5, 0.4 1.5, 0.7 1.15" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round" opacity="0.55"/>
      </g>
      {/* secondary coral · slightly below main · along arc */}
      <g transform="translate(42 282) scale(0.72)">
        <g fill="#e46b6b" opacity="0.72">
          <path d="M 0 -7 C 2.8 -6.3, 3.7 -2.3, 1.9 -0.7 C 0.5 0.5, -0.5 0.5, -1.9 -0.7 C -3.7 -2.3, -2.8 -6.3, 0 -7 Z"/>
          <path d="M 6.7 -2.3 C 8 0.5, 6 4.2, 3.1 3.7 C 1.6 3.5, 0.4 2, 0.5 0.6 C 1.6 -0.9, 4.2 -2.8, 6.7 -2.3 Z"/>
          <path d="M 4.2 5.6 C 1.6 7.5, -1.6 6.1, -1.9 3.4 C -1.9 2, -0.7 0.7, 0.7 0.8 C 2.5 1.8, 4.7 3.5, 4.2 5.6 Z"/>
          <path d="M -4.2 5.6 C -6.3 3.5, -5.4 -0.5, -2.8 -0.9 C -1.2 -0.9, -0.5 0.5, -0.6 1.9 C -1.4 3.6, -3.2 5.4, -4.2 5.6 Z"/>
          <path d="M -6.7 -2.3 C -5.6 -5.1, -2.3 -5.6, -1.2 -3.7 C -0.5 -2.3, -0.7 -0.7, -2.1 0 C -4 0.2, -6.3 -0.9, -6.7 -2.3 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.3" fill="var(--paper-washi)" opacity="0.92"/>
      </g>

      {/* — CLUSTER 3 · lower-left arc · 金 gold — Slice-4.0: repositioned
          onto the descending curve at ~y=380 where the arc turns toward
          bottom. Balances the composition. */}
      <g transform="translate(110 378) scale(0.85)">
        <g fill="#e8c15a" opacity="0.78">
          <path d="M 0 -6 C 2.4 -5.4, 3.2 -2, 1.6 -0.6 C 0.4 0.4, -0.4 0.4, -1.6 -0.6 C -3.2 -2, -2.4 -5.4, 0 -6 Z"/>
          <path d="M 5.7 -1.9 C 6.9 0.4, 5.1 3.6, 2.7 3.2 C 1.4 3, 0.4 1.8, 0.5 0.5 C 1.4 -0.8, 3.6 -2.4, 5.7 -1.9 Z"/>
          <path d="M 3.5 4.9 C 1.4 6.5, -1.4 5.3, -1.7 2.9 C -1.6 1.7, -0.6 0.6, 0.6 0.7 C 2.1 1.5, 4 3, 3.5 4.9 Z"/>
          <path d="M -3.5 4.9 C -5.3 3, -4.6 -0.4, -2.4 -0.8 C -1 -0.8, -0.4 0.4, -0.5 1.6 C -1.2 3.1, -2.7 4.7, -3.5 4.9 Z"/>
          <path d="M -5.7 -1.9 C -4.8 -4.4, -2 -4.8, -1 -3.2 C -0.4 -2, -0.6 -0.6, -1.8 0 C -3.4 0.2, -5.4 -0.8, -5.7 -1.9 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.3" fill="var(--paper-washi)" opacity="0.92"/>
        <circle cx="0" cy="-0.8" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.75" cy="-0.25" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.45" cy="0.7" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.45" cy="0.7" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.75" cy="-0.25" r="0.26" fill="var(--ink-soft)" opacity="0.72"/>
      </g>
      {/* buds along the lower + tip section of the branch */}
      <path d="M 138 396 C 139 392, 143 392, 144 396 C 143 400, 139 400, 138 396 Z" fill="#e8c15a" opacity="0.72"/>
      <path d="M 175 412 C 176 408, 180 408, 181 412 C 180 416, 176 416, 175 412 Z" fill="#e8c15a" opacity="0.68"/>

      {/* — CLUSTER 4 · branch tip · small 紫 lavender at the wreath's bottom
          curve · slice-4.0 addition to punctuate the tip near (200 418) */}
      <g transform="translate(198 414) scale(0.65)">
        <g fill="#b899c9" opacity="0.75">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
          <path d="M 5 6.7 C 2 8.9, -2 7.2, -2.3 4 C -2.3 2.3, -0.8 0.9, 0.9 1 C 3 2.2, 5.6 4, 5 6.7 Z"/>
          <path d="M -5 6.7 C -7.5 4.2, -6.5 -0.6, -3.4 -1 C -1.4 -1, -0.6 0.5, -0.7 2.2 C -1.7 4.3, -3.8 6.5, -5 6.7 Z"/>
          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.3" fill="var(--paper-washi)" opacity="0.9"/>
      </g>
    </g>

    {/* — 円花 WREATH · RIGHT COUNTER-BRANCH — extended (slice-4.0) to
        trace the right arc of the ensō from top-right down to lower-right.
        Thinner than the left branch (fukinsei · not equal). */}
    <g class="wreath-right" aria-hidden="true">
      {/* Slice-4.1 · right branch also lightened + extended further along
          the bottom-right arc so it curves under the ensō toward the
          centre-bottom, near-meeting the left branch (fukinsei gap held). */}
      <path d="M 712 108 C 770 138, 795 200, 795 260 C 795 320, 760 370, 720 400 C 640 420, 550 424, 490 418"
        stroke="var(--ink-soft)" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.48"/>
      {/* subtle inner shadow · dialled softer */}
      <path d="M 712 108 C 770 138, 795 200, 795 260 C 795 320, 760 370, 720 400 C 640 420, 550 424, 490 418"
        stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.16"/>
      {/* small side-twig upper */}
      <path d="M 750 148 C 742 152, 734 154, 726 158"
        stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.58"/>
      {/* small side-twig lower */}
      <path d="M 780 340 C 764 344, 750 344, 738 340"
        stroke="var(--ink-soft)" stroke-width="0.65" fill="none" stroke-linecap="round" opacity="0.55"/>
      {/* small lavender blossom at top of right branch */}
      <g transform="translate(738 160) scale(0.7)">
        <g fill="#b899c9" opacity="0.75">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
