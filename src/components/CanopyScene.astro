          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.4" fill="var(--paper-washi)" opacity="0.92"/>
      </g>
      {/* Slice-4.6 · buds restored + added along the extended arc — 5
          buds now trace the wreath from top through left to bottom. */}
      <path d="M 560 78 C 561 74, 565 74, 566 78 C 565 82, 561 82, 560 78 Z" fill="#b899c9" opacity="0.75"/>
