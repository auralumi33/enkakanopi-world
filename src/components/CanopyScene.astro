---
/**
 * CanopyScene — the home's single hand-drawn image, refined.
 * One idea (Law 1): light reaches the ground only by passing through what
 * holds it — and where it lands, a flower bed grows in quiet defiance.
 * The canopy overhead stays canopy-deep, but the abstract dapples are now
 * a mixed drift: some soft-green light dapples, some tiny palette petals
 * falling through with the beam. At the port, where the light lands, a
 * small bed of blooms — lavender bud, coral rose (the maker's mark), yellow
 * bud — grows from the ground line.
 * Motion is CSS-only and gated on prefers-reduced-motion.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A hand-drawn canopy; light falls through the leaves and lands on a small flower bed at the ground.</title>

    <g class="ink block canopy-strokes">
      <path d="M40 150 C 150 60, 300 70, 410 132 C 520 66, 690 74, 790 156" />
      <path d="M96 158 C 150 112, 232 110, 286 150" />
      <path d="M250 150 C 316 104, 404 108, 452 156" />
      <path d="M430 150 C 500 104, 596 108, 648 154" />
      <path d="M582 156 C 640 116, 716 118, 760 156" />
    </g>

    <g class="leaves">
      <path class="leaf-fill" d="M150 128 C 168 108, 208 110, 224 132 C 206 150, 168 150, 150 128 Z" />
      <path class="leaf-fill" d="M356 122 C 376 104, 416 108, 430 130 C 410 148, 372 146, 356 122 Z" />
      <path class="leaf-fill" d="M560 126 C 580 108, 620 110, 636 132 C 616 150, 578 150, 560 126 Z" />
    </g>

    <g class="dapples" aria-hidden="true">
      <circle class="light" cx="210" cy="250" r="9" />
      <circle class="light" cx="360" cy="238" r="7" />
      <circle class="light" cx="500" cy="330" r="6" />
      <circle class="light" cx="330" cy="330" r="5" />
      <circle class="light" cx="470" cy="252" r="6" />
    </g>
    <g class="petals" aria-hidden="true">
      <ellipse cx="268" cy="312" rx="5" ry="7" transform="rotate(-25 268 312)" fill="#b899c9" opacity="0.7"/>
      <ellipse cx="418" cy="286" rx="5.5" ry="7.5" transform="rotate(20 418 286)" fill="#e46b6b" opacity="0.72"/>
      <ellipse cx="556" cy="288" rx="4.5" ry="6.5" transform="rotate(-10 556 288)" fill="#e8c15a" opacity="0.7"/>
      <path d="M395 220 L 397 226 L 402 226 L 398 229 L 400 234 L 395 231 L 390 234 L 392 229 L 388 226 L 393 226 Z" fill="#a4b8c8" opacity="0.7"/>
    </g>

    {/* Slice-2.6 · Isson-contemplative baked layer — hairline sumi-e sprigs
        hanging from the canopy edges (patient, seed-bed grammar), tucked at
        whisper opacity. The soul side of the paradox. */}
    <g class="isson-sprigs" aria-hidden="true">
      <path d="M 178 138 C 176 148, 172 156, 168 162" stroke="var(--canopy-deep)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <path d="M 168 162 C 166 160, 163 160, 161 162" stroke="var(--canopy-deep)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.35"/>
      <ellipse cx="168" cy="164" rx="1.4" ry="1.9" fill="#aeb896" opacity="0.45"/>
      <path d="M 388 132 C 386 142, 383 150, 380 156" stroke="var(--canopy-deep)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <ellipse cx="380" cy="158" rx="1.2" ry="1.7" fill="#aeb896" opacity="0.45"/>
      <ellipse cx="378" cy="155" rx="0.9" ry="1.2" fill="#aeb896" opacity="0.35"/>
      <path d="M 596 138 C 598 148, 601 156, 604 162" stroke="var(--canopy-deep)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <ellipse cx="604" cy="164" rx="1.4" ry="1.9" fill="#aeb896" opacity="0.45"/>
    </g>

    {/* Slice-2.6 · the Isson magpie — perched hairline silhouette on the
        rightmost canopy edge, tucked at 0.32 opacity. Same signature as the
        seed-bed's baked magpie (0.18) and the slate panel's magpie, only a
        touch bolder because this is the hero. Contemplative soul, doubled. */}
    <g class="isson-magpie" transform="translate(686 158)" opacity="0.32" aria-hidden="true">
      <path d="M -8 0 C -6 -3, -2 -4, 2 -3 C 4 -2, 6 -1, 8 0 C 6 1, 4 1.5, 0 1.5 C -4 1.5, -6 1, -8 0 Z" fill="var(--ink)" stroke="var(--ink)" stroke-width="0.3"/>
      <circle cx="-5" cy="-1.5" r="0.6" fill="#f7f2e7"/>
      <circle cx="-5" cy="-1.5" r="0.3" fill="var(--ink)"/>
      <path d="M 8 0 L 18 1" stroke="var(--ink)" stroke-width="0.7" fill="none" stroke-linecap="round"/>
      <path d="M -3 1.5 L -3 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
      <path d="M -1 1.5 L -1 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
    </g>

    {/* Slice-2.6 · Amplified Murakami joy marks — hidden smile-flowers
        scattered in the mid-air register (same grammar as the seed-bed's
        baked 0.20 smile-flowers). Three tiny paradox marks, discovered
        on close look. Joy side of the paradox, doubled. */}
    <g class="hidden-joys" aria-hidden="true">
      <g transform="translate(232 258)" opacity="0.34">
        <g fill="#b899c9">
          <path d="M0 -2.4 C 1.3 -2, 1.6 -0.5, 0 -0.1 C -1.6 -0.5, -1.3 -2, 0 -2.4 Z"/>
          <path d="M2 -0.7 C 2.5 0.9, 1.2 1.6, 0.3 1.1 C 0 -0.1, 1.1 -1.3, 2 -0.7 Z"/>
          <path d="M1.2 1.6 C 0 2.1, -1.2 0.9, -0.4 0 C 0.8 -0.7, 2 0.4, 1.2 1.6 Z"/>
          <path d="M-1.6 0.8 C -2.5 -0.5, -1.6 -1.4, -0.4 -0.7 C 0 0, -0.7 1.5, -1.6 0.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.5" fill="#e8c15a"/>
        <path d="M -0.35 0.1 C -0.2 0.3, 0.2 0.3, 0.35 0.1" stroke="var(--ink-soft)" stroke-width="0.2" fill="none" stroke-linecap="round"/>
      </g>
      <g transform="translate(536 268)" opacity="0.32">
        <g fill="#e08d84">
          <path d="M0 -2.4 C 1.3 -2, 1.6 -0.5, 0 -0.1 C -1.6 -0.5, -1.3 -2, 0 -2.4 Z"/>
          <path d="M2 -0.7 C 2.5 0.9, 1.2 1.6, 0.3 1.1 C 0 -0.1, 1.1 -1.3, 2 -0.7 Z"/>
          <path d="M1.2 1.6 C 0 2.1, -1.2 0.9, -0.4 0 C 0.8 -0.7, 2 0.4, 1.2 1.6 Z"/>
          <path d="M-1.6 0.8 C -2.5 -0.5, -1.6 -1.4, -0.4 -0.7 C 0 0, -0.7 1.5, -1.6 0.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.5" fill="#e8c15a"/>
        <path d="M -0.35 0.1 C -0.2 0.3, 0.2 0.3, 0.35 0.1" stroke="var(--ink-soft)" stroke-width="0.2" fill="none" stroke-linecap="round"/>
      </g>
      <g transform="translate(150 340)" opacity="0.30">
        <g fill="#e8c15a">
          <path d="M0 -2 C 1.1 -1.7, 1.4 -0.4, 0 -0.1 C -1.4 -0.4, -1.1 -1.7, 0 -2 Z"/>
          <path d="M1.7 -0.6 C 2.1 0.7, 1 1.4, 0.25 0.9 C 0 -0.1, 0.9 -1.1, 1.7 -0.6 Z"/>
          <path d="M1 1.4 C 0 1.8, -1 0.7, -0.3 0 C 0.7 -0.6, 1.7 0.3, 1 1.4 Z"/>
          <path d="M-1.4 0.7 C -2.1 -0.4, -1.4 -1.2, -0.3 -0.6 C 0 0, -0.6 1.3, -1.4 0.7 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.4" fill="var(--ink-soft)"/>
      </g>
    </g>

    <path class="ink hair beam" d="M412 168 C 420 250, 404 330, 412 386" stroke-dasharray="1.5 7" />

    <g class="ground">
      <path class="ink block" d="M120 392 C 320 380, 520 380, 700 392" />

      <path d="M378 388 Q 376 372, 378 356" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.65" stroke-linecap="round"/>
      <path d="M412 386 Q 412 366, 412 348" stroke="#4f5b3f" stroke-width="1.1" fill="none" opacity="0.7" stroke-linecap="round"/>
      <path d="M446 388 Q 448 372, 446 356" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.65" stroke-linecap="round"/>

      {/* Slice-2.5 · Murakami paradox smile marks on each ground bloom —
          hairline closed-eye smile with two tiny eye dots, matching the panel
          signature. Kept very small (radius ~0.4, opacity ~0.6) so the mark
          reads only on close look — hidden joy, not shouted. */}
      <g transform="translate(378 350)">
        <g fill="#b899c9">
          <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
          <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
          <ellipse cx="0" cy="4" rx="4" ry="6"/>
        </g>
        <circle cx="0" cy="0" r="1.8" fill="#f7f2e7"/>
        <circle cx="-0.9" cy="-0.4" r="0.35" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="0.9" cy="-0.4" r="0.35" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -0.7 0.4 C -0.4 0.75, 0.4 0.75, 0.7 0.4" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.65"/>
      </g>

      <g transform="translate(412 344)">
        <g fill="#e46b6b">
          <path d="M0 -10 C 4 -9, 4.5 -2, 0 1 C -4.5 -2, -4 -9, 0 -10 Z"/>
          <path d="M9 -4 C 10.5 1, 6 7, 1 5 C 0 -1, 6 -6, 9 -4 Z"/>
          <path d="M5 8 C 0 11, -5 7, -1 3 C 4 0, 8 3, 5 8 Z"/>
          <path d="M-7 6 C -11 3, -8 -3, -3 -1 C -1 3, -5 7, -7 6 Z"/>
          <path d="M-9 -3 C -6 -8, -1 -7, -1 -2 C -3 2, -10 1, -9 -3 Z"/>
        </g>
        <path d="M0 0 C -2 -2, -4.5 -1, -4.5 1.5 C -4.5 4, 0 6, 0 6 C 0 6, 4.5 4, 4.5 1.5 C 4.5 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
        <circle cx="-1.3" cy="1.4" r="0.4" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="1.3" cy="1.4" r="0.4" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -1 2.6 C -0.5 3.1, 0.5 3.1, 1 2.6" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.7"/>
      </g>

      <g transform="translate(446 352)">
        <g fill="#e8c15a">
          <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
          <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
          <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
        </g>
        <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
        <circle cx="-0.8" cy="-0.35" r="0.3" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="0.8" cy="-0.35" r="0.3" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -0.6 0.35 C -0.35 0.65, 0.35 0.65, 0.6 0.35" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round" opacity="0.65"/>
      </g>

      <circle class="port-ring" cx="412" cy="392" r="9" />
      <circle class="port-fill" cx="412" cy="392" r="3.4" />
    </g>

    {/* Slice-2.7 · SceneWeaveSeam woven-thread grammar baked in — a --canopy
        thread crosses the mid-composition horizontally, going OVER the beam
        and UNDER the three ground-bloom stems (over-and-under: the signature
        weave gesture from SceneWeaveSeam). Shows the container beneath the
        craft — the canopy holds and is held. */}
    <g class="woven-thread" aria-hidden="true">
      <path d="M 80 268 C 160 264, 240 272, 320 268" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 322 270 C 328 264, 336 264, 342 270" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 342 270 C 360 274, 380 268, 400 272" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 400 272 C 406 268, 418 268, 424 272" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 424 272 C 442 276, 462 270, 482 274" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 482 274 C 488 268, 498 268, 504 274" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M 504 274 C 580 268, 660 272, 740 268" stroke="var(--canopy)" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.55"/>
    </g>

    {/* Slice-2.7 · SceneWeaveSeam kernel voice — the container beneath the
        craft, whispered mid-figure at low opacity. From Rika's shipped voice. */}
    <text class="kernel-voice" x="412" y="228" text-anchor="middle" font-size="13" opacity="0.55" font-style="italic">held long enough to become</text>

    {/* Slice-2.7 · Panel-style header (inverted hierarchy — kanji label at
        top center like the four botanical panels, so the whole hero reads
        as a fifth, larger panel). */}
    <text class="hero-kanji" x="412" y="30" text-anchor="middle" font-size="16" letter-spacing="0.5" opacity="0.85">円 · canopy</text>
    <text class="hero-sub" x="412" y="52" text-anchor="middle" font-size="12" font-style="italic" opacity="0.6">the container and the light</text>

    <text class="hand-label hand-label--accent" x="418" y="418" font-size="20">the light lands here</text>
  </svg>
</figure>
<style>
  .scene { margin: 0; }
  .scene svg { width: 100%; height: auto; }
  .canopy-strokes path { stroke: var(--canopy-deep); }
  .dapples .light { fill: var(--canopy-soft); stroke: var(--canopy); opacity: 0.5; }
  .beam { opacity: 0.7; }
  /* Slice-2.7 · panel-style header + kernel voice + woven-thread type. */
  .hero-kanji { font-family: "Noto Serif JP", var(--display); fill: var(--ink); font-weight: 500; }
  .hero-sub { font-family: var(--serif); fill: var(--ink-soft); font-style: italic; }
  .kernel-voice { font-family: var(--hand); fill: var(--ink-soft); }

  /* the light breathes — one slow drift, reduced-motion turns it off.
     petals join the drift, a beat slower and gentler. */
  .dapples .light { animation: shimmer var(--drift) ease-in-out infinite; transform-origin: center; }
  .dapples .light:nth-child(2n) { animation-duration: calc(var(--drift) * 1.3); }
  .dapples .light:nth-child(3n) { animation-duration: calc(var(--drift) * 0.8); animation-delay: -3s; }
  .petals ellipse, .petals path { animation: drift calc(var(--drift) * 1.4) ease-in-out infinite; transform-origin: center; }
  .petals :nth-child(2) { animation-delay: -2s; }
  .petals :nth-child(3) { animation-delay: -4s; }
  .petals :nth-child(4) { animation-delay: -1s; }
  /* Slice-2.6 · the hidden joys breathe with the light — a beat slower than
     petals so they read as tucked-in surprises, not moving decoration. */
  .hidden-joys > g { animation: drift calc(var(--drift) * 1.8) ease-in-out infinite; transform-origin: center; }
  .hidden-joys > g:nth-child(2) { animation-delay: -3.5s; }
  .hidden-joys > g:nth-child(3) { animation-delay: -6s; }
  @keyframes shimmer {
    0%, 100% { opacity: 0.28; }
    50%      { opacity: 0.6; }
  }
  @keyframes drift {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.85; }
  }
</style>
