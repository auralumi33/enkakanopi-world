---
/**
 * CanopyScene — the home's single hand-drawn image (slice-3.2 · subsumed
 * within an ensō container · flower-bed on silk-on-washi cloth).
 *
 * One idea (Law 1): light reaches the ground only by passing through what
 * holds it — and where it lands, a flower bed grows on a small cloth of
 * paper the whole scene sits inside a hand-brushed ensō container.
 *
 * Slice-3.2 rework (2026-07-09) — info-hierarchy clarified:
 *   · The whole scene now sits INSIDE a large hand-brushed ensō container
 *     (opens subtly at ~1 o'clock, hairline stroke, low opacity) — matching
 *     the SceneWeaveSeam container register. Reads as: the canopy is not a
 *     scene on the page; it is held.
 *   · The three ground blooms now grow on a small SKIN-toned flower-bed
 *     cloth (silk-on-washi register) sitting on the ground line — vertical
 *     silk-moiré hairlines run down the cloth like SceneWeaveSeam's fabric.
 *   · Canopy top strokes softened to calligraphic feel — reduced opacity +
 *     hairline width so they read as brush-ink, not painted branches.
 *   · Slice-3.0 grammar still held: --ink-soft outlines · canonical pastels
 *     only · one poppy press at 'the light lands here' seal · SceneWeaveSeam
 *     embroidery-needle weave overhead. Slice-2.5 paradox smiles still hidden
 *     in each ground bloom.
 * Motion is CSS-only and gated on prefers-reduced-motion.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A whispered hand-brushed ensō contains the whole scene; inside it a canopy of soft calligraphic arches, three sumi-e botanical sprigs (lavender · coral · gold) hanging delicately from the canopy above, light falling through to a small silk-on-washi cloth at the ground.</title>

    {/* Slice-3.3 · the enclosing ensō container — dialled MUCH softer per
        Rika. Now: two-layer brush (thick 1.6-width at 0.20 opacity, plus a
        hairline 0.4-width echo at 0.16 opacity for the doubled brush edge)
        + three tapered dry-brush segments at the 1 o'clock opening for the
        hand-lifted feel (where the brush leaves the paper). Reads as: a
        whispered container that holds without shouting — encloses the
        canopy but does not overwhelm it. */}
    <g class="enso-container" aria-hidden="true">
      {/* main brush stroke — thick + soft */}
      <path d="M 700 82 C 540 46, 300 42, 156 96 C 46 152, 24 268, 90 358 C 178 424, 402 438, 590 414 C 710 394, 782 322, 782 236 C 782 178, 748 122, 712 96"
        stroke="var(--ink-soft)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.20"/>
      {/* hairline echo — doubled brush edge */}
      <path d="M 700 82 C 540 46, 300 42, 156 96 C 46 152, 24 268, 90 358 C 178 424, 402 438, 590 414 C 710 394, 782 322, 782 236 C 782 178, 748 122, 712 96"
        stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.16"/>
      {/* dry-brush tail at 1 o'clock — three small tapered hairlines where the brush lifts */}
      <path d="M 712 96 C 720 94, 728 96, 734 100" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.22"/>
      <path d="M 720 92 C 726 91, 730 91, 734 92" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.18"/>
      <path d="M 726 88 C 730 87, 733 87, 736 88" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round" opacity="0.14"/>
    </g>

    <g class="ink block canopy-strokes">
      <path d="M40 150 C 150 60, 300 70, 410 132 C 520 66, 690 74, 790 156" />
      <path d="M96 158 C 150 112, 232 110, 286 150" />
      <path d="M250 150 C 316 104, 404 108, 452 156" />
      <path d="M430 150 C 500 104, 596 108, 648 154" />
      <path d="M582 156 C 640 116, 716 118, 760 156" />
    </g>

    {/* Slice-3 · the canopy is WOVEN — SceneWeaveSeam grammar baked into
        the overhead register. Two embroidery needles pierce the canopy
        from left and right (mirrored); each carries a canopy-coloured
        thread that trails off-frame. Where the four canopy arches cross,
        a subtle over-and-under thread signature marks the woven cloth —
        the canopy is not painted, it is stitched. */}
    <g class="canopy-weave" aria-hidden="true">
      {/* over-under thread signature at each of the four canopy-arch intersections */}
      <path d="M 148 140 C 156 137, 164 137, 172 140" stroke="var(--canopy)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.68"/>
      <path d="M 300 140 C 308 143, 316 143, 324 140" stroke="var(--canopy)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.68"/>
      <path d="M 480 140 C 488 137, 496 137, 504 140" stroke="var(--canopy)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.68"/>
      <path d="M 620 140 C 628 143, 636 143, 644 140" stroke="var(--canopy)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.68"/>

      {/* LEFT embroidery needle · piercing the canopy · thread trailing off-frame */}
      <g transform="translate(60 130) rotate(-18)">
        <path d="M -4 0 C -20 -6, -38 4, -58 -4 C -76 -12, -94 0, -110 -8"
          stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.65"/>
        <ellipse cx="0" cy="0" rx="3.4" ry="1.6" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.82"/>
        <line x1="3" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.2" stroke-linecap="round" opacity="0.82"/>
        <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.78"/>
      </g>

      {/* RIGHT embroidery needle · mirrored · same thread trailing */}
      <g transform="translate(760 130) rotate(198)">
        <path d="M -4 0 C -20 -6, -38 4, -58 -4 C -76 -12, -94 0, -110 -8"
          stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.65"/>
        <ellipse cx="0" cy="0" rx="3.4" ry="1.6" fill="none" stroke="var(--ink-soft)" stroke-width="0.65" opacity="0.82"/>
        <line x1="3" y1="0" x2="72" y2="0" stroke="var(--ink-soft)" stroke-width="1.2" stroke-linecap="round" opacity="0.82"/>
        <path d="M 72 -0.5 L 82 0 L 72 0.5 Z" fill="var(--ink-soft)" opacity="0.78"/>
      </g>
    </g>

    <g class="leaves">
      <path class="leaf-fill" d="M150 128 C 168 108, 208 110, 224 132 C 206 150, 168 150, 150 128 Z" />
      <path class="leaf-fill" d="M356 122 C 376 104, 416 108, 430 130 C 410 148, 372 146, 356 122 Z" />
      <path class="leaf-fill" d="M560 126 C 580 108, 620 110, 636 132 C 616 150, 578 150, 560 126 Z" />
    </g>

    <g class="dapples" aria-hidden="true">
      <circle class="light" cx="210" cy="250" r="9" />
      <circle class="light" cx="360" cy="238" r="7" />
      <circle class="light" cx="500" cy="330" r="6" />
      <circle class="light" cx="330" cy="330" r="5" />
      <circle class="light" cx="470" cy="252" r="6" />
    </g>
    <g class="petals" aria-hidden="true">
      <ellipse cx="268" cy="312" rx="5" ry="7" transform="rotate(-25 268 312)" fill="#b899c9" opacity="0.7"/>
      <ellipse cx="418" cy="286" rx="5.5" ry="7.5" transform="rotate(20 418 286)" fill="#e46b6b" opacity="0.72"/>
      <ellipse cx="556" cy="288" rx="4.5" ry="6.5" transform="rotate(-10 556 288)" fill="#e8c15a" opacity="0.7"/>
      <path d="M395 220 L 397 226 L 402 226 L 398 229 L 400 234 L 395 231 L 390 234 L 392 229 L 388 226 L 393 226 Z" fill="#a4b8c8" opacity="0.7"/>
    </g>

    {/* Slice-2.6 · Isson-contemplative baked layer — hairline sumi-e sprigs
        hanging from the canopy edges (patient, seed-bed grammar), tucked at
        whisper opacity. The soul side of the paradox. */}
    <g class="isson-sprigs" aria-hidden="true">
      <path d="M 178 138 C 176 148, 172 156, 168 162" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <path d="M 168 162 C 166 160, 163 160, 161 162" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.35"/>
      <ellipse cx="168" cy="164" rx="1.4" ry="1.9" fill="#aeb896" opacity="0.45"/>
      <path d="M 388 132 C 386 142, 383 150, 380 156" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <ellipse cx="380" cy="158" rx="1.2" ry="1.7" fill="#aeb896" opacity="0.45"/>
      <ellipse cx="378" cy="155" rx="0.9" ry="1.2" fill="#aeb896" opacity="0.35"/>
      <path d="M 596 138 C 598 148, 601 156, 604 162" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.4"/>
      <ellipse cx="604" cy="164" rx="1.4" ry="1.9" fill="#aeb896" opacity="0.45"/>
    </g>

    {/* Slice-2.6 · the Isson magpie — perched hairline silhouette on the
        rightmost canopy edge, tucked at 0.32 opacity. Same signature as the
        seed-bed's baked magpie (0.18) and the slate panel's magpie, only a
        touch bolder because this is the hero. Contemplative soul, doubled. */}
    <g class="isson-magpie" transform="translate(686 158)" opacity="0.32" aria-hidden="true">
      <path d="M -8 0 C -6 -3, -2 -4, 2 -3 C 4 -2, 6 -1, 8 0 C 6 1, 4 1.5, 0 1.5 C -4 1.5, -6 1, -8 0 Z" fill="var(--ink)" stroke="var(--ink)" stroke-width="0.3"/>
      <circle cx="-5" cy="-1.5" r="0.6" fill="#f7f2e7"/>
      <circle cx="-5" cy="-1.5" r="0.3" fill="var(--ink)"/>
      <path d="M 8 0 L 18 1" stroke="var(--ink)" stroke-width="0.7" fill="none" stroke-linecap="round"/>
      <path d="M -3 1.5 L -3 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
      <path d="M -1 1.5 L -1 4" stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round"/>
    </g>

    {/* Slice-2.6 · Amplified Murakami joy marks — hidden smile-flowers
        scattered in the mid-air register (same grammar as the seed-bed's
        baked 0.20 smile-flowers). Three tiny paradox marks, discovered
        on close look. Joy side of the paradox, doubled. */}
    <g class="hidden-joys" aria-hidden="true">
      <g transform="translate(232 258)" opacity="0.34">
        <g fill="#b899c9">
          <path d="M0 -2.4 C 1.3 -2, 1.6 -0.5, 0 -0.1 C -1.6 -0.5, -1.3 -2, 0 -2.4 Z"/>
          <path d="M2 -0.7 C 2.5 0.9, 1.2 1.6, 0.3 1.1 C 0 -0.1, 1.1 -1.3, 2 -0.7 Z"/>
          <path d="M1.2 1.6 C 0 2.1, -1.2 0.9, -0.4 0 C 0.8 -0.7, 2 0.4, 1.2 1.6 Z"/>
          <path d="M-1.6 0.8 C -2.5 -0.5, -1.6 -1.4, -0.4 -0.7 C 0 0, -0.7 1.5, -1.6 0.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.5" fill="#e8c15a"/>
        <path d="M -0.35 0.1 C -0.2 0.3, 0.2 0.3, 0.35 0.1" stroke="var(--ink-soft)" stroke-width="0.2" fill="none" stroke-linecap="round"/>
      </g>
      <g transform="translate(536 268)" opacity="0.32">
        <g fill="#e08d84">
          <path d="M0 -2.4 C 1.3 -2, 1.6 -0.5, 0 -0.1 C -1.6 -0.5, -1.3 -2, 0 -2.4 Z"/>
          <path d="M2 -0.7 C 2.5 0.9, 1.2 1.6, 0.3 1.1 C 0 -0.1, 1.1 -1.3, 2 -0.7 Z"/>
          <path d="M1.2 1.6 C 0 2.1, -1.2 0.9, -0.4 0 C 0.8 -0.7, 2 0.4, 1.2 1.6 Z"/>
          <path d="M-1.6 0.8 C -2.5 -0.5, -1.6 -1.4, -0.4 -0.7 C 0 0, -0.7 1.5, -1.6 0.8 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.5" fill="#e8c15a"/>
        <path d="M -0.35 0.1 C -0.2 0.3, 0.2 0.3, 0.35 0.1" stroke="var(--ink-soft)" stroke-width="0.2" fill="none" stroke-linecap="round"/>
      </g>
      <g transform="translate(150 340)" opacity="0.30">
        <g fill="#e8c15a">
          <path d="M0 -2 C 1.1 -1.7, 1.4 -0.4, 0 -0.1 C -1.4 -0.4, -1.1 -1.7, 0 -2 Z"/>
          <path d="M1.7 -0.6 C 2.1 0.7, 1 1.4, 0.25 0.9 C 0 -0.1, 0.9 -1.1, 1.7 -0.6 Z"/>
          <path d="M1 1.4 C 0 1.8, -1 0.7, -0.3 0 C 0.7 -0.6, 1.7 0.3, 1 1.4 Z"/>
          <path d="M-1.4 0.7 C -2.1 -0.4, -1.4 -1.2, -0.3 -0.6 C 0 0, -0.6 1.3, -1.4 0.7 Z"/>
        </g>
        <circle cx="0" cy="0" r="0.4" fill="var(--ink-soft)"/>
      </g>
    </g>

    <path class="ink hair beam" d="M412 168 C 420 250, 404 330, 412 386" stroke-dasharray="1.5 7" />

    {/* Slice-3.3 · HANGING SUMI-E BOTANICALS — three delicate sumi-e sprigs
        hang DOWN from the canopy arches (per Rika's plum-blossom / peony
        reference). Each: a hairline calligraphic branch descending from
        under a canopy arch, tapering, with a small twig or two + a delicate
        pastel blossom at the tip. The three canonical bloom pastels
        (lavender · coral · gold) preserved, each still carrying its
        Murakami paradox smile in the flower heart. Reads as: what the
        canopy holds up — held from above, offered to the reader.

        Left sprig · 紫 lavender · descends from x≈200 · a plum-branch feel */}
    <g class="hanging-sprig sprig-left" aria-hidden="true">
      {/* main branch · hairline calligraphic curve from canopy → mid-composition */}
      <path d="M 200 148 C 196 172, 188 198, 178 226 C 174 240, 178 254, 184 264"
        stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.72"/>
      {/* small twig off the main branch */}
      <path d="M 186 214 C 178 214, 172 218, 168 224"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.55"/>
      {/* tiny bud on the twig */}
      <circle cx="168" cy="224" r="1.3" fill="#b899c9" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.25"/>
      {/* the lavender blossom at the tip · paradox smile preserved */}
      <g transform="translate(184 268)">
        <g fill="#b899c9" opacity="0.8">
          <ellipse cx="-3.4" cy="-1.6" rx="3.4" ry="5" transform="rotate(-25 -3.4 -1.6)"/>
          <ellipse cx="3.4" cy="-1.6" rx="3.4" ry="5" transform="rotate(25 3.4 -1.6)"/>
          <ellipse cx="0" cy="3.4" rx="3.4" ry="5"/>
        </g>
        <circle cx="0" cy="0" r="1.5" fill="#f7f2e7"/>
        <circle cx="-0.8" cy="-0.35" r="0.3" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="0.8" cy="-0.35" r="0.3" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -0.6 0.35 C -0.35 0.65, 0.35 0.65, 0.6 0.35" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round" opacity="0.65"/>
      </g>
      {/* two small hairline calligraphy strokes near the branch base — plum-blossom register */}
      <path d="M 196 178 C 192 176, 190 176, 188 178" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M 192 196 C 189 195, 186 196, 184 198" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
    </g>

    {/* Middle sprig · 珊瑚 coral · offset from the center beam · peony feel */}
    <g class="hanging-sprig sprig-middle" aria-hidden="true">
      {/* main branch */}
      <path d="M 340 138 C 342 168, 348 198, 356 226 C 360 242, 358 258, 352 270"
        stroke="var(--ink-soft)" stroke-width="0.95" fill="none" stroke-linecap="round" opacity="0.74"/>
      {/* small leaf-hint mid-branch */}
      <ellipse cx="360" cy="200" rx="6" ry="2.4" transform="rotate(28 360 200)" fill="var(--canopy-soft)" opacity="0.42" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round"/>
      {/* small twig */}
      <path d="M 354 238 C 362 240, 368 244, 372 250"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.55"/>
      <circle cx="373" cy="252" r="1.1" fill="#e46b6b" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.25"/>
      {/* the coral blossom at the tip — a bit more elaborate (peony register) · paradox preserved */}
      <g transform="translate(352 276)">
        <g fill="#e46b6b" opacity="0.82">
          <path d="M0 -8 C 3.2 -7.2, 3.6 -1.6, 0 0.8 C -3.6 -1.6, -3.2 -7.2, 0 -8 Z"/>
          <path d="M7 -3.2 C 8.4 0.8, 4.8 5.6, 0.8 4 C 0 -0.8, 4.8 -4.8, 7 -3.2 Z"/>
          <path d="M4 6.4 C 0 8.8, -4 5.6, -0.8 2.4 C 3.2 0, 6.4 2.4, 4 6.4 Z"/>
          <path d="M-5.6 4.8 C -8.8 2.4, -6.4 -2.4, -2.4 -0.8 C -0.8 2.4, -4 5.6, -5.6 4.8 Z"/>
          <path d="M-7.2 -2.4 C -4.8 -6.4, -0.8 -5.6, -0.8 -1.6 C -2.4 1.6, -8 0.8, -7.2 -2.4 Z"/>
        </g>
        <path d="M0 0 C -1.6 -1.6, -3.6 -0.8, -3.6 1.2 C -3.6 3.2, 0 4.8, 0 4.8 C 0 4.8, 3.6 3.2, 3.6 1.2 C 3.6 -0.8, 1.6 -1.6, 0 0 Z" fill="#f7f2e7"/>
        <circle cx="-1" cy="1.1" r="0.35" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="1" cy="1.1" r="0.35" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -0.8 2.1 C -0.4 2.5, 0.4 2.5, 0.8 2.1" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.7"/>
      </g>
      {/* hairline plum-blossom marks on the branch */}
      <path d="M 344 170 C 340 168, 338 168, 336 170" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M 350 210 C 346 208, 344 208, 342 210" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
    </g>

    {/* Right sprig · 金 gold · descends from x≈610 · cherry-blossom feel */}
    <g class="hanging-sprig sprig-right" aria-hidden="true">
      {/* main branch */}
      <path d="M 610 148 C 614 172, 622 198, 632 226 C 636 240, 632 254, 626 264"
        stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.72"/>
      {/* small twig */}
      <path d="M 624 214 C 632 214, 638 218, 642 224"
        stroke="var(--ink-soft)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.55"/>
      {/* tiny gold bud */}
      <circle cx="642" cy="224" r="1.2" fill="#e8c15a" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.25"/>
      {/* the gold blossom at the tip · paradox preserved */}
      <g transform="translate(626 268)">
        <g fill="#e8c15a" opacity="0.82">
          <ellipse cx="-2.6" cy="-0.9" rx="2.6" ry="4" transform="rotate(-25 -2.6 -0.9)"/>
          <ellipse cx="2.6" cy="-0.9" rx="2.6" ry="4" transform="rotate(25 2.6 -0.9)"/>
          <ellipse cx="0" cy="3.4" rx="2.6" ry="4"/>
        </g>
        <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
        <circle cx="-0.7" cy="-0.3" r="0.28" fill="var(--ink-soft)" opacity="0.6"/>
        <circle cx="0.7" cy="-0.3" r="0.28" fill="var(--ink-soft)" opacity="0.6"/>
        <path d="M -0.55 0.32 C -0.3 0.6, 0.3 0.6, 0.55 0.32" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round" opacity="0.65"/>
      </g>
      {/* hairline calligraphy marks */}
      <path d="M 614 180 C 618 178, 620 178, 622 180" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
      <path d="M 620 200 C 623 198, 626 198, 628 200" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.5"/>
    </g>

    <g class="ground">
      <path class="ink block" d="M120 392 C 320 380, 520 380, 700 392" />

      {/* Slice-3.3 · flower-bed cloth softened further — the botanicals now
          hang from the canopy above, so the cloth reads as the LIGHT-CATCHING
          cloth (silk-on-washi register at the ground) waiting for what falls
          from above. Reduced opacity to whisper. */}
      <g class="flower-bed-cloth" aria-hidden="true">
        <rect x="330" y="342" width="164" height="60" rx="4" ry="4"
          fill="#f2e0d0" fill-opacity="0.20"
          stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round" opacity="0.42"/>
        {/* silk-moiré vertical hairlines · 8 whispers · lower opacity */}
        <g stroke="var(--ink-soft)" stroke-width="0.22" opacity="0.22" stroke-linecap="round">
          <line x1="348" y1="348" x2="348" y2="396"/>
          <line x1="366" y1="348" x2="366" y2="396"/>
          <line x1="384" y1="348" x2="384" y2="396"/>
          <line x1="402" y1="348" x2="402" y2="396"/>
          <line x1="420" y1="348" x2="420" y2="396"/>
          <line x1="438" y1="348" x2="438" y2="396"/>
          <line x1="456" y1="348" x2="456" y2="396"/>
          <line x1="474" y1="348" x2="474" y2="396"/>
        </g>
      </g>

      <circle class="port-ring" cx="412" cy="392" r="9" />
      <circle class="port-fill" cx="412" cy="392" r="3.4" />
    </g>

    {/* Slice-2.7 · SceneWeaveSeam woven-thread grammar baked in — a --canopy
        thread crosses the mid-composition horizontally, going OVER the beam
        and UNDER the three ground-bloom stems (over-and-under: the signature
        weave gesture from SceneWeaveSeam). Shows the container beneath the
        craft — the canopy holds and is held. */}
