---
/**
 * CanopyScene — the home's single hand-drawn image (slice-3.8 · 円花
 * keystone made real · wreath composition).
 *
 * Vision (Rika 2026-07-09, tightened): a singular minimalist sumi-e
 * image — bold ensō stroke as the container, cherry-blossom branches
 * hanging DIRECTLY from the ensō (not from a separate canopy inside),
 * larger blossoms per reference, and a small 円花 hanko seal baked
 * into the composition. Wreath-style asymmetry per fukinsei — the
 * left side of the ensō is "carried" by sakura, the right is bare
 * ink stroke.
 *
 * Layers (kept spare · yugen simplicity):
 *   · Panel-style header (円 · canopy + subtitle) at top
 *   · The ensō (bold minimalist single stroke · unchanged from 3.5/3.7)
 *   · Cherry-blossom wreath — one main branch descending from the ensō
 *     top-left, curving around the left side · larger 5-petal sakura
 *     blossoms clustered in 3 groups along the branch (Isson-hairline
 *     branch, blooms in canonical pastels, ink stamens)
 *   · A smaller counter-branch hanging from the top-right of the ensō
 *     for balance
 *   · 円花 hanko seal at bottom-right (poppy square with white 円花
 *     kanji · maker's mark register)
 *   · Isson magpie (small silhouette perched on the ensō right edge)
 *   · Kernel voice · "held long enough to become"
 *   · Light beam (dashed hairline) falling to a small poppy port —
 *     "the light lands here" seal at the bottom centre
 *
 * Retired in this slice: canopy arches + leaf ovals · paintbrush at
 * ensō start · both embroidery needles · previous 3 hanging sprigs +
 * their cascade buds · light-lands flower bed cloth + silk-moiré +
 * 3 tall-stem flowers.
 *
 * Wabi-sabi principles held: fukinsei · kanso · shizen · yugen · seijaku.
 * One fluid intention.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A hand-brushed sumi-e ensō with a handcrafted asymmetric opening at the top-right (11:30 to 3 o'clock). A single cherry-blossom branch traces the left half of the circle from top-left down to bottom-centre, carrying four 5-petal sakura clusters in lavender, coral, and gold. A red 円花 maker's-seal sits at the bottom-right; a small Isson magpie perches near the top-right end of the ensō; a dashed light beam falls to a coral-highlighted 'the light lands here' seal at the base.</title>

    {/* — Panel-style header (kanji + subtitle) — */}
    <text class="hero-kanji" x="412" y="24" text-anchor="middle" font-size="18" letter-spacing="0.5" opacity="0.88">円 · canopy</text>
    <text class="hero-sub" x="412" y="44" text-anchor="middle" font-size="12" font-style="italic" opacity="0.6">the container and the light</text>

    {/* — THE ENSŌ · asymmetric handcrafted opening at 11:30–3pm —
        Slice-4.4: opening rotated per Rika to the top-right (11:30 to
        3 o'clock), capturing the slight asymmetrical handcrafted feel
        of a real sumi-e ensō. Path starts at (320 62) at ~11:30 and ends
        at (782 236) at ~3 o'clock — the stroke traces ~2/3 of the circle
        CCW, leaving ~1/3 as the handcrafted gap. Opacity nudged UP
        slightly for a bit more presence (0.20 → 0.32) so it reads as
        the maker's stroke, not just a whisper. */}
    <g class="enso-container" aria-hidden="true">
      {/* Slice-4.6 · thicker brush illusion for wet-ink feel — main stroke
          1.2 → 1.8 · echo 0.4 → 0.55 · opacity nudged up so the ensō
          reads as a confident brushed circle, not a faint outline */}
      <path d="M 320 62 C 156 106, 24 268, 90 358 C 200 424, 402 438, 590 414 C 710 394, 782 322, 782 236"
        stroke="var(--ink-soft)" stroke-width="1.8" fill="none" stroke-linecap="round" opacity="0.42"/>
      <path d="M 320 62 C 156 106, 24 268, 90 358 C 200 424, 402 438, 590 414 C 710 394, 782 322, 782 236"
        stroke="var(--ink)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.32"/>
      {/* dry-brush tail at the END of the stroke (~3 o'clock at 782,236) — brush lifts up-right */}
      <path d="M 782 236 C 790 226, 796 218, 800 210" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.24"/>
      <path d="M 790 220 C 794 214, 796 210, 798 206" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round" opacity="0.18"/>
      <path d="M 796 210 C 798 206, 800 203, 802 200" stroke="var(--ink-soft)" stroke-width="0.24" fill="none" stroke-linecap="round" opacity="0.14"/>
    </g>

    {/* — Slice-4.4 · PAINTBRUSH moved to the 3 o'clock opening —
        Positioned at the ensō stroke's endpoint (782, 236). Rotation
        -42° preserved so the bamboo handle rises up-right from the
        contact point — brush is lifting off after tracing 2/3 of the
        circle CCW. Pairs with the dry-brush tail trailing up-right. */}
    <g class="enso-brush" aria-hidden="true">
      <g transform="translate(782 236) rotate(-42)">
        <rect x="5" y="-1.3" width="30" height="2.6" rx="1.2" fill="var(--bamboo)" opacity="0.82"
          stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round"/>
        <rect x="3.5" y="-1.55" width="2" height="3.1" fill="var(--ink-soft)" opacity="0.62"/>
        <path d="M 3.5 -1.05 C 2.2 -0.85, 0.75 -0.4, 0 0 C 0.75 0.4, 2.2 0.85, 3.5 1.05 Z" fill="var(--ink-soft)" opacity="0.74"/>
        <path d="M 0 0 C -0.5 -0.15, -0.9 0, -1.3 0.15" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.64"/>
      </g>
      <circle cx="780" cy="237" r="0.6" fill="var(--ink-soft)" opacity="0.68"/>
    </g>

    {/* — 円花 WREATH · MAIN LEFT BRANCH — extended (slice-4.0) to trace
        along the full left arc of the ensō, from top-left curving down
        along the ensō left side to bottom-left. The BRANCH itself now
        forms the shape of the circle here — the ink stroke is only a
        whisper behind it. */}
    <g class="wreath-main" aria-hidden="true">
      {/* Slice-4.7 · branch SPLIT into two paths so the extended top can
          dial DOWN while the original body keeps its confident wet-ink
          weight. Extended top (620 90 → 148 108) dialled to 0.38 opacity ·
          slightly thinner width (2.2 → 1.6) so the top-of-the-ceiling
          florals become the visual anchor, not the branch. Original body
          (148 108 → 456 412) keeps its wet-ink weight from slice-4.6. */}
      {/* extended top segment · dialled down */}
      <path d="M 620 90 C 460 62, 260 78, 148 108"
        stroke="var(--ink-soft)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.38"/>
      <path d="M 620 90 C 460 62, 260 78, 148 108"
        stroke="var(--ink)" stroke-width="0.5" fill="none" stroke-linecap="round" opacity="0.14"/>
      {/* original body · full wet-ink weight kept */}
      <path d="M 148 108 C 90 138, 46 200, 34 260 C 26 330, 90 396, 200 418 C 290 428, 380 424, 456 412"
        stroke="var(--ink-soft)" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.68"/>
      <path d="M 148 108 C 90 138, 46 200, 34 260 C 26 330, 90 396, 200 418 C 290 428, 380 424, 456 412"
        stroke="var(--ink)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.32"/>
      {/* Slice-4.6 · side-twigs restored + added along the extended arc
          for the organic illustrative sketch feel Rika asked for. Three
          total: one on the upper-right extension · one on the top arc ·
          one on the lower-left original spot. */}
      <path d="M 500 74 C 494 82, 484 90, 476 96"
        stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.62"/>
      <path d="M 300 78 C 296 88, 290 96, 282 102"
        stroke="var(--ink-soft)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.6"/>
      <path d="M 62 340 C 82 342, 104 340, 122 336"
        stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.65"/>

      {/* — CLUSTER 1 · upper-left arc · densest cluster — 紫 lavender
          repositioned onto the extended arc (slice-4.0). Primary at
          the top curve where the branch enters. */}
      {/* primary large blossom · paradox smile hidden inside */}
      <g transform="translate(128 132) scale(1.15)">
        <g fill="#b899c9" opacity="0.82">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
          <path d="M 5 6.7 C 2 8.9, -2 7.2, -2.3 4 C -2.3 2.3, -0.8 0.9, 0.9 1 C 3 2.2, 5.6 4, 5 6.7 Z"/>
          <path d="M -5 6.7 C -7.5 4.2, -6.5 -0.6, -3.4 -1 C -1.4 -1, -0.6 0.5, -0.7 2.2 C -1.7 4.3, -3.8 6.5, -5 6.7 Z"/>
          <path d="M -8.1 -2.8 C -6.7 -6.2, -2.8 -6.7, -1.4 -4.5 C -0.5 -2.8, -0.7 -0.8, -2.5 0 C -4.8 0.2, -7.5 -1.1, -8.1 -2.8 Z"/>
        </g>
