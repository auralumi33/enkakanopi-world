        <path d="M -0.8 1.15 C -0.45 1.55, 0.45 1.55, 0.8 1.15" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.6"/>
      </g>
      {/* secondary blossom · upper-right of primary · along arc */}
      <g transform="translate(155 116) scale(0.86)">
        <g fill="#b899c9" opacity="0.75">
          <path d="M 0 -8.5 C 3.4 -7.6, 4.5 -2.8, 2.3 -0.8 C 0.7 0.5, -0.7 0.5, -2.3 -0.8 C -4.5 -2.8, -3.4 -7.6, 0 -8.5 Z"/>
          <path d="M 8.1 -2.8 C 9.6 0.5, 7.2 4.6, 3.8 4.1 C 2 3.8, 0.5 2.3, 0.6 0.7 C 2 -1, 5.1 -3.4, 8.1 -2.8 Z"/>
