        <circle cx="0.85" cy="-0.28" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="0.52" cy="0.75" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.52" cy="0.75" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
        <circle cx="-0.85" cy="-0.28" r="0.28" fill="var(--ink-soft)" opacity="0.72"/>
      </g>

      {/* Slice-4.6 · NEW CLUSTER B · top arc · 紫 lavender + 金 gold pair —
          sits at the top of the wreath (12 o'clock area) mixing two pastels
          for the varied-flower-colour feel Rika asked for. */}
      <g transform="translate(410 66) scale(1.08)">
        <g fill="#b899c9" opacity="0.8">
          <path d="M 0 -8 C 3.2 -7.2, 4.2 -2.6, 2.2 -0.7 C 0.6 0.5, -0.6 0.5, -2.2 -0.7 C -4.2 -2.6, -3.2 -7.2, 0 -8 Z"/>
