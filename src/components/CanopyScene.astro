---
/**
 * CanopyScene — the home's single hand-drawn image, refined.
 * One idea (Law 1): light reaches the ground only by passing through what
 * holds it — and where it lands, a flower bed grows in quiet defiance.
 * The canopy overhead stays canopy-deep, but the abstract dapples are now
 * a mixed drift: some soft-green light dapples, some tiny palette petals
 * falling through with the beam. At the port, where the light lands, a
 * small bed of blooms — lavender bud, coral rose (the maker's mark), yellow
 * bud — grows from the ground line.
 * Motion is CSS-only and gated on prefers-reduced-motion.
 */
---
<figure class="scene">
  <svg width="820" height="440" viewBox="0 0 820 440" role="img" aria-labelledby="scene-t" preserveAspectRatio="xMidYMid meet">
    <title id="scene-t">A hand-drawn canopy; light falls through the leaves and lands on a small flower bed at the ground.</title>

    <g class="ink block canopy-strokes">
      <path d="M40 150 C 150 60, 300 70, 410 132 C 520 66, 690 74, 790 156" />
      <path d="M96 158 C 150 112, 232 110, 286 150" />
      <path d="M250 150 C 316 104, 404 108, 452 156" />
      <path d="M430 150 C 500 104, 596 108, 648 154" />
      <path d="M582 156 C 640 116, 716 118, 760 156" />
    </g>

    <g class="leaves">
      <path class="leaf-fill" d="M150 128 C 168 108, 208 110, 224 132 C 206 150, 168 150, 150 128 Z" />
      <path class="leaf-fill" d="M356 122 C 376 104, 416 108, 430 130 C 410 148, 372 146, 356 122 Z" />
      <path class="leaf-fill" d="M560 126 C 580 108, 620 110, 636 132 C 616 150, 578 150, 560 126 Z" />
    </g>

    <g class="dapples" aria-hidden="true">
      <circle class="light" cx="210" cy="250" r="9" />
      <circle class="light" cx="360" cy="238" r="7" />
      <circle class="light" cx="500" cy="330" r="6" />
      <circle class="light" cx="330" cy="330" r="5" />
      <circle class="light" cx="470" cy="252" r="6" />
    </g>
    <g class="petals" aria-hidden="true">
      <ellipse cx="268" cy="312" rx="5" ry="7" transform="rotate(-25 268 312)" fill="#b899c9" opacity="0.7"/>
      <ellipse cx="418" cy="286" rx="5.5" ry="7.5" transform="rotate(20 418 286)" fill="#e46b6b" opacity="0.72"/>
      <ellipse cx="556" cy="288" rx="4.5" ry="6.5" transform="rotate(-10 556 288)" fill="#e8c15a" opacity="0.7"/>
      <path d="M395 220 L 397 226 L 402 226 L 398 229 L 400 234 L 395 231 L 390 234 L 392 229 L 388 226 L 393 226 Z" fill="#a4b8c8" opacity="0.7"/>
    </g>

    <path class="ink hair beam" d="M412 168 C 420 250, 404 330, 412 386" stroke-dasharray="1.5 7" />

    <g class="ground">
      <path class="ink block" d="M120 392 C 320 380, 520 380, 700 392" />

      <path d="M378 388 Q 376 372, 378 356" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.65" stroke-linecap="round"/>
      <path d="M412 386 Q 412 366, 412 348" stroke="#4f5b3f" stroke-width="1.1" fill="none" opacity="0.7" stroke-linecap="round"/>
      <path d="M446 388 Q 448 372, 446 356" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.65" stroke-linecap="round"/>

      <g transform="translate(378 350)">
        <g fill="#b899c9">
          <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-25 -4 -2)"/>
          <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(25 4 -2)"/>
          <ellipse cx="0" cy="4" rx="4" ry="6"/>
        </g>
        <circle cx="0" cy="0" r="1.8" fill="#f7f2e7"/>
      </g>

      <g transform="translate(412 344)">
        <g fill="#e46b6b">
          <path d="M0 -10 C 4 -9, 4.5 -2, 0 1 C -4.5 -2, -4 -9, 0 -10 Z"/>
          <path d="M9 -4 C 10.5 1, 6 7, 1 5 C 0 -1, 6 -6, 9 -4 Z"/>
          <path d="M5 8 C 0 11, -5 7, -1 3 C 4 0, 8 3, 5 8 Z"/>
          <path d="M-7 6 C -11 3, -8 -3, -3 -1 C -1 3, -5 7, -7 6 Z"/>
          <path d="M-9 -3 C -6 -8, -1 -7, -1 -2 C -3 2, -10 1, -9 -3 Z"/>
        </g>
        <path d="M0 0 C -2 -2, -4.5 -1, -4.5 1.5 C -4.5 4, 0 6, 0 6 C 0 6, 4.5 4, 4.5 1.5 C 4.5 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
      </g>

      <g transform="translate(446 352)">
        <g fill="#e8c15a">
          <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
          <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
          <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
        </g>
        <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
      </g>

      <circle class="port-ring" cx="412" cy="392" r="9" />
      <circle class="port-fill" cx="412" cy="392" r="3.4" />
    </g>

    <text class="hand-label" x="470" y="120" font-size="21">the canopy</text>
    <text class="hand-label hand-label--accent" x="418" y="418" font-size="20">the light lands here</text>
  </svg>
</figure>
<style>
  .scene { margin: 0; }
  .scene svg { width: 100%; height: auto; }
  .canopy-strokes path { stroke: var(--canopy-deep); }
  .dapples .light { fill: var(--canopy-soft); stroke: var(--canopy); opacity: 0.5; }
  .beam { opacity: 0.7; }

  /* the light breathes — one slow drift, reduced-motion turns it off.
     petals join the drift, a beat slower and gentler. */
  .dapples .light { animation: shimmer var(--drift) ease-in-out infinite; transform-origin: center; }
  .dapples .light:nth-child(2n) { animation-duration: calc(var(--drift) * 1.3); }
  .dapples .light:nth-child(3n) { animation-duration: calc(var(--drift) * 0.8); animation-delay: -3s; }
  .petals ellipse, .petals path { animation: drift calc(var(--drift) * 1.4) ease-in-out infinite; transform-origin: center; }
  .petals :nth-child(2) { animation-delay: -2s; }
  .petals :nth-child(3) { animation-delay: -4s; }
  .petals :nth-child(4) { animation-delay: -1s; }
  @keyframes shimmer {
    0%, 100% { opacity: 0.28; }
    50%      { opacity: 0.6; }
  }
  @keyframes drift {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.85; }
  }
</style>
