---
/**
 * RowPlanter — the row-planter mark, used above each stream's h1 as the
 * small signature for that room. `lead` rotates one accent per stream
 * (lavender → Field Notes · yellow → The Workbench · blue → Body & Spine ·
 * coral → default/Lexicon fallback), now the held bloom inside an EnkaMark
 * ensō ring rather than a bespoke three-flower arrangement.
 */
import EnkaMark from "./EnkaMark.astro";
import type { EnkaAccent } from "./EnkaMark.astro";
interface Props { lead?: "lavender" | "yellow" | "blue" | "coral"; size?: number; }
const { lead = "lavender", size = 132 } = Astro.props;
// Existing call sites pass `size` calibrated for the old elongated
// 220x70 three-flower strip (e.g. 148 wide, ~47 tall). EnkaMark is a square
// medallion, so scale down to land at roughly the same visual weight/height
// as the strip it replaces, without touching any call site's props.
const markSize = Math.round(size * 0.62);

const leadToAccent: Record<NonNullable<Props["lead"]>, EnkaAccent> = {
  lavender: "lavender",
  yellow: "gold",
  blue: "slate",
  coral: "poppy",
};
---
<EnkaMark size={markSize} ring="closed" hold="bloom" accent={leadToAccent[lead]} />
