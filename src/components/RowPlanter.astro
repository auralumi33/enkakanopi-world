---
/**
 * RowPlanter — the row-planter mark (variant B of the bloom family), used
 * above each stream's h1 as the small floral signature for that room.
 * `lead`: which accent color leads (rotates one per stream)
 *   lavender  → Field Notes
 *   yellow    → The Workbench
 *   blue      → Body & Spine
 *   coral     → default / Lexicon fallback (though Lexicon uses the medallion)
 * Palette: coral #e46b6b · lavender #b899c9 · pastel blue #a4b8c8 ·
 * marimekko yellow #e8c15a · cream heart #f7f2e7 · canopy deep #4f5b3f.
 */
interface Props { lead?: "lavender" | "yellow" | "blue" | "coral"; size?: number; }
const { lead = "lavender", size = 132 } = Astro.props;
const h = Math.round((size * 70) / 220);

const lavenderLily = `
  <g fill="#b899c9">
    <ellipse cx="-7" cy="-3" rx="7" ry="10" transform="rotate(-30 -7 -3)"/>
    <ellipse cx="7" cy="-3" rx="7" ry="10" transform="rotate(30 7 -3)"/>
    <ellipse cx="0" cy="8" rx="7" ry="10"/>
  </g>
  <circle cx="0" cy="1" r="3.2" fill="#f7f2e7"/>
`;
const coralRose = `
  <g fill="#e46b6b">
    <path d="M0 -12 C 5 -11, 6 -2, 0 2 C -6 -2, -5 -11, 0 -12 Z"/>
    <path d="M11 -6 C 13 1, 7 8, 1 5 C -1 -2, 5 -8, 11 -6 Z"/>
    <path d="M7 10 C 0 13, -6 7, -2 3 C 4 -1, 9 3, 7 10 Z"/>
    <path d="M-9 8 C -13 3, -9 -4, -4 -2 C -2 3, -6 9, -9 8 Z"/>
    <path d="M-11 -4 C -8 -10, -1 -8, -1 -3 C -4 3, -13 2, -11 -4 Z"/>
  </g>
  <path d="M0 0 C -2 -2, -5 -1, -5 2 C -5 5, 0 7, 0 7 C 0 7, 5 5, 5 2 C 5 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
`;
const blueStar = `
  <g fill="#a4b8c8"><path d="M0 -10 L 2 -3 L 9 -3 L 4 1 L 6 8 L 0 4 L -6 8 L -4 1 L -9 -3 L -2 -3 Z"/></g>
  <circle cx="0" cy="0" r="2.6" fill="#f7f2e7"/>
`;
const yellowBud = `
  <g fill="#e8c15a">
    <ellipse cx="-4" cy="-2" rx="4" ry="7" transform="rotate(-30 -4 -2)"/>
    <ellipse cx="4" cy="-2" rx="4" ry="7" transform="rotate(30 4 -2)"/>
    <ellipse cx="0" cy="6" rx="4" ry="7"/>
  </g>
  <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
`;

const arrangements = {
  lavender: { left: lavenderLily, center: coralRose, right: blueStar, sprinkle: "#e8c15a" },
  yellow:   { left: yellowBud,    center: coralRose, right: lavenderLily, sprinkle: "#a4b8c8" },
  blue:     { left: blueStar,     center: coralRose, right: lavenderLily, sprinkle: "#e8c15a" },
  coral:    { left: lavenderLily, center: coralRose, right: blueStar, sprinkle: "#e8c15a" },
};
const A = arrangements[lead];
---
<svg width={size} height={h} viewBox="0 0 220 70" class="row-planter" aria-hidden="true">
  <rect x="10" y="8" width="200" height="52" rx="3" fill="#efe8d6" stroke="#4f5b3f" stroke-width="1"/>
  <g transform="translate(50 40)" set:html={A.left}></g>
  <g transform="translate(110 38)" set:html={A.center}></g>
  <g transform="translate(170 40)" set:html={A.right}></g>
  <circle cx="80" cy="22" r="1" fill={A.sprinkle}/>
  <circle cx="140" cy="55" r="1" fill={A.sprinkle}/>
  <circle cx="30" cy="52" r="0.9" fill={A.sprinkle}/>
  <circle cx="195" cy="20" r="0.9" fill={A.sprinkle}/>
</svg>
<style>
  .row-planter { display: block; }
</style>
