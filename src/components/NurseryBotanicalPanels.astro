---
/**
 * NurseryBotanicalPanels — the seed-bed page's eight panel doors, distributed
 * across the page as two rows via the row-prop distribution pattern.
 *
 * Migrated to the shared PanelDoors system (2026-07-11): data + hand-tuned
 * vignettes stay here; layout, hue tokens, hover/focus, caption grammar,
 * and the nav landmark are owned by `PanelDoors.astro`.
 *
 * Row 1: the scrap · the germination · the wobble · the cracked seed
 * Row 2: the closed bud · the pressed leaf · the tangent · the small vessel
 *
 * Each panel is a door to its semantic room — same doctrine as Home + Colophon.
 */
import PanelDoors, { type Panel } from "./PanelDoors.astro";

export interface Props {
  row?: 1 | 2 | "all";
}
const { row = "all" } = Astro.props as Props;
const showRow1 = row === "all" || row === 1;
const showRow2 = row === "all" || row === 2;

const row1Panels: Panel[] = [
  { hue: "lavender", role: "the scrap",        caption: "a scrap · fragment caught · smile in the corner bloom", href: "/field-notes", cta: "enter Field Notes" },
  { hue: "gold",     role: "the germination",  caption: "the germination · first shoot · smile in the gold bud", href: "/workbench",   cta: "enter The Workbench" },
  { hue: "coral",    role: "the wobble",       caption: "the ruler couldn't hold · smile at the tip",             href: "/body-spine",  cta: "enter Body & Spine" },
  { hue: "slate",    role: "the cracked seed", caption: "the cracked seed · root emerging · smile inside the crack", href: "/versions",  cta: "enter Versions of Me" },
];

const row2Panels: Panel[] = [
  { hue: "lavender", role: "the closed bud",   caption: "potential · not yet open · smile sleeping inside",        href: "/volume-i",   cta: "enter Volume I" },
  { hue: "gold",     role: "the pressed leaf", caption: "a leaf preserved · veins remembered · smile at the tip",  href: "/colophon",   cta: "enter the Colophon" },
  { hue: "coral",    role: "the tangent",      caption: "loving the curve · smile at the arrival",                 href: "/lexicon",    cta: "enter the Lexicon" },
  { hue: "slate",    role: "the small vessel", caption: "a tiny pot · tender growth · smile in the bell",          href: "/studio",     cta: "enter the Studio" },
];

const signature = "we arrive at legibility not by becoming linear, but by loving the curve enough to know where the tangent leaves it";
---
{showRow1 && (
  <PanelDoors
    panels={row1Panels}
    ariaLabel="Nursery seed-bed panels · row one — fragments before they are essays"
    variant="seedbed"
    row={showRow2 ? 1 : row}
    rows={2}
    signature={!showRow2 && row === 1 ? undefined : signature}
  >
    <svg slot="vignette-1" viewBox="0 0 200 220" role="img" aria-labelledby="n1-t"><title id="n1-t">A torn paper scrap with a small lavender bloom holding a hidden smile</title>
      <rect x="10" y="10" width="180" height="200" fill="#b899c9" opacity="0.10" rx="1"/>
      <path d="M 60 60 L 140 55 L 145 130 L 138 145 L 55 148 L 52 130 L 58 90 Z" fill="var(--paper-washi)" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
      <path d="M 68 82 C 90 80, 115 82, 132 80" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.55" stroke-linecap="round"/>
      <path d="M 68 96 C 88 94, 108 96, 128 94" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.55" stroke-linecap="round"/>
      <path d="M 68 110 C 82 108, 96 110, 108 108" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.55" stroke-linecap="round"/>
      <g transform="translate(122 128)">
        <g fill="#b899c9" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round">
          <path d="M 0 -4 C 2.2 -3.4, 2.8 -0.8, 0 -0.15 C -2.8 -0.8, -2.2 -3.4, 0 -4 Z"/>
          <path d="M 3.4 -1.4 C 4.2 1, 2.2 2.8, 0.6 1.6 C 0 -0.15, 1.8 -2.2, 3.4 -1.4 Z"/>
          <path d="M 2.2 2.8 C 0 3.6, -2.2 1.6, -0.8 0 C 1.4 -1.1, 3.4 0.9, 2.2 2.8 Z"/>
          <path d="M -2.8 1.4 C -4.2 -0.8, -2.8 -2.5, -0.8 -1.4 C 0 0, -1.4 2.5, -2.8 1.4 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.2" fill="#e8c15a" opacity="0.95"/>
        <path d="M -0.6 -0.15 C -0.35 0.05, 0.35 0.05, 0.6 -0.15" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
      </g>
      <path d="M 140 55 L 155 65 L 145 130" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.55" stroke-linecap="round"/>
    </svg>

    <svg slot="vignette-2" viewBox="0 0 200 220" role="img" aria-labelledby="n2-t"><title id="n2-t">A gold sprout breaking through soil with a hidden smile in the bud</title>
      <rect x="10" y="10" width="180" height="200" fill="#e8c15a" opacity="0.10" rx="1"/>
      <path d="M 40 175 C 70 165, 130 165, 160 175 L 160 200 L 40 200 Z" fill="var(--canopy-soft)" opacity="0.35" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linejoin="round"/>
      <path d="M 90 175 L 92 170" stroke="var(--ink-soft)" stroke-width="0.3" opacity="0.5"/>
      <path d="M 115 175 L 118 172" stroke="var(--ink-soft)" stroke-width="0.3" opacity="0.5"/>
      <path d="M 100 165 C 100 140, 98 115, 100 90" stroke="var(--canopy)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.85"/>
      <path d="M 100 120 C 88 118, 82 122, 82 128 C 88 128, 96 124, 100 120 Z" fill="var(--canopy-soft)" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 100 110 C 112 108, 118 112, 118 118 C 112 118, 104 114, 100 110 Z" fill="var(--canopy-soft)" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <g transform="translate(100 85)">
        <circle cx="0" cy="0" r="4.2" fill="#e8c15a" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.4"/>
        <path d="M -1.4 -0.3 C -0.8 0.4, 0.8 0.4, 1.4 -0.3" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round"/>
        <circle cx="-1.4" cy="-1.4" r="0.35" fill="var(--ink-soft)"/>
        <circle cx="1.4" cy="-1.4" r="0.35" fill="var(--ink-soft)"/>
      </g>
    </svg>

    <svg slot="vignette-3" viewBox="0 0 200 220" role="img" aria-labelledby="n3-t"><title id="n3-t">A wobbling curve leaving a dashed ruler with a coral bloom at the tip</title>
      <rect x="10" y="10" width="180" height="200" fill="#e46b6b" opacity="0.09" rx="1"/>
      <path d="M 30 160 C 45 155, 50 165, 65 158 C 82 150, 88 168, 105 160 C 122 152, 128 170, 145 162 C 160 155, 168 168, 178 160" stroke="var(--ink-soft)" stroke-width="0.75" fill="none" stroke-linecap="round" opacity="0.7"/>
      <line x1="30" y1="120" x2="178" y2="120" stroke="var(--ink-faint)" stroke-width="0.4" stroke-dasharray="2 3" opacity="0.55"/>
      <g stroke="var(--ink-faint)" stroke-width="0.4" opacity="0.55">
        <line x1="50" y1="118" x2="50" y2="122"/>
        <line x1="80" y1="118" x2="80" y2="122"/>
        <line x1="110" y1="118" x2="110" y2="122"/>
        <line x1="140" y1="118" x2="140" y2="122"/>
      </g>
      <g transform="translate(178 155)">
        <g fill="#e08d84" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round">
          <path d="M 0 -3.6 C 2 -3, 2.5 -0.7, 0 -0.15 C -2.5 -0.7, -2 -3, 0 -3.6 Z"/>
          <path d="M 3 -1.2 C 3.6 0.9, 2 2.4, 0.5 1.4 C 0 -0.15, 1.6 -1.9, 3 -1.2 Z"/>
          <path d="M 2 2.4 C 0 3, -2 1.4, -0.7 0 C 1.2 -1, 3 0.8, 2 2.4 Z"/>
          <path d="M -2.5 1.2 C -3.6 -0.7, -2.5 -2.2, -0.7 -1.2 C 0 0, -1.2 2.2, -2.5 1.2 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.1" fill="#e8c15a" opacity="0.95"/>
        <path d="M -0.55 -0.15 C -0.3 0.05, 0.3 0.05, 0.55 -0.15" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
      </g>
    </svg>

    <svg slot="vignette-4" viewBox="0 0 200 220" role="img" aria-labelledby="n4-t"><title id="n4-t">A cracked seed with a small root emerging and a hidden smile inside</title>
      <rect x="10" y="10" width="180" height="200" fill="#a4b8c8" opacity="0.14" rx="1"/>
      <ellipse cx="100" cy="115" rx="30" ry="42" fill="#a4b8c8" opacity="0.35" stroke="var(--ink-soft)" stroke-width="0.7"/>
      <path d="M 100 78 C 96 90, 104 105, 100 118 C 96 130, 106 145, 100 158" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.75"/>
      <path d="M 100 158 C 100 175, 96 190, 90 200" stroke="var(--canopy)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.7"/>
      <path d="M 96 178 C 92 182, 88 185, 84 188" stroke="var(--canopy)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.6"/>
      <g transform="translate(100 118)">
        <circle cx="0" cy="0" r="1.6" fill="#e8c15a" opacity="0.85"/>
        <path d="M -0.8 -0.2 C -0.5 0.15, 0.5 0.15, 0.8 -0.2" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
      </g>
    </svg>
  </PanelDoors>
)}

{showRow2 && (
  <PanelDoors
    panels={row2Panels}
    ariaLabel="Nursery seed-bed panels · row two — fragments before they are essays"
    variant="seedbed"
    row={showRow1 ? 2 : row}
    rows={2}
    signature={signature}
  >
    <svg slot="vignette-1" viewBox="0 0 200 220" role="img" aria-labelledby="n5-t"><title id="n5-t">A closed lavender bud on a stem with a hidden smile sleeping inside</title>
      <rect x="10" y="10" width="180" height="200" fill="#b899c9" opacity="0.10" rx="1"/>
      <path d="M 100 210 C 100 180, 98 140, 100 100" stroke="var(--canopy)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.75"/>
      <path d="M 100 150 C 82 148, 76 154, 76 162 C 82 162, 94 158, 100 150 Z" fill="var(--canopy-soft)" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 100 100 C 88 95, 84 82, 90 68 C 94 60, 100 55, 100 55 C 100 55, 106 60, 110 68 C 116 82, 112 95, 100 100 Z" fill="#b899c9" opacity="0.72" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
      <path d="M 100 100 C 98 82, 100 65, 100 55" stroke="var(--ink-soft)" stroke-width="0.4" opacity="0.5" fill="none" stroke-linecap="round"/>
      <g transform="translate(100 80)">
        <path d="M -1.4 -0.3 C -0.8 0.4, 0.8 0.4, 1.4 -0.3" stroke="var(--ink-soft)" stroke-width="0.35" fill="none" stroke-linecap="round" opacity="0.75"/>
        <circle cx="-1.2" cy="-1.2" r="0.28" fill="var(--ink-soft)" opacity="0.7"/>
        <circle cx="1.2" cy="-1.2" r="0.28" fill="var(--ink-soft)" opacity="0.7"/>
      </g>
    </svg>

    <svg slot="vignette-2" viewBox="0 0 200 220" role="img" aria-labelledby="n6-t"><title id="n6-t">A pressed leaf with veins preserved and a gold smile at the tip</title>
      <rect x="10" y="10" width="180" height="200" fill="#e8c15a" opacity="0.11" rx="1"/>
      <path d="M 100 190 C 70 180, 55 155, 55 120 C 55 85, 75 60, 100 45 C 125 60, 145 85, 145 120 C 145 155, 130 180, 100 190 Z" fill="var(--canopy-soft)" opacity="0.55" stroke="var(--ink-soft)" stroke-width="0.65" stroke-linejoin="round"/>
      <path d="M 100 45 C 100 90, 100 145, 100 190" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.75"/>
      <g stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.6" stroke-linecap="round">
        <path d="M 100 70 C 90 78, 78 84, 68 88"/>
        <path d="M 100 70 C 110 78, 122 84, 132 88"/>
        <path d="M 100 100 C 88 108, 74 114, 62 118"/>
        <path d="M 100 100 C 112 108, 126 114, 138 118"/>
        <path d="M 100 130 C 90 138, 78 144, 68 148"/>
        <path d="M 100 130 C 110 138, 122 144, 132 148"/>
      </g>
      <g transform="translate(100 46)">
        <circle cx="0" cy="0" r="2.4" fill="#e8c15a" opacity="0.9"/>
        <path d="M -0.9 -0.15 C -0.55 0.15, 0.55 0.15, 0.9 -0.15" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
      </g>
    </svg>

    <svg slot="vignette-3" viewBox="0 0 200 220" role="img" aria-labelledby="n7-t"><title id="n7-t">A curve leaving a dashed ruler with a coral bloom at the arrival, smile at the tip</title>
      <rect x="10" y="10" width="180" height="200" fill="#e46b6b" opacity="0.09" rx="1"/>
      <line x1="30" y1="80" x2="170" y2="80" stroke="var(--ink-faint)" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.6"/>
      <path d="M 30 80 C 50 80, 65 82, 78 88 C 92 96, 105 110, 120 128 C 135 148, 150 168, 165 180" stroke="var(--ink-soft)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.78"/>
      <g transform="translate(168 182)">
        <g fill="#e08d84" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round">
          <path d="M 0 -3.6 C 2 -3, 2.5 -0.7, 0 -0.15 C -2.5 -0.7, -2 -3, 0 -3.6 Z"/>
          <path d="M 3 -1.2 C 3.6 0.9, 2 2.4, 0.5 1.4 C 0 -0.15, 1.6 -1.9, 3 -1.2 Z"/>
          <path d="M 2 2.4 C 0 3, -2 1.4, -0.7 0 C 1.2 -1, 3 0.8, 2 2.4 Z"/>
          <path d="M -2.5 1.2 C -3.6 -0.7, -2.5 -2.2, -0.7 -1.2 C 0 0, -1.2 2.2, -2.5 1.2 Z"/>
        </g>
        <circle cx="0" cy="0" r="1.1" fill="#e8c15a" opacity="0.95"/>
        <path d="M -0.55 -0.15 C -0.3 0.05, 0.3 0.05, 0.55 -0.15" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
      </g>
    </svg>

    <svg slot="vignette-4" viewBox="0 0 200 220" role="img" aria-labelledby="n8-t"><title id="n8-t">A small pot with a tender slate-bell sprout inside and a hidden smile</title>
      <rect x="10" y="10" width="180" height="200" fill="#a4b8c8" opacity="0.14" rx="1"/>
      <path d="M 65 130 C 68 128, 72 126, 100 126 C 128 126, 132 128, 135 130 L 130 190 C 128 195, 122 200, 100 200 C 78 200, 72 195, 70 190 Z" fill="var(--canopy-soft)" opacity="0.45" stroke="var(--ink-soft)" stroke-width="0.7" stroke-linejoin="round"/>
      <path d="M 65 130 C 70 128, 78 130, 88 129 C 100 128, 112 130, 122 129 C 130 128, 134 130, 135 130" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.75"/>
      <path d="M 100 126 C 100 108, 98 90, 100 72" stroke="var(--canopy)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.85"/>
      <path d="M 100 100 C 88 98, 82 102, 82 108 C 88 108, 96 104, 100 100 Z" fill="var(--canopy-soft)" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <path d="M 100 90 C 112 88, 118 92, 118 98 C 112 98, 104 94, 100 90 Z" fill="var(--canopy-soft)" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.4" stroke-linejoin="round"/>
      <g transform="translate(100 68)">
        <path d="M -3 -1 C -3.6 3, -2.4 4, 0 4 C 2.4 4, 3.6 3, 3 -1 Z" fill="#a4b8c8" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round"/>
        <circle cx="0" cy="4" r="0.7" fill="#e8c15a" opacity="0.85"/>
        <path d="M -0.6 2 C -0.35 2.4, 0.35 2.4, 0.6 2" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
      </g>
    </svg>
  </PanelDoors>
)}
