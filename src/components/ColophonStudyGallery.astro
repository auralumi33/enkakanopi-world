---
/**
 * ColophonStudyGallery — the demo control (SHIP-PROMPT-COLOPHON §B·3, §C).
 *
 * "Prior handcrafted studies as proof-of-concept craft-provenance" — a
 * restrained, native <details> toggle (zero JS, fully keyboard-operable)
 * that opens onto three cards: a static screenshot of each remediated
 * GARDEN-SCULPT study, captioned "a study, not the shipped site", each
 * linking out to the sanitized standalone file (public/studies/*.html)
 * and, where the shipped surface already exists, across to it.
 *
 * Firewall: the three linked files are re-grepped copies (guard.words +
 * guard.words.local clean, confirmed at build time this session); the
 * canopy-memory-study copy additionally had its ask/speak/hush Q&A loop
 * removed — RESTRUCTURE-CHARTER §2 intake #6 sanctions read-aloud only,
 * never a Q&A that "answers" (Rika's ruling, 2026-07-13). The "hear it"
 * per-node read-aloud stayed; only the question-answering loop is gone.
 *
 * Never a product demo (the site never sells) — process-over-product,
 * craft lineage shown, not pitched (AESTHETIC-DIRECTION §5, §8).
 */
interface Study {
  file: string;
  image: string;
  name: string;
  eyebrow: string;
  shippedHref?: string;
  shippedLabel?: string;
}

const studies: Study[] = [
  {
    file: "/studies/canopy-home-map.html",
    image: "/studies-preview/canopy-home-map.jpg",
    name: "a view from above",
    eyebrow: "the home study",
    shippedHref: "/",
    shippedLabel: "the garden, from above",
  },
  {
    file: "/studies/touchable-workbench-study.html",
    image: "/studies-preview/touchable-workbench-study.jpg",
    name: "left out on the bench",
    eyebrow: "the workbench study",
    shippedHref: "/workbench",
    shippedLabel: "the Workbench",
  },
  {
    file: "/studies/canopy-memory-study.html",
    image: "/studies-preview/canopy-memory-study.jpg",
    name: "how the garden's ideas connect",
    eyebrow: "the lexicon study",
    shippedHref: "/lexicon",
    shippedLabel: "the Lexicon",
  },
];
---
<details class="study-control">
  {/* PROPOSED · ratify — heading + intro assembled from the ship-prompt's
      own words (SHIP-PROMPT-COLOPHON §B·3: "the design's own drafts as
      provenance"; AESTHETIC-DIRECTION §5: "process over product") rather
      than newly authored; hers to keep, cut, or rewrite. */}
  <summary>The design's own drafts, kept</summary>
  <p class="control-intro">
    Process over product: three earlier studies, held here as provenance —
    not a product demo, the craft this page grew from.
  </p>
  <div class="study-grid">
    {studies.map((s) => (
      <figure class="study-card">
        <a class="thumb" href={s.file} target="_blank" rel="noopener noreferrer" aria-label={`View the study "${s.name}" (opens in a new tab, a study, not the shipped site)`}>
          <img src={s.image} alt={`A screenshot of the "${s.name}" study — an earlier, static draft, not the shipped page.`} loading="lazy" width="900" height="633" />
        </a>
        <figcaption>
          <p class="eyebrow">{s.eyebrow}</p>
          <p class="name">{s.name}</p>
          <p class="tag">a study, not the shipped site</p>
          <p class="links">
            <a href={s.file} target="_blank" rel="noopener noreferrer">view the study →</a>
            {s.shippedHref && (
              <a href={s.shippedHref}>shipped: {s.shippedLabel} →</a>
            )}
          </p>
        </figcaption>
      </figure>
    ))}
  </div>
</details>
<style>
  .study-control { margin: 1.6rem 0 0; }
  .study-control summary {
    cursor: pointer; font-family: var(--serif); font-style: italic;
    font-size: 1.02rem; color: var(--ink-soft);
    padding: 0.2rem 0; list-style: none;
  }
  .study-control summary::-webkit-details-marker { display: none; }
  .study-control summary::before {
    content: "◦"; display: inline-block; margin-right: 0.5rem;
    color: var(--canopy-deep); transition: transform 0.15s ease;
  }
  .study-control[open] summary::before { transform: rotate(90deg); }
  .study-control summary:focus-visible { outline: 2px solid var(--poppy); outline-offset: 3px; }
  .control-intro {
    font-size: 0.86rem; color: var(--ink-faint); max-width: 40rem;
    margin: 0.6rem 0 1.2rem; line-height: 1.6;
  }
  .study-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem;
  }
  .study-card {
    margin: 0; background: var(--paper-deep);
    border: 1.1px solid var(--paper-edge); border-radius: 4px;
    overflow: hidden;
  }
  .study-card .thumb { display: block; }
  .study-card img { width: 100%; height: auto; display: block; border-bottom: 0.7px solid var(--paper-edge); }
  .study-card .thumb:focus-visible { outline: 2px solid var(--poppy); outline-offset: -2px; }
  .study-card figcaption { padding: 0.75rem 0.85rem 0.9rem; }
  .study-card .eyebrow {
    font-family: var(--sans); font-size: 0.64rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint); margin: 0 0 0.2rem;
  }
  .study-card .name {
    font-family: var(--display); font-style: italic; font-size: 0.98rem;
    color: var(--ink); margin: 0 0 0.3rem;
  }
  .study-card .tag {
    font-family: var(--sans); font-size: 0.68rem; color: var(--ink-faint);
    margin: 0 0 0.55rem;
  }
  .study-card .links { display: flex; flex-direction: column; gap: 0.3rem; margin: 0; }
  .study-card .links a {
    font-size: 0.78rem; color: var(--canopy-deep);
  }
  @media (max-width: 40rem) {
    .study-grid { grid-template-columns: 1fr; }
  }
</style>
