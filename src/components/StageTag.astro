---
/**
 * StageTag — a piece's growth stage, shown as a tiny ensō in the site
 * palette. Organised by maturity, never by date. Ring-closure is the state
 * signal (an open brush-gap reads as just-begun, a closed ring as settled):
 *   seedling  = wide-open ring, gold held bloom (tender, unsure)
 *   budding   = partial ring, lavender held bloom (taking shape)
 *   evergreen = closed ring, poppy held bloom (stands on its own)
 */
import EnkaMark from "./EnkaMark.astro";
import type { EnkaRing, EnkaAccent } from "./EnkaMark.astro";
interface Props { stage: "seedling" | "budding" | "evergreen"; tended?: string; }
const { stage, tended } = Astro.props;
const meta = {
  seedling:  { label: "seedling",  note: "just planted — tender, unsure" },
  budding:   { label: "budding",   note: "taking shape" },
  evergreen: { label: "evergreen", note: "stands on its own" },
}[stage];
const stageToRing: Record<Props["stage"], EnkaRing> = {
  seedling: "open",
  budding: "partial",
  evergreen: "closed",
};
const stageToAccent: Record<Props["stage"], EnkaAccent> = {
  seedling: "gold",
  budding: "lavender",
  evergreen: "poppy",
};
---
<span class={`stage stage--${stage}`} title={tended ? `${meta.note} · ${tended}` : meta.note}>
  <span class="mark" aria-hidden="true">
    <EnkaMark size={18} ring={stageToRing[stage]} hold="bloom" accent={stageToAccent[stage]} />
  </span>
  <span class="lbl">{meta.label}</span>
</span>
<style>
  /* Panel-language IA pass (2026-07-11): colour bumped ink-faint → ink-soft
     for WCAG AA at 0.68rem uppercase tracking. Quiet register held by size. */
  .stage {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-family: var(--sans); font-size: 0.68rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-soft);
  }
  .mark { line-height: 0; display: inline-flex; }
</style>
