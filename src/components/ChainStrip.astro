---
/**
 * ChainStrip — the workshop, and the ONLY place the dark, starry,
 * intimate skin lives (the rest of the site is warm Charts & Crafts paper).
 * This is the machine's room, v2-framed as a bench with apprentices: they
 * fetch, steady, and time the furnace; the gaffer's hands shape the glass.
 * Voice-locked — every piece starts from Rika's note and passes the mirror
 * (the one apprentice with the right to refuse, on four grounds) before it
 * grows. Assisted, never authored. Edges carry verbs (Law 2).
 * Honesty rule: never animate or imply a live agent — this strip describes
 * a practice, not a running process.
 */
import Glyph from "./Glyph.astro";
// The five apprentices, each carrying its own bloom in the palette.
// note → lavender lily (a voice arriving). pulse → pastel blue starflower
// (the edge, sharp and honest). tend → yellow bud (young structure).
// mirror → coral rose with cream heart (Rika's mark, the point of judgment,
// echoes the favicon). grow → mini canopy bed (the whole garden, in public).
const chain = [
  { key: "note",   job: "Rika writes",           edge: "gather" },
  { key: "pulse",  job: "scans the edge",        edge: "sharpen" },
  { key: "tend",   job: "structures, tightens",  edge: "guard" },
  { key: "mirror", job: "keeps voice & privacy", edge: "grow" },
  { key: "grow",   job: "in public",             edge: null },
] as const;
// a few deterministic stars (no Math.random at build time)
const stars = [[8,22],[19,64],[27,38],[36,80],[44,18],[53,58],[61,30],[70,72],[78,26],[86,54],[92,40],[14,44],[48,84],[66,14],[83,78]];
---
<section class="night" aria-label="How a piece is tended — the workshop">
  <div class="stars" aria-hidden="true">
    {stars.map(([x, y]) => <span style={`left:${x}%;top:${y}%`}></span>)}
  </div>
  <div class="inner">
    <p class="kick">the workshop</p>
    <h2 class="hero">A garden kept by a human hand,<br />tended alongside the machines.</h2>
    <p class="sub">The apprentices fetch, steady, and time the furnace; the hands that shape the glass are hers. The bench retrains too — what she keeps is the judgment.</p>

    <ol class="flow">
      {chain.map((n) => (
        <li class="node">
          <span class="g" class:list={[{ mir: n.key === "mirror" }]} aria-hidden="true">
            {n.key === "note" && (
              <svg width="26" height="26" viewBox="0 0 26 26">
                <g fill="#b899c9">
                  <ellipse cx="9" cy="9" rx="3.2" ry="4.8" transform="rotate(-30 9 9)"/>
                  <ellipse cx="17" cy="9" rx="3.2" ry="4.8" transform="rotate(30 17 9)"/>
                  <ellipse cx="13" cy="17" rx="3.2" ry="4.8"/>
                  <ellipse cx="8" cy="15" rx="3.2" ry="4.8" transform="rotate(70 8 15)"/>
                </g>
                <circle cx="13" cy="12" r="1.7" fill="#f7f2e7"/>
              </svg>
            )}
            {n.key === "pulse" && (
              <svg width="26" height="26" viewBox="0 0 26 26">
                <g fill="#a4b8c8"><path d="M13 3 L 14.5 9 L 20.5 9 L 15.5 13 L 17 19 L 13 15 L 9 19 L 10.5 13 L 5.5 9 L 11.5 9 Z"/></g>
                <circle cx="13" cy="12" r="1.7" fill="#f7f2e7"/>
              </svg>
            )}
            {n.key === "tend" && (
              <svg width="26" height="26" viewBox="0 0 26 26">
                <g fill="#e8c15a">
                  <ellipse cx="9" cy="11" rx="3" ry="4.8" transform="rotate(-25 9 11)"/>
                  <ellipse cx="17" cy="11" rx="3" ry="4.8" transform="rotate(25 17 11)"/>
                  <ellipse cx="13" cy="16" rx="3" ry="4.8"/>
                </g>
                <circle cx="13" cy="13" r="1.5" fill="#f7f2e7"/>
              </svg>
            )}
            {n.key === "mirror" && (
              <svg width="28" height="28" viewBox="0 0 26 26">
                <g fill="#e46b6b">
                  <path d="M13 3 C 15.7 3.6, 16.1 8.6, 13 10.6 C 9.9 8.6, 10.3 3.6, 13 3 Z"/>
                  <path d="M20 6 C 22.2 8.7, 20.3 12.9, 16.5 12.2 C 14.1 9.4, 16.9 5.3, 20 6 Z"/>
                  <path d="M17.4 16 C 14.9 18.6, 10.8 17.2, 12 13.4 C 14.7 11.6, 18 12.7, 17.4 16 Z"/>
                  <path d="M6.5 15.5 C 4.3 13, 6 9.6, 8.7 10.4 C 11.4 11.4, 10.8 16, 6.5 15.5 Z"/>
                  <path d="M4.6 6 C 7.9 5.4, 11 8, 9.5 11.5 C 5.8 12.2, 3 8, 4.6 6 Z"/>
                </g>
                <path d="M13 10.5 C 11.9 9, 9 9.2, 9 11.4 C 9 13.4, 13 15.1, 13 15.1 C 13 15.1, 17 13.4, 17 11.4 C 17 9.2, 14.1 9, 13 10.5 Z" fill="#f7f2e7"/>
              </svg>
            )}
            {n.key === "grow" && (
              <svg width="32" height="26" viewBox="0 0 34 26">
                <path d="M3 8 C 7 3, 13 2, 17 2.5 C 21 2, 27 3, 31 8" fill="none" stroke="#e8c15a" stroke-width="0.9" stroke-linecap="round"/>
                <circle cx="9" cy="13" r="2.2" fill="#b899c9"/>
                <circle cx="9" cy="13" r="0.8" fill="#f7f2e7"/>
                <circle cx="17" cy="13" r="2.2" fill="#e46b6b"/>
                <circle cx="17" cy="13" r="0.8" fill="#f7f2e7"/>
                <circle cx="25" cy="13" r="2.2" fill="#a4b8c8"/>
                <circle cx="25" cy="13" r="0.8" fill="#f7f2e7"/>
                <path d="M4.5 18 C 4.3 20, 4.4 21.6, 4.7 22.5 L 29.3 22.5 C 29.6 21.6, 29.7 20, 29.5 18 C 21 17.5, 13 17.5, 4.5 18 Z" fill="#e8c15a" opacity="0.75"/>
              </svg>
            )}
          </span>
          <span class="k">{n.key}</span>
          <span class="j">{n.job}</span>
          {n.edge && <span class="edge" aria-hidden="true"><span class="v">{n.edge}</span><Glyph name="arrow" size={18} /></span>}
        </li>
      ))}
    </ol>

    <p class="lock">
      Every piece starts from a note in Rika&rsquo;s own hand and passes the
      <em>mirror</em> — the one apprentice with the right to refuse — before it
      grows in public. It will hold a piece back on four grounds only:
    </p>
    <ul class="refuse" aria-label="The four grounds on which the mirror refuses">
      <li>a privacy leak</li>
      <li>a voice that isn&rsquo;t hers</li>
      <li>a wall that must hold — things this garden does not write about</li>
      <li>a claim outrunning what is known</li>
    </ul>
    <p class="lock">
      The machines keep the scaffold — the feeds, the plumbing, the link that
      doesn&rsquo;t rot; the turn of an essay, the curation, and the yes stay in her hands.
      <span class="say">Assisted, never authored. Nothing is published without her yes.</span>
    </p>
  </div>
</section>
<style>
  .night {
    position: relative; overflow: hidden;
    background: var(--night); color: var(--night-ink);
    margin-top: 4rem; padding: 3.2rem 0 3rem;
  }
  .stars { position: absolute; inset: 0; pointer-events: none; }
  .stars span {
    position: absolute; width: 2px; height: 2px; border-radius: 50%;
    background: var(--gold); opacity: 0.5;
    box-shadow: 0 0 3px var(--gold);
    animation: twinkle 6s ease-in-out infinite;
  }
  .stars span:nth-child(3n) { animation-duration: 9s; opacity: 0.35; }
  .stars span:nth-child(4n) { animation-delay: -3s; background: var(--night-ink); }
  @keyframes twinkle { 0%,100% { opacity: 0.2; } 50% { opacity: 0.6; } }

  .inner { position: relative; max-width: var(--page); margin-inline: auto; padding-inline: var(--gutter); }
  .kick { font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--gold); }
  .hero {
    font-family: var(--display); font-optical-sizing: auto;
    font-style: italic; font-weight: 460; color: var(--night-ink);
    font-size: clamp(1.5rem, 3.6vw, 2.4rem); line-height: 1.24;
    letter-spacing: -0.01em; margin: 0.9rem 0 0; max-width: 24ch;
  }

  .flow { list-style: none; margin: 2rem 0 0; padding: 0; display: flex; flex-wrap: wrap; align-items: flex-start; gap: 0.4rem 0.2rem; }
  .node { display: grid; grid-template-columns: auto auto; grid-template-rows: auto auto; column-gap: 0.5rem; align-items: center; padding: 0.5rem 0.2rem; }
  .node .g { grid-row: 1 / span 2; color: var(--gold); line-height: 0; }
  .node .g.mir { color: var(--bloom); }
  .node .k { font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--night-ink); }
  .node .j { font-family: var(--hand); font-size: 1.05rem; color: var(--night-dim); line-height: 1; grid-column: 2; }
  .edge { display: inline-flex; align-items: center; gap: 0.25rem; margin: 0 0.55rem; align-self: center; grid-row: 1 / span 2; grid-column: 3; color: var(--night-dim); }
  .edge .v { font-family: var(--hand); font-size: 0.95rem; color: var(--gold); }
  .edge :global(svg) { opacity: 0.6; }
  .edge :global(svg path) { stroke: var(--night-dim); }

  .sub { font-family: var(--serif); font-style: italic; font-size: 1.02rem; color: var(--night-dim); margin: 1rem 0 0; max-width: 50ch; line-height: 1.55; letter-spacing: 0; }

  .lock { font-size: 0.92rem; color: var(--night-dim); margin-top: 1.4rem; max-width: 60ch; }
  .lock + .refuse + .lock { margin-top: 1rem; }
  .lock em { font-style: normal; color: var(--bloom); }
  .lock .say { display: block; font-family: var(--hand); font-size: 1.15rem; color: var(--gold); margin-top: 0.3rem; }

  .refuse { list-style: none; margin: 0.7rem 0 0; padding: 0; max-width: 60ch; }
  .refuse li { font-family: var(--hand); font-size: 1.08rem; color: var(--night-dim); line-height: 1.55; padding-left: 0.9rem; }
  .refuse li::before { content: "·"; color: var(--gold); opacity: 0.7; margin-left: -0.9rem; padding-right: 0.55rem; }

  @media (max-width: 46rem) {
    .flow { flex-direction: column; align-items: stretch; }
    .edge { display: none; }
    .node { border-left: 1.4px solid var(--night-line); padding-left: 0.7rem; }
  }
</style>
