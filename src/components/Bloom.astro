---
/**
 * Bloom — the home hero mark, redrawn to sprout FROM BEHIND the signature
 * text rather than sit above it as a card. Stems root from the bottom edge,
 * curl up, and blooms crown around the h1: three peek above the top line
 * (lavender · coral · blue), and a yellow bud peeks from below the last
 * line. Composition kept symmetrical enough to preserve title alignment,
 * loose enough to read organic.
 * Marimekko lineage warmed toward Margiela Replica "From the Garden".
 */
interface Props { size?: number; }
const { size = 780 } = Astro.props;
---
<svg width={size} viewBox="0 0 800 300" class="bloom" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
  <path d="M200 290 Q 195 240, 205 180 Q 195 130, 210 90 Q 205 75, 210 65" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.55" stroke-linecap="round"/>
  <path d="M600 290 Q 605 240, 595 180 Q 605 130, 590 90 Q 595 75, 590 65" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.55" stroke-linecap="round"/>
  <path d="M400 290 Q 402 220, 398 150 Q 400 100, 400 55" stroke="#4f5b3f" stroke-width="1.15" fill="none" opacity="0.65" stroke-linecap="round"/>
  <path d="M400 290 Q 402 270, 400 250" stroke="#4f5b3f" stroke-width="1" fill="none" opacity="0.55" stroke-linecap="round"/>

  <path d="M195 175 C 188 170, 178 173, 182 182 C 190 187, 200 182, 195 175 Z" fill="#4f5b3f" opacity="0.32"/>
  <path d="M605 175 C 612 170, 622 173, 618 182 C 610 187, 600 182, 605 175 Z" fill="#4f5b3f" opacity="0.32"/>
  <path d="M402 180 C 395 175, 385 178, 389 187 C 397 192, 407 187, 402 180 Z" fill="#4f5b3f" opacity="0.3"/>
  <path d="M400 220 C 407 215, 417 218, 413 227 C 405 232, 395 227, 400 220 Z" fill="#4f5b3f" opacity="0.3"/>

  <g transform="translate(210 60)">
    <g fill="#b899c9">
      <ellipse cx="-7" cy="-3" rx="7" ry="10" transform="rotate(-30 -7 -3)"/>
      <ellipse cx="7" cy="-3" rx="7" ry="10" transform="rotate(30 7 -3)"/>
      <ellipse cx="0" cy="8" rx="7" ry="10"/>
      <ellipse cx="-7" cy="5" rx="7" ry="10" transform="rotate(70 -7 5)"/>
    </g>
    <circle cx="0" cy="1" r="3.4" fill="#f7f2e7"/>
  </g>

  <g transform="translate(590 62)">
    <g fill="#a4b8c8">
      <path d="M0 -14 L 3 -5 L 12 -5 L 5 1 L 8 10 L 0 5 L -8 10 L -5 1 L -12 -5 L -3 -5 Z"/>
    </g>
    <circle cx="0" cy="-1" r="3.2" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 50)">
    <g fill="#e46b6b">
      <path d="M0 -16 C 6 -15, 7 -4, 0 2 C -7 -4, -6 -15, 0 -16 Z"/>
      <path d="M15 -7 C 17 1, 10 10, 3 7 C 0 -2, 8 -9, 15 -7 Z"/>
      <path d="M9 13 C 0 17, -8 10, -3 4 C 5 -1, 13 4, 9 13 Z"/>
      <path d="M-11 10 C -17 4, -13 -5, -5 -3 C -3 4, -7 11, -11 10 Z"/>
      <path d="M-14 -5 C -9 -12, -1 -10, -1 -4 C -4 3, -16 3, -14 -5 Z"/>
    </g>
    <path d="M0 0 C -3 -3, -7 -1, -7 2 C -7 6, 0 8, 0 8 C 0 8, 7 6, 7 2 C 7 -1, 3 -3, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 248)">
    <g fill="#e8c15a">
      <ellipse cx="-4" cy="-2" rx="4.5" ry="7" transform="rotate(-25 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4.5" ry="7" transform="rotate(25 4 -2)"/>
      <ellipse cx="0" cy="5" rx="4.5" ry="7"/>
    </g>
    <circle cx="0" cy="0" r="2.4" fill="#f7f2e7"/>
  </g>

  <g transform="translate(140 200)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="5" transform="rotate(-25)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="5" transform="rotate(25)"/>
    </g>
    <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
    <path d="M140 205 Q 145 250, 140 290" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.4" stroke-linecap="round" transform="translate(-140 -200)"/>
  </g>

  <g transform="translate(660 210)">
    <g fill="#b899c9">
      <ellipse cx="-3" cy="-1" rx="3.5" ry="5" transform="rotate(-25)"/>
      <ellipse cx="3" cy="-1" rx="3.5" ry="5" transform="rotate(25)"/>
      <ellipse cx="0" cy="4" rx="3.5" ry="5"/>
    </g>
    <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
    <path d="M660 215 Q 655 255, 660 290" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.4" stroke-linecap="round" transform="translate(-660 -210)"/>
  </g>

  <circle cx="150" cy="285" r="1.2" fill="#e46b6b"/>
  <circle cx="240" cy="290" r="1" fill="#b899c9"/>
  <circle cx="310" cy="288" r="1" fill="#e8c15a"/>
  <circle cx="380" cy="292" r="1" fill="#a4b8c8"/>
  <circle cx="420" cy="290" r="1" fill="#b899c9"/>
  <circle cx="490" cy="288" r="1" fill="#e8c15a"/>
  <circle cx="560" cy="290" r="1" fill="#e46b6b"/>
  <circle cx="650" cy="285" r="1.2" fill="#a4b8c8"/>

  <path d="M180 165 L 180 168 M186 166 L 186 169 M192 165 L 192 168" stroke="#4f5b3f" stroke-width="0.5" opacity="0.45" stroke-linecap="round"/>
  <path d="M608 165 L 608 168 M614 166 L 614 169 M620 165 L 620 168" stroke="#4f5b3f" stroke-width="0.5" opacity="0.45" stroke-linecap="round"/>
</svg>
<style>
  .bloom { display: block; height: auto; overflow: visible; width: 100%; max-width: 100%; }
</style>
