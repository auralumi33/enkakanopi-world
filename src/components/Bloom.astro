---
/**
 * Bloom — the home hero mark, split into two strips so the h1 text has
 * clean paper behind it.
 *   .crown : sits in the .signature-garden padding-top zone (above h1).
 *            3 crown blooms + bokeh halos + tendrils + loose petals.
 *   .floor : sits in the padding-bottom zone (below h1).
 *            2 buds + tiny sailboats + veined leaves + berry clusters.
 * Nothing renders behind the reading. Handcrafted register preserved
 * from the Maison Margiela Replica pass.
 */
interface Props { size?: number; }
const { size = 780 } = Astro.props;
---
<svg class="crown" width={size} viewBox="0 0 800 60" aria-hidden="true" preserveAspectRatio="xMidYMax meet">
  <circle cx="60" cy="16" r="3" fill="#e8c15a" opacity="0.14"/>
  <circle cx="60" cy="16" r="0.9" fill="#e8c15a"/>
  <circle cx="112" cy="22" r="0.7" fill="#e46b6b"/>
  <circle cx="245" cy="14" r="2.6" fill="#a4b8c8" opacity="0.14"/>
  <circle cx="245" cy="14" r="0.8" fill="#a4b8c8"/>
  <circle cx="332" cy="22" r="0.7" fill="#b899c9"/>
  <circle cx="470" cy="14" r="3" fill="#e8c15a" opacity="0.14"/>
  <circle cx="470" cy="14" r="0.9" fill="#e8c15a"/>
  <circle cx="555" cy="22" r="2.6" fill="#e46b6b" opacity="0.14"/>
  <circle cx="555" cy="22" r="0.8" fill="#e46b6b"/>
  <circle cx="692" cy="14" r="0.7" fill="#b899c9"/>
  <circle cx="775" cy="22" r="0.9" fill="#e8c15a"/>

  <path d="M105 28 Q 109 23, 112 28 Q 114 34, 110 36" stroke="#4f5b3f" stroke-width="0.5" fill="none" opacity="0.5" stroke-linecap="round"/>
  <path d="M340 30 Q 345 24, 348 30 Q 350 36, 346 38" stroke="#4f5b3f" stroke-width="0.5" fill="none" opacity="0.5" stroke-linecap="round"/>
  <path d="M700 28 Q 705 23, 708 28 Q 710 34, 706 36" stroke="#4f5b3f" stroke-width="0.5" fill="none" opacity="0.5" stroke-linecap="round"/>

  <ellipse cx="220" cy="34" rx="2" ry="3.2" transform="rotate(15 220 34)" fill="#b899c9" opacity="0.5"/>
  <ellipse cx="380" cy="38" rx="1.8" ry="3" transform="rotate(-10 380 38)" fill="#e46b6b" opacity="0.5"/>
  <ellipse cx="605" cy="34" rx="2" ry="3.2" transform="rotate(20 605 34)" fill="#e8c15a" opacity="0.5"/>
  <ellipse cx="750" cy="36" rx="1.8" ry="3" transform="rotate(-15 750 36)" fill="#a4b8c8" opacity="0.5"/>

  <g transform="translate(160 50)">
    <g fill="#b899c9">
      <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-30 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(30 4 -2)"/>
      <ellipse cx="0" cy="4" rx="4" ry="6"/>
      <ellipse cx="-4" cy="3" rx="4" ry="6" transform="rotate(70 -4 3)"/>
    </g>
    <circle cx="0" cy="1" r="2" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 48)">
    <g fill="#e46b6b">
      <path d="M0 -9 C 4 -8, 4.5 -2, 0 1 C -4.5 -2, -4 -8, 0 -9 Z"/>
      <path d="M8 -4 C 10 1, 6 6, 2 4 C 0 -1, 5 -5, 8 -4 Z"/>
      <path d="M5 8 C 0 10, -5 7, -1 3 C 4 -1, 8 3, 5 8 Z"/>
      <path d="M-7 6 C -10 3, -8 -2, -3 -1 C -1 3, -4 7, -7 6 Z"/>
      <path d="M-9 -2 C -6 -7, -1 -6, -1 -2 C -3 2, -10 2, -9 -2 Z"/>
    </g>
    <path d="M0 0 C -2 -2, -4 -1, -4 1 C -4 3, 0 5, 0 5 C 0 5, 4 3, 4 1 C 4 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <g transform="translate(640 52)">
    <g fill="#a4b8c8">
      <path d="M0 -8 L 1.7 -2.5 L 6 -2.5 L 2.5 0.5 L 4 6 L 0 3 L -4 6 L -2.5 0.5 L -6 -2.5 L -1.7 -2.5 Z"/>
    </g>
    <circle cx="0" cy="0" r="2" fill="#f7f2e7"/>
  </g>
</svg>

<svg class="floor" width={size} viewBox="0 0 800 60" aria-hidden="true" preserveAspectRatio="xMidYMin meet">
  <path d="M50 20 Q 200 14, 400 16 Q 600 14, 750 20" stroke="#4f5b3f" stroke-width="0.5" fill="none" opacity="0.35" stroke-linecap="round"/>

  <g transform="translate(160 20)">
    <path d="M-4 3 Q 0 4.3, 4 3" stroke="#4f5b3f" stroke-width="0.65" fill="none" opacity="0.55" stroke-linecap="round"/>
    <path d="M0 3 L 0 -4" stroke="#4f5b3f" stroke-width="0.5" opacity="0.55"/>
    <path d="M0 -4 L 0 1.6 L 3.5 1.6 Z" fill="#4f5b3f" opacity="0.36"/>
  </g>

  <g transform="translate(620 19)">
    <path d="M-4 3 Q 0 4.3, 4 3" stroke="#4f5b3f" stroke-width="0.65" fill="none" opacity="0.55" stroke-linecap="round"/>
    <path d="M0 3 L 0 -5" stroke="#4f5b3f" stroke-width="0.5" opacity="0.55"/>
    <path d="M0 -5 L 0 1.6 L 4 1.6 Z" fill="#4f5b3f" opacity="0.36"/>
  </g>

  <g transform="translate(280 24)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 22)">
    <g fill="#e46b6b">
      <ellipse cx="-2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="0" cy="2" rx="2" ry="3"/>
    </g>
    <circle cx="0" cy="1" r="0.9" fill="#f7f2e7"/>
  </g>

  <g transform="translate(520 24)">
    <g fill="#b899c9">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-30 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(30 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <ellipse cx="90" cy="10" rx="2" ry="3" transform="rotate(-15 90 10)" fill="#e8c15a" opacity="0.5"/>
  <ellipse cx="700" cy="12" rx="2" ry="3" transform="rotate(20 700 12)" fill="#b899c9" opacity="0.5"/>

  <g transform="translate(50 40)">
    <path d="M-4 0 Q 0 -3, 4 0 Q 0 3, -4 0 Z" fill="#4f5b3f" opacity="0.35"/>
    <path d="M-4 0 L 4 0" stroke="#4f5b3f" stroke-width="0.35" opacity="0.55"/>
  </g>
  <g transform="translate(220 44)">
    <path d="M-4 0 Q 0 -3, 4 0 Q 0 3, -4 0 Z" fill="#4f5b3f" opacity="0.35"/>
    <path d="M-4 0 L 4 0" stroke="#4f5b3f" stroke-width="0.35" opacity="0.55"/>
  </g>
  <g transform="translate(350 44)">
    <path d="M-4 0 Q 0 -3, 4 0 Q 0 3, -4 0 Z" fill="#4f5b3f" opacity="0.35"/>
    <path d="M-4 0 L 4 0" stroke="#4f5b3f" stroke-width="0.35" opacity="0.55"/>
  </g>
  <g transform="translate(560 44)">
    <path d="M-4 0 Q 0 -3, 4 0 Q 0 3, -4 0 Z" fill="#4f5b3f" opacity="0.35"/>
    <path d="M-4 0 L 4 0" stroke="#4f5b3f" stroke-width="0.35" opacity="0.55"/>
  </g>
  <g transform="translate(750 40)">
    <path d="M-4 0 Q 0 -3, 4 0 Q 0 3, -4 0 Z" fill="#4f5b3f" opacity="0.35"/>
    <path d="M-4 0 L 4 0" stroke="#4f5b3f" stroke-width="0.35" opacity="0.55"/>
  </g>

  <g opacity="0.55">
    <circle cx="130" cy="50" r="1" fill="#e46b6b"/>
    <circle cx="136" cy="53" r="0.9" fill="#e46b6b"/>
    <circle cx="142" cy="50" r="1" fill="#e46b6b"/>
  </g>
  <g opacity="0.55">
    <circle cx="690" cy="50" r="0.9" fill="#e8c15a"/>
    <circle cx="695" cy="53" r="0.9" fill="#e8c15a"/>
    <circle cx="700" cy="50" r="0.9" fill="#e8c15a"/>
  </g>

  <circle cx="450" cy="52" r="0.7" fill="#a4b8c8"/>
  <circle cx="600" cy="54" r="0.7" fill="#b899c9"/>
</svg>
<style>
  .crown, .floor {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    overflow: visible;
  }
</style>
