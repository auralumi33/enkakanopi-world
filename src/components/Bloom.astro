---
/**
 * Bloom — the home hero mark, pared to the essential crown + floor blooms.
 * Everything else in the whispered-garden vocabulary (bokeh halos, tendrils,
 * loose petals, berry clusters, character leaves, sailboats) now lives in
 * BotanicalScatter strips between sections — spread across the whole page
 * rather than crowding the h1.
 */
interface Props { size?: number; }
const { size = 780 } = Astro.props;
---
<svg class="crown" width={size} viewBox="0 0 800 40" aria-hidden="true" preserveAspectRatio="xMidYMax meet">
  <g transform="translate(160 32)">
    <g fill="#b899c9">
      <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-30 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(30 4 -2)"/>
      <ellipse cx="0" cy="4" rx="4" ry="6"/>
      <ellipse cx="-4" cy="3" rx="4" ry="6" transform="rotate(70 -4 3)"/>
    </g>
    <circle cx="0" cy="1" r="2" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 30)">
    <g fill="#e46b6b">
      <path d="M0 -9 C 4 -8, 4.5 -2, 0 1 C -4.5 -2, -4 -8, 0 -9 Z"/>
      <path d="M8 -4 C 10 1, 6 6, 2 4 C 0 -1, 5 -5, 8 -4 Z"/>
      <path d="M5 8 C 0 10, -5 7, -1 3 C 4 -1, 8 3, 5 8 Z"/>
      <path d="M-7 6 C -10 3, -8 -2, -3 -1 C -1 3, -4 7, -7 6 Z"/>
      <path d="M-9 -2 C -6 -7, -1 -6, -1 -2 C -3 2, -10 2, -9 -2 Z"/>
    </g>
    <path d="M0 0 C -2 -2, -4 -1, -4 1 C -4 3, 0 5, 0 5 C 0 5, 4 3, 4 1 C 4 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <g transform="translate(640 34)">
    <g fill="#a4b8c8">
      <path d="M0 -8 L 1.7 -2.5 L 6 -2.5 L 2.5 0.5 L 4 6 L 0 3 L -4 6 L -2.5 0.5 L -6 -2.5 L -1.7 -2.5 Z"/>
    </g>
    <circle cx="0" cy="0" r="2" fill="#f7f2e7"/>
  </g>
</svg>

<svg class="floor" width={size} viewBox="0 0 800 40" aria-hidden="true" preserveAspectRatio="xMidYMin meet">
  <g transform="translate(280 12)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <g transform="translate(520 12)">
    <g fill="#b899c9">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-30 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(30 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>
</svg>
<style>
  .crown, .floor {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    overflow: visible;
  }
</style>
