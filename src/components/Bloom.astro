---
/**
 * Bloom — the home hero mark as a handcrafted constellation, warmed in
 * the direction of Maison Margiela Replica (Under the Stars · Flower
 * Market · Never-ending Summer): tactile detail, layered depth, and the
 * soft bokeh-glow of a memory captured. Composition bones untouched from
 * the last pass — still 5 crown blooms + mid clusters + sailboats + leaves
 * + stars. Added: tendril vines, loose falling petals, berry clusters,
 * character leaves with a centre vein, and bokeh-halo sprinkles.
 */
interface Props { size?: number; }
