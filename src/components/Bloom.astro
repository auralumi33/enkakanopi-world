---
/**
 * Bloom — the home hero mark. Formerly a two-part crown+floor bloom scatter
 * bracketing the h1; now one small EnkaMark medallion (the ensō ring +
 * one held bloom), watermarked behind the signature the same way the
 * scatter was — faint, z-index -1, decoration only (parent `.sprout` is
 * itself `aria-hidden`, so EnkaMark's own title never reaches AT).
 */
import EnkaMark from "./EnkaMark.astro";
interface Props { size?: number; }
const { size = 220 } = Astro.props;
---
<EnkaMark size={size} ring="closed" />
