---
/**
 * Bloom — the home hero mark as a constellation.
 * Top crown: three blooms (lavender · coral · blue) at the h1 top edge.
 * Bottom crown: two buds (yellow · lavender) at the h1 bottom edge.
 * Between them, a mid-band filled with a delicate scatter — small bud
 * clusters in the palette, three whisper sailboats (echoing the keystone's
 * "small convoy of selves… sailing water"), tiny botanical leaves, and a
 * dozen sprinkle-stars. Every element sized to whisper.
 */
interface Props { size?: number; }
const { size = 780 } = Astro.props;
---
<svg width={size} viewBox="0 0 800 240" class="bloom" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
  <g transform="translate(160 24)">
    <g fill="#b899c9">
      <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-30 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(30 4 -2)"/>
      <ellipse cx="0" cy="4" rx="4" ry="6"/>
      <ellipse cx="-4" cy="3" rx="4" ry="6" transform="rotate(70 -4 3)"/>
    </g>
    <circle cx="0" cy="1" r="2" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 22)">
    <g fill="#e46b6b">
      <path d="M0 -9 C 4 -8, 4.5 -2, 0 1 C -4.5 -2, -4 -8, 0 -9 Z"/>
      <path d="M8 -4 C 10 1, 6 6, 2 4 C 0 -1, 5 -5, 8 -4 Z"/>
      <path d="M5 8 C 0 10, -5 7, -1 3 C 4 -1, 8 3, 5 8 Z"/>
      <path d="M-7 6 C -10 3, -8 -2, -3 -1 C -1 3, -4 7, -7 6 Z"/>
      <path d="M-9 -2 C -6 -7, -1 -6, -1 -2 C -3 2, -10 2, -9 -2 Z"/>
    </g>
    <path d="M0 0 C -2 -2, -4 -1, -4 1 C -4 3, 0 5, 0 5 C 0 5, 4 3, 4 1 C 4 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <g transform="translate(640 26)">
    <g fill="#a4b8c8">
      <path d="M0 -8 L 1.7 -2.5 L 6 -2.5 L 2.5 0.5 L 4 6 L 0 3 L -4 6 L -2.5 0.5 L -6 -2.5 L -1.7 -2.5 Z"/>
    </g>
    <circle cx="0" cy="0" r="2" fill="#f7f2e7"/>
  </g>

  <g transform="translate(90 95)">
    <g fill="#b899c9">
      <ellipse cx="-2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="0" cy="2" rx="2" ry="3"/>
    </g>
    <circle cx="0" cy="1" r="0.9" fill="#f7f2e7"/>
  </g>

  <g transform="translate(305 90)">
    <g fill="#e8c15a">
      <ellipse cx="-2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="2" cy="-1" rx="2" ry="3"/>
    </g>
    <circle cx="0" cy="0" r="0.85" fill="#f7f2e7"/>
  </g>

  <g transform="translate(505 100)">
    <g fill="#e46b6b">
      <ellipse cx="-2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="2" cy="-1" rx="2" ry="3"/>
      <ellipse cx="0" cy="2" rx="2" ry="3"/>
    </g>
    <circle cx="0" cy="1" r="0.9" fill="#f7f2e7"/>
  </g>

  <g transform="translate(725 95)">
    <g fill="#a4b8c8">
      <path d="M0 -5 L 1 -1.5 L 4 -1.5 L 1.6 0.5 L 2.5 4 L 0 2 L -2.5 4 L -1.6 0.5 L -4 -1.5 L -1 -1.5 Z"/>
    </g>
    <circle cx="0" cy="0" r="0.85" fill="#f7f2e7"/>
  </g>

  <g transform="translate(200 130)">
    <path d="M-4.5 2 Q 0 3.5, 4.5 2" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.6" stroke-linecap="round"/>
    <path d="M0 2 L 0 -5.5" stroke="#4f5b3f" stroke-width="0.5" opacity="0.6"/>
    <path d="M0 -5.5 L 0 0.8 L 4 0.8 Z" fill="#4f5b3f" opacity="0.38"/>
  </g>

  <g transform="translate(400 150)">
    <path d="M-5 2 Q 0 3.8, 5 2" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.65" stroke-linecap="round"/>
    <path d="M0 2 L 0 -6" stroke="#4f5b3f" stroke-width="0.55" opacity="0.65"/>
    <path d="M0 -6 L 0 1 L 4.5 1 Z" fill="#4f5b3f" opacity="0.42"/>
  </g>

  <g transform="translate(620 128)">
    <path d="M-4 2 Q 0 3.3, 4 2" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.6" stroke-linecap="round"/>
    <path d="M0 2 L 0 -5" stroke="#4f5b3f" stroke-width="0.5" opacity="0.6"/>
    <path d="M0 -5 L 0 0.5 L 3.5 0.5 Z" fill="#4f5b3f" opacity="0.38"/>
  </g>

  <path d="M60 165 Q 64 162, 68 165 Q 64 168, 60 165 Z" fill="#4f5b3f" opacity="0.35"/>
  <path d="M245 170 Q 249 167, 253 170 Q 249 173, 245 170 Z" fill="#4f5b3f" opacity="0.35"/>
  <path d="M460 168 Q 464 165, 468 168 Q 464 171, 460 168 Z" fill="#4f5b3f" opacity="0.35"/>
  <path d="M570 170 Q 574 167, 578 170 Q 574 173, 570 170 Z" fill="#4f5b3f" opacity="0.35"/>
  <path d="M735 168 Q 739 165, 743 168 Q 739 171, 735 168 Z" fill="#4f5b3f" opacity="0.35"/>

  <g transform="translate(280 214)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <g transform="translate(520 216)">
    <g fill="#b899c9">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-30 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(30 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <circle cx="55" cy="60" r="0.9" fill="#e8c15a"/>
  <circle cx="145" cy="70" r="0.7" fill="#e46b6b"/>
  <circle cx="235" cy="60" r="0.8" fill="#a4b8c8"/>
  <circle cx="365" cy="70" r="0.7" fill="#b899c9"/>
  <circle cx="450" cy="60" r="0.9" fill="#e8c15a"/>
  <circle cx="565" cy="70" r="0.8" fill="#e46b6b"/>
  <circle cx="685" cy="60" r="0.7" fill="#b899c9"/>
  <circle cx="775" cy="70" r="0.9" fill="#e8c15a"/>

  <circle cx="130" cy="155" r="0.7" fill="#e46b6b"/>
  <circle cx="355" cy="120" r="0.8" fill="#e8c15a"/>
  <circle cx="440" cy="185" r="0.9" fill="#b899c9"/>
  <circle cx="580" cy="105" r="0.7" fill="#a4b8c8"/>
  <circle cx="675" cy="180" r="0.8" fill="#e46b6b"/>
  <circle cx="750" cy="145" r="0.7" fill="#e8c15a"/>
</svg>
<style>
  .bloom { display: block; height: auto; overflow: visible; width: 100%; max-width: 100%; }
</style>
