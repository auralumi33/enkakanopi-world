---
/**
 * Bloom — the home hero mark, seen from above. A top-down bird's-eye of the
 * garden bed: lavender lily + pastel blue starflower on the north row, a
 * yellow bud at the heart of the plot (the nursery of dreams), a coral rose
 * in the south-east (Rika's mark, from the favicon), a pastel blue bud in
 * the south-west, a tender yellow sprout at the north-east. Curling stems,
 * a faint grid, dainty sprinkles between the blooms.
 * Marimekko lineage, hand-drawn wobble. Palette locked to the site family.
 */
interface Props { size?: number; }
const { size = 220 } = Astro.props;
---
<svg width={size} viewBox="0 0 260 200" class="bloom" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
  <rect x="18" y="18" width="224" height="164" rx="4" fill="#efe8d6" stroke="#4f5b3f" stroke-width="1.4"/>
  <path d="M18 66 Q 130 67, 242 66" stroke="#4f5b3f" stroke-width="0.4" opacity="0.25" fill="none"/>
  <path d="M18 118 Q 130 119, 242 118" stroke="#4f5b3f" stroke-width="0.4" opacity="0.25" fill="none"/>
  <path d="M92 18 Q 93 100, 92 182" stroke="#4f5b3f" stroke-width="0.4" opacity="0.25" fill="none"/>
  <path d="M168 18 Q 169 100, 168 182" stroke="#4f5b3f" stroke-width="0.4" opacity="0.25" fill="none"/>

  <path d="M65 60 Q 95 90, 78 125 Q 68 150, 100 158" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.5"/>
  <path d="M180 55 Q 158 90, 175 118 Q 190 148, 165 158" stroke="#4f5b3f" stroke-width="0.7" fill="none" opacity="0.5"/>

  <!-- lavender lily, north-west -->
  <g transform="translate(65 60)">
    <g fill="#b899c9">
      <ellipse cx="-7" cy="-3" rx="7" ry="10" transform="rotate(-30 -7 -3)"/>
      <ellipse cx="7" cy="-3" rx="7" ry="10" transform="rotate(30 7 -3)"/>
      <ellipse cx="0" cy="8" rx="7" ry="10"/>
      <ellipse cx="-7" cy="5" rx="7" ry="10" transform="rotate(70 -7 5)"/>
    </g>
    <circle cx="0" cy="1" r="3.4" fill="#f7f2e7"/>
  </g>

  <!-- pastel blue starflower, north-east -->
  <g transform="translate(175 55)">
    <g fill="#a4b8c8">
      <path d="M0 -14 L 3 -5 L 12 -5 L 5 1 L 8 10 L 0 5 L -8 10 L -5 1 L -12 -5 L -3 -5 Z"/>
    </g>
    <circle cx="0" cy="-1" r="3.2" fill="#f7f2e7"/>
  </g>

  <!-- yellow tender bud, centre (the nursery of dreams) -->
  <g transform="translate(130 100)">
    <g fill="#e8c15a">
      <ellipse cx="-4" cy="-2" rx="4.5" ry="7" transform="rotate(-25 -4 -2)"/>
      <ellipse cx="4" cy="-2" rx="4.5" ry="7" transform="rotate(25 4 -2)"/>
      <ellipse cx="0" cy="5" rx="4.5" ry="7"/>
    </g>
    <circle cx="0" cy="0" r="2.4" fill="#f7f2e7"/>
  </g>

  <!-- pastel blue small bud, south-west -->
  <g transform="translate(78 145)">
    <g fill="#a4b8c8">
      <ellipse cx="-4" cy="0" rx="4" ry="6" transform="rotate(-25)"/>
      <ellipse cx="4" cy="0" rx="4" ry="6" transform="rotate(25)"/>
      <ellipse cx="0" cy="5" rx="4" ry="6"/>
    </g>
    <circle cx="0" cy="0" r="2.2" fill="#f7f2e7"/>
  </g>

  <!-- coral rose, south-east — the maker's mark (echoes favicon) -->
  <g transform="translate(175 145)">
    <g fill="#e46b6b">
      <path d="M0 -14 C 5 -13, 6 -3, 0 1 C -6 -3, -5 -13, 0 -14 Z"/>
      <path d="M13 -6 C 15 1, 8 9, 2 6 C 0 -2, 7 -8, 13 -6 Z"/>
      <path d="M7 11 C 0 15, -7 9, -2 3 C 4 -1, 11 3, 7 11 Z"/>
      <path d="M-10 8 C -15 3, -11 -5, -4 -2 C -2 3, -6 9, -10 8 Z"/>
      <path d="M-12 -4 C -8 -11, -1 -9, -1 -3 C -4 3, -14 2, -12 -4 Z"/>
    </g>
    <path d="M0 0 C -3 -3, -6 -1, -6 2 C -6 5, 0 8, 0 8 C 0 8, 6 5, 6 2 C 6 -1, 3 -3, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <!-- tender yellow sprout, top-right corner -->
  <g transform="translate(210 32)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="5" transform="rotate(-25)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="5" transform="rotate(25)"/>
    </g>
    <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
  </g>

  <circle cx="120" cy="42" r="1.1" fill="#b899c9"/>
  <circle cx="128" cy="48" r="0.9" fill="#e8c15a"/>
  <circle cx="115" cy="52" r="0.9" fill="#a4b8c8"/>
  <circle cx="45" cy="98" r="1" fill="#e46b6b"/>
  <circle cx="215" cy="100" r="1.1" fill="#b899c9"/>
  <circle cx="220" cy="105" r="0.8" fill="#e8c15a"/>
  <circle cx="125" cy="150" r="1" fill="#b899c9"/>
  <circle cx="132" cy="156" r="0.9" fill="#a4b8c8"/>
  <circle cx="38" cy="160" r="0.9" fill="#e8c15a"/>
  <circle cx="228" cy="170" r="0.9" fill="#e46b6b"/>

  <path d="M108 100 Q 103 97, 100 101 Q 104 105, 108 100 Z" fill="#4f5b3f" opacity="0.7"/>
  <path d="M152 100 Q 157 97, 160 101 Q 156 105, 152 100 Z" fill="#4f5b3f" opacity="0.7"/>
</svg>
<style>
  .bloom { display: block; height: auto; overflow: visible; }
</style>
