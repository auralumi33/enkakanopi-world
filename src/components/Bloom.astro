---
/**
 * Bloom — the home hero mark, refined to a delicate constellation.
 * Blooms live at the TOP and BOTTOM edges of the h1's rendered area,
 * with dainty sprinkles scattered through the middle like stars.
 * No long vertical stems cutting through the text — the composition
 * respects the reading. Marimekko lineage warmed toward Margiela
 * Replica "From the Garden".
 */
interface Props { size?: number; }
const { size = 780 } = Astro.props;
---
<svg width={size} viewBox="0 0 800 260" class="bloom" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
  <g transform="translate(200 32)">
    <g fill="#b899c9">
      <ellipse cx="-5" cy="-2" rx="5" ry="7" transform="rotate(-30 -5 -2)"/>
      <ellipse cx="5" cy="-2" rx="5" ry="7" transform="rotate(30 5 -2)"/>
      <ellipse cx="0" cy="5" rx="5" ry="7"/>
      <ellipse cx="-5" cy="4" rx="5" ry="7" transform="rotate(70 -5 4)"/>
    </g>
    <circle cx="0" cy="1" r="2.4" fill="#f7f2e7"/>
  </g>

  <g transform="translate(400 30)">
    <g fill="#e46b6b">
      <path d="M0 -11 C 5 -10, 5 -3, 0 1 C -5 -3, -5 -10, 0 -11 Z"/>
      <path d="M10 -5 C 12 1, 7 7, 2 5 C 0 -1, 5 -6, 10 -5 Z"/>
      <path d="M6 9 C 0 12, -6 8, -2 3 C 4 -1, 9 3, 6 9 Z"/>
      <path d="M-8 7 C -12 3, -9 -3, -3 -2 C -1 3, -5 8, -8 7 Z"/>
      <path d="M-10 -3 C -6 -8, -1 -7, -1 -3 C -3 2, -11 2, -10 -3 Z"/>
    </g>
    <path d="M0 0 C -2 -2, -5 -1, -5 1 C -5 4, 0 6, 0 6 C 0 6, 5 4, 5 1 C 5 -1, 2 -2, 0 0 Z" fill="#f7f2e7"/>
  </g>

  <g transform="translate(600 34)">
    <g fill="#a4b8c8">
      <path d="M0 -10 L 2 -3 L 8 -3 L 3 1 L 5 7 L 0 4 L -5 7 L -3 1 L -8 -3 L -2 -3 Z"/>
    </g>
    <circle cx="0" cy="0" r="2.4" fill="#f7f2e7"/>
  </g>

  <g transform="translate(60 210)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="0" r="1.6" fill="#f7f2e7"/>
  </g>

  <g transform="translate(280 226)">
    <g fill="#b899c9">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-30 -3 -1)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(30 3 -1)"/>
      <ellipse cx="0" cy="4" rx="3" ry="4.5"/>
    </g>
    <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
  </g>

  <g transform="translate(500 224)">
    <g fill="#e8c15a">
      <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25)"/>
      <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25)"/>
    </g>
    <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
  </g>

  <g transform="translate(730 218)">
    <path d="M0 -6 L 1.4 -2 L 5 -2 L 2 0.5 L 3.5 5 L 0 2 L -3.5 5 L -2 0.5 L -5 -2 L -1.4 -2 Z" fill="#a4b8c8"/>
    <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
  </g>

  <circle cx="100" cy="55" r="0.9" fill="#e8c15a"/>
  <circle cx="145" cy="80" r="0.7" fill="#b899c9"/>
  <circle cx="310" cy="60" r="0.8" fill="#e46b6b"/>
  <circle cx="350" cy="90" r="0.7" fill="#a4b8c8"/>
  <circle cx="470" cy="55" r="0.8" fill="#b899c9"/>
  <circle cx="530" cy="85" r="0.7" fill="#e8c15a"/>
  <circle cx="680" cy="65" r="0.9" fill="#e46b6b"/>
  <circle cx="720" cy="95" r="0.7" fill="#b899c9"/>

  <circle cx="130" cy="130" r="0.7" fill="#a4b8c8"/>
  <circle cx="250" cy="140" r="0.8" fill="#e8c15a"/>
  <circle cx="400" cy="145" r="0.7" fill="#b899c9"/>
  <circle cx="560" cy="135" r="0.8" fill="#e46b6b"/>
  <circle cx="680" cy="140" r="0.7" fill="#a4b8c8"/>

  <circle cx="160" cy="180" r="0.7" fill="#b899c9"/>
  <circle cx="230" cy="195" r="0.9" fill="#e8c15a"/>
  <circle cx="380" cy="185" r="0.7" fill="#a4b8c8"/>
  <circle cx="440" cy="200" r="0.8" fill="#e46b6b"/>
  <circle cx="610" cy="190" r="0.7" fill="#e8c15a"/>
  <circle cx="660" cy="200" r="0.7" fill="#b899c9"/>

  <path d="M240 45 C 244 42, 249 42, 252 45 C 249 49, 244 49, 240 45 Z" fill="#4f5b3f" opacity="0.28"/>
  <path d="M550 42 C 554 39, 559 39, 562 42 C 559 46, 554 46, 550 42 Z" fill="#4f5b3f" opacity="0.28"/>
  <path d="M340 232 C 344 229, 349 229, 352 232 C 349 236, 344 236, 340 232 Z" fill="#4f5b3f" opacity="0.28"/>
  <path d="M580 232 C 584 229, 589 229, 592 232 C 589 236, 584 236, 580 232 Z" fill="#4f5b3f" opacity="0.28"/>
</svg>
<style>
  .bloom { display: block; height: auto; overflow: visible; width: 100%; max-width: 100%; }
</style>
