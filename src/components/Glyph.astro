---
/**
 * Glyph — the tiny hand-drawn mark language (section markers, list bullets).
 * Each mark either guides the eye or encodes a relationship, or it is cut (Law 8).
 * Slight wobble is hand-set per path, not a filter — warmth = imperfection (§3).
 */
interface Props {
  name: "leaf" | "canopy" | "seam" | "spine" | "compass" | "light" | "arrow";
  size?: number;
  accent?: boolean;
  label?: string;
}
const { name, size = 22, accent = false, label } = Astro.props;
const stroke = accent ? "var(--poppy)" : "var(--ink)";
---
<svg
  width={size} height={size} viewBox="0 0 24 24"
  fill="none" aria-hidden={label ? undefined : "true"}
  role={label ? "img" : undefined}
  class="glyph"
  style={`--gs:${stroke}`}
>
  {label && <title>{label}</title>}
  {name === "leaf" && (
    <>
      <path d="M4.2 19.6 C 5 12.5, 11 5.4, 19.7 4.1 C 19.2 12.8, 12.6 19.1, 4.2 19.6 Z" />
      <path d="M6.6 17.4 C 10.1 13.8, 14 9.9, 17.9 6.3" />
    </>
  )}
  {name === "canopy" && (
    <>
      <path d="M3.4 14.6 C 4 9.8, 8.1 6.2, 12 6.4 C 15.9 6.6, 19.6 10.1, 20.4 14.8" />
      <path d="M6.9 14.2 C 7.5 11.1, 9.6 9, 12 9.1" />
      <path d="M11.9 15 C 13 12, 15.4 10.2, 17.6 10.9" />
      <path d="M12 16.6 L 12 20.4" />
    </>
  )}
  {name === "seam" && (
    <path d="M2.6 14.4 C 6 9.2, 9.4 18.6, 12.6 12.8 C 15.4 7.8, 18.4 17.4, 21.6 11.2"
          stroke-dasharray="0.2 3.4" />
  )}
  {name === "spine" && (
    <>
      <path d="M12 3.2 C 10.6 7, 13.4 10.4, 11.8 14 C 10.4 17.2, 12.8 19.2, 12 21" />
      <path d="M9.3 6.1 L 14.5 5.4 M9 10.2 L 14.8 9.6 M9.2 14.1 L 14.6 13.6 M9.6 17.9 L 14.2 17.6" class="hair" />
    </>
  )}
  {name === "compass" && (
    <>
      <path d="M12 3.4 C 16.9 3.5, 20.6 7.4, 20.5 12.2 C 20.4 16.9, 16.4 20.6, 11.7 20.4 C 7 20.2, 3.4 16.2, 3.6 11.6 C 3.8 7.1, 7.4 3.7, 12 3.4 Z" />
      <path d="M8.6 15.6 L 12.4 7.8 L 15.2 15 L 12.1 12.9 Z" />
    </>
  )}
  {name === "light" && (
    <>
      <path d="M12 2.6 L 12 6 M5.4 5 L 7.6 7.6 M18.7 5.2 L 16.4 7.7 M3 12.4 L 6 12.2 M21 12.2 L 18 12.2" class="hair" />
      <path d="M8.4 15.4 C 9 12.9, 15.1 12.7, 15.8 15.3 C 16.4 17.8, 8 18, 8.4 15.4 Z" />
    </>
  )}
  {name === "arrow" && (
    <path d="M3.4 12.3 C 8 11.6, 14 12.8, 19.6 11.9 M15.6 8.4 C 17.6 10, 19.4 11, 20.6 11.8 C 19 12.9, 17.2 14.4, 15.9 16.2" />
  )}
</svg>
<style>
  .glyph :global(path) {
    stroke: var(--gs);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  .glyph :global(.hair) { stroke-width: 0.9; opacity: 0.85; }
  .glyph { display: inline-block; vertical-align: middle; }
</style>
