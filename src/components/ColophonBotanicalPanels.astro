            <path d="M 0 -3 C 1.5 -2.5, 2 -0.7, 0 -0.15 C -2 -0.7, -1.5 -2.5, 0 -3 Z"/>
            <path d="M 2.4 -0.8 C 3 0.9, 1.5 2, 0.4 1.3 C 0 -0.15, 1.4 -1.6, 2.4 -0.8 Z"/>
            <path d="M 1.5 2 C 0 2.5, -1.5 1.2, -0.5 0 C 1 -0.7, 2.4 0.5, 1.5 2 Z"/>
            <path d="M -2 1 C -3 -0.5, -2 -1.8, -0.5 -1 C 0 0, -1 1.9, -2 1 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.1" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.5 -0.1 C -0.3 0.1, 0.3 0.1, 0.5 -0.1" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
      <p class="panel-cap">the hand that means it · smile at the tip</p>
    </div>

    <div class="panel">
      <p class="panel-label">金 · gold</p>
      <p class="panel-jp">the seal</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c6-t"><title id="c6-t">The maker's-mark wax seal with a hidden smile in the flower heart</title>
        <path d="M 100 70 C 116 68, 126 78, 126 92 C 126 107, 116 118, 100 118 C 84 118, 74 108, 72 94 C 70 80, 84 71, 100 70 Z" fill="var(--poppy)" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
