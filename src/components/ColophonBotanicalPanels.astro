    </div>

    <div class="panel">
      <p class="panel-label">珊瑚 · coral</p>
      <p class="panel-jp">the covenant</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c7-t"><title id="c7-t">Two hands hand-over-hand — the covenant made picture — with a coral bloom smile</title>
        <path d="M 20 160 C 55 156, 145 156, 180 160 C 182 163, 182 178, 180 180 C 145 182, 55 182, 20 180 C 18 178, 18 163, 20 160 Z" fill="var(--paper-washi)" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.35"/>
        <line x1="28" y1="165" x2="120" y2="164" stroke="var(--ink-soft)" stroke-width="0.3" opacity="0.35"/>
        <line x1="28" y1="171" x2="110" y2="170" stroke="var(--ink-soft)" stroke-width="0.3" opacity="0.35"/>
        <path d="M 95 170 C 103 168, 111 165, 117 160" stroke="var(--ink-soft)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.6"/>
        <line x1="118" y1="152" x2="178" y2="60" stroke="var(--bamboo)" stroke-width="6" stroke-linecap="round" opacity="0.9"/>
        <line x1="118" y1="152" x2="178" y2="60" stroke="var(--ink-soft)" stroke-width="0.4" opacity="0.4"/>
        <line x1="113" y1="157" x2="121" y2="163" stroke="var(--ink-soft)" stroke-width="2" stroke-linecap="round"/>
        <path d="M 113 157 L 100 170 L 108 168 Z" fill="var(--ink-soft)" opacity="0.9"/>
        <g transform="translate(125 138)">
