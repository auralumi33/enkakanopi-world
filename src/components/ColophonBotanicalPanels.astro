          <path d="M -6 -2 C -3 -10, 0 -14, 3 -14 C 6 -14, 7 -10, 5 -6 C 4 -3, 3 -1, 2 0" fill="var(--skin)" opacity="0.92" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
          <path d="M 4 -1 C 7 -6, 10 -8, 13 -6 C 15 -3, 14 0, 12 2" fill="var(--skin)" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linejoin="round"/>
          <path d="M 12 2 C 16 4, 19 6, 20 10 C 20 14, 18 15, 16 14" fill="var(--skin)" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.45" stroke-linejoin="round"/>
