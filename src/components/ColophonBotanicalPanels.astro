          <path d="M -8 -5 C -16 -12, -22 -4, -14 2 C -10 5, -8 5, -4 2" fill="var(--skin)" opacity="0.94" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
          <path d="M -4 -5 C -2 -12, 2 -18, 4 -18 C 6 -18, 8 -14, 6 -8 C 4 -4, 2 -2, 0 -2" fill="var(--skin)" opacity="0.94" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
          <path d="M 6 -3 C 8 -8, 12 -12, 14 -8 C 15 -4, 14 -2, 12 -1" fill="var(--skin)" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linejoin="round"/>
          <path d="M 24 18 C 30 28, 36 38, 42 48" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.7"/>
        </g>
        <g transform="translate(145 115) rotate(-10)">
          <path d="M -18 -4 C -22 2, -20 12, -10 14 C 4 15, 18 12, 22 4 C 23 -1, 20 -8, 16 -8 L -14 -8 Z" fill="var(--skin-deep)" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linejoin="round"/>
          <path d="M -18 -4 C -22 -2, -24 4, -20 8 C -16 10, -12 8, -10 6" fill="var(--skin-deep)" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
          <path d="M -4 14 C -5 20, -5 22, -4 24" stroke="var(--ink-soft)" stroke-width="0.45" fill="var(--skin-deep)" fill-opacity="0.85" stroke-linejoin="round"/>
          <path d="M 4 14 C 3 20, 3 22, 4 24" stroke="var(--ink-soft)" stroke-width="0.45" fill="var(--skin-deep)" fill-opacity="0.85" stroke-linejoin="round"/>
          <path d="M 12 12 C 11 18, 11 20, 12 22" stroke="var(--ink-soft)" stroke-width="0.42" fill="var(--skin-deep)" fill-opacity="0.85" stroke-linejoin="round"/>
          <path d="M 20 -6 C 28 -12, 34 -18, 42 -24" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" opacity="0.7"/>
        </g>
        <g transform="translate(78 172)">
          <g fill="#e08d84" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round">
            <path d="M 0 -3.4 C 2 -2.8, 2.6 -0.7, 0 -0.15 C -2.6 -0.7, -2 -2.8, 0 -3.4 Z"/>
