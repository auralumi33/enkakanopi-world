---
/**
 * ColophonBotanicalPanels — Set 3 slice-2.4 · 2026-07-09
 * Twelve panels for the Colophon, arranged as three rows of four telling the full brand-story
 * triptych: (Row 1) What holds the garden — the plot · the canopy · the 円花 ensō · the
 * provenance target — adapted from the shipped inline visuals so all panels share one visual
 * language. (Row 2) How it's made — the hand (v3 · full 5-finger sumi-e grip) · the seal
 * (maker's-mark) · the covenant (v4 · hand-over-hand teacher-student transmission) · the mirror
 * (reviewer's veto register). (Row 3) The retraining — the small hand (picking up brush again)
 * · the first mark (joyful mess) · the wobbly ensō (tremors + ghost strokes + tiny hopeful mark)
 * · the trust (prominent multi-pastel bloom + red 王 seal). Each panel with a hidden closed-eye
 * smile. Unified grammar: hairline ink-soft strokes 0.55–0.7, minimal border, subject-centred,
 * Japanese kanji + English label + italic caption. Anchored to shipped voice:
 * "assisted, never authored — nothing is published without her yes."
 */
---
<figure class="botanical-panels botanical-panels--colophon" aria-label="Twelve Colophon panels — the brand story in three acts">
  <!-- Row 1 · What holds the garden -->
  <p class="row-title">Row 1 · What holds the garden</p>
  <div class="panels-grid">
    <div class="panel">
      <p class="panel-label">紫 · lavender</p>
      <p class="panel-jp">the plot</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c1-t"><title id="c1-t">Sprouts in a dashed boundary plot with a lavender bloom smile</title>
        <path d="M 40 130 C 42 128, 100 126, 160 128 C 162 130, 162 168, 160 170 C 158 172, 100 172, 40 170 C 38 168, 38 130, 40 130 Z" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" stroke-linecap="round" stroke-dasharray="2 3" opacity="0.75"/>
        <g stroke="var(--ink-soft)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.85">
          <line x1="70" y1="165" x2="70" y2="140"/>
          <line x1="95" y1="165" x2="95" y2="132"/>
          <line x1="118" y1="165" x2="118" y2="140"/>
          <line x1="140" y1="165" x2="140" y2="130"/>
        </g>
        <g fill="var(--canopy-soft)" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.35" stroke-linejoin="round">
          <path d="M 70 150 C 64 148, 60 152, 62 156 C 66 155, 70 153, 70 150 Z"/>
          <path d="M 95 140 C 101 138, 105 142, 103 146 C 99 145, 95 143, 95 140 Z"/>
          <path d="M 118 148 C 112 146, 108 150, 110 154 C 114 153, 118 151, 118 148 Z"/>
        </g>
        <g transform="translate(140 128)">
          <g fill="#b899c9" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round">
            <path d="M0 -3 C 1.5 -2.5, 2 -0.7, 0 -0.15 C -2 -0.7, -1.5 -2.5, 0 -3 Z"/>
            <path d="M 2.4 -0.8 C 3 0.9, 1.5 2, 0.4 1.3 C 0 -0.15, 1.4 -1.6, 2.4 -0.8 Z"/>
            <path d="M 1.5 2 C 0 2.5, -1.5 1.2, -0.5 0 C 1 -0.7, 2.4 0.5, 1.5 2 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.1" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.5 -0.1 C -0.3 0.05, 0.3 0.05, 0.5 -0.1" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
        </g>
        <line x1="40" y1="172" x2="160" y2="172" stroke="var(--ink-soft)" stroke-width="0.5" opacity="0.55"/>
      </svg>
      <p class="panel-cap">a plot kept · noise stays out · smile in the bloom</p>
    </div>

    <div class="panel">
      <p class="panel-label">金 · gold</p>
      <p class="panel-jp">the canopy</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c2-t"><title id="c2-t">Three canopy arches with pastel blooms and a hidden smile</title>
        <path d="M 20 155 C 20 100, 90 100, 90 155" stroke="var(--canopy)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.75"/>
        <path d="M 60 155 C 60 90, 140 90, 140 155" stroke="var(--canopy)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.75"/>
        <path d="M 110 155 C 110 100, 180 100, 180 155" stroke="var(--canopy)" stroke-width="0.85" fill="none" stroke-linecap="round" opacity="0.75"/>
        <circle cx="55" cy="118" r="4" fill="var(--canopy-soft)" opacity="0.7"/>
        <circle cx="100" cy="98" r="5" fill="#b899c9" opacity="0.7"/>
        <circle cx="140" cy="110" r="4" fill="#e8c15a" opacity="0.7"/>
        <circle cx="75" cy="85" r="1.2" fill="#b899c9" opacity="0.65"/>
        <circle cx="130" cy="80" r="1" fill="#a4b8c8" opacity="0.65"/>
        <circle cx="170" cy="112" r="1.2" fill="#e8c15a" opacity="0.7"/>
        <line x1="20" y1="155" x2="180" y2="155" stroke="var(--ink-soft)" stroke-width="0.5" opacity="0.6"/>
        <g transform="translate(102 100)">
          <circle cx="0" cy="0" r="1.5" fill="#e8c15a" opacity="0.9"/>
