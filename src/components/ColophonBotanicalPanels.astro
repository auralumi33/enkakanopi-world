        <circle cx="100" cy="100" r="32" stroke="var(--canopy)" stroke-width="0.7" fill="none" opacity="0.7"/>
        <circle cx="100" cy="100" r="14" stroke="var(--ink-soft)" stroke-width="0.65" fill="none" opacity="0.7"/>
        <g transform="translate(100 100)">
          <circle cx="0" cy="0" r="3.2" fill="#e08d84" opacity="0.9"/>
          <path d="M -0.7 -0.1 C -0.4 0.15, 0.4 0.15, 0.7 -0.1" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
          <circle cx="-0.9" cy="-0.9" r="0.28" fill="var(--ink-soft)" opacity="0.85"/>
          <circle cx="0.9" cy="-0.9" r="0.28" fill="var(--ink-soft)" opacity="0.85"/>
        </g>
        <circle cx="100" cy="48" r="1.4" fill="#b899c9" opacity="0.72"/>
        <circle cx="152" cy="100" r="1.4" fill="#e8c15a" opacity="0.72"/>
        <circle cx="100" cy="152" r="1.4" fill="#a4b8c8" opacity="0.72"/>
        <circle cx="48" cy="100" r="1.4" fill="#e08d84" opacity="0.72"/>
        <text font-family="var(--hand)" x="100" y="188" font-size="8.5" text-anchor="middle" opacity="0.65" font-style="italic" fill="var(--ink-soft)">summer 07/2026 · tended by Fang Rika</text>
      </svg>
      <p class="panel-cap">provenance held · four grounds circled</p>
    </div>
  </div>

  <!-- Row 2 · How it's made -->
  <p class="row-title">Row 2 · How it's made</p>
  <div class="panels-grid">
    <div class="panel">
      <p class="panel-label">紫 · lavender</p>
      <p class="panel-jp">the hand</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c5-t"><title id="c5-t">A hand gripping a vertical sumi-e brush with all five fingers visible</title>
        <g transform="translate(105 -10)">
