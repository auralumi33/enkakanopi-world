        <path d="M 98 90 L 98 78" stroke="var(--canopy)" stroke-width="0.55" stroke-linecap="round" opacity="0.75"/>
        <path d="M 94 82 L 90 78" stroke="var(--canopy)" stroke-width="0.4" stroke-linecap="round" opacity="0.65"/>
        <path d="M 102 82 L 106 78" stroke="var(--canopy)" stroke-width="0.4" stroke-linecap="round" opacity="0.65"/>
        <path d="M 90 78 C 88 76, 88 74, 90 75 C 91 76, 91 78, 90 78 Z" fill="var(--canopy-soft)" opacity="0.75"/>
        <path d="M 106 78 C 108 76, 108 74, 106 75 C 105 76, 105 78, 106 78 Z" fill="var(--canopy-soft)" opacity="0.75"/>
        <g transform="translate(98 72)">
