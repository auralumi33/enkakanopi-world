    </div>

    <div class="panel">
      <p class="panel-label">青 · slate</p>
      <p class="panel-jp">the mirror</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c8-t"><title id="c8-t">A hand-held mirror reflecting a small smile</title>
        <ellipse cx="100" cy="90" rx="42" ry="52" fill="#a4b8c8" opacity="0.20" stroke="var(--ink-soft)" stroke-width="0.65"/>
        <ellipse cx="100" cy="90" rx="34" ry="44" fill="none" stroke="var(--ink-soft)" stroke-width="0.4" opacity="0.55"/>
        <path d="M 100 142 C 98 155, 96 172, 96 185 C 100 185, 104 185, 104 185 C 104 172, 102 155, 100 142 Z" fill="#a4b8c8" opacity="0.5" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round"/>
        <g transform="translate(100 88)">
          <g fill="#e08d84" opacity="0.85" stroke="var(--ink-soft)" stroke-width="0.28" stroke-linejoin="round">
            <path d="M 0 -6 C 3.3 -5, 4.2 -1.2, 0 -0.3 C -4.2 -1.2, -3.3 -5, 0 -6 Z"/>
