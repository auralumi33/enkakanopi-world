          </g>
          <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.6 -0.1 C -0.35 0.15, 0.35 0.15, 0.6 -0.1" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
      <p class="panel-cap">the mirror agent · smile in what it reflects</p>
    </div>
  </div>

  <!-- Row 3 · The retraining -->
  <p class="row-title">Row 3 · The retraining</p>
  <div class="panels-grid">
    <div class="panel">
      <p class="panel-label">紫 · lavender</p>
      <p class="panel-jp">the small hand</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c9-t"><title id="c9-t">A small child's hand picking up a paintbrush with a hopeful lavender mark below</title>
        <line x1="60" y1="165" x2="155" y2="65" stroke="var(--bamboo)" stroke-width="5.5" stroke-linecap="round" opacity="0.88"/>
        <line x1="60" y1="165" x2="155" y2="65" stroke="var(--ink-soft)" stroke-width="0.4" opacity="0.45"/>
        <line x1="56" y1="169" x2="64" y2="176" stroke="var(--ink-soft)" stroke-width="1.8" stroke-linecap="round"/>
