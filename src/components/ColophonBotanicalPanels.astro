        <g transform="translate(100 93)">
          <g fill="#e8c15a" opacity="0.85">
            <path d="M 0 -3 C 1.5 -2.5, 2 -0.8, 0 -0.2 C -2 -0.8, -1.5 -2.5, 0 -3 Z"/>
            <path d="M 2.5 -0.8 C 3 0.8, 1.5 2, 0.3 1.4 C 0 -0.2, 1.4 -1.6, 2.5 -0.8 Z"/>
            <path d="M 1.5 2 C 0 2.5, -1.5 1.2, -0.5 0 C 1 -0.7, 2.5 0.6, 1.5 2 Z"/>
            <path d="M -2 1 C -3 -0.5, -2 -1.8, -0.5 -1 C 0 0, -1 1.9, -2 1 Z"/>
          </g>
          <path d="M -0.6 -0.1 C -0.35 0.15, 0.35 0.15, 0.6 -0.1" stroke="var(--poppy)" stroke-width="0.32" fill="none" stroke-linecap="round"/>
        </g>
        <text font-family="var(--hand)" x="100" y="140" font-size="9" text-anchor="middle" opacity="0.7" font-style="italic" fill="var(--ink-soft)">the garden · summer 07/ 2026</text>
        <text font-family="var(--hand)" x="100" y="153" font-size="8" text-anchor="middle" opacity="0.6" font-style="italic" fill="var(--ink-soft)">tended by Fang Rika ·</text>
      </svg>
