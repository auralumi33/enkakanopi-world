        </g>
        <circle cx="98" cy="34" r="1.4" fill="#b899c9" opacity="0.7"/>
        <circle cx="175" cy="108" r="1.4" fill="#e8c15a" opacity="0.7"/>
        <circle cx="98" cy="180" r="1.4" fill="#a4b8c8" opacity="0.7"/>
        <circle cx="22" cy="108" r="1.4" fill="#e08d84" opacity="0.7"/>
      </svg>
      <p class="panel-cap">円花 keystone · flower held in the circle</p>
    </div>

    <div class="panel">
      <p class="panel-label">青 · slate</p>
      <p class="panel-jp">the provenance</p>
      <svg viewBox="0 0 200 200" role="img" aria-labelledby="c4-t"><title id="c4-t">A target with three concentric rings and four cardinal orbit dots</title>
