        </g>
        <g transform="translate(105 145)">
          <path d="M -22 8 C -26 18, -22 30, -10 32 C 6 34, 20 30, 24 18 C 26 10, 22 4, 18 2 L -16 2 Z" fill="var(--skin)" opacity="0.92" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linejoin="round"/>
