---
/**
 * CanopyFromAbove — the garden, painted from above (the homepage hero).
 *
 * Ported from GARDEN-SCULPT/canopy-home-map.html (Rika's own study) into a
 * self-contained, prop-driven component: surfaces + tokens are inputs, nothing
 * venture-specific is hardcoded in the logic below, so the shape of this piece
 * (one crown, N wayfinding masses, one core) can be reused wherever a garden
 * needs a painted map, not just this one.
 *
 * Fixed from the study: the nine leaf-masses were spaced at 360/7 (a leftover
 * from an earlier seven-surface draft), which is why two pairs of labels
 * overlapped (top and right). Spacing is now 360/n — even, collision-free —
 * plus a label-anchor flip (masses right of centre carry their label to the
 * right; left of centre, to the left; near-vertical masses centre their
 * label) so long names never run into a neighbour.
 *
 * Motion: everything is static except one falling blossom (mono no aware,
 * Charter §2 #8b) — an ambient, slow, restrained loop, confined to the
 * SVG's own bounds. `prefers-reduced-motion` removes it entirely (the
 * script never starts the loop; no reduced-motion listener is needed at
 * runtime since the check runs once on load).
 */
import MaturityBud from "./motifs/MaturityBud.astro";

interface Room {
  slug: string;
  href: string;
  name: string;
  /** short form for the on-canopy label, when `name` is too long to sit on the crown */
  label?: string;
  register: string;
  maturity: "seedling" | "budding" | "evergreen";
  blurb: string;
}
interface Props {
  rooms: readonly Room[];
  headingId: string;
  eyebrow?: string;
  heading?: string;
  intro?: string;
}
const {
  rooms,
  headingId,
  eyebrow = "the living map",
  heading = "the garden, from above",
  intro = "Nine surfaces grow from one crown. Their size and light here are an illustrative sketch, not a measurement — move over a leaf-mass to feel it stir; this is a place, not a menu.",
} = Astro.props;

const CX = 470, CY = 320;
const N = rooms.length;
const MAT_SIZE: Record<Room["maturity"], number> = { seedling: 46, budding: 54, evergreen: 60 };
---

<figure class="canopy-figure" id={`${headingId}-root`} data-canopy>
  <figcaption class="head">
    <p class="eyebrow">{eyebrow}</p>
    <h2 id={headingId}>{heading}</h2>
    <p class="lede">{intro}</p>
  </figcaption>

  <div class="mapbox" data-mapbox>
    {/* No role="img" here: the crown carries real, independently-focusable
        <a> links for the nine rooms, and an img role tells assistive tech to
        treat the whole graphic as flat — which can swallow those nested
        links' own semantics (axe: nested-interactive). aria-labelledby/
        -describedby still name and describe the whole figure either way. */}
    <svg
      viewBox="0 0 940 640"
      aria-labelledby={`${headingId}-svg-t`}
      aria-describedby={`${headingId}-svg-d`}
    >
      <title id={`${headingId}-svg-t`}>The garden seen from above — nine leaf-masses growing from one crown, each a door to a room.</title>
      <desc id={`${headingId}-svg-d`}>
        {rooms.map((r) => r.name).join(" · ")}. Each is a real link to its room.
      </desc>
      <defs>
        <filter id={`${headingId}-rough`} x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.014" numOctaves="2" seed="3" result="n" />
          <feDisplacementMap in="SourceGraphic" in2="n" scale="9" />
        </filter>
        <filter id={`${headingId}-brush`} x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" seed="7" result="t" />
          <feDisplacementMap in="SourceGraphic" in2="t" scale="6" />
        </filter>
        <radialGradient id={`${headingId}-sun`} cx="50%" cy="45%" r="60%">
          <stop offset="0%" stop-color="var(--paper-washi)" stop-opacity="0.9" />
          <stop offset="100%" stop-color="var(--paper-washi)" stop-opacity="0" />
        </radialGradient>
        <radialGradient id={`${headingId}-crown`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="var(--canopy-soft)" stop-opacity="0.55" />
          <stop offset="62%" stop-color="var(--canopy)" stop-opacity="0.32" />
          <stop offset="100%" stop-color="var(--canopy-deep)" stop-opacity="0" />
        </radialGradient>
      </defs>

      {/* notan — layered translucent crown mass, built once server-side so no
          client script is needed just to paint the still parts of the scene */}
      <g filter={`url(#${headingId}-rough)`} data-crown-rings></g>
      <circle cx={CX} cy={CY} r="150" fill={`url(#${headingId}-sun)`} opacity="0.7" />
      <g data-dapple aria-hidden="true"></g>
      <g data-branches aria-hidden="true"></g>
      <g data-masses></g>

      {/* the 円 core — the ensō, preserved as the painted canopy's centre
          (Charter §2 #2): "the container and the light" */}
      <g data-enso-core>
        <g filter={`url(#${headingId}-brush)`} fill="none" stroke="var(--ink-soft)" stroke-linecap="round">
          <g data-enso-strokes></g>
          <circle data-enso-start r="7" fill="var(--ink-soft)" stroke="none" opacity="0.6" />
        </g>
        <circle cx={CX} cy={CY} r="34" fill="var(--paper)" stroke="var(--canopy-deep)" stroke-width="1.4" opacity="0.94" />
        <text x={CX} y={CY + 9} text-anchor="middle" class="core-kanji">円</text>
      </g>

      {/* the one governed exception — a single falling blossom, ambient and
          slow; the script below never starts it if reduced-motion is set */}
      <path data-blossom d="M0 0 C 4 -6 12 -6 8 2 C 12 8 4 8 0 4 C -4 8 -12 8 -8 2 C -12 -6 -4 -6 0 0 Z" fill="var(--poppy-soft)" opacity="0" aria-hidden="true" />
    </svg>
    <div class="leaf-tip" data-leaf-tip role="status" aria-hidden="true">
      <div class="n" data-tip-n></div>
      <div class="m" data-tip-m></div>
      <div class="l" data-tip-l></div>
    </div>
  </div>
  <p class="core-caption">円 · the container and the light</p>

  {/* Hidden bud templates — the one source of the maturity glyphs (shared
      with the growth-stages list) is MaturityBud.astro; the client script
      below clones the matching stage as a nested <svg> per room, instead
      of duplicating the path data in JS. */}
  <template data-bud="seedling"><MaturityBud stage="seedling" size={22} stem={false} /></template>
  <template data-bud="budding"><MaturityBud stage="budding" size={22} stem={false} /></template>
  <template data-bud="evergreen"><MaturityBud stage="evergreen" size={22} stem={false} /></template>
</figure>

<script define:vars={{ rooms, CX, CY, N, MAT_SIZE, rootId: `${headingId}-root` }}>
(function () {
  // document.currentScript is unreliable for Astro's define:vars scripts
  // (they run as-if-inline, but not always with currentScript set on
  // multi-instance pages) — same fix GraphCanvas.astro already uses:
  // a stable id + direct lookup instead of walking up from the script tag.
  const root = document.getElementById(rootId);
  if (!root) return;
  const svg = root.querySelector("svg");
  const gRings = root.querySelector("[data-crown-rings]");
  const gDapple = root.querySelector("[data-dapple]");
  const gBranches = root.querySelector("[data-branches]");
  const gMasses = root.querySelector("[data-masses]");
  const tip = root.querySelector("[data-leaf-tip]");
  const mapbox = root.querySelector("[data-mapbox]");
  const NS = "http://www.w3.org/2000/svg";
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function el(tag, attrs) {
    const e = document.createElementNS(NS, tag);
    for (const k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }

  // deterministic pseudo-random — stable across renders, no Math.random drift
  let seed = 20260713;
  function rnd() {
    seed = (seed * 1103515245 + 12345) & 0x7fffffff;
    return seed / 0x7fffffff;
  }

  function blob(rBase, fill, opacity) {
    const pts = [];
    const M = 34;
    for (let i = 0; i < M; i++) {
      const a = (i / M) * Math.PI * 2;
      const rr = rBase * (0.82 + rnd() * 0.32);
      pts.push([CX + Math.cos(a) * rr, CY + Math.sin(a) * rr]);
    }
    let d = `M${pts[0][0].toFixed(1)} ${pts[0][1].toFixed(1)}`;
    for (let i = 1; i <= M; i++) {
      const p0 = pts[i - 1], p1 = pts[i % M];
      const mx = (p0[0] + p1[0]) / 2, my = (p0[1] + p1[1]) / 2;
      d += `Q${p0[0].toFixed(1)} ${p0[1].toFixed(1)} ${mx.toFixed(1)} ${my.toFixed(1)}`;
    }
    d += "Z";
    return el("path", { d, fill, opacity });
  }

  // notan — three concentric, uneven translucent masses (dark/light mass,
  // not a flat fill), plus a bolder outer ring so the crown reads as paint
  const crownGradId = root.querySelector("radialGradient[id$='-crown']").id;
  gRings.appendChild(blob(300, `url(#${crownGradId})`, 0.92));
  gRings.appendChild(blob(248, "var(--canopy-soft)", 0.4));
  gRings.appendChild(blob(196, "var(--canopy)", 0.32));

  // dapple — light falling through the weave (static; no opacity animation)
  for (let i = 0; i < 12; i++) {
    const r = 18 + rnd() * 44, a = rnd() * Math.PI * 2, rad = rnd() * 260;
    const x = CX + Math.cos(a) * rad, y = CY + Math.sin(a) * rad * 0.9;
    const sunId = root.querySelector("radialGradient[id$='-sun']").id;
    gDapple.appendChild(el("circle", { cx: x.toFixed(1), cy: y.toFixed(1), r: r.toFixed(1), fill: `url(#${sunId})`, opacity: (0.16 + rnd() * 0.26).toFixed(2) }));
  }

  // nine leaf-masses, evenly spaced (the 360/N fix), each a real link
  const masses = [];
  rooms.forEach((room, i) => {
    const angle = (-90 + i * (360 / N)) * Math.PI / 180;
    const radius = 205 + (i % 2 ? 18 : -6);
    const x = CX + Math.cos(angle) * radius;
    const y = CY + Math.sin(angle) * radius * 0.92;
    const size = MAT_SIZE[room.maturity] || 52;

    const mx = (CX + x) / 2 + (CY - y) * 0.1, my = (CY + y) / 2 + (x - CX) * 0.1;
    gBranches.appendChild(el("path", {
      d: `M${CX} ${CY} Q${mx.toFixed(1)} ${my.toFixed(1)} ${x.toFixed(1)} ${y.toFixed(1)}`,
      fill: "none", stroke: "var(--ink-faint)", "stroke-width": (1.1 + size / 46).toFixed(1), opacity: "0.55",
    }));

    const link = el("a", {
      href: room.href,
      "aria-label": `${room.name} — ${room.register} · ${room.maturity}. ${room.blurb}`,
    });
    const g = el("g", { class: "mass", transform: `translate(${x.toFixed(1)},${y.toFixed(1)})` });
    const glow = el("circle", { r: (size + 16).toFixed(0), fill: `url(#${root.querySelector("radialGradient[id$='-sun']").id})`, opacity: "0" });
    g.appendChild(glow);

    const leafCount = 8 + Math.round(size / 12);
    // the pastel-leaf register (Rika, 2026-07-14): lighter, gentler tones
    // than the structural --canopy family used everywhere else on the site.
    const tones = ["var(--leaf-pastel-2)", "var(--leaf-pastel-1)", "var(--leaf-pastel-3)", "var(--leaf-pastel-1)"];
    for (let k = 0; k < leafCount; k++) {
      const la = rnd() * Math.PI * 2, lr = rnd() * size * 0.6;
      const lx = Math.cos(la) * lr, ly = Math.sin(la) * lr * 0.9;
      const lsz = size * (0.34 + rnd() * 0.3);
      g.appendChild(el("ellipse", {
        cx: lx.toFixed(1), cy: ly.toFixed(1), rx: (lsz * 0.9).toFixed(1), ry: (lsz * 0.6).toFixed(1),
        fill: tones[k % tones.length], opacity: (0.5 + rnd() * 0.32).toFixed(2),
        transform: `rotate(${(rnd() * 360).toFixed(0)} ${lx.toFixed(1)} ${ly.toFixed(1)})`,
      }));
    }

    // label — anchor flips by side, so text never crowds a neighbour
    const onRight = Math.cos(angle) > 0.15;
    const onLeft = Math.cos(angle) < -0.15;
    const anchor = onRight ? "start" : onLeft ? "end" : "middle";
    const lx = onRight ? size * 0.62 + 8 : onLeft ? -(size * 0.62 + 8) : 0;
    const ly = size * 0.5 + 15;
    const label = el("text", { x: lx.toFixed(1), y: ly.toFixed(0), "text-anchor": anchor, class: "mass-label" });
    label.textContent = room.label || room.name;
    g.appendChild(label);

    // the maturity marker — a small potted bud/flower (MaturityBud, the
    // same icon the growth-stages list uses), not a text glyph. Cloned
    // from the hidden <template> so the shape lives in one source.
    const budTpl = root.querySelector(`template[data-bud="${room.maturity}"]`);
    if (budTpl) {
      const budSvg = budTpl.content.firstElementChild.cloneNode(true);
      const budSize = 20;
      budSvg.setAttribute("width", String(budSize));
      budSvg.setAttribute("height", String(budSize));
      const budX = anchor === "start" ? lx : anchor === "end" ? lx - budSize : lx - budSize / 2;
      budSvg.setAttribute("x", budX.toFixed(1));
      budSvg.setAttribute("y", (ly + 4).toFixed(0));
      g.appendChild(budSvg);
    }

    const lite = el("circle", { r: (size * 0.42).toFixed(0), fill: `url(#${root.querySelector("radialGradient[id$='-sun']").id})`, opacity: "0.22" });
    g.appendChild(lite);

    // the one governed second exception (Rika, 2026-07-14): a slow, gentle,
    // continuous sway per mass — "potting little plants in a canopy" —
    // additive to the mass's static translate, phase-offset per index so
    // nine masses never move in lockstep. prefers-reduced-motion: the
    // <animateTransform> is simply never appended.
    if (!reduced) {
      const swayAmp = (0.9 + rnd() * 0.7).toFixed(2);
      const swayDur = (9 + i * 1.3 + rnd() * 3).toFixed(1);
      g.appendChild(el("animateTransform", {
        attributeName: "transform", type: "rotate", additive: "sum",
        values: `0 0 0; ${swayAmp} 0 0; 0 0 0; -${swayAmp} 0 0; 0 0 0`,
        dur: `${swayDur}s`, repeatCount: "indefinite",
      }));
    }

    link.appendChild(g);
    gMasses.appendChild(link);
    masses.push({ room, g, glow, branch: gBranches.lastChild, x, y });
  });

  function setActive(m, on) {
    m.glow.setAttribute("opacity", on ? "0.65" : "0");
    m.branch.setAttribute("opacity", on ? "0.85" : "0.55");
    masses.forEach((o) => { if (o !== m) o.g.setAttribute("opacity", on ? "0.5" : "1"); });
  }
  function showTip(m) {
    const r = mapbox.getBoundingClientRect(), sv = svg.getBoundingClientRect();
    const px = (m.x / 940) * sv.width + (sv.left - r.left);
    const py = (m.y / 640) * sv.height + (sv.top - r.top);
    tip.querySelector("[data-tip-n]").textContent = m.room.name;
    tip.querySelector("[data-tip-m]").textContent = `${m.room.register} · ${m.room.maturity}`;
    tip.querySelector("[data-tip-l]").textContent = m.room.blurb;
    tip.style.left = px + "px";
    tip.style.top = py + "px";
    tip.style.opacity = "1";
  }
  function hideTip() { tip.style.opacity = "0"; }

  masses.forEach((m) => {
    m.g.parentElement.addEventListener("pointerenter", () => { setActive(m, true); showTip(m); });
    m.g.parentElement.addEventListener("pointerleave", () => { setActive(m, false); hideTip(); });
    m.g.parentElement.addEventListener("focus", () => { setActive(m, true); showTip(m); });
    m.g.parentElement.addEventListener("blur", () => { setActive(m, false); hideTip(); });
  });

  // the ensō — a lighter, more organic single brushstroke (Rika, 2026-07-14):
  // built as several overlapping tapered segments sharing one continuous
  // path of points, rather than two fixed-width lines, so it reads as one
  // loaded brush moving from a wet belly to a dry tail. Shape (the open
  // upper-right gap) is unchanged; only the ink's weight and opacity taper.
  (function drawEnso() {
    const R = 118;
    const a0 = -18 * Math.PI / 180, a1 = 300 * Math.PI / 180, STEPS = 220;
    const pts = [];
    for (let i = 0; i <= STEPS; i++) {
      const u = i / STEPS, a = a0 + (a1 - a0) * u;
      // a touch more organic wobble than before — a real hand's unsteadiness,
      // not a mechanical curve
      const wob = (rnd() - 0.5) * 7 + Math.sin(u * 9) * 3.1 + Math.sin(u * 23) * 0.9;
      const rr = R + wob + u * 10;
      pts.push([CX + Math.cos(a) * rr, CY + Math.sin(a) * rr]);
    }
    const gStrokes = root.querySelector("[data-enso-strokes]");
    gStrokes.innerHTML = "";
    // wet-belly-to-dry-tail taper across 6 overlapping segments: width and
    // opacity both fall as u climbs, so the brush visibly runs out of ink.
    const SEGMENTS = 6;
    for (let s = 0; s < SEGMENTS; s++) {
      const from = Math.floor((s / SEGMENTS) * STEPS);
      const to = Math.floor(((s + 1) / SEGMENTS) * STEPS) + 1;
      const t = s / (SEGMENTS - 1); // 0 = wet belly, 1 = dry tail
      let d = "";
      for (let i = from; i <= to && i <= STEPS; i++) {
        const [x, y] = pts[i];
        d += (i === from ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1);
      }
      const width = 11.5 * (1 - t) + 2.6 * t;
      const opacity = 0.62 * (1 - t * 0.75);
      gStrokes.appendChild(el("path", { d, "stroke-width": width.toFixed(1), opacity: opacity.toFixed(2) }));
    }
    const sx = CX + Math.cos(a0) * R, sy = CY + Math.sin(a0) * R;
    const start = root.querySelector("[data-enso-start]");
    start.setAttribute("cx", sx.toFixed(1));
    start.setAttribute("cy", sy.toFixed(1));
  })();

  // the one governed exception — a single, slow, ambient falling blossom.
  // Confirmed with Rika: a continuous restrained loop, not a one-shot fall.
  // prefers-reduced-motion: the loop is simply never started.
  if (!reduced) {
    const petal = root.querySelector("[data-blossom]");
    let t = 0;
    (function fall() {
      t += 0.0011;
      const u = t % 1;
      const x = 150 + Math.sin(u * 6.5) * 36 + u * 30;
      const y = -20 + u * 660;
      petal.setAttribute("transform", `translate(${x.toFixed(1)},${y.toFixed(1)}) rotate(${(u * 480).toFixed(0)})`);
      petal.setAttribute("opacity", (u < 0.08 ? u * 5 : u > 0.92 ? (1 - u) * 5 : 0.4).toFixed(2));
      requestAnimationFrame(fall);
    })();
  }
})();
</script>

<style>
  .canopy-figure { margin: 0; }
  .head { text-align: left; }
  .head .eyebrow { font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--canopy-deep); margin: 0; }
  .head h2 { font-family: var(--display); font-weight: 500; font-style: italic; font-size: clamp(1.3rem, 3vw, 1.7rem); margin: 0.5rem 0 0; color: var(--ink); }
  .head .lede { font-size: 0.92rem; color: var(--ink-soft); max-width: 42rem; margin: 0.5rem 0 0; line-height: 1.6; }

  .mapbox { position: relative; margin: 1.4rem auto 0; max-width: 940px; }
  .mapbox svg { display: block; width: 100%; height: auto; aspect-ratio: 940 / 640; touch-action: manipulation; }

  .mass-label { font-family: var(--display); font-style: italic; font-size: 15px; fill: var(--ink); pointer-events: none; }
  :global([data-masses] a) { cursor: pointer; }
  :global([data-masses] a:focus-visible) { outline: 2px solid var(--poppy); outline-offset: 4px; }

  .core-caption {
    text-align: center; font-family: var(--display); font-style: italic;
    font-size: 0.9rem; color: var(--ink-soft); margin: 0.6rem 0 0;
  }

  .leaf-tip {
    position: absolute; z-index: 8; pointer-events: none; opacity: 0;
    transform: translate(-50%, -118%);
    background: var(--paper); border: 1px solid var(--paper-edge); border-radius: 8px;
    padding: 0.55rem 0.8rem; box-shadow: 0 8px 22px rgba(42, 37, 29, 0.14);
    max-width: 15rem; text-align: center; transition: opacity 0.2s ease;
  }
  .leaf-tip .n { font-family: var(--display); font-size: 0.85rem; font-weight: 600; color: var(--ink); }
  .leaf-tip .m { font-size: 0.68rem; letter-spacing: 0.03em; color: var(--ink-faint); margin-top: 0.15rem; }
  .leaf-tip .l { font-size: 0.72rem; color: var(--ink-soft); margin-top: 0.3rem; line-height: 1.4; font-style: italic; }

  @media (prefers-reduced-motion: reduce) {
    .leaf-tip { transition: none; }
  }
</style>
