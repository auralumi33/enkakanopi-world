---
// One idea: home isn't the harbour you return to — it's the keel you carry that
// keeps you upright in any water.
---
<svg viewBox="0 0 600 250" role="img" aria-labelledby="keel-t">
  <title id="keel-t">Along a coastline sit several small harbours, each faded and behind. Out on the open water is a little boat; beneath it, drawn boldly, is its keel — the one thing it carries everywhere that keeps it upright.</title>
  <!-- coastline with faded harbours (left behind) -->
  <path class="ink hair" d="M20 60 C 120 66, 220 58, 320 64" opacity="0.5" />
  <g class="ink hair" opacity="0.5">
    <path d="M60 60 L 66 44 L 78 60 M150 62 L 156 46 L 168 62 M250 60 L 256 44 L 268 60" />
  </g>
  <text class="hand-label" x="70" y="90" font-size="14" opacity="0.6">harbours, behind</text>
  <!-- waterline -->
  <path class="ink hair" d="M20 150 C 160 142, 320 158, 580 148" />
  <path class="ink hair" d="M40 168 C 120 162, 200 172, 300 166" opacity="0.6" />
  <!-- the little boat -->
  <path class="ink block" d="M430 150 C 452 150, 500 150, 522 150 C 516 168, 500 178, 476 178 C 452 178, 436 168, 430 150 Z" />
  <path class="ink hair" d="M476 150 L 476 118 L 508 140 L 476 144" />
  <!-- the keel: the load-bearing thing carried everywhere -->
  <path class="ink spine" d="M470 178 C 468 196, 476 210, 474 224" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="486" y="210" font-size="16">the keel</text>
  <text class="hand-label" x="486" y="230" font-size="14" opacity="0.8">carried, always</text>
</svg>
