---
// One idea: the still frame catches the craft — the surface, the pose — and loses
// the container underneath; the object deflates the instant you still it.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="cc-t">
  <title id="cc-t">On the left, a still frame holding only a flat pose labelled "the craft, caught" — a thin surface. On the right, the same subject in motion, a fuller moving form labelled "the container, alive," with the surface passing through it.</title>
  <!-- the still frame: craft only, thin -->
  <rect x="46" y="52" width="150" height="110" rx="3" class="ink block" />
  <path class="ink hair" d="M80 130 C 110 96, 132 96, 162 130" opacity="0.55" />
  <text class="hand-label" x="56" y="182" font-size="13">the craft, caught (deflates)</text>
  <!-- turn -->
  <path class="ink hair" d="M212 108 C 240 106, 258 110, 280 112" stroke-dasharray="2 6" stroke="var(--poppy)" />
  <!-- in motion: the container, alive -->
  <path class="ink spine" d="M330 150 C 320 110, 360 78, 400 86 C 440 94, 452 130, 438 156 C 424 182, 344 184, 330 150 Z" stroke="var(--canopy-deep)" />
  <path class="ink hair" d="M348 132 C 372 100, 412 104, 424 138" opacity="0.6" />
  <circle class="port-fill" cx="392" cy="128" r="3.4" />
  <text class="hand-label hand-label--accent" x="330" y="182" font-size="13">the container, alive (appreciates)</text>
</svg>
