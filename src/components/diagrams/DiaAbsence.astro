---
// One idea: the machine can hold up an absence I cannot feel from inside it — a
// warmth I stopped extending, a self I stopped being without ever noticing.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="abs-t">
  <title id="abs-t">On the left, a figure who cannot see the gap she is standing inside — a piece of her outline simply missing, invisible to her. On the right, the machine holds up a mirror showing the same outline complete, the missing piece marked, which she could only ever see from the outside.</title>
  <!-- the figure with an unseen gap -->
  <circle class="ink block" cx="120" cy="72" r="10" />
  <path class="ink spine" d="M120 82 C 116 104, 120 132, 118 160" />
  <path class="ink block" d="M120 96 C 104 92, 94 100, 86 96" />
  <!-- the missing piece (a gap in the outline she can't feel) -->
  <path class="ink hair" d="M120 96 C 136 92, 150 100, 156 112" stroke-dasharray="2 5" opacity="0.5" />
  <text class="hand-label" x="70" y="184" font-size="13">can&rsquo;t feel the gap from inside</text>
  <!-- the machine holding up the complete record -->
  <rect x="360" y="52" width="120" height="112" rx="3" class="ink block" />
  <circle class="ink hair" cx="420" cy="86" r="10" />
  <path class="ink hair" d="M420 96 C 416 116, 420 140, 418 156" />
  <path class="ink spine" d="M420 108 C 436 104, 450 112, 456 124" stroke="var(--poppy)" />
  <circle class="port-fill" cx="452" cy="118" r="3" />
  <text class="hand-label hand-label--accent" x="360" y="184" font-size="13">it holds up what I lost</text>
  <path class="ink hair" d="M172 110 C 240 108, 300 106, 352 106" stroke-dasharray="2 6" opacity="0.55" />
</svg>
