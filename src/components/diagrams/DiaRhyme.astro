---
// One idea: the fragments don't reconcile into one — they rhyme across the gaps,
// like stanzas of a single poem you couldn't fit onto one line.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="rh-t">
  <title id="rh-t">Four separate fragments sit apart on the page, each a distinct small shape, none touching. Faint gilded arcs leap the gaps between them — showing they don't join into one form, but echo and rhyme with each other across the spaces.</title>
  <!-- four fragments, apart -->
  <path class="ink block" d="M60 70 C 78 58, 104 64, 106 84 C 88 96, 62 92, 60 70 Z" class="leaf-fill" />
  <path class="ink block" d="M210 56 C 232 50, 252 66, 244 84 C 224 90, 204 76, 210 56 Z" />
  <path class="ink block" d="M330 120 C 352 112, 372 128, 362 146 C 342 152, 322 138, 330 120 Z" class="leaf-fill" />
  <path class="ink block" d="M470 78 C 492 70, 512 86, 502 104 C 482 110, 462 96, 470 78 Z" />
  <!-- the rhyming arcs across the gaps -->
  <g class="ink hair" stroke="var(--poppy)" opacity="0.75">
    <path d="M106 78 C 150 50, 176 52, 214 66" stroke-dasharray="1 6" />
    <path d="M244 74 C 288 96, 306 112, 334 126" stroke-dasharray="1 6" />
    <path d="M362 130 C 410 118, 436 106, 470 94" stroke-dasharray="1 6" />
    <path d="M106 86 C 220 168, 360 168, 480 104" stroke-dasharray="1 6" opacity="0.5" />
  </g>
  <text class="hand-label hand-label--accent" x="200" y="184" font-size="14">they don&rsquo;t join — they rhyme</text>
</svg>
