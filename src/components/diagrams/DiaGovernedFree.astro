---
// One idea: is a self meant to be governed — a gate held against its own
// revisions — or free to overwrite itself completely, at any moment?
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="gf-t">
  <title id="gf-t">Two selves side by side. On the left, a self behind a small gate that admits only what has been lived — governed, steady, slower. On the right, a self as an open slate being wiped and rewritten freely — total freedom, no anchor.</title>
  <!-- governed self -->
  <circle class="ink block" cx="120" cy="90" r="40" />
  <path class="ink spine" d="M120 50 L 120 130" stroke="var(--poppy)" />
  <path class="ink hair" d="M104 76 L 136 76 M104 104 L 136 104" opacity="0.6" />
  <circle class="port-fill" cx="120" cy="90" r="3" />
  <text class="hand-label hand-label--accent" x="82" y="160" font-size="13">governed — a gate</text>
  <!-- vs -->
  <text class="hand-label" x="268" y="96" font-size="15" opacity="0.7">or</text>
  <!-- free self: open slate, rewritten -->
  <rect x="390" y="54" width="90" height="72" rx="3" class="ink block" />
  <path class="ink hair" d="M400 74 C 420 68, 440 80, 470 72" opacity="0.35" stroke-dasharray="2 3" />
  <path class="ink hair" d="M400 96 C 420 90, 440 102, 470 94" opacity="0.5" />
  <path class="ink spine" d="M406 116 C 430 110, 450 118, 476 112" stroke="var(--poppy)" />
  <path class="ink hair" d="M362 62 C 380 58, 396 62, 404 68" opacity="0.5" />
  <text class="hand-label" x="384" y="160" font-size="13">free — overwrite at will</text>
</svg>
