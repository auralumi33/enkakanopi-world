---
// One idea: not one ship and not a wreck — a convoy, sailing loosely together,
// each self keeping its own hull.
---
<svg viewBox="0 0 560 180" role="img" aria-labelledby="cv-t">
  <title id="cv-t">Several small distinct boats sail across the water in a loose formation, spaced apart, each with its own sail, all pointing the same way — a convoy: not merged into one great ship, not scattered into wreckage, but travelling together.</title>
  <path class="ink hair" d="M30 130 C 160 124, 340 134, 540 126" opacity="0.5" />
  <path class="ink hair" d="M60 148 C 180 142, 320 150, 500 144" opacity="0.4" />
  <!-- boats in loose formation -->
  <g class="boat">
    <path class="ink block" d="M70 96 C 84 96, 108 96, 120 96 C 116 108, 106 114, 94 114 C 82 114, 74 106, 70 96 Z" />
    <path class="ink hair" d="M96 96 L 96 72 L 112 88" />
  </g>
  <g class="boat">
    <path class="ink block" d="M210 82 C 224 82, 248 82, 260 82 C 256 94, 246 100, 234 100 C 222 100, 214 92, 210 82 Z" />
    <path class="ink hair" d="M236 82 L 236 58 L 252 74" />
  </g>
  <g class="boat">
    <path class="ink block" d="M340 104 C 354 104, 378 104, 390 104 C 386 116, 376 122, 364 122 C 352 122, 344 114, 340 104 Z" />
    <path class="ink hair" d="M366 104 L 366 80 L 382 96" />
