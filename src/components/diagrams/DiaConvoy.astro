  <g class="boat">
    <path class="ink block" d="M456 88 C 470 88, 494 88, 506 88 C 502 100, 492 106, 480 106 C 468 106, 460 98, 456 88 Z" />
    <path class="ink hair" d="M482 88 L 482 64 L 498 80" />
