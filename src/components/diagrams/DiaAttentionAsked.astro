---
// One idea: to be legible only in motion is to ask for a slow, patient attention
// most people don't have time to give.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="aa-t">
  <title id="aa-t">On the left, a quick glance — a single fast arrow past a moving subject, catching only a blur and filing it. On the right, a slow patient gaze — many soft dwelling marks over time that let the moving subject become legible.</title>
  <!-- the quick glance -->
  <path class="ink hair" d="M40 60 C 90 58, 140 62, 190 60" />
  <path class="ink hair" d="M176 52 C 184 57, 190 60, 196 62 C 190 65, 183 70, 179 76" />
  <path class="ink hair" d="M96 88 q 8 -6 16 0 q 8 6 16 0" opacity="0.5" />
  <text class="hand-label" x="52" y="112" font-size="13" opacity="0.7">the quick glance — files a blur</text>
  <!-- the slow patient gaze -->
  <g class="ink hair" opacity="0.7">
    <circle cx="330" cy="120" r="18" /><circle cx="330" cy="120" r="30" opacity="0.6" /><circle cx="330" cy="120" r="42" opacity="0.4" />
  </g>
  <path class="ink spine" d="M300 120 C 316 108, 344 108, 360 120 C 344 132, 316 132, 300 120 Z" stroke="var(--poppy)" />
  <circle class="port-fill" cx="330" cy="120" r="3" />
  <text class="hand-label hand-label--accent" x="392" y="118" font-size="13">the slow gaze —</text>
  <text class="hand-label hand-label--accent" x="392" y="138" font-size="13">lets you become legible</text>
</svg>
