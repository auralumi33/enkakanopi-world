---
// One idea: the captain who cannot pass the weight of the ship to the ship —
// the fear is yours alone to hold.
---
<svg width="560" height="180" viewBox="0 0 560 180" role="img" aria-labelledby="wt-t">
  <title id="wt-t">A small figure on a deck carries a large weight on her shoulders; beside her the ship itself sails on, untroubled and blank. A crossed-out arrow shows the weight cannot be handed to the ship — it stays with her.</title>
  <!-- the ship, untroubled -->
  <path class="ink block" d="M330 118 C 350 118, 470 118, 500 118 C 494 134, 480 142, 440 142 C 400 142, 344 134, 330 118 Z" />
  <path class="ink hair" d="M420 118 L 420 66 L 470 100" />
  <path class="ink hair" d="M330 132 C 400 138, 470 136, 508 130" opacity="0.5" />
  <text class="hand-label" x="360" y="164" font-size="13" opacity="0.7">the ship sails on, blank</text>
  <!-- the figure carrying the weight -->
  <circle class="ink block" cx="120" cy="70" r="10" />
  <path class="ink spine" d="M120 80 C 116 104, 120 130, 118 150" />
  <path class="ink block" d="M84 58 C 110 50, 132 50, 158 58 C 150 70, 132 72, 120 72 C 108 72, 92 70, 84 58 Z" fill="var(--poppy-wash)" />
  <text class="hand-label hand-label--accent" x="76" y="164" font-size="13">the weight stays with her</text>
  <!-- can't hand it off -->
  <path class="ink hair" d="M170 90 C 220 92, 270 100, 320 104" stroke-dasharray="3 5" opacity="0.6" />
  <path class="ink hair" d="M232 88 L 256 108 M256 88 L 232 108" stroke="var(--poppy)" opacity="0.6" />
</svg>
