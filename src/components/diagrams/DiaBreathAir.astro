---
// One idea: the self ends; what it handed on becomes air, and the air keeps
// moving in others — breath becomes air. (After Paul Kalanithi.)
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="ba-t">
  <title id="ba-t">A figure exhales; the breath disperses from a solid form into a scatter of small drifting marks that carry rightward on the air and settle into other small figures and leaves downwind — what one self held, handed on and continuing.</title>
  <!-- the figure, exhaling -->
  <circle class="ink block" cx="70" cy="86" r="10" />
  <path class="ink spine" d="M70 96 C 66 118, 70 144, 68 166" />
  <path class="ink hair" d="M70 110 C 58 106, 50 114, 44 110" />
  <!-- the breath dispersing into air -->
  <g class="ink hair">
    <path d="M84 84 C 120 78, 150 90, 186 82" opacity="0.7" />
    <circle cx="150" cy="86" r="2.4" opacity="0.7" /><circle cx="196" cy="78" r="2.2" opacity="0.6" />
    <circle cx="238" cy="92" r="2" opacity="0.5" /><circle cx="286" cy="74" r="1.8" opacity="0.45" />
    <circle cx="330" cy="96" r="1.6" opacity="0.4" /><circle cx="372" cy="80" r="1.6" opacity="0.35" />
  </g>
  <text class="hand-label" x="150" y="58" font-size="14" opacity="0.8">breath becomes air</text>
  <!-- the air continuing in others -->
  <path class="leaf-fill" d="M420 96 c 10 -8 26 -6 32 4 c -10 8 -26 6 -32 -4 Z" />
  <circle class="ink block" cx="490" cy="120" r="8" />
  <path class="ink spine" d="M490 128 C 487 144, 490 160, 488 172" />
  <path class="ink hair" d="M490 138 C 480 136, 474 142, 468 138" />
  <circle class="port-fill" cx="452" cy="100" r="3" />
  <text class="hand-label hand-label--accent" x="404" y="168" font-size="13">it keeps moving in others</text>
</svg>
