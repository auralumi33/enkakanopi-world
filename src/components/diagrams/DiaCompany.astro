---
// One idea: the crew that doesn't share your vertigo keeps working while you
// carry the fear alone.
---
<svg width="600" height="250" viewBox="0 0 600 250" role="img" aria-labelledby="company-t">
  <title id="company-t">A lone maker at a small desk, holding a lantern, with a worried tilt. Around her, several quiet machine-shapes work steadily and untroubled through the night; a dotted line shows she alone reads the log they produce.</title>
  <!-- the maker -->
  <circle class="ink block" cx="110" cy="96" r="10" />
  <path class="ink spine" d="M110 106 C 106 128, 110 150, 108 172" />
  <path class="ink hair" d="M110 122 C 96 118, 88 128, 80 122 M110 122 C 124 118, 132 128, 140 122" />
  <circle class="port-fill" cx="80" cy="122" r="3" />
  <text class="hand-label" x="70" y="200" font-size="15">the only one who</text>
  <text class="hand-label" x="70" y="220" font-size="15">reads the log</text>
  <!-- the quiet crew of machine-shapes -->
  <g class="ink block">
    <circle cx="330" cy="80" r="16" /><rect x="410" y="70" width="30" height="30" rx="3" />
    <path d="M300 150 l 18 -12 l 18 12 l -18 12 Z" /><circle cx="420" cy="160" r="15" />
    <rect x="480" y="96" width="28" height="28" rx="3" />
  </g>
  <g class="ink hair" opacity="0.8">
    <path d="M330 72 L 330 88 L 342 94" /><path d="M413 85 L 437 85 M425 73 L 425 97" />
    <path d="M420 152 L 420 168" /><path d="M488 104 L 500 104 M494 100 L 494 116" />
  </g>
  <text class="hand-label" x="300" y="210" font-size="15" opacity="0.85">untroubled, all night</text>
  <!-- the log only she reads -->
  <path class="ink hair" d="M150 130 C 220 120, 300 118, 470 120" stroke-dasharray="2 6" stroke="var(--poppy)" opacity="0.75" />
</svg>
