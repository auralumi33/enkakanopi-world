---
// One idea: a wholeness made of seams — not one smooth blank surface, but many
// pieces whose visible joins are the whole point.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="whole-t">
  <title id="whole-t">On the left, a smooth blank oval labelled "one surface" — flawless and empty. On the right, a vessel of the same shape made of many distinct pieces held together by visible inked-and-gilded seams, labelled "a wholeness made of seams" — clearly more alive.</title>
  <!-- the smooth blank surface -->
  <ellipse cx="130" cy="100" rx="70" ry="56" class="ink block" fill="var(--paper-deep)" />
  <text class="hand-label" x="96" y="176" font-size="13" opacity="0.7">one surface (empty)</text>
  <!-- the wholeness of seams -->
  <ellipse cx="410" cy="100" rx="72" ry="58" class="ink block" />
  <path class="ink spine" d="M410 42 C 396 74, 424 104, 408 158" stroke="var(--poppy)" />
  <path class="ink block" d="M340 88 C 372 96, 448 96, 480 86" />
  <path class="ink block" d="M348 128 C 386 118, 434 118, 470 130" />
  <path class="ink hair" d="M374 60 C 384 74, 384 86, 380 92 M446 66 C 438 78, 438 90, 442 96" stroke="var(--poppy)" />
  <circle class="port-fill" cx="410" cy="100" r="3" />
  <text class="hand-label hand-label--accent" x="344" y="176" font-size="13">a wholeness made of seams</text>
</svg>
