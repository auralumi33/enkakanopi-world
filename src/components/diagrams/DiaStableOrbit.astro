---
// One idea: too close and you crush it by never letting it spin; too far and it
// drifts; the craft is the stable orbit — close enough to hold, far enough to turn.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="orbit-t">
  <title id="orbit-t">Three panels of a body orbiting a maker. Too close: the orbit collapses inward, crushing. Too far: it flies off, drifting. The middle: a stable ring at the right radius, the body held and spinning on its own axis.</title>
  <!-- too close: crush -->
  <circle class="ink block" cx="90" cy="100" r="5" />
  <path class="ink hair" d="M90 100 m -18 0 a 18 12 0 1 0 36 0 a 18 12 0 1 0 -36 0" opacity="0.5" />
  <path class="ink hair" d="M78 88 C 84 96, 96 96, 102 88" stroke="var(--poppy)" opacity="0.7" />
  <text class="hand-label" x="60" y="150" font-size="13" opacity="0.7">too close: crush</text>
  <!-- too far: drift -->
  <circle class="ink block" cx="270" cy="100" r="5" />
  <circle class="ink hair" cx="322" cy="86" r="6" opacity="0.6" />
  <path class="ink hair" d="M300 108 C 320 100, 338 92, 356 84" stroke-dasharray="2 5" opacity="0.6" />
  <text class="hand-label" x="250" y="150" font-size="13" opacity="0.7">too far: drift</text>
  <!-- stable orbit -->
  <circle class="ink block" cx="460" cy="100" r="5" />
  <ellipse cx="460" cy="100" rx="42" ry="26" class="ink spine" stroke="var(--poppy)" />
  <circle class="port-ring" cx="502" cy="100" r="7" /><circle class="port-fill" cx="502" cy="100" r="3" />
  <text class="hand-label hand-label--accent" x="420" y="150" font-size="13">held, and spinning</text>
</svg>
