---
// One idea: I still linger by the door, hand half-raised — while the work happens
// correctly, in my absence, in a room I've already left.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="door-t">
  <title id="door-t">A doorway. On the near side, a small figure lingers, one hand half-raised toward the room. Beyond the threshold, a little system works on steadily and correctly, needing nothing.</title>
  <!-- the doorway -->
  <path class="ink block" d="M250 30 L 250 175 M340 30 L 340 175 M250 30 L 340 30" />
  <!-- the lingering figure, hand half-raised -->
  <circle class="ink block" cx="180" cy="80" r="9" />
  <path class="ink spine" d="M180 90 C 177 112, 180 140, 178 168" />
  <path class="ink spine" d="M180 104 C 200 96, 218 88, 236 82" stroke="var(--poppy)" />
  <path class="ink hair" d="M180 108 C 168 112, 160 120, 154 116" />
  <text class="hand-label hand-label--accent" x="120" y="188" font-size="13">hand half-raised</text>
  <!-- the work, fine without her -->
  <g class="ink block"><circle cx="410" cy="80" r="14" /><rect x="452" y="96" width="24" height="24" rx="3" /></g>
  <path class="ink hair" d="M410 70 L 410 80 L 420 88 M456 100 l 16 0 M464 96 l 0 16" opacity="0.8" />
  <circle class="port-fill" cx="410" cy="80" r="3" />
  <text class="hand-label" x="384" y="150" font-size="13">working, correctly, without me</text>
</svg>
