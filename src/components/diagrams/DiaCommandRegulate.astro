---
// One idea: trust isn't gripping tighter — it's the shift from command to
// regulate; steady the vessel, don't seize the wheel.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="cr-t">
  <title id="cr-t">On the left, a white-knuckled fist clenched around a wheel — command, gripping, straining. On the right, an open steady hand resting lightly on a tiller as a small boat holds its own course — regulate, holding without seizing.</title>
  <!-- command: clenched grip on a wheel -->
  <circle class="ink block" cx="120" cy="96" r="34" />
  <path class="ink hair" d="M120 62 L 120 130 M86 96 L 154 96 M96 72 L 144 120 M144 72 L 96 120" opacity="0.6" />
  <path class="ink block" d="M104 96 c -4 -10 6 -14 10 -6 c 2 -10 12 -8 12 0 c 4 -8 12 -4 10 4 c 4 -2 8 4 2 10 c -6 6 -22 8 -30 2 c -6 -4 -8 -12 -4 -14 Z" fill="var(--poppy-wash)" />
  <text class="hand-label" x="82" y="158" font-size="13" opacity="0.75">command — grip</text>
  <!-- regulate: light hand on a tiller, boat holding course -->
  <path class="ink hair" d="M300 140 C 360 134, 430 146, 520 138" opacity="0.6" />
  <path class="ink block" d="M356 116 C 400 112, 460 118, 500 116" />
  <path class="ink block" d="M356 116 C 372 130, 460 130, 500 116" />
  <path class="ink hair" d="M420 116 L 424 92" />
  <path class="ink block" d="M410 84 c -2 -8 6 -10 10 -4 c 2 -8 10 -6 10 2 c 4 -4 10 0 6 8 c -4 6 -18 8 -26 2 c -4 -2 -6 -8 -2 -8 Z" />
  <circle class="port-fill" cx="424" cy="92" r="3" />
  <text class="hand-label hand-label--accent" x="360" y="168" font-size="13">regulate — steady, not seize</text>
</svg>
