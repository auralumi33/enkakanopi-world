---
// One idea: hands, screen, room — one continuous appetite for making the thing
// you can stand inside; the materials are the ground the digital grows from.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="arc-t">
  <title id="arc-t">Three stages joined by one rising line: a lump of clay in a hand, then a screen sketch, then a whole room you can stand inside — one continuous appetite from material to digital to space.</title>
  <path class="ink spine" d="M80 150 C 200 138, 320 120, 470 78" stroke="var(--poppy)" />
  <!-- clay in hand -->
  <path class="ink block" d="M70 150 c 6 -14 34 -14 40 0 c -8 8 -32 8 -40 0 Z" class="leaf-fill" />
  <text class="hand-label" x="64" y="180" font-size="13">hands · clay</text>
  <!-- screen -->
  <rect x="248" y="94" width="60" height="44" rx="3" class="ink block" />
  <path class="ink hair" d="M258 128 C 272 108, 286 116, 298 104" opacity="0.7" />
  <text class="hand-label" x="248" y="164" font-size="13">screen · code</text>
  <!-- room you stand inside -->
  <path class="ink block" d="M430 44 L 510 44 L 510 96 L 430 96 Z" />
  <path class="ink hair" d="M430 44 L 470 26 L 510 44 M470 96 L 470 60" opacity="0.7" />
  <circle class="port-fill" cx="470" cy="70" r="3" />
  <text class="hand-label hand-label--accent" x="426" y="120" font-size="13">room · light</text>
</svg>
