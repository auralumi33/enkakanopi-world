---
// One idea: when the merciful, forgetting self and the exact, remembering machine
// disagree about who you are, which do you let win — and is accuracy the truth?
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="ww-t">
  <title id="ww-t">A beam balance. On the left pan sits a soft, blurred face labelled "mercy — forgets"; on the right, an exact grid-face labelled "accuracy — keeps." A hand rests on the beam, undecided which way to let it tip.</title>
  <!-- the balance beam + fulcrum -->
  <path class="ink spine" d="M120 78 L 440 78" />
  <path class="ink block" d="M280 78 L 268 130 L 292 130 Z" />
  <!-- left pan: mercy (soft, blurred) -->
  <path class="ink hair" d="M120 78 L 120 104" />
  <path class="ink hair" d="M96 104 C 120 118, 144 118, 144 104" />
  <path class="ink hair" d="M110 92 C 120 86, 130 86, 132 96" opacity="0.5" />
  <text class="hand-label" x="86" y="146" font-size="13">mercy — forgets</text>
  <!-- right pan: accuracy (exact grid) -->
  <path class="ink hair" d="M440 78 L 440 104" />
  <path class="ink block" d="M418 104 h 44 v 24 h -44 Z" />
  <g class="ink hair" opacity="0.8"><path d="M418 116 h44 M440 104 v24" /></g>
  <circle class="port-fill" cx="440" cy="116" r="2.6" />
  <text class="hand-label" x="404" y="146" font-size="13">accuracy — keeps</text>
  <!-- the hand on the beam, undecided -->
  <path class="ink block" d="M270 60 C 268 50, 276 48, 280 56 C 282 47, 292 47, 292 56 C 296 48, 304 50, 300 62 C 306 56, 314 62, 308 72 C 304 80, 296 84, 284 84 C 274 84, 266 72, 270 60 Z" />
  <text class="hand-label hand-label--accent" x="250" y="40" font-size="13">which do you let win?</text>
</svg>
