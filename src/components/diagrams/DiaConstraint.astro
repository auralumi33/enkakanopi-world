---
// One idea: constraint is the generator — a small kit you trust invents more than
// a big one you're afraid of.
---
<svg width="560" height="180" viewBox="0 0 560 180" role="img" aria-labelledby="con-t">
  <title id="con-t">On the left, a small kit of three primitives fans out into many varied combinations. On the right, a huge overflowing box sits shut, producing almost nothing — the constraint generates, the abundance stalls.</title>
  <!-- small kit -> many combinations -->
  <g class="ink block"><path d="M40 60 l 30 0" /><circle cx="46" cy="86" r="7" /><path d="M40 108 c 10 -10 24 -10 32 0" /></g>
  <path class="ink hair" d="M84 84 C 120 60, 150 60, 180 66 M84 90 C 120 96, 150 104, 180 108 M84 96 C 120 120, 150 128, 178 130" stroke="var(--poppy)" opacity="0.7" />
  <g class="ink block" opacity="0.85">
    <circle cx="196" cy="64" r="6" /><path d="M190 104 l 12 0 M196 98 l 0 12" /><path d="M188 126 c 8 -8 18 -8 24 0" />
  </g>
  <text class="hand-label hand-label--accent" x="52" y="158" font-size="13">a small kit — invents</text>
  <!-- big box -> stalls -->
  <rect x="400" y="52" width="110" height="86" rx="4" class="ink block" fill="var(--paper-deep)" />
  <g class="ink hair" opacity="0.6"><path d="M414 70 h82 M414 88 h82 M414 106 h82" /></g>
  <path class="ink hair" d="M400 46 L 510 46" opacity="0.7" />
  <text class="hand-label" x="404" y="158" font-size="13" opacity="0.7">a big box — stalls</text>
</svg>
