---
// One idea: the ache that says you can never go home is the same ache that drives
// you to build one you can carry — one source, two pulls.
---
<svg viewBox="0 0 560 200" role="img" aria-labelledby="ache-t">
  <title id="ache-t">A single small source at the centre with two arrows springing from it: one pulling back and left toward a faded, closed harbour marked "no return"; the other driving forward and right toward a small boat being built plank by plank, marked "the rebuild." The same ache, both directions.</title>
  <!-- the closed harbour, behind (faded) -->
  <g opacity="0.5">
    <path class="ink hair" d="M40 96 L 120 96 M60 96 L 66 80 L 78 96 M92 96 L 98 80 L 110 96" />
    <path class="ink hair" d="M36 116 C 76 122, 116 118, 130 118" />
  </g>
  <text class="hand-label" x="44" y="150" font-size="13" opacity="0.6">no return</text>
  <!-- the source (the ache) -->
  <path class="ink block" d="M272 78 C 270 68, 280 66, 284 74 C 288 66, 298 66, 298 76 C 300 84, 286 96, 284 98 C 282 96, 270 86, 272 78 Z" fill="var(--poppy-wash)" />
  <circle class="port-fill" cx="285" cy="82" r="3" />
  <text class="hand-label hand-label--accent" x="256" y="120" font-size="13">the same ache</text>
  <!-- pull back -->
  <path class="ink spine" d="M272 84 C 220 92, 170 100, 132 106" stroke="var(--ink-soft)" />
  <path class="ink hair" d="M148 98 C 140 103, 134 106, 128 108 C 134 111, 141 116, 145 122" stroke="var(--ink-soft)" />
  <!-- drive forward -->
  <path class="ink spine" d="M298 84 C 350 88, 400 96, 440 104" stroke="var(--poppy)" />
  <path class="ink hair" d="M424 96 C 432 101, 438 104, 444 106 C 438 109, 431 114, 427 120" stroke="var(--poppy)" />
  <!-- the boat being built -->
  <path class="ink block" d="M470 108 C 486 108, 516 108, 530 108 C 526 122, 514 130, 498 130 C 482 130, 474 120, 470 108 Z" />
  <path class="ink hair" d="M500 108 L 500 90 L 520 102" />
  <text class="hand-label" x="470" y="150" font-size="13">the rebuild</text>
</svg>
