---
// One idea: the head's strategy for falling is to stiffen and fight the floor;
// the body, left to its own counsel, knows to go soft.
---
<svg width="560" height="180" viewBox="0 0 560 180" role="img" aria-labelledby="hb2-t">
  <title id="hb2-t">On the left, the head in charge — a rigid straight figure bracing against the ground, and a jarring impact mark. On the right, the body in charge — a soft rolling curve meeting the ground gently, the impact spread along the arc.</title>
  <!-- head in charge: stiff, jarring -->
  <path class="ink hair" d="M100 40 L 100 120" />
  <circle class="ink hair" cx="100" cy="34" r="8" />
  <path class="ink block" d="M60 130 L 140 130" />
  <path class="ink hair" d="M88 122 l 4 -10 l 8 8 l 8 -10 l 4 12" stroke="var(--poppy)" opacity="0.7" />
  <text class="hand-label" x="66" y="156" font-size="13" opacity="0.7">head: stiffen, jar</text>
  <!-- body in charge: soft roll -->
  <path class="ink spine" d="M330 44 C 352 84, 330 112, 372 128 C 410 142, 470 136, 500 132" stroke="var(--poppy)" />
  <circle class="port-ring" cx="330" cy="44" r="8" /><circle class="port-fill" cx="330" cy="44" r="3" />
  <path class="ink block" d="M320 132 C 400 126, 470 130, 510 132" opacity="0.6" />
  <text class="hand-label hand-label--accent" x="360" y="156" font-size="13">body: go soft, land</text>
</svg>
