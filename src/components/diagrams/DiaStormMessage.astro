---
// One idea: how do you tell the storm that is only weather from the storm trying,
// at last, to tell you something true?
---
<svg width="560" height="180" viewBox="0 0 560 180" role="img" aria-labelledby="sm-t">
  <title id="sm-t">Two storms side by side, drawn almost identically. The left is labelled "only weather — it will pass." The right, nearly the same, carries a small folded letter inside it, labelled "a message — heed it." A question mark hangs between them: which is which.</title>
  <!-- storm 1: only weather -->
  <path class="ink block" d="M70 66 C 64 54, 86 50, 92 60 C 98 50, 120 54, 114 70 C 128 70, 128 84, 112 84 L 76 84 C 62 84, 62 70, 70 66 Z" />
  <path class="ink hair" d="M82 90 l -4 12 M96 90 l -4 12 M110 90 l -4 12" />
  <text class="hand-label" x="56" y="128" font-size="13" opacity="0.7">only weather</text>
  <!-- the question -->
  <text class="hand-label hand-label--accent" x="266" y="80" font-size="24">?</text>
  <!-- storm 2: a message -->
  <path class="ink block" d="M400 66 C 394 54, 416 50, 422 60 C 428 50, 450 54, 444 70 C 458 70, 458 84, 442 84 L 406 84 C 392 84, 392 70, 400 66 Z" />
  <path class="ink hair" d="M412 90 l -4 12 M426 90 l -4 12 M440 90 l -4 12" />
  <path class="ink block" d="M410 66 L 434 66 L 434 80 L 410 80 Z" fill="var(--paper)" />
  <path class="ink hair" d="M410 66 L 422 74 L 434 66" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="392" y="128" font-size="13">a message?</text>
</svg>
