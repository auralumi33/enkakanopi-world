---
// One idea: what crumbled wasn't a setback to repair but a foundation to rebuild
// differently — the home remade, not restored.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="crb-t">
  <title id="crb-t">On the left, a rigid house of hard straight lines collapsing, its blocks falling. In the middle, a heap of the fallen pieces. On the right, from those same pieces, a lighter, rounder dwelling is rebuilt — not the old house restored, but a different one raised from the rubble.</title>
  <!-- the rigid house, collapsing -->
  <g class="ink hair" opacity="0.6">
    <path d="M40 120 L 40 70 L 90 46 L 140 70 L 140 120" />
    <path d="M40 120 L 140 120" />
    <path d="M100 118 L 116 100 M120 112 L 138 96" stroke-dasharray="0" transform="rotate(12 120 110)" />
  </g>
  <path class="ink hair" d="M118 60 l 14 -10 M150 92 l 16 -6 M132 116 l 18 4" opacity="0.5" />
  <text class="hand-label" x="44" y="150" font-size="13" opacity="0.65">what was rigid, fell</text>
  <!-- the rubble -->
  <g class="ink block" opacity="0.7">
    <rect x="238" y="110" width="16" height="12" /><rect x="258" y="114" width="14" height="10" transform="rotate(-14 265 119)" />
    <rect x="276" y="108" width="16" height="12" transform="rotate(10 284 114)" />
  </g>
  <path class="ink hair" d="M304 108 C 320 106, 336 108, 350 108" stroke-dasharray="2 5" stroke="var(--poppy)" />
  <!-- the rebuilt, lighter dwelling -->
  <path class="ink spine" d="M420 118 C 420 82, 460 58, 500 82 C 500 118, 500 118, 500 118" />
  <path class="ink block" d="M420 118 L 500 118" />
  <path class="ink hair" d="M448 118 L 448 96 C 452 90, 468 90, 472 96 L 472 118" opacity="0.7" />
  <circle class="port-fill" cx="460" cy="72" r="3" />
  <text class="hand-label hand-label--accent" x="408" y="150" font-size="13">rebuilt, not restored</text>
</svg>
