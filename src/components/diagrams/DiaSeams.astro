---
// One idea: the truth is in the seam between versions, not the average of them.
---
<svg width="600" height="260" viewBox="0 0 600 260" role="img" aria-labelledby="seams-t">
  <title id="seams-t">Two versions of a self, drawn apart; the value is the stitched seam between them, not the faint averaged shape in the middle.</title>
  <!-- version A -->
  <path class="ink block" d="M60 70 C 96 52, 150 58, 168 96 C 178 132, 150 176, 104 184 C 66 190, 44 150, 50 116 C 54 92, 56 82, 60 70 Z" />
  <text class="hand-label" x="70" y="128" font-size="19">version</text>
  <text class="hand-label" x="96" y="150" font-size="19">A</text>
  <!-- version B -->
  <path class="ink block" d="M436 74 C 480 58, 540 70, 552 112 C 560 150, 528 186, 484 188 C 446 190, 420 156, 424 120 C 426 96, 428 84, 436 74 Z" />
  <text class="hand-label" x="470" y="132" font-size="19">version</text>
  <text class="hand-label" x="500" y="154" font-size="19">B</text>
  <!-- the faint average (what the world wants) -->
  <ellipse cx="300" cy="128" rx="52" ry="46" class="ink hair" stroke-dasharray="2 6" opacity="0.5" />
  <text class="hand-label" x="256" y="210" font-size="16" opacity="0.6">the averaged self</text>
  <!-- the seam: a stitched line carrying the value -->
  <path class="ink spine" d="M172 130 C 214 108, 250 150, 300 128 C 350 106, 388 150, 428 128"
        stroke="var(--poppy)" stroke-dasharray="0.5 9" />
  <text class="hand-label hand-label--accent" x="238" y="96" font-size="19">the seam</text>
</svg>
