---
// One idea: don't hide the break, or merely tolerate it — gild it, until the
// mended seam is the most precious line on the whole vessel.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="kin-t">
  <title id="kin-t">Three bowls. The first hides its crack, faint and ashamed. The second merely tolerates it, a plain grey join. The third fills the crack with gold — kintsugi — and the gilded seam is the most beautiful line on the bowl, the eye drawn straight to it.</title>
  <!-- hidden -->
  <path class="ink block" d="M40 78 C 44 128, 128 128, 132 78" />
  <path class="ink block" d="M40 78 C 60 66, 112 66, 132 78" />
  <path class="ink hair" d="M86 78 L 82 118" opacity="0.25" />
  <text class="hand-label" x="52" y="152" font-size="12" opacity="0.6">hidden</text>
  <!-- tolerated -->
  <path class="ink block" d="M214 78 C 218 128, 302 128, 306 78" />
  <path class="ink block" d="M214 78 C 234 66, 286 66, 306 78" />
  <path class="ink block" d="M260 78 L 256 118" opacity="0.7" />
  <text class="hand-label" x="222" y="152" font-size="12" opacity="0.7">tolerated</text>
  <!-- gilded -->
  <path class="ink block" d="M388 78 C 392 128, 476 128, 480 78" />
  <path class="ink block" d="M388 78 C 408 66, 460 66, 480 78" />
  <path class="ink spine" d="M434 78 C 430 92, 440 104, 430 118" stroke="var(--poppy)" />
  <path class="ink hair" d="M420 90 L 434 86 M438 104 L 450 100" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="392" y="152" font-size="13">gilded — the finest line</text>
</svg>
