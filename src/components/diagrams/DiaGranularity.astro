---
// One idea: a precisely named feeling gives you a heading; "bad" gives you
// nowhere to steer. Granularity is agency.
---
<svg viewBox="0 0 600 240" role="img" aria-labelledby="gran-t">
  <title id="gran-t">On the left, one large undifferentiated grey blob labelled "bad" with a compass whose needle spins uselessly. An arrow resolves it, on the right, into several precisely-named smaller states — under-resourced, lonely, hungry, uneasy — each with its own clear heading arrow pointing to a different action.</title>

  <!-- the undifferentiated blob + spinning needle -->
  <path class="ink hair" d="M60 70 C 44 92, 52 140, 88 148 C 128 156, 150 116, 138 88 C 128 64, 84 52, 60 70 Z" opacity="0.5" />
  <text class="hand-label" x="78" y="110" font-size="18" opacity="0.7">&ldquo;bad&rdquo;</text>
  <circle class="ink hair" cx="98" cy="188" r="16" opacity="0.6" />
  <path class="ink hair" d="M98 188 L 110 178 M98 188 L 88 200" stroke="var(--poppy)" opacity="0.7" />
  <text class="hand-label" x="60" y="224" font-size="13" opacity="0.6">needle spins — no heading</text>

  <!-- resolving arrow -->
  <path class="ink hair" d="M168 108 C 210 106, 236 110, 268 112" stroke-dasharray="2 6" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="184" y="98" font-size="14">named finely</text>

  <!-- the precise, named states, each with a heading -->
  <g class="ink block" font-size="13">
    <g>
      <path d="M300 56 h 150 v 26 h -150 Z" />
      <path class="ink hair" d="M456 69 l 14 0 M466 63 l 6 6 l -6 6" stroke="var(--poppy)" />
    </g>
    <g>
      <path d="M300 96 h 150 v 26 h -150 Z" />
      <path class="ink hair" d="M456 109 l 14 0 M466 103 l 6 6 l -6 6" stroke="var(--poppy)" />
    </g>
    <g>
      <path d="M300 136 h 150 v 26 h -150 Z" />
      <path class="ink hair" d="M456 149 l 14 0 M466 143 l 6 6 l -6 6" stroke="var(--poppy)" />
    </g>
    <g>
      <path d="M300 176 h 150 v 26 h -150 Z" />
      <path class="ink hair" d="M456 189 l 14 0 M466 183 l 6 6 l -6 6" stroke="var(--poppy)" />
    </g>
  </g>
  <g class="hand-label" font-size="14">
    <text x="312" y="74">under-resourced, not in danger</text>
    <text x="312" y="114">lonely, not unlovable</text>
    <text x="312" y="154">hungry, not failing</text>
    <text x="312" y="194">uneasy, not doomed</text>
  </g>
  <text class="hand-label hand-label--accent" x="478" y="130" font-size="14">a heading</text>
</svg>
