  <!-- the head + the whole plan -->
  <circle class="ink block" cx="70" cy="80" r="16" />
  <rect x="100" y="44" width="90" height="112" rx="3" class="ink block" />
  <g class="ink hair" opacity="0.7"><path d="M112 62 h66 M112 78 h66 M112 94 h66 M112 110 h66 M112 126 h66 M112 142 h40" /></g>
  <path class="ink hair" d="M86 80 C 96 76, 104 74, 112 72" opacity="0.6" />
  <text class="hand-label" x="70" y="182" font-size="13" opacity="0.7">the whole plan, not one mark made</text>
  <!-- the hand, beginning -->
  <path class="ink block" d="M360 120 C 358 106, 366 104, 370 114 C 372 102, 382 102, 382 114 C 386 104, 394 106, 392 118 C 398 110, 406 116, 400 128 C 396 140, 388 148, 374 148 C 362 148, 356 132, 360 120 Z" />
