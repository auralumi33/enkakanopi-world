---
// One idea: a self is not what it remembers but what it lets become permanent —
// most of what knocks should stay provisional until it has been lived.
---
<svg width="600" height="260" viewBox="0 0 600 260" role="img" aria-labelledby="wa-t">
  <title id="wa-t">Four things knock to be written into a self — a lived thing, an inherited belief, a borrowed verdict, a passing mood. Only the lived one passes the gate into the durable core; the rest are held as provisional.</title>

  <!-- inbound knocks -->
  <g class="hand-label" font-size="16">
    <text x="16" y="52">lived</text>
    <text x="16" y="104">inherited</text>
    <text x="16" y="156">borrowed</text>
    <text x="16" y="208">a mood</text>
  </g>
  <g class="ink hair">
    <path d="M92 47 C 150 55, 190 78, 226 100" />
    <path d="M110 99 C 160 104, 195 108, 228 116" stroke-dasharray="2 5" />
    <path d="M110 151 C 160 146, 195 138, 228 130" stroke-dasharray="2 5" />
    <path d="M92 203 C 150 190, 195 160, 228 146" stroke-dasharray="2 5" />
  </g>

  <!-- the gate -->
  <path class="ink spine" d="M250 66 L 250 194" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="234" y="222" font-size="15">the gate</text>
  <!-- only 'lived' passes -->
  <path class="ink spine" d="M252 104 C 300 110, 340 118, 372 122" stroke="var(--poppy)" />
  <path class="ink hair" d="M356 114 C 366 119, 372 122, 378 124 C 372 127, 365 133, 360 139" stroke="var(--poppy)" />
  <text class="hand-label" x="270" y="96" font-size="14">ratified by living</text>

  <!-- the durable core (the self) -->
  <path class="ink block" d="M392 122 C 388 84, 470 74, 520 92 C 566 108, 560 168, 512 178 C 460 190, 396 172, 392 122 Z" />
  <text class="hand-label" x="430" y="122" font-size="16">what is</text>
  <text class="hand-label" x="424" y="142" font-size="16">permanent</text>
  <circle class="port-fill" cx="475" cy="130" r="3.4" />

  <!-- held provisional -->
  <text class="hand-label" x="250" y="250" font-size="14" opacity="0.7">the rest: held provisional, never yet true</text>
</svg>
