---
// One idea: the many selves don't collapse to one — they pair off into tensions
// held in balance; multiplicity resolved as duality, not as a single average.
---
<svg width="560" height="200" viewBox="0 0 560 200" role="img" aria-labelledby="md-t">
  <title id="md-t">On the left, a scatter of many small marks labelled "the many." They do not merge into one; instead they gather, on the right, into three balanced pairs — each pair two marks held in tension on a small beam, poised, not resolved into a single point.</title>
  <!-- the many -->
  <g class="ink hair" opacity="0.8">
    <circle cx="46" cy="60" r="3" /><circle cx="72" cy="92" r="3" /><circle cx="40" cy="118" r="3" />
    <circle cx="80" cy="140" r="3" /><circle cx="60" cy="72" r="3" /><circle cx="52" cy="150" r="3" />
    <circle cx="88" cy="66" r="3" /><circle cx="36" cy="88" r="3" />
  </g>
  <text class="hand-label" x="38" y="180" font-size="13" opacity="0.7">the many</text>
  <!-- gather (not merge) -->
  <path class="ink hair" d="M108 100 C 150 98, 180 100, 214 102" stroke-dasharray="2 6" stroke="var(--poppy)" />
  <text class="hand-label hand-label--accent" x="120" y="88" font-size="13">held as pairs</text>
  <!-- three balanced pairs (duality) -->
  <g class="ink block">
    <path d="M260 60 L 340 60" /><path d="M300 60 L 296 74 L 304 74 Z" />
    <circle cx="260" cy="52" r="7" class="node-fill" fill="var(--paper)" /><circle cx="340" cy="52" r="7" fill="var(--poppy-wash)" />
    <path d="M400 100 L 480 100" /><path d="M440 100 L 436 114 L 444 114 Z" />
    <circle cx="400" cy="92" r="7" fill="var(--paper)" /><circle cx="480" cy="92" r="7" fill="var(--poppy-wash)" />
    <path d="M300 150 L 380 150" /><path d="M340 150 L 336 164 L 344 164 Z" />
    <circle cx="300" cy="142" r="7" fill="var(--paper)" /><circle cx="380" cy="142" r="7" fill="var(--poppy-wash)" />
  </g>
  <text class="hand-label hand-label--accent" x="386" y="180" font-size="13">tensions, held — not averaged</text>
</svg>
