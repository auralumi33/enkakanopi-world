---
// One idea: the age keeps learning; the hand keeps tending — the quiet is what makes the small work legible.
---
<svg width="560" height="220" viewBox="0 0 560 220" role="img" aria-labelledby="tq-t">
  <title id="tq-t">On the left, a dense scattered field of small angular marks — the noise of the wider world. On the right, one hand tending a single stem, held close and low, kept legible against the noise.</title>

  <!-- the noise of the age — dense, small, deliberately non-directional -->
  <g class="ink hair" opacity="0.7" aria-hidden="true">
    <path d="M40 50 l6 3 M55 65 l-3 5 M75 45 l4 6 M90 70 l-6 3 M110 55 l4 -4 M125 80 l-5 4 M45 95 l6 3 M70 110 l-4 5 M100 100 l5 -3 M130 115 l-6 4 M50 140 l6 -3 M80 155 l-4 -5 M115 145 l5 4 M140 165 l-5 -4 M55 175 l6 -3 M95 185 l-4 -5 M125 180 l5 3 M155 130 l-5 4" />
    <circle cx="60" cy="120" r="1.3" fill="var(--ink)" stroke="none" opacity="0.6"/>
    <circle cx="105" cy="140" r="1.2" fill="var(--ink)" stroke="none" opacity="0.6"/>
    <circle cx="140" cy="90" r="1.2" fill="var(--ink)" stroke="none" opacity="0.6"/>
    <circle cx="85" cy="60" r="1.2" fill="var(--ink)" stroke="none" opacity="0.6"/>
    <circle cx="150" cy="170" r="1.3" fill="var(--ink)" stroke="none" opacity="0.6"/>
    <circle cx="35" cy="160" r="1.2" fill="var(--ink)" stroke="none" opacity="0.6"/>
  </g>

  <!-- a soft seam between the noise and the quiet -->
  <path class="ink hair" d="M180 100 v 60" opacity="0.35" />

  <!-- the tended stem + poppy bud (the quiet, held small) -->
  <path class="ink block" d="M320 175 C 322 150, 320 130, 322 112" />
  <path class="leaf-fill" d="M322 130 C 310 122, 296 128, 296 138 C 306 142, 318 138, 322 130 Z" />
  <circle cx="322" cy="108" r="4" fill="var(--poppy)" />
  <path class="ink hair" d="M322 104 q 3 -4 5 -1 M322 104 q -3 -4 -5 -1" stroke="var(--poppy)" opacity="0.85" />

  <!-- the hand, cupped low, tending -->
  <path class="ink block" d="M360 165 C 358 155, 366 152, 372 158 C 372 150, 380 148, 384 156 C 388 148, 396 152, 396 160 C 402 156, 408 164, 404 172 C 400 182, 388 186, 376 184 C 366 182, 358 174, 360 165 Z" fill="var(--paper)" />

  <text class="hand-label" x="45" y="200" font-size="15">the age, keeps learning us</text>
  <text class="hand-label hand-label--accent" x="310" y="200" font-size="15">a hand, keeps tending</text>
</svg>
