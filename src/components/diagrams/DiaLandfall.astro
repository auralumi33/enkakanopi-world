---
// One idea: each trial is a landfall where you pick up the one thing only that
// island held — something you'd have no other way to carry.
---
<svg viewBox="0 0 560 180" role="img" aria-labelledby="lf-t">
  <title id="lf-t">A wandering route touches three small islands in turn; at each landfall a hand picks up a small distinct gift — a leaf, a stone, a spark — that could be found nowhere else, and carries it on to the next.</title>
  <path class="ink spine" d="M40 120 C 90 90, 130 96, 170 116 C 220 140, 260 96, 310 100 C 360 104, 400 140, 450 116 C 490 98, 510 108, 528 104" stroke="var(--poppy)" />
  <!-- islands -->
  <g class="leaf-fill">
    <path d="M156 118 c 8 -6 22 -6 28 2 c -8 6 -22 6 -28 -2 Z" />
    <path d="M296 102 c 8 -6 22 -6 28 2 c -8 6 -22 6 -28 -2 Z" />
    <path d="M436 118 c 8 -6 22 -6 28 2 c -8 6 -22 6 -28 -2 Z" />
  </g>
  <!-- gifts picked up -->
  <path class="ink hair" d="M168 96 c 4 -6 14 -4 16 2 c -4 6 -14 4 -16 -2 Z" />
  <circle class="ink block" cx="310" cy="82" r="4" />
  <path class="ink hair" d="M448 96 l 0 -8 m -6 4 l 6 -4 l 6 4" stroke="var(--poppy)" />
  <circle class="port-fill" cx="184" cy="98" r="2.6" /><circle class="port-fill" cx="464" cy="92" r="2.6" />
  <text class="hand-label hand-label--accent" x="150" y="160" font-size="14">each trial, a gift only that island held</text>
</svg>
