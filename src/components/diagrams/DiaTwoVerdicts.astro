---
// One idea: a self that cannot be averaged — read one way it's a failure of
// integration; read the other, the only kind worth keeping.
---
<svg viewBox="0 0 560 190" role="img" aria-labelledby="tv-t">
  <title id="tv-t">At the centre, a self made of many un-averaged pieces. Two readings fork from it: to the left, "a failure of integration" — the pieces shown as a wound that never closed; to the right, "the only kind worth keeping" — the same pieces gilded into a whole.</title>
  <!-- the un-averaged self at centre -->
  <g class="ink block">
    <path d="M262 76 C 276 68, 298 74, 300 90 C 284 100, 262 94, 262 76 Z" class="leaf-fill" />
    <path d="M262 96 C 276 90, 298 96, 296 112 C 280 120, 260 112, 262 96 Z" />
  </g>
  <text class="hand-label" x="246" y="150" font-size="13">un-averageable</text>
  <!-- fork left: wound -->
  <path class="ink hair" d="M258 92 C 200 88, 150 92, 110 96" opacity="0.7" />
  <path class="ink hair" d="M70 78 C 84 88, 84 100, 70 110" stroke="var(--ink-soft)" />
  <path class="ink hair" d="M62 84 l 16 20 M78 84 l -16 20" stroke="var(--ink-soft)" opacity="0.6" />
  <text class="hand-label" x="30" y="132" font-size="12" opacity="0.7">a failure of integration?</text>
  <!-- fork right: gilded whole -->
  <path class="ink spine" d="M302 92 C 360 88, 420 92, 460 96" stroke="var(--poppy)" />
  <path class="ink block" d="M470 74 C 500 74, 512 92, 500 108 C 484 122, 462 112, 462 92 C 462 84, 466 78, 470 74 Z" />
  <path class="ink hair" d="M486 74 C 482 88, 490 100, 484 112" stroke="var(--poppy)" />
  <circle class="port-fill" cx="484" cy="92" r="3" />
  <text class="hand-label hand-label--accent" x="440" y="132" font-size="12">the only kind worth keeping?</text>
</svg>
