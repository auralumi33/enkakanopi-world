  <!-- the room -->
  <path class="ink block" d="M40 40 L 300 40 L 300 210 L 40 210 Z" />
  <text class="hand-label" x="58" y="66" font-size="17">the room you are in</text>
  <!-- the hand (simple open palm) -->
  <path class="ink block" d="M120 150 C 118 132, 126 128, 130 140 C 132 126, 142 126, 142 140 C 146 128, 154 130, 152 144 C 158 136, 166 142, 160 154 C 156 168, 150 180, 132 180 C 118 180, 112 166, 120 150 Z" />
