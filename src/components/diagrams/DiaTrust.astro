  <path class="ink spine" d="M176 130 C 236 120, 320 120, 388 128" stroke="var(--poppy)" />
  <path class="ink spine" d="M372 118 C 382 124, 390 128, 396 130 C 388 134, 380 142, 374 150" stroke="var(--poppy)" />
