---
/**
 * The seam cards — Lexicon · "what the terms quietly admit" (SHIP-PROMPT-LEX
 * §B.3, Restructure Charter §2 intake #4). Reads the same edge weights as
 * lexiconConfig (lexicon.config.ts) — never a separate or fabricated tally.
 * Framed suggestive, not measured. Honestly empty when no seam is dense
 * enough yet (most terms stand alone — see DESIGN-SYSTEM.md § theLexiconMap).
 */
import MotifInkedSeam from "../motifs/MotifInkedSeam.astro";
import type { LexiconSeam } from "./lexicon.config";

interface Props {
  seams: LexiconSeam[];
  headingId?: string;
}
const { seams, headingId = "what-the-terms-admit" } = Astro.props;
---
<section class="seams" aria-labelledby={headingId}>
  <h2 id={headingId}>what the terms quietly admit</h2>
  {seams.length > 0 ? (
    <>
      <p class="intro">
        The seams where two terms keep arriving in the same piece — suggestive, not measured.
      </p>
      <div class="cards">
        {seams.map((s) => (
          <div class="card">
            <div class="mark" aria-hidden="true"><MotifInkedSeam size={140} /></div>
            <p class="pair"><span>{s.aLabel}</span><span class="join">↔</span><span>{s.bLabel}</span></p>
            <p class="note">held together in {s.weight} {s.weight === 1 ? "piece" : "pieces"} so far — a seam still forming, not a measurement.</p>
          </div>
        ))}
      </div>
    </>
  ) : (
    <p class="intro empty">No seam sits dense enough to name yet — most terms still stand alone. As the essays grow to hold more than one, a seam will surface here.</p>
  )}
</section>
<style>
  .seams { margin: 3rem 0 0; padding-top: 2rem; border-top: 1.1px solid var(--paper-edge); }
  .seams h2 {
    font-family: var(--serif); font-style: italic; font-size: 1.3rem;
    color: var(--ink); margin: 0; letter-spacing: -0.01em;
  }
  .intro { color: var(--ink-soft); max-width: var(--measure); margin: 0.7rem 0 0; font-size: 0.98rem; }
  .intro.empty { color: var(--ink-faint); font-style: italic; }
  .cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem; margin-top: 1.4rem;
  }
  .card {
    border: 1.1px solid var(--paper-edge); border-radius: 2px;
    padding: 1.1rem 1.2rem; background: var(--paper-washi);
  }
  .mark { opacity: 0.85; margin: 0 0 0.3rem -0.2rem; }
  .mark :global(svg) { width: 100%; max-width: 140px; height: auto; }
  .pair {
    font-family: var(--serif); font-style: italic; font-size: 1.05rem;
    color: var(--ink); margin: 0; line-height: 1.4;
  }
  .pair .join { color: var(--poppy); font-style: normal; margin: 0 0.35rem; }
  .note { color: var(--ink-faint); font-size: 0.85rem; margin: 0.5rem 0 0; }
</style>
