---
/**
 * GraphCanvas — the one force-directed knowledge-map engine.
 *
 * Ported from two GARDEN-SCULPT reference studies (a touchable-map study
 * and a citation-map study), merged into a single, config-driven component
 * so every knowledge-map on the site is consistent by construction. Leaf
 * callers supply data + copy only via MapConfig — this file owns all
 * physics, tokens, and a11y.
 *
 * Two panel registers:
 *   "specimen"  — click a node → material / constraint / tally / maturity
 *                 (one thing, examined closely)
 *   "bookmarks" — click a node → its blurb + the real entries that hold it;
 *                 click an entry → pivot to see the terms it carries
 *                 (walking a citation graph)
 *
 * The paper stays still: the layout settles once, synchronously, before
 * first paint — nothing animates on load. Motion is a response to touch
 * (drag), never ambient, and self-terminates once velocities go quiet.
 * Fully inert under prefers-reduced-motion.
 *
 * illustrative: true suppresses every hard number — weight/count data
 * drives sizing only, never printed as a figure.
 *
 * Zero deps. No network calls. No storage.
 */
import type { MapConfig } from "./graph.types";

const {
  nodes,
  edges,
  entries = [],
  lenses,
  panel,
  illustrative,
  headingId,
  heading,
  intro,
  defaultRelation = "appears with",
} = Astro.props as MapConfig;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hasStages = nodes.some((n) => n.stage);
const stageGlyph: Record<string, string> = { seedling: "•", budding: "••", evergreen: "•••" };

const config = { nodes, edges, entries, lenses, panel, illustrative, defaultRelation };
const configJson = JSON.stringify(config);
const graphId = `graph-${headingId}`;
---

<section class="graph-canvas" id={headingId} data-graph-id={graphId} data-base={base} data-config={configJson}>
  <h2>{heading}</h2>
  {intro && <p class="intro">{intro}</p>}

  {lenses && lenses.length > 0 && (
    <>
      <div class="lens-rail" role="tablist" aria-label="reading lens">
        <span class="lens-lbl">one graph · many lenses</span>
        {lenses.map((l, i) => (
          <button class="lens" data-lens={l.key} role="tab" aria-selected={i === 0 ? "true" : "false"}>{l.label}</button>
        ))}
      </div>
      <p class="lens-read" data-role="lens-read">{lenses[0].read}</p>
    </>
  )}

  <div class="stage-wrap" data-role="stage-wrap">
    <p class="hint" data-role="hint">
      ↳ <span class="k">drag</span> a node · <span class="k">hover</span> for one breath ·
      <span class="k">click</span> to open its {panel === "specimen" ? "specimen" : "bookmarks"}
    </p>
    <svg class="stage" viewBox="0 0 1120 480" preserveAspectRatio="xMidYMid meet" data-role="svg">
      <title>An interactive map — {heading}</title>
      <g data-role="edges"></g>
      <g data-role="nodes"></g>
    </svg>
    <div class="legend">
      <span><i class="dot dot-soul"></i>soul</span>
      <span><i class="dot dot-craft"></i>craft</span>
      {hasStages && <span>maturity — seedling <b>•</b> budding <b>••</b> evergreen <b>•••</b></span>}
      {illustrative && <span class="illus">an illustrative sketch, not a measurement</span>}
    </div>
    <div class="tip" data-role="tip" aria-hidden="true">
      <div class="tip-k" data-role="tip-k"></div>
      <div class="tip-n" data-role="tip-n"></div>
      <div class="tip-b" data-role="tip-b"></div>
    </div>

    <div class="gc-panel" data-role="panel">
      <button class="panel-close" data-role="panel-close" aria-label="close">×</button>
      <div class="panel-k" data-role="panel-k"></div>
      <div class="panel-n" data-role="panel-n"></div>
      <div class="panel-b" data-role="panel-b"></div>
      <div class="panel-meta" data-role="panel-meta"></div>
      <div class="panel-sub" data-role="panel-sub"></div>
      <div class="panel-list" data-role="panel-list"></div>
    </div>
  </div>
</section>

<script>
  interface GNode {
    id: string; label: string; kind: "soul" | "craft"; weight?: number;
    stage?: string; blurb: string; material?: string; constraint?: string; tally?: string;
    x: number; y: number; hx: number; hy: number; vx: number; vy: number; r: number;
  }
  interface GEdge { a: string; b: string; weight?: number; relation?: string; }
  interface GEntry { id: string; label: string; meta?: string; href: string; nodeIds: string[]; }
  interface GLens { key: string; label: string; read: string; relabel?: Record<string, string>; }
  interface GConfig {
    nodes: Omit<GNode, "x" | "y" | "hx" | "hy" | "vx" | "vy" | "r">[];
    edges: GEdge[];
    entries: GEntry[];
    lenses?: GLens[];
    panel: "specimen" | "bookmarks";
    illustrative: boolean;
    defaultRelation: string;
  }

  const STAGE_GLYPH: Record<string, string> = { seedling: "•", budding: "••", evergreen: "•••" };

  function el<K extends keyof SVGElementTagNameMap>(tag: K, attrs: Record<string, string> = {}) {
    const e = document.createElementNS("http://www.w3.org/2000/svg", tag);
    for (const k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }

  function initGraph(root: HTMLElement) {
    const raw = root.dataset.config;
    if (!raw) return;
    const cfg: GConfig = JSON.parse(raw);
    const base = root.dataset.base ?? "";
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const VB = { w: 1120, h: 480 };
    const maxNodeWeight = Math.max(1, ...cfg.nodes.map((n) => n.weight ?? 1));
    const maxEdgeWeight = Math.max(1, ...cfg.edges.map((e) => e.weight ?? 1));

    const nodes: GNode[] = cfg.nodes.map((n, i) => {
      const ang = (i / cfg.nodes.length) * Math.PI * 2;
      const rad = 170 + ((i * 41) % 110);
      const x = VB.w / 2 + Math.cos(ang) * rad;
      const y = VB.h / 2 + Math.sin(ang) * rad;
      // Dainty scale: small blooms in a wide bed, not the earlier heavier stones.
      const r = 13 + ((n.weight ?? 1) / maxNodeWeight) * 9;
      return { ...n, x, y, hx: x, hy: y, vx: 0, vy: 0, r };
    });
    const byId = new Map(nodes.map((n) => [n.id, n]));

    // The active lens changes what a node is CALLED everywhere — the SVG
    // label, the hover tip, and the specimen/bookmarks panel alike — not
    // just the graph face. cfg.lenses[0] is the default active lens.
    let activeLensKey: string | null = cfg.lenses?.[0]?.key ?? null;
    function labelFor(n: GNode): string {
      const lens = activeLensKey ? cfg.lenses?.find((l) => l.key === activeLensKey) : undefined;
      return lens?.relabel?.[n.id] ?? n.label;
    }

    const svg = root.querySelector<SVGSVGElement>('[data-role="svg"]')!;
    const gEdges = root.querySelector<SVGGElement>('[data-role="edges"]')!;
    const gNodes = root.querySelector<SVGGElement>('[data-role="nodes"]')!;
    const tip = root.querySelector<HTMLElement>('[data-role="tip"]')!;
    const hint = root.querySelector<HTMLElement>('[data-role="hint"]')!;
    const panelEl = root.querySelector<HTMLElement>('[data-role="panel"]')!;

    // ---------- edges ----------
    // Two-layer stroke (the site's own wet-ink idiom, inverted to a light
    // gloss): the base line carries the weight/opacity signal; a thin,
    // lighter highlight rides its centre for a subtle sheen.
    const edgeEls = cfg.edges.map((e) => {
      const p = el("path", { fill: "none", stroke: "var(--ink-faint)", "stroke-linecap": "round" });
      const gloss = el("path", { fill: "none", stroke: "var(--paper-washi)", "stroke-linecap": "round", class: "edge-gloss" });
      const hitP = el("path", { fill: "none", stroke: "transparent", "stroke-width": "14" });
      const label = el("text", { class: "edge-label", "text-anchor": "middle" });
      gEdges.appendChild(p);
      gEdges.appendChild(gloss);
      gEdges.appendChild(hitP);
      gEdges.appendChild(label);
      return { data: e, p, gloss, hitP, label, lit: false };
    });

    // ---------- nodes ----------
    const nodeEls = new Map<string, { g: SVGGElement; halo: SVGCircleElement; circle: SVGCircleElement; label: SVGTextElement }>();
    nodes.forEach((n) => {
      const g = el("g", { class: "node", tabindex: "0", role: "button", "aria-label": `${labelFor(n)} — open its ${cfg.panel === "specimen" ? "specimen" : "bookmarks"}` });
      const halo = el("circle", { r: String(n.r + 7), class: "halo", opacity: "0" });
      const isSoul = n.kind === "soul";
      const circle = el("circle", {
        r: String(n.r),
        class: isSoul ? "node-soul" : "node-craft",
      });
      const label = el("text", { y: String(n.r + 15), "text-anchor": "middle", class: "node-label" });
      label.textContent = labelFor(n);
      const glyph = n.stage ? STAGE_GLYPH[n.stage] : "";
      let markEl: SVGTextElement | null = null;
      if (glyph) {
        markEl = el("text", { y: String(-n.r - 8), "text-anchor": "middle", class: "node-mark" });
        markEl.textContent = glyph;
      }
      g.appendChild(halo);
      g.appendChild(circle);
      if (markEl) g.appendChild(markEl);
      g.appendChild(label);
      gNodes.appendChild(g);
      nodeEls.set(n.id, { g, halo, circle, label });
    });

    function project() {
      nodes.forEach((n) => {
        const els = nodeEls.get(n.id)!;
        els.g.setAttribute("transform", `translate(${n.x},${n.y})`);
      });
      edgeEls.forEach((e) => {
        const a = byId.get(e.data.a), b = byId.get(e.data.b);
        if (!a || !b) return;
        const mx = (a.x + b.x) / 2 + (a.y - b.y) * 0.1;
        const my = (a.y + b.y) / 2 + (b.x - a.x) * 0.1;
        const d = `M${a.x} ${a.y} Q${mx} ${my} ${b.x} ${b.y}`;
        e.p.setAttribute("d", d);
        e.gloss.setAttribute("d", d);
        e.hitP.setAttribute("d", d);
        const w = e.data.weight ?? 1;
        const baseWidth = 0.8 + (w / maxEdgeWeight) * 2.2;
        e.p.setAttribute("stroke-width", String(baseWidth));
        e.p.setAttribute("opacity", String(0.32 + 0.35 * (w / maxEdgeWeight)));
        e.gloss.setAttribute("stroke-width", String(baseWidth * 0.38));
        e.label.setAttribute("x", String(0.25 * a.x + 0.5 * mx + 0.25 * b.x));
        e.label.setAttribute("y", String(0.25 * a.y + 0.5 * my + 0.25 * b.y - 6));
      });
    }

    // ---------- force layout (repulsion + edge-spring + weak centering) ----------
    let dragging: GNode | null = null;
    function physicsStep() {
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const d2 = dx * dx + dy * dy || 1;
          const d = Math.sqrt(d2);
          const rep = 6600 / d2;
          const ux = dx / d, uy = dy / d;
          if (a !== dragging) { a.vx -= ux * rep; a.vy -= uy * rep; }
          if (b !== dragging) { b.vx += ux * rep; b.vy += uy * rep; }
        }
        if (a !== dragging) {
          a.vx += (VB.w / 2 - a.x) * 0.0012;
          a.vy += (VB.h / 2 - a.y) * 0.0012;
        }
      }
      cfg.edges.forEach((e) => {
        const a = byId.get(e.a), b = byId.get(e.b);
        if (!a || !b) return;
        const dx = b.x - a.x, dy = b.y - a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 1;
        const w = e.weight ?? 1;
        const want = 215 - (w / maxEdgeWeight) * 55;
        const f = (d - want) * 0.006;
        const ux = dx / d, uy = dy / d;
        if (a !== dragging) { a.vx += ux * f; a.vy += uy * f; }
        if (b !== dragging) { b.vx -= ux * f; b.vy -= uy * f; }
      });
      let moving = false;
      nodes.forEach((n) => {
        if (n === dragging) return;
        n.vx *= 0.82; n.vy *= 0.82;
        n.x += n.vx; n.y += n.vy;
        n.x = Math.max(n.r + 12, Math.min(VB.w - n.r - 12, n.x));
        n.y = Math.max(n.r + 24, Math.min(VB.h - n.r - 24, n.y));
        if (Math.abs(n.vx) > 0.03 || Math.abs(n.vy) > 0.03) moving = true;
      });
      return moving;
    }

    // Settle synchronously before first paint — the paper stays still: nothing animates on load.
    for (let i = 0; i < 260; i++) physicsStep();
    project();

    // A short-lived rAF loop, started only by touch, that stops itself once quiet.
    let rafId: number | null = null;
    function runLoop() {
      const moving = physicsStep();
      project();
      if (moving || dragging) {
        rafId = requestAnimationFrame(runLoop);
      } else {
        rafId = null;
      }
    }
    function wake() {
      if (reduced || rafId !== null) return;
      rafId = requestAnimationFrame(runLoop);
    }

    // ---------- drag + hover ----------
    function svgPoint(e: PointerEvent) {
      const pt = svg.createSVGPoint();
      pt.x = e.clientX; pt.y = e.clientY;
      return pt.matrixTransform(svg.getScreenCTM()!.inverse());
    }
    let hintShown = true;
    let pointerMoved = false;

    svg.addEventListener("pointerdown", (e) => {
      const g = (e.target as Element).closest(".node") as SVGGElement | null;
      if (!g) return;
      const id = [...nodeEls.entries()].find(([, v]) => v.g === g)?.[0];
      if (!id) return;
      dragging = byId.get(id) ?? null;
      pointerMoved = false;
      svg.setPointerCapture(e.pointerId);
      if (hintShown) { hint.style.opacity = "0"; hintShown = false; }
    });
    svg.addEventListener("pointermove", (e) => {
      if (dragging) {
        const p = svgPoint(e);
        dragging.x = Math.max(dragging.r + 12, Math.min(VB.w - dragging.r - 12, p.x));
        dragging.y = Math.max(dragging.r + 24, Math.min(VB.h - dragging.r - 24, p.y));
        pointerMoved = true;
        if (reduced) project(); else wake();
        return;
      }
      const g = (e.target as Element).closest(".node") as SVGGElement | null;
      if (g) {
        const id = [...nodeEls.entries()].find(([, v]) => v.g === g)?.[0];
        if (id) showTip(byId.get(id)!, e);
      } else {
        hideTip();
      }
    });
    svg.addEventListener("pointerup", () => {
      const wasDragging = dragging;
      dragging = null;
      if (wasDragging && !pointerMoved) openNode(wasDragging);
      else if (wasDragging) wake();
    });
    svg.addEventListener("pointerleave", hideTip);

    function showTip(n: GNode, e: PointerEvent) {
      tip.querySelector('[data-role="tip-k"]')!.textContent = "in one breath";
      tip.querySelector('[data-role="tip-n"]')!.textContent = labelFor(n);
      tip.querySelector('[data-role="tip-b"]')!.textContent = n.blurb;
      const r = root.querySelector('[data-role="stage-wrap"]')!.getBoundingClientRect();
      tip.style.left = Math.min(r.width - 260, Math.max(8, e.clientX - r.left + 14)) + "px";
      tip.style.top = Math.max(8, e.clientY - r.top - 12) + "px";
      tip.style.opacity = "1";
      nodeEls.get(n.id)!.halo.setAttribute("opacity", ".85");
    }
    function hideTip() {
      tip.style.opacity = "0";
      nodeEls.forEach((v) => v.halo.setAttribute("opacity", "0"));
    }

    // ---------- keyboard ----------
    const order = nodes.map((n) => n.id);
    root.querySelectorAll<SVGGElement>(".node").forEach((g, i) => {
      g.addEventListener("keydown", (e: KeyboardEvent) => {
        const id = order[i];
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); openNode(byId.get(id)!); }
        else if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          const next = order[(i + 1) % order.length];
          nodeEls.get(next)!.g.focus();
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          const prev = order[(i - 1 + order.length) % order.length];
          nodeEls.get(prev)!.g.focus();
        } else if (e.key === "Escape") {
          closePanel();
        }
      });
    });

    // ---------- focus-dim + typed edges ----------
    let focusedId: string | null = null;
    function dimTo(keepIds: Set<string> | null) {
      nodeEls.forEach((v, id) => {
        const on = !keepIds || keepIds.has(id);
        v.g.setAttribute("opacity", on ? "1" : "0.24");
      });
      edgeEls.forEach((e) => {
        const on = !keepIds || (keepIds.has(e.data.a) && keepIds.has(e.data.b));
        const w = e.data.weight ?? 1;
        e.p.setAttribute("opacity", on ? String(0.32 + 0.35 * (w / maxEdgeWeight)) : "0.06");
        const lit = !!(keepIds && on && keepIds.size <= 2);
        e.label.classList.toggle("show", lit);
        if (lit) {
          const rel = e.data.relation || cfg.defaultRelation;
          e.label.textContent = rel;
        }
      });
    }

    // A quiet hover preview on the edge itself, before anything is focused —
    // once a node/entry is focused, dimTo owns the labels exclusively.
    edgeEls.forEach((e) => {
      e.hitP.addEventListener("pointerenter", () => {
        if (focusedId) return;
        e.label.textContent = e.data.relation || cfg.defaultRelation;
        e.label.classList.add("show");
      });
      e.hitP.addEventListener("pointerleave", () => {
        if (focusedId) return;
        e.label.classList.remove("show");
      });
    });

    const panelCloseBtn = panelEl.querySelector<HTMLButtonElement>('[data-role="panel-close"]')!;
    function focusPanel() {
      // Keyboard users who opened the panel land inside it, not stuck on the node.
      panelCloseBtn.focus();
    }

    // ---------- panel: specimen ----------
    function openSpecimen(n: GNode) {
      panelEl.querySelector('[data-role="panel-k"]')!.textContent = "specimen";
      panelEl.querySelector('[data-role="panel-n"]')!.textContent = labelFor(n);
      panelEl.querySelector('[data-role="panel-b"]')!.textContent = n.blurb;
      const meta = panelEl.querySelector('[data-role="panel-meta"]')!;
      meta.innerHTML = "";
      const rows: [string, string | undefined][] = [
        ["material", n.material],
        ["constraint", n.constraint],
        ["tally", n.tally],
        ["maturity", n.stage ? `${n.stage} ${STAGE_GLYPH[n.stage] ?? ""}` : undefined],
      ];
      rows.forEach(([k, v]) => {
        if (!v) return;
        const row = document.createElement("div");
        row.innerHTML = `<span>${k}</span><b></b>`;
        row.querySelector("b")!.textContent = v;
        meta.appendChild(row);
      });
      panelEl.querySelector('[data-role="panel-sub"]')!.textContent = "";
      panelEl.querySelector('[data-role="panel-list"]')!.innerHTML = "";
      panelEl.classList.add("show");
      focusPanel();
    }

    // ---------- panel: bookmarks ----------
    function openBookmarkNode(n: GNode) {
      panelEl.querySelector('[data-role="panel-k"]')!.textContent = "term";
      panelEl.querySelector('[data-role="panel-n"]')!.textContent = labelFor(n);
      panelEl.querySelector('[data-role="panel-b"]')!.textContent = n.blurb;
      panelEl.querySelector('[data-role="panel-meta"]')!.innerHTML = "";
      const list = cfg.entries.filter((en) => en.nodeIds.includes(n.id));
      const sub = panelEl.querySelector('[data-role="panel-sub"]')!;
      sub.textContent = list.length ? "held in" : "not yet held in a published piece";
      const L = panelEl.querySelector('[data-role="panel-list"]')!;
      L.innerHTML = "";
      list.forEach((en) => {
        const row = document.createElement("div");
        row.className = "panel-item";
        const btn = document.createElement("button");
        btn.className = "panel-item-pivot";
        btn.type = "button";
        btn.textContent = en.label;
        btn.setAttribute("aria-label", `see the terms ${en.label} holds`);
        btn.addEventListener("focus", () => previewEntry(en));
        btn.addEventListener("mouseenter", () => previewEntry(en));
        btn.addEventListener("click", () => openBookmarkEntry(en));
        const link = document.createElement("a");
        link.href = base + en.href;
        link.className = "panel-item-link";
        link.textContent = "read →";
        row.appendChild(btn);
        if (en.meta) {
          const m = document.createElement("span");
          m.className = "panel-item-meta";
          m.textContent = en.meta;
          row.appendChild(m);
        }
        row.appendChild(link);
        L.appendChild(row);
      });
      focusedId = n.id;
      dimTo(new Set([n.id, ...list.flatMap((en) => en.nodeIds)]));
      panelEl.classList.add("show");
      focusPanel();
    }
    function previewEntry(en: GEntry) {
      dimTo(new Set(en.nodeIds));
    }
    function openBookmarkEntry(en: GEntry) {
      panelEl.querySelector('[data-role="panel-k"]')!.textContent = "entry";
      panelEl.querySelector('[data-role="panel-n"]')!.textContent = en.label;
      panelEl.querySelector('[data-role="panel-b"]')!.textContent = en.meta
        ? `${en.meta} — holds ${en.nodeIds.length} term${en.nodeIds.length === 1 ? "" : "s"}.`
        : `holds ${en.nodeIds.length} term${en.nodeIds.length === 1 ? "" : "s"}.`;
      panelEl.querySelector('[data-role="panel-meta"]')!.innerHTML = "";
      const sub = panelEl.querySelector('[data-role="panel-sub"]')!;
      sub.textContent = "terms it holds";
      const L = panelEl.querySelector('[data-role="panel-list"]')!;
      L.innerHTML = "";
      en.nodeIds.forEach((id) => {
        const n = byId.get(id);
        if (!n) return;
        const row = document.createElement("div");
        row.className = "panel-item";
        const btn = document.createElement("button");
        btn.className = "panel-item-pivot";
        btn.type = "button";
        btn.textContent = labelFor(n);
        btn.addEventListener("click", () => openBookmarkNode(n));
        row.appendChild(btn);
        L.appendChild(row);
      });
      const readRow = document.createElement("a");
      readRow.href = base + en.href;
      readRow.className = "panel-read-link";
      readRow.textContent = "read the piece →";
      L.appendChild(readRow);
      focusedId = en.id;
      dimTo(new Set(en.nodeIds));
      panelEl.classList.add("show");
      focusPanel();
    }

    let lastGraphNodeId: string | null = null;
    function openNode(n: GNode) {
      lastGraphNodeId = n.id;
      if (cfg.panel === "specimen") {
        focusedId = n.id;
        dimTo(new Set([n.id]));
        openSpecimen(n);
      } else {
        openBookmarkNode(n);
      }
    }
    function closePanel() {
      panelEl.classList.remove("show");
      focusedId = null;
      dimTo(null);
      const returnTo = lastGraphNodeId ? nodeEls.get(lastGraphNodeId)?.g : null;
      returnTo?.focus();
      lastGraphNodeId = null;
    }
    panelEl.querySelector('[data-role="panel-close"]')!.addEventListener("click", closePanel);
    // Escape closes from anywhere inside the panel too — not just from a
    // graph node's own keydown handler, since opening moves focus INTO the
    // panel (focusPanel()), where a node-scoped listener can no longer hear it.
    panelEl.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape") closePanel();
    });

    // ---------- lenses ----------
    if (cfg.lenses && cfg.lenses.length > 0) {
      const lensButtons = root.querySelectorAll<HTMLButtonElement>(".lens");
      const lensRead = root.querySelector<HTMLElement>('[data-role="lens-read"]')!;
      lensButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          lensButtons.forEach((b) => { b.classList.remove("on"); b.setAttribute("aria-selected", "false"); });
          btn.classList.add("on");
          btn.setAttribute("aria-selected", "true");
          const lens = cfg.lenses!.find((l) => l.key === btn.dataset.lens);
          if (!lens) return;
          activeLensKey = lens.key;
          lensRead.textContent = lens.read;
          nodes.forEach((n) => {
            const els = nodeEls.get(n.id)!;
            const current = labelFor(n);
            els.label.textContent = current;
            els.g.setAttribute("aria-label", `${current} — open its ${cfg.panel === "specimen" ? "specimen" : "bookmarks"}`);
          });
        });
      });
      lensButtons[0]?.classList.add("on");
    }
  }

  document.querySelectorAll<HTMLElement>(".graph-canvas[data-graph-id]").forEach(initGraph);
</script>

