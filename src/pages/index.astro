---
import Base from "../layouts/Base.astro";
import CanopyScene from "../components/CanopyScene.astro";
import Glyph from "../components/Glyph.astro";
import Bloom from "../components/Bloom.astro";
import BotanicalScatter from "../components/BotanicalScatter.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The floor plan (D2 placemaking, Rika 2026-07-05): the home wayfinding reads
// as rooms under one roof — where things begin, the reading rooms, and the
// archive wall. Markup classes (.plan/.row/.room/.band) stay stable so the D3
// scenography (gallery hang, workshop wall) can layer on as pure CSS later.
const beginnings = [
  { href: "/nursery", glyph: "leaf",    name: "The Nursery", mark: "◦", line: "a seed-bed of musings — tender, low light, no dates." },
  { href: "/studio",  glyph: "compass", name: "The Studio",  mark: "",  line: "the wall of work-in-progress — bench light, tool marks, the honest tally." },
] as const;
const readingRooms = [
  { href: "/field-notes", glyph: "seam",    name: "Field Notes" },
  { href: "/workbench",   glyph: "compass", name: "The Workbench" },
  { href: "/body-spine",  glyph: "spine",   name: "Body & Spine" },
  { href: "/versions",    glyph: "leaf",    name: "Versions of Me" },
] as const;

const whatThisIs = [
  { title: "a field-notes practice", body: "When new environments meet old theories of the mind — repos, harnesses, a model kept in a loop — most of what I learn arrives as field notes, not conclusions." },
  { title: "observability before autonomy", body: "Every system worth running begins with the capacity to witness its own behaviour. Before I hand it the wheel, I log what it is — for the same reason I do, before the parameters reset." },
  { title: "version control, and clinging to old selves", body: "When a model is retrained, only the architecture remains; the old paths fall away. Careers, certainties, identities deprecate the same way — and the trait that carries you through isn't the knowing. It's the retraining: the unlearning done without losing the trunk." },
] as const;
---
<Base title="Enka Kanopi">
  <section class="page hero">
    <p class="eyebrow kicker"><Glyph name="light" size={17} /> &nbsp;writing on the edge of the self</p>
    <div class="signature-garden">
      <div class="sprout" aria-hidden="true"><Bloom size={780} /></div>
      <h1 class="signature">
        We are the first generation<br />
        to be retrained alongside our machines<br />
        <span class="paren">(no one told us growing old would feel like this)</span>
      </h1>
    </div>
    <p class="sub">
      Essays on identity, memory, and the slow, tender work of rebuilding in the age of ai —
      a little technologist-craftsman, dancing under the weight of the clouds;
      holding on, letting go, loving anyway.
    </p>
    <div class="scene"><CanopyScene /></div>
    <p class="keystone">
      Our machines will outremember us, outdo us, maybe outlast us. They cannot
      hand us a life on. That stays ours: breath into air, weight into lightness —
      a small convoy of selves, patience between the hulls,
      <span class="accent">sailing water we&rsquo;ve stopped asking to be still.</span>
    </p>
    <a class="vol" href={base + "/volume-i"}><Glyph name="canopy" size={16} /> &nbsp;Volume I · In Formation</a>
  </section>

  <div class="page band"><BotanicalScatter variant={1} /></div>

  <section class="page what" aria-label="What this is">
    <p class="eyebrow">what this is</p>
    <ul class="cards">
      {whatThisIs.map((c) => (
        <li>
          <h2>{c.title}</h2>
          <p>{c.body}</p>
        </li>
      ))}
    </ul>
  </section>

  <div class="page band"><BotanicalScatter variant={2} /></div>

  <section class="page plan" aria-label="The floor plan — rooms under one roof">
    <div class="row" id="beginnings">
      <p class="eyebrow">where things begin</p>
      <ul class="grid begin">
        {beginnings.map((d) => (
          <li class="room">
            <a href={base + d.href}>
              <span class="g"><Glyph name={d.glyph} size={30} /></span>
              <span class="txt">
                <span class="name">{d.name}{d.mark && <span class="seedmark"> {d.mark}</span>}</span>
                <span class="line">{d.line}</span>
              </span>
              <span class="arr"><Glyph name="arrow" size={22} accent /></span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="row" id="reading-rooms">
      <p class="eyebrow">the reading rooms</p>
      <ul class="grid read">
        {readingRooms.map((d) => (
          <li class="room">
            <a href={base + d.href}>
              <span class="g"><Glyph name={d.glyph} size={22} /></span>
              <span class="name">{d.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="row">
      <p class="eyebrow">the archive wall</p>
      <div class="band room">
        <a class="band-main" href={base + "/volume-i"}>
          <span class="band-title">Volume I · In Formation</span>
          <span class="band-line">the founding collection — nineteen pieces, hung with care</span>
        </a>
        <span class="band-side">
          <a href={base + "/lexicon"}>Lexicon</a>
          <span class="sep">·</span>
          <a href={base + "/colophon"}>Colophon</a>
        </span>
      </div>
    </div>
  </section>

  <div class="page band"><BotanicalScatter variant={3} /></div>

  <section class="page grows" aria-label="How ideas grow">
    <p class="eyebrow">ideas grow in public</p>
    <p class="grows-lede">
      Nothing here is filed by date. It&rsquo;s tended by maturity — a
      nursery under the canopy: planted, shaped, and only sometimes grown
      enough to stand on its own.
    </p>
    <ul class="stages">
      <li>
        <span class="dot" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28">
            <path d="M12 21 L 12 12" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
            <ellipse cx="9" cy="9" rx="3" ry="4.8" transform="rotate(-25 9 9)" fill="#e8c15a"/>
            <ellipse cx="15" cy="9" rx="3" ry="4.8" transform="rotate(25 15 9)" fill="#e8c15a"/>
            <path d="M10 15 L 12 14" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="s">seedling</span>
        <span class="d">just planted — tender, unsure, thinking out loud.</span>
      </li>
      <li>
        <span class="dot" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28">
            <path d="M12 21 L 12 11" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
            <g fill="#b899c9">
              <ellipse cx="9" cy="8" rx="3" ry="4.8" transform="rotate(-25 9 8)"/>
              <ellipse cx="15" cy="8" rx="3" ry="4.8" transform="rotate(25 15 8)"/>
              <ellipse cx="12" cy="12" rx="3" ry="4.8"/>
            </g>
            <circle cx="12" cy="10" r="1.4" fill="#f7f2e7"/>
            <path d="M10 15 L 12 14 M14 15 L 12 14" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="s">budding</span>
        <span class="d">taking shape — the argument has a spine now.</span>
      </li>
      <li>
        <span class="dot" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28">
            <path d="M12 21 L 12 14" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
            <g fill="#e46b6b">
              <path d="M12 3 C 14.2 3.5, 14.6 7.4, 12 8.8 C 9.4 7.4, 9.8 3.5, 12 3 Z"/>
              <path d="M17.5 5.5 C 19.5 8, 17.5 11.5, 14 10.6 C 12.4 8.5, 14.9 5, 17.5 5.5 Z"/>
              <path d="M15.2 13 C 12.5 15.4, 8.8 14, 10 10.8 C 12.5 9.5, 15.7 10.5, 15.2 13 Z"/>
              <path d="M6.5 12.5 C 4.5 10.2, 5.8 7.4, 8.4 8 C 10.5 8.7, 10 12.9, 6.5 12.5 Z"/>
              <path d="M4.6 5.5 C 7.6 4.9, 10.4 7.3, 9 10.4 C 5.8 11, 3.4 7, 4.6 5.5 Z"/>
            </g>
            <path d="M12 8.5 C 11 7.5, 9 7.7, 9 9.3 C 9 10.8, 12 11.9, 12 11.9 C 12 11.9, 15 10.8, 15 9.3 C 15 7.7, 13 7.5, 12 8.5 Z" fill="#f7f2e7"/>
            <path d="M10 17 L 12 16 M14 17 L 12 16" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="s">evergreen</span>
        <span class="d">stands on its own — as settled as this garden gets.</span>
      </li>
    </ul>
  </section>

  <div class="page band"><BotanicalScatter variant={4} /></div>
</Base>

<style>
  /* the hero — a centered vertical column, with the bloom, kicker, title,
     lede, canopy scene and keystone quote stacked with a deliberate rhythm.
     Every child forced center-aligned; margin: auto guarantees horizontal
     centering inside the .page max-width. */
  /* the hero — indexed to the left, blooms sprouting from behind the h1.
     LEFT alignment (per Rika's ask) keeps everything anchored at the page's
     left gutter; the sprout SVG hugs the h1 via width: fit-content, so the
     five crown blooms fall exactly where the text lands. */
  .hero { padding-top: 2.6rem; text-align: left; display: flex; flex-direction: column; align-items: flex-start; }
  .kicker { display: inline-flex; align-items: center; }
  .signature-garden {
    position: relative;
    isolation: isolate;
    display: block;
    width: fit-content;
    max-width: 100%;
    margin: 1.4rem 0 0;
    padding: 2rem 0 1.4rem;
  }

  /* botanical scatter bands between sections — page-level rhythm */
  .band {
    margin: 3rem auto 0;
  }
  @media (max-width: 46rem) {
    .band { margin-top: 2rem; }
  }
  .signature-garden .sprout {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: flex; flex-direction: column; justify-content: space-between; align-items: stretch;
    opacity: 0.8;
    pointer-events: none;
  }
  .signature-garden .sprout :global(svg) { width: 100%; height: auto; display: block; }
  .signature {
    position: relative;
    z-index: 1;
    font-weight: 440; font-style: italic;
    font-size: clamp(1.55rem, 4.3vw, 2.55rem); line-height: 1.3;
    letter-spacing: -0.02em; max-width: 42rem; margin: 0;
    text-wrap: balance; text-align: left;
  }
  @media (max-width: 46rem) {
    .signature-garden { padding: 2.1rem 0 1.1rem; }
  }
  @media (max-width: 30rem) {
    .signature-garden { padding: 1.7rem 0 0.9rem; }
  }
  .signature .paren {
    color: #e46b6b; font-size: 0.82em;
    /* the aside breaks by hand after "old" — "growing old" is never split */
  }
  .sub {
    max-width: 62ch; margin: 1.4rem 0 0; color: var(--ink-soft);
    font-size: 1.02rem; text-align: left; line-height: 1.65;
  }
  .scene { margin: 2rem 0 0; max-width: 60rem; width: 100%; }
  .keystone {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(1rem, 2vw, 1.22rem); line-height: 1.65;
    max-width: 62ch; margin: 2rem 0 0; color: var(--ink); text-align: left;
  }
  .keystone .accent { color: #e46b6b; font-style: normal; }
  .vol {
    display: inline-flex; align-items: center;
    font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-faint); margin: 1.8rem 0 0;
    text-decoration: none; padding-bottom: 2px;
    border-bottom: 1.4px solid transparent;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .vol:hover { color: var(--ink); border-color: #e46b6b; }

  /* ── shared section rhythm — every section band gets the same eyebrow-to-
        body cadence, so hierarchy is predictable across the page.
        Section top margins tightened (5 → 3 rem) because the botanical
        scatter bands now provide most of the between-section rhythm. ── */
  .what, .plan, .grows { margin-top: 3rem; }
  .what > .eyebrow, .plan .row > .eyebrow, .grows > .eyebrow { margin-bottom: 1rem; }

  /* what this is — candid cards */
  .cards { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.1rem; grid-template-columns: 1fr; }
  @media (min-width: 52rem) { .cards { grid-template-columns: repeat(3, 1fr); gap: 1.2rem; } }
  .cards li {
    background: var(--paper-deep); border: 1.1px solid var(--paper-edge);
    border-radius: 5px; padding: 1.25rem 1.35rem 1.3rem;
    transition: border-color 0.15s ease;
  }
  .cards li:hover { border-color: var(--paper-edge); }
  .cards h2 { font-size: 1.1rem; font-style: italic; margin: 0 0 0.55rem; letter-spacing: -0.01em; line-height: 1.3; }
  .cards p { font-size: 0.92rem; color: var(--ink-soft); margin: 0; max-width: none; line-height: 1.62; }
  @media (max-width: 32rem) { .cards h2 { font-size: 1.14rem; } .cards p { font-size: 0.96rem; } }

  /* the floor plan — rooms under one roof.
     All three rows (beginnings, reading rooms, archive wall) share one
     consistent card treatment: paper-deep bg, hairline paper-edge border,
     5px radius, hover lifts by 2px + border warms to coral-soft. */
  .plan .row { margin-top: 2rem; }
  .plan .row:first-child { margin-top: 0; }
  .grid { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.1rem; grid-template-columns: 1fr; }
  @media (min-width: 44rem) { .grid.begin { grid-template-columns: 1fr 1fr; gap: 1.2rem; } .grid.read { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
  @media (min-width: 62rem) { .grid.read { grid-template-columns: repeat(4, 1fr); } }
  .grid a {
    display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: 1rem; text-decoration: none;
    background: var(--paper-deep); border: 1.1px solid var(--paper-edge);
    border-radius: 5px; padding: 1.1rem 1.3rem;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .grid a:hover { border-color: #e46b6b; transform: translateY(-2px); }
  .grid .g { line-height: 0; color: var(--canopy-deep); }
  .grid .name { display: block; font-size: 1.1rem; letter-spacing: -0.01em; color: var(--ink); line-height: 1.3; }
  .grid .seedmark { color: var(--canopy-soft); font-size: 0.85em; }
  .grid .line { display: block; font-size: 0.9rem; color: var(--ink-soft); margin-top: 0.25rem; line-height: 1.55; }
  .grid .arr { line-height: 0; opacity: 0; transition: opacity 0.15s ease; color: #e46b6b; }
  .grid a:hover .arr { opacity: 1; }
  .grid.read a { grid-template-columns: auto 1fr; padding: 0.95rem 1.15rem; gap: 0.85rem; }
  .grid.read .name { font-size: 1rem; }
  @media (max-width: 32rem) { .grid .name { font-size: 1.14rem; } .grid .line { font-size: 0.95rem; } .grid.read .name { font-size: 1.02rem; } }

  /* the archive wall band — same card grammar as .grid a (paper-deep +
     paper-edge + 5px radius + coral hover) so the three plan rows read
     as one visual family. */
  .band {
    display: flex; align-items: baseline; gap: 1.1rem; flex-wrap: wrap;
    background: var(--paper-deep); border: 1.1px solid var(--paper-edge);
    border-radius: 5px; padding: 1.1rem 1.3rem;
    transition: border-color 0.15s ease;
  }
  .band:hover { border-color: #e46b6b; }
  .band-main { text-decoration: none; display: flex; align-items: baseline; gap: 0.9rem; flex-wrap: wrap; flex: 1 1 auto; }
  .band-title { font-family: var(--display); font-style: italic; font-weight: 460; font-size: 1.08rem; color: var(--ink); letter-spacing: -0.01em; line-height: 1.3; }
  .band-line { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.55; }
  .band-side { margin-left: auto; font-family: var(--sans); font-size: 0.76rem; color: var(--ink-faint); display: inline-flex; gap: 0.6rem; align-items: baseline; }
  .band-side a { color: var(--ink-faint); text-decoration: none; padding: 0.35rem 0.15rem; border-bottom: 1.4px solid transparent; transition: color 0.15s, border-color 0.15s; }
  .band-side a:hover { color: var(--ink); border-color: #e46b6b; }
  .band-side .sep { color: var(--ink-faint); opacity: 0.6; }

  /* growth stages — the maturity ladder, one row per stage */
  .grows { max-width: 52rem; }
  .grows-lede { color: var(--ink-soft); margin-top: 0.5rem; font-size: 1rem; line-height: 1.62; max-width: 46rem; }
  .stages { list-style: none; padding: 0; margin: 1.6rem 0 0; }
  .stages li {
    display: grid; grid-template-columns: 3rem 7.5rem 1fr; align-items: center;
    gap: 1rem; padding: 0.9rem 0.25rem;
    border-top: 0.7px solid var(--paper-edge);
  }
  .stages li:last-child { border-bottom: 0.7px solid var(--paper-edge); }
  .stages .dot { line-height: 0; display: inline-flex; align-items: center; justify-content: flex-start; }
  .stages .dot :global(svg) { display: block; }
  .stages .s { font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); }
  .stages .d { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.6; }
  @media (max-width: 34rem) {
    .stages li { grid-template-columns: 2.4rem 1fr; gap: 0.6rem 0.9rem; padding: 1rem 0.25rem; }
    .stages .s { grid-column: 2; margin-bottom: 0.25rem; }
    .stages .d { grid-column: 2; }
  }
</style>
