---
import Base from "../layouts/Base.astro";
import CanopyFromAbove from "../components/CanopyFromAbove.astro";
import MaturityBud from "../components/motifs/MaturityBud.astro";
import MotifCloudDancer from "../components/motifs/MotifCloudDancer.astro";
import MotifTwoHulls from "../components/motifs/MotifTwoHulls.astro";
import MoonCrescent from "../components/motifs/memoria/MoonCrescent.astro";
import VineTrail from "../components/motifs/memoria/VineTrail.astro";
import ScriptHeart from "../components/motifs/memoria/ScriptHeart.astro";
import Glyph from "../components/Glyph.astro";
import Bloom from "../components/Bloom.astro";
import GraphCanvas from "../components/interactive/GraphCanvas.astro";
import { lexiconConfig } from "../components/interactive/lexicon.config";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The nine rooms (Charter §3 Zone 3 — "the surfaces"), absorbing the old
// floor-plan (beginnings/reading-rooms) and archive-wall band into one grid.
// Every register + line below is reused from copy already shipped elsewhere
// (this page's own prior card lines for Nursery/Studio; each room's own hub
// `description`/eyebrow for the rest) — nothing here is newly authored.
// Maturity + register also drive the CanopyFromAbove map, so the two stay
// in lockstep by construction (one data source, not two).
const rooms = [
  { slug: "nursery", href: base + "/nursery", name: "The Nursery", glyph: "leaf",
    register: "where things begin", maturity: "seedling",
    blurb: "a seed-bed of musings — tender, low light, no dates." },
  { slug: "studio", href: base + "/studio", name: "The Studio", glyph: "compass",
    register: "the making, shown", maturity: "budding",
    blurb: "the wall of work-in-progress — bench light, tool marks, the honest tally." },
  { slug: "field-notes", href: base + "/field-notes", name: "Field Notes", glyph: "seam",
    register: "the diary", maturity: "budding",
    blurb: "short letters from the seams between versions of a self — wabi-sabi, letting go, a self legible only in motion." },
  { slug: "workbench", href: base + "/workbench", name: "The Workbench", glyph: "compass",
    register: "maker · tinkerer", maturity: "evergreen",
    blurb: "a living practice log — rebuilding maker foundations as an adult, the slow arc toward code and space as media." },
  { slug: "body-spine", href: base + "/body-spine", name: "Body & Spine", glyph: "spine",
    register: "the mind-body thread", maturity: "budding",
    blurb: "spine work, skating, mat work — movement as the ground truth the head kept overruling." },
  { slug: "versions", href: base + "/versions", name: "Versions of Me", glyph: "leaf",
    register: "the identity room", maturity: "evergreen",
    blurb: "a hand-drawn map of the selves that won't average into one." },
  { slug: "lexicon", href: base + "/lexicon", name: "Lexicon", glyph: "compass",
    register: "the coined terms", maturity: "evergreen",
    blurb: "the named frameworks this garden tends — the container beneath the craft, the deflation of execution, form follows life." },
  { slug: "colophon", href: base + "/colophon", name: "Colophon", glyph: "light",
    register: "the origin-of-record", maturity: "evergreen",
    blurb: "what this place is, and how it is made — by hand, in company with a small crew of machines." },
  { slug: "volume-i", href: base + "/volume-i", name: "Volume I · In Formation", label: "Volume I", glyph: "canopy",
    register: "the archive wall", maturity: "evergreen",
    blurb: "the founding collection and the merging-frontier trilogy — twenty-two pieces, hung by theme." },
] as const;
---
<Base title="Enka Kanopi">
  {/* ZONE 1 — the painted canopy hero (Charter §3 Zone 1 · rule-7 hero lane).
      Rika, 2026-07-14 (fourth pass): the canopy now leads straight into the
      ideas graph — "ensō then the garden map," nothing between them. The
      identity block (tagline/H1/lede/materiality) moves to the bottom, into
      Zone 4 (see below), rather than interrupting canopy → map. */}
  <section class="page hero">
    <div class="canopy-slot">
      <CanopyFromAbove
        rooms={rooms}
        headingId="the-garden-from-above"
        eyebrow="enka kanopi · a view from above"
        heading="the garden, from above"
        intro="A curated space of thought — drawn to systems, visual art, research, and experimental craft; learning, every day. Nine rooms grow from one crown, a living map, not a menu — move over a leaf-mass to feel it stir."
      />
    </div>
  </section>

  <section class="page ideas" aria-label="The garden's ideas, and how they hold together">
    <GraphCanvas
      {...lexiconConfig}
      headingId="the-gardens-ideas"
      heading="the garden's ideas, and how they hold together"
      intro="A living map of the named frameworks this garden tends, and the pieces that hold them. The full lexicon — every term, defined — is one click further."
      animateNodes={true}
    />
    <p class="ideas-more"><a class="vol" href={base + "/lexicon"}><Glyph name="canopy" size={16} /> &nbsp;the full Lexicon →</a></p>
  </section>

  {/* ZONE 3 — the surfaces: nine rooms, one garden (Charter §3 Zone 3).
      Absorbs the old "where things begin" / "reading rooms" / "archive
      wall" rows into one legible grid. */}
  <section class="page surfaces" aria-label="The surfaces — nine rooms, one garden">
    <p class="eyebrow">the surfaces</p>
    <h2 class="surfaces-h">nine rooms, one garden</h2>
    {/* card design ported from GARDEN-SCULPT/canopy-home-map.html's
        "nine rooms, one garden" cards (Rika, 2026-07-14): numbered index,
        a left-border accent keyed to the room's own maturity token, and
        the "maturity · **stage**" line — no new colours, no fabricated
        accent per room (the accent IS the existing growth-stage token). */}
    <ul class="grid rooms">
      {rooms.map((r, i) => (
        <li class="room">
          <a class="card" style={`--accent: var(--${r.maturity})`} href={r.href} aria-label={`${r.name} — ${r.register}. ${r.blurb}`}>
            <span class="idx">{String(i + 1).padStart(2, "0")} · from above</span>
            <span class="reg">{r.register}</span>
            <span class="name"><Glyph name={r.glyph} size={19} /> {r.name}</span>
            <span class="line">{r.blurb}</span>
            <span class="mat">maturity · <b>{r.maturity}</b></span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {/* ZONE 4 — the keystone, the deeper payoff (Charter §3 Zone 4).
      Rika, 2026-07-14 (fourth pass): the identity block (tagline / H1 /
      hand-invitation / lede / materiality / Zone-1 clause / Volume I link)
      moves here from the hero, so the canopy can lead straight into the
      ideas graph with nothing between them ("ensō then the garden map").
      Same words, same centred treatment — just relocated, not duplicated. */}
  <section class="page payoff" aria-label="The deeper payoff">
    <div class="identity-close">
      <p class="eyebrow kicker"><Glyph name="light" size={17} /> &nbsp;writing on the edge of the self</p>
      <div class="signature-garden">
        <div class="sprout" aria-hidden="true"><Bloom size={780} /></div>
        <h1 class="signature">
          We are the first generation<br />
          to be retrained alongside our machines<br />
          <span class="paren">(no one told us growing old would feel like this)</span>
        </h1>
      </div>
      <div class="signature-notch" aria-hidden="true">
        <svg viewBox="0 0 120 22" width="140" height="22">
          <path d="M6 14 C 24 8, 46 8, 58 12" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.78"/>
          <path d="M58 12 C 70 8, 92 8, 114 14" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.78"/>
          <circle cx="58" cy="12" r="1.4" fill="var(--poppy-soft)" opacity="0.92"/>
          <path d="M52 4 L 54 4" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.55"/>
          <path d="M66 4 L 68 4" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linecap="round" opacity="0.55"/>
        </svg>
      </div>

      <p class="hand-invitation">nothing here asks you for anything</p>

      <p class="sub">
        Essays on identity, memory, and the tender work of rebuilding in the age of AI —
        making &amp; honouring the craft on light feet
        <span class="doodle" role="img" aria-label="dancing under the weight of the clouds"><MotifCloudDancer size={40} /></span>
        ; holding on, letting go, loving anyway.
      </p>
      <p class="pepper pepper-moon" aria-hidden="true"><MoonCrescent size={38} /></p>

      {/* the materiality passage (Charter §2 #2 · verbatim from the study —
          this exact wording is the canon material named in the Charter/ship-
          prompt, not newly authored here). */}
      <p class="materiality">
        Seen from above, a canopy is not a wall but a <b>weave</b> — light does
        not stop at it, it comes <em>through</em>, changed and dappled and
        warmer. <b>A home you enter by looking up.</b> Not a hierarchy read
        top-down, but a shelter that holds without fixing — margin drawn to
        centre, the many kept, the tender kept.
      </p>

      {/* Zone-1 heartbeat (Charter §3): one distilled clause, reused verbatim
          from the keystone right below — PROPOSED, Rika's to ratify or
          redline; not authored here. */}
      <p class="up-top">
        <span class="proposed-tag">PROPOSED · ratify</span>
        a small convoy of selves, <span class="accent">sailing deep water we&rsquo;ve stopped asking to be still.</span>
      </p>

      <a class="vol" href={base + "/volume-i"}><Glyph name="canopy" size={16} /> &nbsp;Volume I · In Formation</a>
    </div>

    <figure class="hero-figure">
      <figcaption class="keystone">
        Our machines will outremember us, outdo us — maybe outlast us. A life,
        though — brief, and bright while it lasts — is theirs to admire, never
        to hand to us. That stays ours: breath to air, weight to lightness;
        a small convoy of selves
        <span class="doodle" role="img" aria-label="with patience between the hulls"><MotifTwoHulls size={64} /></span>
        ,
        <span class="accent">sailing deep water we&rsquo;ve stopped asking to be still.</span>
      </figcaption>
    </figure>
    <p class="pepper pepper-heart" aria-hidden="true"><ScriptHeart size={42} /></p>
    <p class="pepper pepper-vine" aria-hidden="true"><VineTrail size={280} /></p>

    <div class="grows">
      <p class="eyebrow">ideas grow in public</p>
      <p class="grows-lede">
        Nothing here is filed by date. It&rsquo;s tended by maturity — a
        nursery under the canopy: planted, shaped, and only sometimes grown
        enough to stand on its own.
      </p>
      <ul class="stages">
        <li>
          <span class="dot" aria-hidden="true"><MaturityBud stage="seedling" /></span>
          <span class="s">seedling</span>
          <span class="d">just planted — tender, unsure, thinking out loud.</span>
        </li>
        <li>
          <span class="dot" aria-hidden="true"><MaturityBud stage="budding" /></span>
          <span class="s">budding</span>
          <span class="d">taking shape — the argument has a spine now.</span>
        </li>
        <li>
          <span class="dot" aria-hidden="true"><MaturityBud stage="evergreen" /></span>
          <span class="s">evergreen</span>
          <span class="d">stands on its own — as settled as this garden gets.</span>
        </li>
      </ul>
    </div>

    <p class="hand-correspondence">if something here finds you — the garden keeps a line open</p>
  </section>
</Base>

<style>
  /* the hero — the canopy only (Rika, 2026-07-14, fourth pass): leads
     straight into the ideas graph, nothing between them. */
  .hero { padding-top: 1.8rem; position: relative; text-align: center; }
  .hero::before {
    content: "";
    position: absolute;
    inset: -1rem -2rem -1rem -2rem;
    background:
      radial-gradient(ellipse 65% 55% at 50% 50%, var(--paper-washi) 0%, rgba(251, 248, 238, 0.75) 40%, rgba(251, 248, 238, 0) 78%);
    z-index: -2;
    pointer-events: none;
  }
  /* the identity block — moved to Zone 4 (fourth pass): the same centred
     sequence matching canopy-home-map.html's own order (tagline → H1 →
     lede → materiality), just relocated so it no longer sits between the
     canopy and the ideas graph. The sitewide `p { max-width: var(--measure) }`
     rule caps each of these below full width; margin: auto centres that
     capped box itself (the same fix as the canopy's own fine print). */
  .identity-close { text-align: center; margin-bottom: 3rem; }
  .identity-close > p, .identity-close > .signature-garden, .identity-close > .signature-notch {
    margin-left: auto; margin-right: auto;
  }
  .kicker { display: inline-flex; align-items: center; }
  .signature-garden {
    position: relative;
    isolation: isolate;
    display: block;
    width: fit-content;
    max-width: 100%;
    margin-top: 2.2rem;
    padding: 2rem 0 1.4rem;
  }
  .signature-garden .sprout {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: flex; flex-direction: column; justify-content: space-between; align-items: stretch;
    opacity: 0.58;
    pointer-events: none;
  }
  .signature-garden .sprout :global(svg) { width: 100%; height: auto; display: block; }
  .signature {
    position: relative;
    z-index: 1;
    font-weight: 520; font-style: italic;
    font-size: clamp(1.88rem, 5.5vw, 2.72rem); line-height: 1.28;
    letter-spacing: -0.022em; max-width: 42rem; margin: 0 auto;
    text-wrap: balance; text-align: center;
  }
  @media (min-width: 60rem) {
    .signature { font-size: clamp(2.32rem, 6.4vw, 3.7rem); max-width: 58rem; }
  }
  .signature-notch { display: block; width: fit-content; margin-top: 0.9rem; opacity: 0.72; }
  .signature-notch svg { display: block; }

  .hand-invitation {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: 1.4;
    margin-top: 0.9rem;
    max-width: 42ch;
    letter-spacing: 0.005em;
    opacity: 0.92;
  }
  @media (max-width: 32rem) { .hand-invitation { font-size: 1.12rem; } }

  .hand-correspondence {
    font-family: var(--hand);
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: 1.4;
    margin: 2.2rem 0 0;
    max-width: 46ch;
    letter-spacing: 0.005em;
    opacity: 0.92;
  }
  @media (max-width: 32rem) { .hand-correspondence { font-size: 1.12rem; } }
  @media (max-width: 46rem) {
    .signature-garden { padding: 2.1rem 0 1.1rem; }
  }
  @media (max-width: 30rem) {
    .signature-garden { padding: 1.7rem 0 0.9rem; }
  }
  .signature .paren {
    color: #e46b6b; font-size: 0.82em;
  }

  /* the canopy hero visual — opens the page, full-bleed within the measure */
  .canopy-slot { margin: 0 auto; max-width: 62rem; width: 100%; }

  /* the materiality passage — the read-the-light framing beneath the map */
  .materiality {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(0.98rem, 1.8vw, 1.12rem); line-height: 1.7;
    max-width: 56rem; margin-top: 1.8rem; color: var(--ink-soft); text-align: center;
  }
  .materiality b { font-weight: 500; font-style: normal; color: var(--ink); }

  /* Zone-1 heartbeat — one distilled clause, quiet, clearly marked PROPOSED */
  .up-top {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(1rem, 2vw, 1.16rem); line-height: 1.6;
    max-width: 46rem; margin-top: 1.4rem; color: var(--ink); text-align: center;
  }
  .up-top .accent { color: #e46b6b; font-style: normal; font-size: 0.96em; }
  .proposed-tag {
    display: block; font-family: var(--sans); font-style: normal;
    font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 0.35rem;
  }

  .scene { margin: 0; max-width: 60rem; width: 100%; }
  .hero-figure {
    margin: 2rem 0 0;
    max-width: 60rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-self: stretch;
  }
  .keystone {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(1rem, 2vw, 1.22rem); line-height: 1.65;
    max-width: 62ch; margin: 0; color: var(--ink); text-align: left;
  }
  .keystone .accent {
    color: #e46b6b; font-style: normal;
    font-size: 0.94em;
  }
  @media (min-width: 60rem) {
    .keystone { max-width: 58rem; line-height: 1.7; }
  }
  .sub .doodle, .keystone .doodle {
    display: inline-block; vertical-align: middle;
    line-height: 0; margin: 0 0.15em;
  }
  .sub .doodle :global(svg), .keystone .doodle :global(svg) {
    display: inline-block; vertical-align: middle;
  }
  .pepper { margin: 0; line-height: 0; opacity: 0.94; }
  /* the moon sits in the hero now (Rika, 2026-07-14 third pass) — its box
     centres like every other hero paragraph; text-align:right keeps the
     moon itself toward that centred box's own right edge. */
  .pepper-moon { text-align: right; margin: 0.6rem auto 0; }
  .pepper-vine { display: flex; justify-content: center; margin: 3rem 0 0; opacity: 0.88; }
  .pepper-vine :global(svg) { max-width: 100%; height: auto; }
  .pepper-heart { text-align: right; margin: 0.6rem 0.4rem 0 0; }
  .vol {
    display: inline-flex; align-items: center;
    font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-faint); margin: 1.8rem 0 0;
    text-decoration: none; padding-bottom: 2px;
    border-bottom: 1.4px solid transparent;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .vol:hover { color: var(--ink); border-color: #e46b6b; }

  /* ── shared section rhythm ────────────────────────────────────────────── */
  .surfaces, .payoff { margin-top: 5rem; }
  .surfaces > .eyebrow { margin-bottom: 0.4rem; }
  .surfaces-h { font-family: var(--display); font-weight: 500; font-style: italic; font-size: clamp(1.3rem, 3vw, 1.7rem); margin: 0 0 1.3rem; color: var(--ink); }

  .ideas { margin-top: 3rem; }
  .ideas-more { margin: 0.6rem 0 0; }
  .ideas-more .vol { margin-top: 0; }

  .sub {
    max-width: 62ch; margin-top: 1.4rem; color: var(--ink-soft);
    font-size: 1.02rem; text-align: center; line-height: 1.65;
  }
  @media (min-width: 60rem) {
    .sub { max-width: 52rem; font-size: 1.14rem; line-height: 1.7; }
  }

  /* the surfaces — nine rooms, one garden. Card design ported from the
     canopy-home-map study (Rika, 2026-07-14): numbered index, a left-
     border accent keyed to each room's own maturity token, refined
     shadow-lift on hover. */
  .grid { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.1rem; grid-template-columns: 1fr; }
  @media (min-width: 44rem) { .grid.rooms { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 68rem) { .grid.rooms { grid-template-columns: repeat(3, 1fr); } }
  .grid > .room { display: flex; }
  .grid a.card {
    position: relative; display: flex; flex-direction: column; gap: 0.4rem;
    width: 100%; text-decoration: none; overflow: hidden;
    background: var(--paper); border: 1px solid var(--paper-edge); border-radius: 13px;
    padding: 1.3rem 1.4rem 1.15rem;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .grid a.card::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: var(--accent, var(--canopy)); opacity: 0.75;
  }
  .grid a.card:hover, .grid a.card:focus-visible {
    transform: translateY(-3px); box-shadow: 0 14px 32px rgba(70, 60, 35, 0.1); border-color: var(--canopy-soft);
  }
  /* text stays a fixed, AA-safe tone regardless of maturity — only the
     left-border bar (decorative, not text) carries the per-room accent.
     --seedling on --paper fails small-text contrast; ink-faint does too
     (the same fix this codebase already made once for .band-side). */
  .grid .idx { font-family: var(--display); font-size: 0.72rem; color: var(--ink-soft); letter-spacing: 0.04em; }
  .grid .reg { font-family: var(--sans); font-size: 0.64rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--canopy-deep); }
  .grid .name { display: flex; align-items: center; gap: 0.4rem; font-family: var(--display); font-style: italic; font-weight: 600; font-size: 1.06rem; color: var(--ink); line-height: 1.28; margin-top: 0.05rem; }
  .grid .line { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.58; }
  .grid .mat { margin-top: 0.35rem; font-family: var(--display); font-size: 0.72rem; color: var(--ink-soft); letter-spacing: 0.06em; }
  .grid .mat b { color: var(--canopy-deep); font-weight: 500; font-style: italic; }
  @media (max-width: 32rem) { .grid .name { font-size: 1.1rem; } .grid .line { font-size: 0.94rem; } }

  /* growth stages — the maturity ladder, one row per stage */
  .grows { max-width: 52rem; margin-top: 4rem; }
  .grows-lede { color: var(--ink-soft); margin-top: 0.5rem; font-size: 1rem; line-height: 1.62; max-width: 46rem; }
  .stages { list-style: none; padding: 0; margin: 1.6rem 0 0; }
  .stages li {
    display: grid; grid-template-columns: 3rem 7.5rem 1fr; align-items: center;
    gap: 1rem; padding: 0.9rem 0.25rem;
    border-top: 0.7px solid var(--paper-edge);
  }
  .stages li:last-child { border-bottom: 0.7px solid var(--paper-edge); }
  .stages .dot { line-height: 0; display: inline-flex; align-items: center; justify-content: flex-start; }
  .stages .dot :global(svg) { display: block; }
  .stages .s { font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); }
  .stages .d { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.6; }
  @media (max-width: 34rem) {
    .stages li { grid-template-columns: 2.4rem 1fr; gap: 0.6rem 0.9rem; padding: 1rem 0.25rem; }
    .stages .s { grid-column: 2; margin-bottom: 0.25rem; }
    .stages .d { grid-column: 2; }
  }
</style>
