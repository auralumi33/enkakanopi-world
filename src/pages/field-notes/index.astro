---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EssayList from "../../components/EssayList.astro";
import NotesFromMargin from "../../components/NotesFromMargin.astro";
import Glyph from "../../components/Glyph.astro";

const entries = (await getCollection("fieldNotes")).sort((a, b) => a.data.order - b.data.order);
const items = entries.map((e) => ({ slug: e.id, ...e.data }));
---
<Base title="Field Notes" description="Short letters from the seams between versions of a self — on wabi-sabi, letting go, canopy, and staying honestly unfinished.">
  <section class="page head">
    <p class="eyebrow"><Glyph name="seam" size={18} /> &nbsp;the diary</p>
    <h1>Field Notes</h1>
    <p class="lede">
      Short letters, written from the seams — the joins between one version of a
      self and the next. They do not resolve; they are not meant to. Each one
      ends inside the question it opened.
    </p>
  </section>
  <section class="page listing">
    <EssayList items={items} basePath="/field-notes" />
  </section>
  <section class="page">
    <NotesFromMargin />
  </section>
</Base>
<style>
  .head { max-width: 46rem; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.18rem; color: var(--ink-soft); margin-top: 1rem; max-width: 52ch; }
  .listing { max-width: 46rem; margin-top: 1.5rem; }
</style>
