---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EssayList from "../../components/EssayList.astro";
import NotesFromMargin from "../../components/NotesFromMargin.astro";
import Glyph from "../../components/Glyph.astro";
import RowPlanter from "../../components/RowPlanter.astro";
import PanelDoors, { type Panel } from "../../components/PanelDoors.astro";

const entries = (await getCollection("fieldNotes")).sort((a, b) => a.data.order - b.data.order);
const items = entries.map((e) => ({ slug: e.id, ...e.data }));

// The hub doors — stage-exemplar entrances derived from frontmatter, not
// invented groupings. One door per canonical stage (Law 9: growth stage is
// the axis). Each door lands the reader in the highest-order essay at that
// stage, so the door itself carries a real reading path forward.
const doors: Panel[] = [
  { hue: "lavender", role: "the seedling",  caption: "a fiction we grew up inside · the shelf tilted · smile at the door",     href: "/field-notes/a-fiction-we-grew-up-inside", cta: "enter A Fiction We Grew Up Inside" },
  { hue: "gold",     role: "the budding",   caption: "the white bear · damn is turning to look · smile in the mercy",           href: "/field-notes/the-white-bear",             cta: "enter The White Bear" },
  { hue: "coral",    role: "the evergreen", caption: "the silent workspace · held long enough to become · smile in the J-space", href: "/field-notes/the-silent-workspace",       cta: "enter The Silent Workspace" },
];
---
<Base title="Field Notes" description="Short letters from the seams between versions of a self — on wabi-sabi, letting go, a self legible only in motion, and staying honestly unfinished.">
  <section class="page head">
    <div class="planter"><RowPlanter lead="lavender" size={148} /></div>
    <p class="eyebrow"><Glyph name="seam" size={18} /> &nbsp;the diary</p>
    <h1>Field Notes</h1>
    <p class="lede">
      Short letters, written from the seams — the joins between one version of a
      self and the next. They do not resolve; they are not meant to. Each one
      ends inside the question it opened.
    </p>
  </section>
  <section class="page doors">
    <PanelDoors
      panels={doors}
      variant="hub"
      ariaLabel="Field Notes hub doors — three reading paths, one per growth stage"
      signature="one door per stage · the axis is maturity, not date"
    >
      <!-- 紫 · lavender · the seedling → A Fiction We Grew Up Inside -->
      <svg slot="vignette-1" viewBox="0 0 200 220" role="img" aria-labelledby="fn-l-t"><title id="fn-l-t">A tilted book with a lavender bloom holding a hidden smile at the corner</title>
        <rect x="10" y="10" width="180" height="200" fill="#b899c9" opacity="0.10" rx="1"/>
        <g transform="translate(100 130) rotate(-8)">
          <rect x="-52" y="-38" width="104" height="72" fill="var(--paper-washi)" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.6" stroke-linejoin="round"/>
          <line x1="-52" y1="-38" x2="-52" y2="34" stroke="var(--ink-soft)" stroke-width="0.55" opacity="0.7"/>
          <path d="M -42 -22 C -20 -24, 8 -22, 42 -22" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.5" stroke-linecap="round"/>
          <path d="M -42 -8 C -20 -10, 8 -8, 42 -8"     stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.5" stroke-linecap="round"/>
          <path d="M -42 6 C -20 4, 8 6, 42 6"          stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.5" stroke-linecap="round"/>
          <path d="M -42 20 C -20 18, 8 20, 30 20"      stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.5" stroke-linecap="round"/>
        </g>
        <g transform="translate(146 78)">
          <g fill="#b899c9" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.32" stroke-linejoin="round">
            <path d="M0 -6 C 3.5 -5, 4.5 -1.6, 0 -0.4 C -4.5 -1.6, -3.5 -5, 0 -6 Z"/>
            <path d="M5 -2.5 C 6 2.5, 2.5 4, 0.5 2.4 C 0 -0.4, 3.5 -4.5, 5 -2.5 Z"/>
            <path d="M3.5 4 C 0 5, -3.5 2.4, -1.2 0 C 2 -1.7, 5 1.6, 3.5 4 Z"/>
            <path d="M-4.5 2.5 C -6 -1.6, -4.5 -4, -1 -2.4 C 0 0, -1.6 4, -4.5 2.5 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.2" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.6 -0.15 C -0.35 0.05, 0.35 0.05, 0.6 -0.15" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round"/>
        </g>
      </svg>

      <!-- 金 · gold · the budding → The White Bear -->
      <svg slot="vignette-2" viewBox="0 0 200 220" role="img" aria-labelledby="fn-g-t"><title id="fn-g-t">A small bear silhouette at the page edge with a hand-caveat 'damn' smoke curl and a hidden smile</title>
        <rect x="10" y="10" width="180" height="200" fill="#e8c15a" opacity="0.11" rx="1"/>
        <path d="M 20 175 L 180 175" stroke="var(--ink-soft)" stroke-width="0.55" opacity="0.55" stroke-linecap="round"/>
        <path d="M 20 175 L 20 55 L 155 55" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.55" stroke-linecap="round"/>
        <g transform="translate(100 148)">
          <ellipse cx="0" cy="0" rx="26" ry="18" fill="var(--paper-washi)" opacity="0.95" stroke="var(--ink-soft)" stroke-width="0.55"/>
          <ellipse cx="-18" cy="-14" rx="6" ry="7" fill="var(--paper-washi)" opacity="0.95" stroke="var(--ink-soft)" stroke-width="0.5"/>
          <circle cx="-22" cy="-19" r="2.6" fill="var(--paper-washi)" opacity="0.95" stroke="var(--ink-soft)" stroke-width="0.4"/>
          <circle cx="-15" cy="-18" r="2.4" fill="var(--paper-washi)" opacity="0.95" stroke="var(--ink-soft)" stroke-width="0.4"/>
          <circle cx="-20" cy="-14" r="0.6" fill="var(--ink-soft)"/>
          <path d="M -20 -11 C -19.6 -10.7, -18.8 -10.7, -18.4 -11" stroke="var(--ink-soft)" stroke-width="0.32" fill="none" stroke-linecap="round"/>
        </g>
        <path d="M 130 105 C 138 92, 132 78, 142 68 C 152 62, 158 70, 152 78" stroke="#e8c15a" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.7"/>
        <text font-family="var(--hand)" x="146" y="60" font-size="10" text-anchor="start" font-style="italic" fill="var(--ink-soft)" opacity="0.72">damn.</text>
        <g transform="translate(70 100)">
          <circle cx="0" cy="0" r="2.2" fill="#e8c15a" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.35"/>
          <path d="M -0.9 -0.2 C -0.55 0.1, 0.55 0.1, 0.9 -0.2" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
        </g>
      </svg>

      <!-- 珊瑚 · coral · the evergreen → The Silent Workspace -->
      <svg slot="vignette-3" viewBox="0 0 200 220" role="img" aria-labelledby="fn-c-t"><title id="fn-c-t">A keyhole aperture with hairline horizontal J-space bands and a coral bloom held inside</title>
        <rect x="10" y="10" width="180" height="200" fill="#e46b6b" opacity="0.08" rx="1"/>
        <path d="M 100 45 C 60 45, 45 78, 45 108 C 45 128, 55 148, 75 158 C 80 162, 85 168, 85 178 L 115 178 C 115 168, 120 162, 125 158 C 145 148, 155 128, 155 108 C 155 78, 140 45, 100 45 Z" fill="var(--paper-washi)" opacity="0.75" stroke="var(--ink-soft)" stroke-width="0.65" stroke-linejoin="round"/>
        <g stroke="var(--ink-soft)" stroke-width="0.4" fill="none" opacity="0.55" stroke-linecap="round">
          <path d="M 60 82 C 80 82, 120 82, 140 82"/>
          <path d="M 55 96 C 78 96, 122 96, 145 96"/>
          <path d="M 52 110 C 76 110, 124 110, 148 110"/>
          <path d="M 55 124 C 78 124, 122 124, 145 124"/>
          <path d="M 60 138 C 80 138, 120 138, 140 138"/>
        </g>
        <g transform="translate(100 110)">
          <g fill="#e08d84" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.32" stroke-linejoin="round">
            <path d="M 0 -6 C 3.5 -5, 4.5 -1.6, 0 -0.4 C -4.5 -1.6, -3.5 -5, 0 -6 Z"/>
            <path d="M 5 -2.5 C 6 2.5, 2.5 4, 0.5 2.4 C 0 -0.4, 3.5 -4.5, 5 -2.5 Z"/>
            <path d="M 3.5 4 C 0 5, -3.5 2.4, -1.2 0 C 2 -1.7, 5 1.6, 3.5 4 Z"/>
            <path d="M -4.5 2.5 C -6 -1.6, -4.5 -4, -1 -2.4 C 0 0, -1.6 4, -4.5 2.5 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.6 -0.15 C -0.35 0.1, 0.35 0.1, 0.6 -0.15" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
    </PanelDoors>
  </section>
  <section class="page listing">
    <EssayList items={items} basePath="/field-notes" />
  </section>
  <section class="page">
    <NotesFromMargin />
  </section>
</Base>
<style>
  .head { max-width: 46rem; }
  .head .planter { margin-bottom: 0.9rem; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 54ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  .listing { max-width: 46rem; margin-top: 1.5rem; }
</style>
