---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Glyph from "../components/Glyph.astro";
import StageTag from "../components/StageTag.astro";
import MotifPressedNineteen from "../components/motifs/MotifPressedNineteen.astro";
import MotifEnso from "../components/motifs/MotifEnso.astro";
import MotifArchiveGate from "../components/motifs/MotifArchiveGate.astro";
import MotifTreeFriend from "../components/motifs/MotifTreeFriend.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// The founding collection — every piece keeps its place (URLs unchanged).
const [fieldNotes, workbench, bodySpine] = await Promise.all([
  getCollection("fieldNotes"),
  getCollection("workbench"),
  getCollection("bodySpine"),
]);

type Piece = {
  href: string;
  title: string;
  dek: string;
  stage: "seedling" | "budding" | "evergreen";
  tended?: string;
};
const pieces = new Map<string, Piece>();
const shelve = (entries: typeof fieldNotes, path: string) => {
  for (const e of entries)
    pieces.set(e.id, {
      href: `${path}/${e.id}`,
      title: e.data.title,
      dek: e.data.dek,
      stage: e.data.stage,
      tended: e.data.tended,
    });
};
shelve(fieldNotes, "/field-notes");
shelve(workbench, "/workbench");
shelve(bodySpine, "/body-spine");

// Hung by theme, not by collection — the wall is curated, not filed.
const clusters = [
  {
    label: "the merging frontier",
    slugs: ["a-fiction-we-grew-up-inside", "the-silent-workspace", "the-white-bear"],
  },
  {
    label: "home & the rebuild",
    slugs: ["the-keel-not-the-harbour", "a-home-you-keep-rebuilding", "the-room-i-left", "in-formation"],
  },
  {
    label: "the machines",
    slugs: ["the-company-of-machines", "who-gets-to-write-to-you", "what-the-machine-remembers-of-me", "hallucinations-of-the-past"],
  },
  {
    label: "the selves",
    slugs: ["the-seam", "only-in-motion", "fragments-that-rhyme", "the-weather-and-the-sky", "the-detours-were-the-voyage"],
  },
  {
    label: "the hands",
    slugs: ["why-start-with-the-hands", "trust-the-little-kit", "the-shape-of-things"],
  },
  {
    label: "the body",
    slugs: ["relearning-to-fall", "articulation", "the-tide-knows-when"],
  },
].map((c) => ({
  label: c.label,
  items: c.slugs.map((s) => {
    const p = pieces.get(s);
    if (!p) throw new Error(`volume-i: no piece found for slug "${s}"`);
    return p;
  }),
}));

const hung = clusters.reduce((n, c) => n + c.items.length, 0);
if (hung !== pieces.size) throw new Error(`volume-i: ${hung} pieces hung, ${pieces.size} in the collection`);
---
<Base
  title="Volume I · In Formation"
  description="The founding collection and the merging-frontier trilogy — twenty-two pieces, hung by theme, every one still tended. A completed opening movement plus notes from inside the current turn; the wobble kept in view, and the coda folded into the Colophon so the whole garden speaks in one voice."
>
  <section class="page head">
    <div class="hung" aria-hidden="true">
      {/* Pastel-refined hanging wire — coral → poppy-soft, softer opacities (SUCCESSION §19). */}
      <svg viewBox="0 0 240 42" width="200" height="35">
        <path d="M8 4 L 232 4" stroke="var(--canopy)" stroke-width="0.5" opacity="0.28" stroke-dasharray="1 3"/>
        <path d="M40 4 L 40 12" stroke="var(--canopy)" stroke-width="0.5" opacity="0.32"/>
        <path d="M100 4 L 100 12" stroke="var(--canopy)" stroke-width="0.5" opacity="0.32"/>
        <path d="M160 4 L 160 12" stroke="var(--canopy)" stroke-width="0.5" opacity="0.32"/>
        <path d="M215 4 L 215 12" stroke="var(--canopy)" stroke-width="0.5" opacity="0.32"/>
        <g transform="translate(40 20)" opacity="0.82">
          <g fill="#b899c9">
            <ellipse cx="-4" cy="-2" rx="4" ry="6" transform="rotate(-30 -4 -2)"/>
            <ellipse cx="4" cy="-2" rx="4" ry="6" transform="rotate(30 4 -2)"/>
            <ellipse cx="0" cy="4" rx="4" ry="6"/>
          </g>
          <circle cx="0" cy="1" r="1.8" fill="#f7f2e7"/>
        </g>
        <g transform="translate(100 20)" opacity="0.92">
          <g fill="var(--poppy-soft)">
            <path d="M0 -8 C 3 -7, 4 -1, 0 1 C -4 -1, -3 -7, 0 -8 Z"/>
            <path d="M8 -3 C 9 2, 4 7, 1 5 C 0 -1, 5 -5, 8 -3 Z"/>
            <path d="M5 7 C 0 9, -4 6, -1 3 C 3 0, 7 2, 5 7 Z"/>
            <path d="M-6 6 C -9 3, -6 -2, -3 -1 C -1 3, -4 7, -6 6 Z"/>
            <path d="M-8 -2 C -5 -7, -1 -6, 0 -2 C -2 2, -8 2, -8 -2 Z"/>
          </g>
          <path d="M0 0 C -1.5 -2, -4 -1, -4 1 C -4 3, 0 5, 0 5 C 0 5, 4 3, 4 1 C 4 -1, 1.5 -2, 0 0 Z" fill="#f7f2e7"/>
        </g>
        <g transform="translate(160 20)" opacity="0.78">
          <g fill="#a4b8c8">
            <path d="M0 -8 L 1.7 -2.5 L 6 -2.5 L 2.5 0.5 L 4 6 L 0 3 L -4 6 L -2.5 0.5 L -6 -2.5 L -1.7 -2.5 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.7" fill="#f7f2e7"/>
        </g>
        <g transform="translate(215 20)" opacity="0.78">
          <g fill="#e8c15a">
            <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-30 -3 -1)"/>
            <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(30 3 -1)"/>
            <ellipse cx="0" cy="3" rx="3" ry="4.5"/>
          </g>
          <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
        </g>
        <circle cx="70" cy="36" r="0.8" fill="#e8c15a" opacity="0.7"/>
        <circle cx="130" cy="36" r="0.8" fill="#a4b8c8" opacity="0.7"/>
        <circle cx="188" cy="36" r="0.8" fill="var(--poppy-soft)" opacity="0.85"/>
      </svg>
    </div>
    <p class="eyebrow"><Glyph name="canopy" size={18} /> &nbsp;the archive wall</p>
    <h1>Volume I · In Formation</h1>
    <p class="lede">
      A completed opening movement, plus notes from inside the current turn —
      twenty-two pieces, hung with care, by theme rather than by shelf; every
      piece keeps its place. The wobble the ruler couldn't hold is kept in the
      Nursery and the Studio, not filed here; the coda that once closed the
      trilogy has been folded into the <a class="link" href={base + "/colophon"}>Colophon</a>,
      so the whole garden speaks in one voice.
    </p>
    <div class="nineteen" aria-hidden="true">
      <MotifPressedNineteen size={340} />
    </div>
  </section>

  <section class="page wall" aria-label="The founding collection">
    {clusters.map((c, i) => (
      <div class="cluster">
        {i > 0 && (
          <div class="cluster-pin" aria-hidden="true">
            <MotifEnso size={62} />
          </div>
        )}
        <p class="cluster-label">{c.label}</p>
        <ul class="frames">
          {c.items.map((p) => (
            <li class="frame">
              <a href={base + p.href}>
                <span class="title">{p.title}</span>
                <span class="dek">{p.dek}</span>
                <StageTag stage={p.stage} tended={p.tended} />
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <section class="page close">
    {/* Slice-3 (2026-07-09) · the tree-friend arrival motif — looking up
        from below into the canopy. The founding-collection close reads:
        the archive is a tree; the reader is at its base, looking up. */}
    <div class="tree-friend" aria-hidden="true">
      <MotifTreeFriend size={260} />
    </div>
    <p class="close-line">
      The founding collection stays open — each piece is still tended: a living
      line you can return to and find changed. The
      <a class="link" href={base + "/lexicon"}>lexicon</a> and the
      <a class="link" href={base + "/colophon"}>colophon</a> hang in this room too.
    </p>
    <div class="gate" aria-hidden="true">
      <MotifArchiveGate size={420} />
    </div>
  </section>
</Base>

<style>
  .head { max-width: 46rem; }
  .head .hung { margin-bottom: 0.7rem; opacity: 0.94; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 54ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  /* the pressed nineteen — intro visual under the lede (SUCCESSION §19) */
  .nineteen { display: flex; justify-content: center; margin: 1.4rem 0 0.4rem; opacity: 0.94; }
  .nineteen :global(svg) { max-width: 100%; height: auto; }
  /* the pinned cluster — marks each theme cluster after the first */
  .cluster-pin { display: flex; justify-content: center; margin: 0.4rem 0 0.6rem; opacity: 0.94; }
  /* the archive gate — closes the room */
  .gate { display: flex; justify-content: center; margin: 2.4rem 0 0; opacity: 0.94; }
  /* Slice-3 · the tree-friend arrival · looking up. */
  .tree-friend { display: flex; justify-content: center; margin: 0 0 1.4rem; opacity: 0.9; }
  .tree-friend :global(svg) { max-width: 100%; height: auto; }
  .gate :global(svg) { max-width: 100%; height: auto; }

  /* ── the wall · clusters · frames ─────────────────────────────
     Stable structure: .wall > .cluster > .frames > .frame — a later
     "gallery hang" (varied frame heights) can be a pure CSS layer. */
  .wall { margin-top: 2.5rem; }
  .cluster + .cluster { margin-top: 3rem; }
  .cluster-label {
    font-family: var(--hand); font-size: 1.45rem; line-height: 1.2;
    color: var(--canopy-deep); margin-bottom: 0.9rem;
  }
  .frames {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1rem; grid-template-columns: 1fr;
  }
  @media (min-width: 44rem) { .frames { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 62rem) { .frames { grid-template-columns: repeat(3, 1fr); } }
  .frame a {
    display: flex; flex-direction: column; gap: 0.55rem; height: 100%;
    box-sizing: border-box; text-decoration: none;
    background: var(--paper-deep); border: 1.1px solid var(--paper-edge);
    border-radius: 4px; padding: 1.15rem 1.25rem; min-height: 44px;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .frame a:hover { border-color: var(--poppy-soft); transform: translateY(-2px); }
  .frame .title { font-family: var(--serif); font-size: 1.22rem; letter-spacing: -0.01em; color: var(--ink); }
  .frame .dek { font-size: 0.95rem; line-height: 1.55; color: var(--ink-soft); flex-grow: 1; }

  /* ── the quiet close ─────────────────────────────────────────── */
  .close { margin-top: 3.5rem; max-width: 46rem; }
  .close-line {
    border-top: 0.7px solid var(--paper-edge); padding-top: 1.4rem;
    font-family: var(--serif); font-style: italic;
    font-size: 1.05rem; color: var(--ink-soft); max-width: 52ch;
  }
  /* comfortable tap areas for the small links, ink unmoved */
  .close-line a { position: relative; }
  .close-line a::after { content: ""; position: absolute; inset: -0.7rem -0.4rem; }
</style>
