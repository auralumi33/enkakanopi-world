---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Glyph from "../components/Glyph.astro";
import TheCurveKept from "../components/motifs/memoria/TheCurveKept.astro";
import MoonCrescent from "../components/motifs/memoria/MoonCrescent.astro";
import VineTrail from "../components/motifs/memoria/VineTrail.astro";
import MotifNurseryPot from "../components/motifs/MotifNurseryPot.astro";
import MotifSeasonalRound from "../components/motifs/MotifSeasonalRound.astro";
import NurseryBotanicalPanels from "../components/NurseryBotanicalPanels.astro";
import NurseryRelocatedBotanicals from "../components/NurseryRelocatedBotanicals.astro";

// Seeds render above the beds when they exist. None do yet — they arrive
// in Rika's hand, or not at all; nothing here is written for her.
const stageOrder = { seed: 0, seedling: 1, budding: 2, evergreen: 3 } as const;
const seeds = (await getCollection("nursery")).sort(
  (a, b) => stageOrder[a.data.stage] - stageOrder[b.data.stage] || a.data.title.localeCompare(b.data.title),
);
const marks = { seed: "◦", seedling: "•", budding: "••", evergreen: "•••" } as const;

// the ladder, extended downward to seed — mirrors the home page's stages list.
const stages = [
  { key: "seed",      d: "caught, not yet planted — a fragment in her own hand." },
  { key: "seedling",  d: "just planted — tender, unsure, thinking out loud." },
  { key: "budding",   d: "taking shape — the argument has a spine now." },
  { key: "evergreen", d: "stands on its own — as settled as this garden gets." },
] as const;

// the prepared beds — honestly empty, in the house's SLOT tradition.
// PROPOSED (2026-07-13 · content redline, Prompt C · awaiting Rika's yes) —
// the fourth bed below. Canon: PILLARS.md P5 + SUCCESSION.md §37.1, which
// already notes this ground's essay "await[s] Rika's seeding notes." A
// prepared-bed entry (not a src/content/nursery/ seed file — those are
// hers alone per this page's own rule two lines up) is the honest way to
// hold the space without pretending a seed exists yet.
const beds = [
  { title: "a bed for experimental voices",   note: "kept for voices not yet real — separation is earned, never assumed" },
  { title: "a bed for the craft logs",        note: "what the hands are learning — mat, wheels, pen, code" },
  { title: "a bed kept for the one true story", note: "planted only by hand, only when ready" },
  // PROPOSED · ratify — note line supplied via SHIP-PROMPT-C-DEBUG-IA §F-5, not authored fresh.
  { title: "a bed for the hardest register",  note: "some beds are prepared long before they're planted — the parent, held at the distance mercy needs" },
] as const;
---
<Base
  title="Nursery"
  description="The nursery of musings and dreams — where fragments land before they are essays. Seeds are the wobble the ruler couldn't hold; tended in the open, not smoothed."
>
  <div class="dim">
    <section class="page head">
      <p class="eyebrow"><Glyph name="leaf" size={18} /> &nbsp;the seed-bed</p>
      <h1>Musings &amp; Dreams</h1>

      {/* Slice-2.6 (2026-07-09): Row 1 (scrap · germination · wobble · cracked
          seed) moved UP to sit above the "Seeds land here first" lede — the
          four fragment states land as visual overture before the words say
          what a seed is. Storytelling arc: paradox panels → lede → the rest.

          2026-07-13 (Rika): rows 2 and 3 joined row 1 here too, so all three
          panel rows read as one clean, flushed visual block right after the
          first set — nothing (ladder, lede) breaks up the panels any more.
          Row 2 suppresses its own mid-cluster caption (showSignature=false);
          row 3's closing line now reads as the single caption for all three. */}
      <NurseryBotanicalPanels row={1} />
      <NurseryBotanicalPanels row={2} showSignature={false} />

      {/* Relocated from the arrival hero (RESTRUCTURE-CHARTER §2 intake #7 ·
          §3 mapping) — the homepage restructure drops the door-panel
          affordance there in favour of the painted canopy + the nine-room
          grid, so these four botanicals move home to the seed-bed. A third,
          distinct row: some destinations now have two doors, one from each
          panel set (Rika, 2026-07-13). */}
      <NurseryRelocatedBotanicals />

      <p class="lede">
        Seeds land here first — fragments caught before they are essays, in her
        hand only.
      </p>

      <div class="breather" aria-hidden="true">
        <MotifNurseryPot size={92} />
      </div>

      <p class="lede">
        Every legible version of a thought is a first-order approximation of
        it; a seed is the wobble the ruler couldn't hold, kept long enough to
        learn what it is. Nothing here is filed, nothing is promised; a seed
        is tended, not timestamped, and most will stay exactly this small.
      </p>

      <p class="pull" aria-label="A phrase held apart">
        tended, not timestamped.<br/>
        kept small, on purpose.
      </p>

      <div class="breather" aria-hidden="true">
        <TheCurveKept size={110} />
      </div>

      <p class="epigraph" aria-label="A note on register">
        We arrive at legibility not by becoming linear, but by loving the curve
        enough to know where the tangent leaves it. The nursery is where the
        curve is kept — before any ruler is asked to hold it.
      </p>

      <div class="breather-wide" aria-hidden="true">
        <VineTrail size={220} />
      </div>
    </section>

    <section class="page grows" aria-label="How a seed grows">
      <p class="eyebrow">the ladder, from the ground down</p>
      <ul class="stages">
        {stages.map((s) => (
          <li>
            <span class="dot" aria-hidden="true">
              {s.key === "seed" && (
                <svg viewBox="0 0 24 24" width="26" height="26">
                  <ellipse cx="12" cy="13" rx="3.2" ry="2.4" fill="#f7f2e7" stroke="#4f5b3f" stroke-width="0.7"/>
                  <path d="M12 10.5 Q 11.6 9, 12 7.5 Q 12.4 9, 12 10.5 Z" fill="#4f5b3f" opacity="0.55"/>
                </svg>
              )}
              {s.key === "seedling" && (
                <svg viewBox="0 0 24 24" width="26" height="26">
                  <path d="M12 21 L 12 12" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
                  <ellipse cx="9" cy="9" rx="3" ry="4.8" transform="rotate(-25 9 9)" fill="#e8c15a"/>
                  <ellipse cx="15" cy="9" rx="3" ry="4.8" transform="rotate(25 15 9)" fill="#e8c15a"/>
                  <path d="M10 15 L 12 14" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
                </svg>
              )}
              {s.key === "budding" && (
                <svg viewBox="0 0 24 24" width="26" height="26">
                  <path d="M12 21 L 12 11" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
                  <g fill="#b899c9">
                    <ellipse cx="9" cy="8" rx="3" ry="4.8" transform="rotate(-25 9 8)"/>
                    <ellipse cx="15" cy="8" rx="3" ry="4.8" transform="rotate(25 15 8)"/>
                    <ellipse cx="12" cy="12" rx="3" ry="4.8"/>
                  </g>
                  <circle cx="12" cy="10" r="1.4" fill="#f7f2e7"/>
                  <path d="M10 15 L 12 14 M14 15 L 12 14" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
                </svg>
              )}
              {s.key === "evergreen" && (
                <svg viewBox="0 0 24 24" width="26" height="26">
                  <path d="M12 21 L 12 14" stroke="#4f5b3f" stroke-width="1" stroke-linecap="round"/>
                  <g fill="#e46b6b">
                    <path d="M12 3 C 14.2 3.5, 14.6 7.4, 12 8.8 C 9.4 7.4, 9.8 3.5, 12 3 Z"/>
                    <path d="M17.5 5.5 C 19.5 8, 17.5 11.5, 14 10.6 C 12.4 8.5, 14.9 5, 17.5 5.5 Z"/>
                    <path d="M15.2 13 C 12.5 15.4, 8.8 14, 10 10.8 C 12.5 9.5, 15.7 10.5, 15.2 13 Z"/>
                    <path d="M6.5 12.5 C 4.5 10.2, 5.8 7.4, 8.4 8 C 10.5 8.7, 10 12.9, 6.5 12.5 Z"/>
                    <path d="M4.6 5.5 C 7.6 4.9, 10.4 7.3, 9 10.4 C 5.8 11, 3.4 7, 4.6 5.5 Z"/>
                  </g>
                  <path d="M12 8.5 C 11 7.5, 9 7.7, 9 9.3 C 9 10.8, 12 11.9, 12 11.9 C 12 11.9, 15 10.8, 15 9.3 C 15 7.7, 13 7.5, 12 8.5 Z" fill="#f7f2e7"/>
                  <path d="M10 17 L 12 16 M14 17 L 12 16" stroke="#4f5b3f" stroke-width="0.7" fill="none" stroke-linecap="round"/>
                </svg>
              )}
            </span>
            <span class="s">{s.key}</span>
            <span class="d">{s.d}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="page rows" aria-label="Seeds and prepared beds">
      <ul class="bedlist">
        {seeds.map((s) => (
          <li class="row">
            <span class={`dot ${s.data.stage}`} aria-hidden="true">{marks[s.data.stage]}</span>
            <span class="txt">
              <span class="t">{s.data.title}</span>
              {s.data.line && <span class="frag">{s.data.line}</span>}
              {(s.data.tended || s.data.bed) && (
                <span class="note">{[s.data.bed, s.data.tended].filter(Boolean).join(" · ")}</span>
              )}
            </span>
          </li>
        ))}
        {beds.map((b) => (
          <li class="row row--empty">
            <span class="dot seed" aria-hidden="true">◦</span>
            <span class="txt">
              <span class="t">{b.title}</span>
              <span class="note">{b.note}</span>
            </span>
          </li>
        ))}
      </ul>
      <div class="breather" aria-hidden="true">
        <MotifSeasonalRound size={100} />
      </div>
      <p class="close">seeds arrive in her hand, or not at all — the wobble kept in view.</p>
    </section>
  </div>
</Base>
<style>
  /* the nursery's lower light — a full-bleed wash; the paper stays warm */
  .dim {
    background: var(--paper-dim);
    border-top: 0.7px solid var(--paper-edge);
    border-bottom: 0.7px solid var(--paper-edge);
    margin-top: -1px;
    padding: 0.5rem 0 3.5rem;
  }

  .head { max-width: 46rem; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 54ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  /* the epigraph — a smaller register-note that sits under the lede, carrying
     the wobble/first-order-approximation voice (SUCCESSION §24) */
  .epigraph {
    font-family: var(--serif); font-style: italic;
    font-size: 0.98rem; color: var(--ink-soft); margin-top: 0.9rem;
    max-width: 54ch; line-height: 1.6;
    border-left: 1.4px solid var(--paper-edge); padding-left: 1rem;
  }
  /* memoria breathers — fine-line spacers between paragraphs (SUCCESSION §25).
     Single mark centered, generous margins, whisper opacity. */
  .breather { display: flex; justify-content: center; margin: 1.6rem 0; opacity: 0.88; }
  .breather :global(svg) { max-width: 100%; height: auto; }
  .breather-wide { display: flex; justify-content: center; margin: 1.8rem 0 0.4rem; opacity: 0.85; }
  .breather-wide :global(svg) { max-width: 100%; height: auto; }
  /* the pull — a phrase held apart from prose, calligraphic, poppy-adjacent */
  .pull {
    font-family: var(--hand); font-size: 1.4rem; color: var(--canopy-deep);
    text-align: center; margin: 1.4rem auto 0.4rem; max-width: 42ch; line-height: 1.35;
  }
  @media (max-width: 32rem) { .pull { font-size: 1.5rem; } }

  /* the ladder — matches the home page's stages idiom, extended to seed */
  .grows { margin-top: 3.2rem; max-width: 52rem; }
  .stages { list-style: none; padding: 0; margin: 1.1rem 0 0; }
  .stages li {
    display: grid; grid-template-columns: 3rem 7rem 1fr; align-items: center;
    gap: 0.6rem; padding: 0.7rem 0; border-top: 0.7px solid var(--paper-edge);
  }
  .stages .dot { line-height: 0; display: inline-flex; align-items: center; justify-content: flex-start; }
  .stages .dot :global(svg) { display: block; }
  .stages .s { font-family: var(--sans); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); }
  .stages .d { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.55; }
  @media (max-width: 34rem) {
    .stages li { grid-template-columns: 2rem 1fr; }
    .stages .s { grid-column: 2; }
    .stages .d { grid-column: 2; }
  }

  /* seeds + beds — the quiet list idiom */
  .rows { max-width: 46rem; margin-top: 3.2rem; }
  .bedlist { list-style: none; padding: 0; margin: 0; }
  .row {
    display: grid; grid-template-columns: 2rem 1fr; gap: 0.7rem;
    align-items: baseline; padding: 1.1rem 0.2rem;
    border-top: 0.7px solid var(--paper-edge);
  }
  .row .t { display: block; font-size: 1.22rem; letter-spacing: -0.01em; }
  .row--empty .t { color: var(--ink-soft); font-style: italic; }
  .frag { display: block; font-family: var(--serif); font-style: italic; color: var(--ink-soft); margin-top: 0.25rem; max-width: 54ch; }
  .note { display: block; font-family: var(--hand); font-size: 1.05rem; color: var(--canopy-deep); margin-top: 0.35rem; }

  .close {
    font-family: var(--hand); font-size: 1.35rem; color: var(--canopy-deep);
    margin-top: 2.4rem; padding-top: 1.4rem; border-top: 0.7px solid var(--paper-edge);
  }
</style>
