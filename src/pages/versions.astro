            <path d="M 5 -2.5 C 6.5 2.5, 3 4.5, 0.7 3 C 0 -0.4, 4 -5, 5 -2.5 Z"/>
            <path d="M 4 4.5 C 0 5.5, -4 3, -1.4 0 C 2.5 -2, 6 2, 4 4.5 Z"/>
            <path d="M -5 3 C -6.5 -1.6, -5 -4.5, -1 -3 C 0 0, -2 4.5, -5 3 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
