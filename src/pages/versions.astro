        <g transform="translate(74 154)">
          <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.6 -0.15 C -0.35 0.1, 0.35 0.1, 0.6 -0.15" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
