        <path d="M 45 155 C 55 158, 70 162, 90 165" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.42"/>
        <path d="M 60 144 C 75 148, 90 152, 105 156" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" stroke-linecap="round" opacity="0.32"/>
