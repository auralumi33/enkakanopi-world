        </g>
      </svg>

      {/* 青 · slate · fragments that rhyme — three fragmented shapes connected by rhyming hairlines, one hidden smile in the third fragment */}
      <svg slot="vignette-4" viewBox="0 0 200 220" role="img" aria-labelledby="vm-s-t"><title id="vm-s-t">Three fragmented sumi-e shapes connected by rhyming hairlines with a hidden slate smile in the third fragment</title>
        <rect x="10" y="10" width="180" height="200" fill="#a4b8c8" opacity="0.13" rx="1"/>
        <path d="M 40 70 C 42 62, 52 60, 60 64 C 68 68, 68 82, 62 88 C 54 92, 42 88, 38 82 C 34 76, 36 72, 40 70 Z" fill="#a4b8c8" opacity="0.28" stroke="var(--ink-soft)" stroke-width="0.85" stroke-linejoin="round"/>
        <path d="M 44 74 C 52 76, 60 82, 60 88" stroke="var(--ink)" stroke-width="0.4" fill="none" opacity="0.35"/>
        <path d="M 120 100 C 122 92, 132 88, 142 92 C 152 96, 152 112, 144 118 C 134 122, 122 118, 118 110 C 114 104, 116 100, 120 100 Z" fill="#a4b8c8" opacity="0.3" stroke="var(--ink-soft)" stroke-width="0.85" stroke-linejoin="round"/>
