        <g transform="translate(170 138)">
          <circle cx="0" cy="0" r="3.5" fill="#e8c15a" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.42"/>
          <path d="M -1.3 -0.3 C -0.8 0.4, 0.8 0.4, 1.3 -0.3" stroke="var(--ink-soft)" stroke-width="0.38" fill="none" stroke-linecap="round"/>
          <circle cx="-1.3" cy="-1.3" r="0.32" fill="var(--ink-soft)"/>
          <circle cx="1.3" cy="-1.3" r="0.32" fill="var(--ink-soft)"/>
        </g>
        <text font-family="var(--hand)" x="100" y="120" text-anchor="middle" font-size="10" font-style="italic" fill="var(--ink-soft)" opacity="0.55">still forming</text>
      </svg>

      {/* 珊瑚 · coral · only in motion — a figure trailing sumi-e motion-strokes, one hidden smile in the trailing edge */}
      <svg slot="vignette-3" viewBox="0 0 200 220" role="img" aria-labelledby="vm-c-t"><title id="vm-c-t">A sumi-e figure trailing motion-strokes with a hidden coral smile in the trail</title>
        <rect x="10" y="10" width="180" height="200" fill="#e46b6b" opacity="0.09" rx="1"/>
        <line x1="20" y1="180" x2="180" y2="180" stroke="var(--ink-soft)" stroke-width="0.55" opacity="0.55" stroke-linecap="round"/>
        <path d="M 155 178 L 155 155" stroke="var(--ink-soft)" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.78"/>
        <circle cx="155" cy="148" r="7" fill="var(--paper-washi)" opacity="0.94" stroke="var(--ink-soft)" stroke-width="0.7"/>
        <path d="M 155 155 C 160 158, 168 156, 172 152" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.72"/>
