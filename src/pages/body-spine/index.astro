---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EssayList from "../../components/EssayList.astro";
import Glyph from "../../components/Glyph.astro";
import RowPlanter from "../../components/RowPlanter.astro";
import MotifArchiveGate from "../../components/motifs/MotifArchiveGate.astro";

const entries = (await getCollection("bodySpine")).sort((a, b) => a.data.order - b.data.order);
const items = entries.map((e) => ({ slug: e.id, ...e.data }));
---
<Base title="Body & Spine" description="The mind-body thread — spine work, skating, mat work. Movement as the ground truth the head kept overruling.">
  <section class="page head">
    <div class="planter"><RowPlanter lead="blue" size={148} /></div>
    <p class="eyebrow"><Glyph name="spine" size={18} /> &nbsp;the mind-body thread</p>
    <h1>Body &amp; Spine</h1>
    <p class="lede">
      Notes from the long work of coming back into a body — spine, skates, the
      slow mat mornings. This is where the head learns to stop overruling the
      one instrument that was, in the end, more competent than it. Written as
      practice, not as disclosure.
    </p>
  </section>
  <section class="page listing">
    <EssayList items={items} basePath="/body-spine" />
  </section>
  {/* Slice-4.1 · MotifArchiveGate (arch) relocated from Volume I → to the
      bottom of Workbench + Body-Spine per Rika. Reads as: the archway
      that closes each practice tab. */}
  <div class="gate" aria-hidden="true">
    <MotifArchiveGate size={340} />
  </div>
</Base>
<style>
  .head { max-width: 46rem; }
  .head .planter { margin-bottom: 0.9rem; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 56ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  .listing { max-width: 46rem; margin-top: 1.5rem; }
  /* Slice-4.1 · archway at the tab close */
  .gate { display: flex; justify-content: center; margin: 2.6rem 0 0.4rem; opacity: 0.9; }
  .gate :global(svg) { max-width: 100%; height: auto; }
</style>
