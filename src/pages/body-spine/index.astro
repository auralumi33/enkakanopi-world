---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EssayList from "../../components/EssayList.astro";
import Glyph from "../../components/Glyph.astro";
import RowPlanter from "../../components/RowPlanter.astro";
import MotifArchiveGate from "../../components/motifs/MotifArchiveGate.astro";
import PanelDoors, { type Panel } from "../../components/PanelDoors.astro";

const entries = (await getCollection("bodySpine")).sort((a, b) => a.data.order - b.data.order);
const items = entries.map((e) => ({ slug: e.id, ...e.data }));

// The hub doors — one restrained row, one door per shipped entry, ordered
// by the essay's own frontmatter order. Same pattern as the Workbench hub:
// the room is small; the doors are honest about that.
const doors: Panel[] = [
  { hue: "lavender", role: "relearning to fall",  caption: "the body as first instrument · relearning to land · smile in the ground", href: "/body-spine/relearning-to-fall", cta: "enter Relearning to Fall" },
  { hue: "gold",     role: "articulation",        caption: "the spine as a sentence · re-punctuated · smile in the pause",           href: "/body-spine/articulation",       cta: "enter Articulation" },
  { hue: "coral",    role: "the tide knows when", caption: "the body's own tides · rhythm before force · smile at the turn",          href: "/body-spine/the-tide-knows-when", cta: "enter The Tide Knows When" },
];
---
<Base title="Body & Spine" description="The mind-body thread — spine work, skating, mat work. Movement as the ground truth the head kept overruling.">
  <section class="page head">
    <div class="planter"><RowPlanter lead="blue" size={148} /></div>
    <p class="eyebrow"><Glyph name="spine" size={18} /> &nbsp;the mind-body thread</p>
    <h1>Body &amp; Spine</h1>
    <p class="lede">
      Notes from the long work of coming back into a body — spine, skates, the
      slow mat mornings. This is where the head learns to stop overruling the
      one instrument that was, in the end, more competent than it. Written as
      practice, not as disclosure.
    </p>
    <!-- PROPOSED · ratify (2026-07-13, content/directional, Prompt C debug/IA pass) —
         the P4 pillar-framing line, drawn from canon (PILLARS.md P4 / lexicon
         "the body as archive"), not authored fresh. Rika's to keep, cut, or
         rewrite. -->
    <p class="lede framing">
      The body keeps the record — pain with weight and scent, read with a practitioner's hand.
    </p>
  </section>
  <section class="page doors">
    <PanelDoors
      panels={doors}
      variant="hub"
      ariaLabel="Body & Spine hub doors — three reading paths into the mind-body thread"
      signature="a small room · three doors · the ground truth the head kept overruling"
    >
      <!-- 紫 · lavender · relearning to fall -->
      <svg slot="vignette-1" viewBox="0 0 200 220" role="img" aria-labelledby="bs-l-t"><title id="bs-l-t">A figure tilted mid-fall into a bloom-cushioned ground with a hidden lavender smile</title>
        <rect x="10" y="10" width="180" height="200" fill="#b899c9" opacity="0.10" rx="1"/>
        <path d="M 20 175 C 60 168, 140 168, 180 175 C 180 180, 20 180, 20 175 Z" fill="var(--canopy-soft)" opacity="0.42" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linejoin="round"/>
        <g transform="translate(90 130) rotate(-24)">
          <circle cx="0" cy="-38" r="8" fill="var(--skin)" opacity="0.94" stroke="var(--ink-soft)" stroke-width="0.55"/>
          <path d="M 0 -30 C 0 -18, 0 -6, 0 6" stroke="var(--ink-soft)" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.8"/>
          <path d="M 0 -22 C -8 -18, -14 -10, -18 -2" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.75"/>
          <path d="M 0 -22 C 8 -18, 14 -12, 18 -6" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.75"/>
          <path d="M 0 6 C -6 14, -10 22, -12 30" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.75"/>
          <path d="M 0 6 C 6 12, 12 18, 14 24" stroke="var(--ink-soft)" stroke-width="0.7" fill="none" stroke-linecap="round" opacity="0.75"/>
        </g>
        <g transform="translate(140 168)">
          <g fill="#b899c9" opacity="0.9" stroke="var(--ink-soft)" stroke-width="0.3" stroke-linejoin="round">
            <path d="M 0 -4 C 2.2 -3.3, 2.8 -0.9, 0 -0.2 C -2.8 -0.9, -2.2 -3.3, 0 -4 Z"/>
            <path d="M 3.4 -1.4 C 4 1, 2 2.6, 0.6 1.6 C 0 -0.2, 1.8 -2.2, 3.4 -1.4 Z"/>
            <path d="M 2 2.6 C 0 3.4, -2 1.6, -0.6 0 C 1.4 -1.1, 3.4 0.8, 2 2.6 Z"/>
            <path d="M -2.8 1.4 C -4 -0.9, -2.8 -2.5, -0.8 -1.4 C 0 0, -1.4 2.5, -2.8 1.4 Z"/>
          </g>
          <circle cx="0" cy="0" r="1.2" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.55 -0.15 C -0.3 0.1, 0.3 0.1, 0.55 -0.15" stroke="var(--ink-soft)" stroke-width="0.28" fill="none" stroke-linecap="round"/>
        </g>
      </svg>

      <!-- 金 · gold · articulation -->
      <svg slot="vignette-2" viewBox="0 0 200 220" role="img" aria-labelledby="bs-g-t"><title id="bs-g-t">A curving spine of vertebrae drawn as punctuation marks with a hidden gold smile</title>
        <rect x="10" y="10" width="180" height="200" fill="#e8c15a" opacity="0.11" rx="1"/>
        <path d="M 100 40 C 108 60, 92 82, 100 104 C 108 126, 92 148, 100 170 C 106 188, 100 200, 100 200" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.35" stroke-dasharray="2 3"/>
        <g fill="var(--paper-washi)" stroke="var(--ink-soft)" stroke-width="0.55" stroke-linejoin="round" opacity="0.95">
          <path d="M 100 42 C 110 42, 112 46, 108 50 C 104 52, 96 52, 92 50 C 88 46, 90 42, 100 42 Z"/>
          <path d="M 102 62 C 110 62, 112 66, 108 70 C 104 72, 96 72, 92 70 C 88 66, 92 62, 102 62 Z"/>
          <path d="M 96 84 C 106 84, 110 88, 106 92 C 102 94, 92 94, 88 92 C 84 88, 88 84, 96 84 Z"/>
          <path d="M 102 106 C 112 106, 114 110, 110 114 C 106 116, 96 116, 92 114 C 88 110, 92 106, 102 106 Z"/>
          <path d="M 96 128 C 106 128, 110 132, 106 136 C 102 138, 92 138, 88 136 C 84 132, 88 128, 96 128 Z"/>
          <path d="M 102 150 C 112 150, 114 154, 110 158 C 106 160, 96 160, 92 158 C 88 154, 92 150, 102 150 Z"/>
        </g>
        <g stroke="var(--ink-soft)" stroke-width="0.75" stroke-linecap="round" fill="none" opacity="0.7">
          <path d="M 128 60 L 138 60"/>
          <path d="M 133 55 L 133 65"/>
          <path d="M 132 90 L 140 90"/>
          <path d="M 132 118 L 140 118"/>
          <circle cx="136" cy="132" r="1.4" fill="var(--ink-soft)"/>
          <circle cx="136" cy="150" r="1.4" fill="var(--ink-soft)"/>
        </g>
        <g transform="translate(72 178)">
          <circle cx="0" cy="0" r="4.2" fill="#e8c15a" opacity="0.88" stroke="var(--ink-soft)" stroke-width="0.4"/>
          <path d="M -1.4 -0.3 C -0.8 0.4, 0.8 0.4, 1.4 -0.3" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round"/>
          <circle cx="-1.4" cy="-1.4" r="0.35" fill="var(--ink-soft)"/>
          <circle cx="1.4" cy="-1.4" r="0.35" fill="var(--ink-soft)"/>
        </g>
      </svg>

      <!-- 珊瑚 · coral · the tide knows when -->
      <svg slot="vignette-3" viewBox="0 0 200 220" role="img" aria-labelledby="bs-c-t"><title id="bs-c-t">A hairline horizon with tidal curves and a small coral shell holding a hidden smile</title>
        <rect x="10" y="10" width="180" height="200" fill="#e46b6b" opacity="0.08" rx="1"/>
        <line x1="20" y1="110" x2="180" y2="110" stroke="var(--ink-soft)" stroke-width="0.55" opacity="0.7" stroke-linecap="round"/>
        <path d="M 20 110 C 40 108, 60 112, 80 108 C 100 104, 120 112, 140 108 C 160 104, 175 110, 180 110" stroke="var(--ink-soft)" stroke-width="0.5" fill="none" opacity="0.55" stroke-linecap="round"/>
        <path d="M 20 130 C 44 126, 68 134, 92 128 C 116 122, 140 132, 164 126 C 172 124, 178 128, 180 130" stroke="var(--ink-soft)" stroke-width="0.55" fill="none" opacity="0.62" stroke-linecap="round"/>
        <path d="M 20 152 C 48 148, 76 158, 104 150 C 132 142, 160 154, 180 152" stroke="var(--ink-soft)" stroke-width="0.6" fill="none" opacity="0.68" stroke-linecap="round"/>
        <path d="M 20 176 C 52 172, 84 184, 116 174 C 148 164, 172 178, 180 176" stroke="var(--ink-soft)" stroke-width="0.65" fill="none" opacity="0.72" stroke-linecap="round"/>
        <path d="M 100 78 C 108 74, 116 78, 116 88 C 116 96, 108 100, 100 96 C 92 92, 92 82, 100 78 Z" fill="#e08d84" opacity="0.7" stroke="var(--ink-soft)" stroke-width="0.5" stroke-linejoin="round"/>
        <path d="M 100 82 C 105 82, 108 86, 108 90 C 108 94, 104 96, 100 94" stroke="var(--ink-soft)" stroke-width="0.4" fill="none" stroke-linecap="round" opacity="0.6"/>
        <g transform="translate(108 90)">
          <circle cx="0" cy="0" r="1.4" fill="#e8c15a" opacity="0.95"/>
          <path d="M -0.6 -0.15 C -0.35 0.1, 0.35 0.1, 0.6 -0.15" stroke="var(--ink-soft)" stroke-width="0.3" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
    </PanelDoors>
  </section>
  <section class="page listing">
    <EssayList items={items} basePath="/body-spine" />
  </section>
  {/* Slice-4.1 · MotifArchiveGate (arch) relocated from Volume I → to the
      bottom of Workbench + Body-Spine per Rika. Reads as: the archway
      that closes each practice tab. */}
  <div class="gate" aria-hidden="true">
    <MotifArchiveGate size={340} />
  </div>
</Base>
<style>
  .head { max-width: 46rem; }
  .head .planter { margin-bottom: 0.9rem; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 56ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  .listing { max-width: 46rem; margin-top: 1.5rem; }
  /* Slice-4.1 · archway at the tab close */
  .gate { display: flex; justify-content: center; margin: 2.6rem 0 0.4rem; opacity: 0.9; }
  .gate :global(svg) { max-width: 100%; height: auto; }
</style>
