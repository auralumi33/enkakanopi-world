---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import Glyph from "../components/Glyph.astro";
import MotifApprenticeBench from "../components/motifs/MotifApprenticeBench.astro";
import MotifWorkbench from "../components/motifs/MotifWorkbench.astro";
import MotifTallyMark from "../components/motifs/MotifTallyMark.astro";
import TheFirstApproximation from "../components/motifs/memoria/TheFirstApproximation.astro";
import MotifTallyMark from "../components/motifs/MotifTallyMark.astro";
import MotifApprenticeBench from "../components/motifs/MotifApprenticeBench.astro";
import VineTrail from "../components/motifs/memoria/VineTrail.astro";

// The wall's hanging order — flagship first; anything new hangs after.
const hang = ["the-tension-sketches", "the-glyph-kit", "the-mechanical-mirror", "the-chain-strip"];
const entries = (await getCollection("studio")).sort((a, b) => {
  const ai = hang.indexOf(a.id), bi = hang.indexOf(b.id);
  return (ai === -1 ? hang.length : ai) - (bi === -1 ? hang.length : bi) || a.data.title.localeCompare(b.data.title);
});
const pieces = await Promise.all(
  entries.map(async (e) => ({ ...e.data, id: e.id, Content: (await render(e)).Content, hasBody: e.body?.trim().length > 0 })),
);
---
<Base
  title="Studio"
  description="The studio wall — the making, shown with its working notes: material, constraint, tally. Every piece is a first-order approximation of what it was trying to be; the tally is what tracks the wobble the ruler couldn't hold."
>
  <section class="page head">
    <div class="scatter" aria-hidden="true">
      {/* Pastel-refined scatter — coral → poppy-soft, softer opacities (SUCCESSION §19). */}
      <svg viewBox="0 0 130 26" width="120" height="24">
        <g transform="translate(18 14)" opacity="0.78">
          <g fill="#e8c15a">
            <ellipse cx="-3" cy="-1" rx="3" ry="4.5" transform="rotate(-25)"/>
            <ellipse cx="3" cy="-1" rx="3" ry="4.5" transform="rotate(25)"/>
          </g>
          <circle cx="0" cy="0" r="1.4" fill="#f7f2e7"/>
        </g>
        <g transform="translate(65 12)" opacity="0.78">
          <g fill="#b899c9">
            <ellipse cx="-3.5" cy="-1.5" rx="3.5" ry="5" transform="rotate(-25)"/>
            <ellipse cx="3.5" cy="-1.5" rx="3.5" ry="5" transform="rotate(25)"/>
            <ellipse cx="0" cy="4" rx="3.5" ry="5"/>
          </g>
          <circle cx="0" cy="1" r="1.6" fill="#f7f2e7"/>
        </g>
        <g transform="translate(112 14)" opacity="0.78">
          <path d="M0 -6 L 1.4 -2 L 5 -2 L 2 0.5 L 3.5 5 L 0 2 L -3.5 5 L -2 0.5 L -5 -2 L -1.4 -2 Z" fill="#a4b8c8"/>
          <circle cx="0" cy="-0.5" r="1.4" fill="#f7f2e7"/>
        </g>
        <circle cx="40" cy="18" r="0.9" fill="var(--poppy-soft)" opacity="0.85"/>
        <circle cx="90" cy="20" r="0.9" fill="#e8c15a" opacity="0.7"/>
        <circle cx="8" cy="22" r="0.7" fill="#b899c9" opacity="0.7"/>
        <circle cx="125" cy="22" r="0.7" fill="#a4b8c8" opacity="0.7"/>
      </svg>
    </div>
    <p class="eyebrow"><Glyph name="compass" size={18} /> &nbsp;the studio wall</p>
    <h1>The Studio</h1>
    <p class="lede">
      The making, shown — each piece hangs with its working note: material,
      constraint, tally.
    </p>

    <div class="breather" aria-hidden="true">
      <MotifApprenticeBench size={140} />
    </div>

    <p class="lede">
      Every piece here is a first-order approximation of what it was trying
      to be; the practice is to make the approximation and then find its
      edge, to retrain the ruler by loving the curve.
    </p>

    <div class="breather" aria-hidden="true">
      <TheFirstApproximation size={112} />
    </div>

    <p class="lede">
      Process over product; what you see is what was actually made, counted
      as it happened.
    </p>

    <p class="pull" aria-label="A phrase held apart">
      make the approximation, then find its edge.<br/>
      retrain the ruler by loving the curve.
    </p>

    <div class="breather" aria-hidden="true">
      <MotifTallyMark size={140} />
    </div>

    <p class="handnote" aria-label="A note in the margin">the tally starts now — honest counts, no invented histories. the wobble is the truth the ruler couldn't hold.</p>

    <div class="breather-wide" aria-hidden="true">
      <VineTrail size={220} />
    </div>
    <div class="apprentice" aria-hidden="true">
      <MotifApprenticeBench size={280} />
    </div>
  </section>

  <section class="page bench-anchor" aria-label="The making surface">
    <div class="bench" aria-hidden="true">
      <MotifWorkbench size={420} />
    </div>
  </section>

  <section class="page wallwrap" aria-label="Pieces on the wall">
    <ul class="wall">
      {pieces.map(({ Content, hasBody, ...p }) => (
        <li class="piece" data-kind={p.kind}>
          <article>
            <header class="phead">
              <span class="kind">{p.kind}</span>
              <h2>{p.title}</h2>
            </header>
            {hasBody && (
              <div class="pbody">
                <Content />
              </div>
            )}
            <dl class="process">
              <div><dt>material</dt><dd>{p.material}</dd></div>
              <div><dt>constraint</dt><dd>{p.constraint}</dd></div>
              {p.tally && <div><dt>tally</dt><dd>{p.tally}</dd></div>}
            </dl>
            {p.note && <p class="aside">{p.note}</p>}
          </article>
        </li>
      ))}
    </ul>

    <p class="slot">
      <span class="dot" aria-hidden="true">◦</span>
      clay, wood, thread, lens — when the objects are photographed, they hang here.
    </p>

    <div class="tally" aria-hidden="true">
      <MotifTallyMark size={260} />
    </div>
  </section>
</Base>
<style>
  .head { max-width: 46rem; }
  .head .scatter { margin-bottom: 0.7rem; opacity: 0.94; }
  .head .eyebrow { display: flex; align-items: center; }
  h1 { margin-top: 0.8rem; }
  .lede { font-size: 1.04rem; color: var(--ink-soft); margin-top: 1rem; max-width: 54ch; line-height: 1.6; }
  @media (max-width: 32rem) { .lede { font-size: 1.08rem; } }
  .handnote { font-family: var(--hand); font-size: 1.3rem; color: var(--canopy-deep); margin-top: 1.2rem; }
  /* memoria breathers — fine-line spacers between paragraphs (SUCCESSION §25) */
  .breather { display: flex; justify-content: center; margin: 1.4rem 0; opacity: 0.88; }
  .breather :global(svg) { max-width: 100%; height: auto; }
  .breather-wide { display: flex; justify-content: center; margin: 1.8rem 0 0.4rem; opacity: 0.85; }
  .breather-wide :global(svg) { max-width: 100%; height: auto; }
  /* the pull — a phrase held apart, calligraphic */
  .pull {
    font-family: var(--hand); font-size: 1.4rem; color: var(--canopy-deep);
    text-align: center; margin: 1.4rem auto 0.4rem; max-width: 42ch; line-height: 1.4;
  }
  @media (max-width: 32rem) { .pull { font-size: 1.5rem; } }
  /* apprentice bench — the co-creation register threaded through Studio (SUCCESSION §19) */
  .apprentice { display: flex; justify-content: center; margin: 1.2rem 0 0; opacity: 0.94; }
  .apprentice :global(svg) { max-width: 100%; height: auto; }
  /* the workbench — mid-page anchor, this IS the working surface */
  .bench-anchor { max-width: 46rem; }
  .bench { display: flex; justify-content: center; margin: 2.4rem 0 0; opacity: 0.94; }
  .bench :global(svg) { max-width: 100%; height: auto; }
  /* the tally mark — beside the honest-counts slot */
  .tally { display: flex; justify-content: center; margin: 1.6rem 0 0; opacity: 0.94; }
  .tally :global(svg) { max-width: 100%; height: auto; }

  /* the wall — card markup kept flat so a masonry layer can replace the
     grid later without touching the content model */
  .wallwrap { margin-top: 2.4rem; }
  .wall { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 44rem) { .wall { grid-template-columns: 1fr 1fr; } }
  .piece article {
    height: 100%; box-sizing: border-box;
    background: var(--paper-deep); border: 1.1px solid var(--paper-edge);
    border-radius: 4px; padding: 1.3rem 1.25rem 1.2rem;
  }
  .kind {
    font-family: var(--sans); font-size: 0.64rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  .phead h2 { font-size: 1.14rem; font-style: italic; letter-spacing: -0.01em; margin: 0.35rem 0 0; }
  .pbody { margin-top: 0.6rem; }
  .pbody :global(p) { font-size: 0.9rem; color: var(--ink-soft); max-width: none; margin: 0; line-height: 1.55; }
  .pbody :global(p + p) { margin-top: 0.55rem; }

  /* the working note — hand voice, per the house's status idiom */
  .process { margin: 0.9rem 0 0; padding-top: 0.7rem; border-top: 0.7px solid var(--paper-edge); }
  .process > div { display: grid; grid-template-columns: 5.8rem 1fr; gap: 0.55rem; align-items: baseline; padding: 0.2rem 0; }
  .process dt {
    font-family: var(--sans); font-size: 0.62rem; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  .process dd { margin: 0; font-family: var(--hand); font-size: 1rem; line-height: 1.3; color: var(--canopy-deep); }
  .aside { font-family: var(--hand); font-size: 0.98rem; color: var(--ink-soft); margin-top: 0.65rem; }
  @media (max-width: 32rem) {
    .phead h2 { font-size: 1.18rem; }
    .pbody :global(p) { font-size: 0.95rem; }
    .process dd { font-size: 1.05rem; }
  }
  @media (max-width: 24rem) {
    .process > div { grid-template-columns: 1fr; gap: 0.1rem; }
  }

  /* the one prepared slot — honestly empty */
  .slot {
    display: grid; grid-template-columns: 2rem 1fr; gap: 0.7rem; align-items: baseline;
    margin-top: 2rem; padding: 1.2rem 0.2rem 0; border-top: 0.7px solid var(--paper-edge);
    font-style: italic; color: var(--ink-soft); max-width: 46rem;
  }
  .slot .dot { color: var(--canopy-soft); font-size: 1rem; }
</style>
