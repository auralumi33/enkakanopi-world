---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Enka Kanopi",
  description = "A canopy for a self in motion — essays on identity, craft, and the slow work of becoming. Volume I · In Formation.",
} = Astro.props;
const fullTitle = title === "Enka Kanopi" ? title : `${title} · Enka Kanopi`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL("/og/og-card.png", Astro.site).href : "/og/og-card.png";
const ogImageAlt =
  "Enka Kanopi — a hand-drawn canopy over the words 'a canopy for a self in motion'";

// Site + author structured data — so answer engines can attribute the frameworks
// to a named source (AEO/GEO). Person kept minimal + non-identifying by design.
// (sameAs omitted deliberately — external profiles to be confirmed by Rika.)
const ldSite = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.enkakanopi.world/#website",
      name: "Enka Kanopi",
      url: Astro.site?.href,
      description: "A canopy for a self in motion — essays on identity, craft, memory, and the body.",
      publisher: { "@id": "https://www.enkakanopi.world/#rika" },
      author: { "@id": "https://www.enkakanopi.world/#rika" },
    },
    {
      "@type": "Person",
      "@id": "https://www.enkakanopi.world/#rika",
      name: "Rika Fang",
      url: Astro.site ? new URL("/colophon", Astro.site).href : undefined,
      description: "Writer and maker. Essays on the container beneath the craft, the deflation of execution, and the canopy and the light.",
      knowsAbout: [
        "identity under AI",
        "design inquiry at the intersection of architectural design methodology and urban theory",
        "craft and embodied practice",
        "digital gardens",
        "human–machine co-creation",
      ],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="color-scheme" content="light dark" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="Enka Kanopi" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f7f2e7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#221c14" />
    <link rel="alternate" type="application/rss+xml" title="Enka Kanopi" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,460;0,9..144,500;1,9..144,400;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Caveat:wght@400;600&display=swap"
    />
    <link
      rel="icon"
      href={`data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' fill='%23f7f2e7'/%3E%3Cpath d='M3.4 15 C4 10 8 6.4 12 6.6 C16 6.8 19.6 10.3 20.4 15' fill='none' stroke='%236f7d5a' stroke-width='1.4' stroke-linecap='round'/%3E%3Cpath d='M12 16.6 L12 20.4' stroke='%232a251d' stroke-width='1.4' stroke-linecap='round'/%3E%3C/svg%3E`}
    />
    <script type="application/ld+json" set:html={JSON.stringify(ldSite)} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
