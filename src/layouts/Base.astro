---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Enka Kanopi",
  description = "A quiet garden of writings, craft, and identity — essays kept by hand in the age of AI. Volume I · In Formation.",
} = Astro.props;
const homeTitle = "enkakanopi · a quiet garden of musings in the age of AI";
const fullTitle = title === "Enka Kanopi" ? homeTitle : `${title} · enkakanopi`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL("/og/og-card.png", Astro.site).href : "/og/og-card.png";
const ogImageAlt =
  "Enka Kanopi — a hand-drawn canopy over the words 'a quiet garden of writings, craft, and identity in the age of AI'";

// Site + author structured data — so answer engines can attribute the frameworks
// to a named source (AEO/GEO). Person kept minimal + non-identifying by design.
// (sameAs omitted deliberately — external profiles to be confirmed by Rika.)
const ldSite = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.enkakanopi.world/#website",
      name: "Enka Kanopi",
      url: Astro.site?.href,
      description: "A quiet garden of writings, craft, and identity — essays kept by hand in the age of AI.",
      publisher: { "@id": "https://www.enkakanopi.world/#rika" },
      author: { "@id": "https://www.enkakanopi.world/#rika" },
    },
    {
      "@type": "Person",
      "@id": "https://www.enkakanopi.world/#rika",
      name: "Fang Rika",
      alternateName: "Rika Fang",
      givenName: "Rika",
      familyName: "Fang",
      url: Astro.site ? new URL("/colophon", Astro.site).href : undefined,
      description: "Writer and maker. Essays on the container beneath the craft, the deflation of execution, and the canopy and the light.",
      knowsAbout: [
        "identity under AI",
        "design inquiry at the intersection of architectural design methodology and urban theory",
        "craft and embodied practice",
        "digital gardens",
        "human–machine co-creation",
      ],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="Enka Kanopi" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f7f2e7" />
    <link rel="alternate" type="application/rss+xml" title="Enka Kanopi" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,460;0,9..144,500;1,9..144,400;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Caveat:wght@400;600&display=swap"
    />
    <link
      rel="icon"
      href={`data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' fill='%23f7f2e7'/%3E%3Cpath d='M4 12 C5 7 9 4 12 4.5 C15 4 19 7 20 12' fill='none' stroke='%236f7d5a' stroke-width='1.4' stroke-linecap='round'/%3E%3Cpath d='M8 10 C9 8 11 8 12 10 C13 8 15 8 16 10' fill='none' stroke='%236f7d5a' stroke-width='0.9' stroke-linecap='round' opacity='0.75'/%3E%3Ccircle cx='12' cy='12.2' r='0.85' fill='%23cf4a45'/%3E%3Cpath d='M12 14 L12 20' stroke='%232a251d' stroke-width='1.4' stroke-linecap='round'/%3E%3C/svg%3E`}
    />
    <script type="application/ld+json" set:html={JSON.stringify(ldSite)} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
