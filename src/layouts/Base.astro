---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ChapterOrnament from "../components/ChapterOrnament.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Enka Kanopi",
  description = "A quiet garden of writings, craft, and identity — essays kept by hand in the age of AI. Volume I · In Formation.",
} = Astro.props;
const homeTitle = "enkakanopi · Fang Rika's garden of musings in the age of AI";
const fullTitle = title === "Enka Kanopi" ? homeTitle : `${title} · enkakanopi`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL("/og/og-card.png", Astro.site).href : "/og/og-card.png";
const ogImageAlt =
  "Enka Kanopi — a hand-drawn canopy over the words 'a quiet garden of writings, craft, and identity in the age of AI'";

// The silk-on-washi register (Set 3 · 2026-07-09) — one of three grain
// classes applied to <body> per the reader's stage in the garden. Doctrine:
// DESIGN-SYSTEM.md · the silk-on-washi register.
const rawPath = Astro.url.pathname;
const path = rawPath === "/" ? "/" : rawPath.replace(/\/$/, "");
const arrivalPaths = ["/", "/volume-i", "/field-notes", "/workbench", "/body-spine"];
const referencePaths = ["/studio", "/lexicon"];
const grainTier = arrivalPaths.includes(path)
  ? "grain-arrival"          // home + volume-i + section hubs
  : path === "/nursery"
    ? "grain-seedbed"        // NEW · Nursery only · Japanese refinement
    : referencePaths.includes(path)
      ? "grain-reference"    // studio + lexicon
      : "grain-dwell";       // individual essays + colophon + versions

// ChapterOrnament (slice-2.4) — rendered only on the 7 core section openers where a reader
// crosses a threshold into a new chapter. NOT on individual essays (already inside a room),
// NOT on nursery/studio/lexicon (catalog surfaces with their own visual identity).
const ornamentPaths = [
  "/", "/volume-i", "/field-notes", "/workbench", "/body-spine", "/versions", "/colophon",
];
const showOrnament = ornamentPaths.includes(path);

// Site + author structured data — so answer engines can attribute the frameworks
// to a named source (AEO/GEO). Person kept minimal + non-identifying by design.
// (sameAs omitted deliberately — external profiles to be confirmed by Rika.)
const ldSite = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.enkakanopi.world/#website",
      name: "Enka Kanopi",
      url: Astro.site?.href,
      description: "A quiet garden of writings, craft, and identity — essays kept by hand in the age of AI.",
      publisher: { "@id": "https://www.enkakanopi.world/#rika" },
      author: { "@id": "https://www.enkakanopi.world/#rika" },
    },
    {
      "@type": "Person",
      "@id": "https://www.enkakanopi.world/#rika",
      name: "Fang Rika",
      alternateName: "Rika Fang",
      givenName: "Rika",
      familyName: "Fang",
      url: Astro.site ? new URL("/colophon", Astro.site).href : undefined,
      description: "Writer and maker. Essays on the container beneath the craft, the deflation of execution, and the canopy and the light.",
      knowsAbout: [
        "identity under AI",
        "design inquiry at the intersection of architectural design methodology and urban theory",
        "craft and embodied practice",
        "digital gardens",
        "human–machine co-creation",
      ],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="Enka Kanopi" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f7f2e7" />
    <link rel="alternate" type="application/rss+xml" title="Enka Kanopi" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,460;0,9..144,500;1,9..144,400;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Caveat:wght@400;600&display=swap"
    />
    <link
      rel="icon"
      href={`data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cg fill='%23e46b6b'%3E%3Cpath d='M12 0.6 C 15.4 1.3, 15.8 6.2, 12 8 C 8.2 6.2, 8.6 1.3, 12 0.6 Z'/%3E%3Cpath d='M20.6 4.6 C 23.2 7.5, 21.3 11.9, 17.2 11.3 C 14.8 8.4, 17.2 4, 20.6 4.6 Z'/%3E%3Cpath d='M18 14 C 15.7 16.7, 11.8 15.3, 12.8 12 C 15.4 10.1, 18.6 11, 18 14 Z'/%3E%3Cpath d='M6 14 C 4 12, 5.3 9.4, 8 10 C 10.7 10.9, 10 14.6, 6 14 Z'/%3E%3Cpath d='M3.4 4.6 C 6.8 3.9, 10 6.9, 8.3 10.3 C 4.5 11.3, 2.3 7, 3.4 4.6 Z'/%3E%3C/g%3E%3Cpath d='M12 9.4 C 11.2 8.1, 9.3 8.2, 9.3 9.8 C 9.3 11.4, 12 12.5, 12 12.5 C 12 12.5, 14.7 11.4, 14.7 9.8 C 14.7 8.2, 12.8 8.1, 12 9.4 Z' fill='%23f7f2e7'/%3E%3Cpath d='M11.6 14.4 C 10.9 15.9, 10.8 17.3, 11.3 18.5 L 12.7 18.5 C 13.2 17.3, 13.1 15.9, 12.4 14.4 Z' fill='%234f5b3f'/%3E%3Cpath d='M7 18.5 C 7.4 21, 9 23, 12 23.4 C 15 23, 16.6 21, 17 18.5 C 15.4 18.3, 8.6 18.3, 7 18.5 Z' fill='%234f5b3f'/%3E%3C/svg%3E`}
    />
    <script type="application/ld+json" set:html={JSON.stringify(ldSite)} />
  </head>
  <body class={grainTier}>
    <a class="skip" href="#main">Skip to content</a>
    <Nav />
    {showOrnament && <ChapterOrnament />}
    <main id="main">
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
