---
import Base from "./Base.astro";
import Glyph from "../components/Glyph.astro";
import StageTag from "../components/StageTag.astro";
import dates from "../data/dates.json";
import { termAnchorsByHref } from "../data/lexicon";
interface Props {
  title: string;
  dek: string;
  status?: string;
  glyph?: "leaf" | "canopy" | "seam" | "spine" | "compass" | "light" | "arrow";
  stage?: "seedling" | "budding" | "evergreen";
  tended?: string;
  breath?: string;
  // farewell — an optional hand-written goodbye at the door, rendered in the
  // .end footer above the "more from …" link. Present on the essay schema
  // (content.config.ts) and threaded through every [slug].astro page; still
  // unset on every essay by default — Rika hand-writes each farewell.
  farewell?: string;
  // seal — the maker's-mark closing (G4). Off by default; one piece at a time
  // earns the mark. When true, the essay foot renders the poppy-red wax press
  // + a tiny serif caption ("the garden · summer 07/ 2026 · tended by Fang
  // Rika ·") above the correspondence line. Both the seal and the line are
  // additive; nothing else in the layout changes.
  seal?: boolean;
  backHref: string;
  backLabel: string;
  description?: string;
  // Machine-mirror only — populated ONLY where the essay's prose already names
  // the source. citations → BlogPosting.citation (papers, books, scholarly
  // works). mentionsWorks → BlogPosting.mentions (a work referenced but not
  // the subject of the essay). No rendered surface for either.
  citations?: { name: string; work?: string; url?: string }[];
  mentionsWorks?: { name: string; creator?: string }[];
  // ─── Editorial anchor discipline (codified 2026-07-08 · SUCCESSION §31,
  //     applies to every essay authored via this layout; enforced at
  //     authorship time, no build-time linter exists yet):
  //
  //   1. Scene-anchor rule — a hybrid <Scene*/> visual sits WITH the
  //      paragraph that names the concept it illustrates, never before it.
  //      The visual is the reader's picture of the sentence they just read;
  //      placing it earlier reads as unmoored.
  //   2. No unmoored breathers — when an essay carries scene-scale hybrid
  //      scenes + MarginNotes + a closing memoria mark, small standalone
  //      memoria breather divs (MoonCrescent/ScriptHeart/Dragonfly/
  //      FineLineStar in a centred div between paragraphs) become
  //      decorative filler and read as the "weird squiggle" antipattern.
  //   3. Text-visual de-duplication — any pull-quote or MarginNote adjacent
  //      to a Scene or Figure must add angle from a different lens, not
  //      paraphrase the surrounding paragraph or the scene's hand-labels.
  //   4. Attribution economy — cited authors (Kalanithi, Reisman, Follett,
  //      Wegner, Kaplan, Sizelle …) are KEYSTONE marks for the site, not
  //      repeated attributions. Register can appear anywhere; the specific
  //      attribution is bounded — one place per author, plus the Colophon.
  //
  //   Full rationale + evolving-decisions log lives in DESIGN-NOTES.md.
}
const { title, dek, status = "in formation · v0", glyph = "seam", stage = "seedling", tended, breath, farewell, seal = false, backHref, backLabel, description, citations, mentionsWorks } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;

// the essay's canonical path — key into dates.json + the lexicon's seeIn map.
// machine metadata only: the surface stays tended, not timestamped.
const essayPath = Astro.url.pathname.slice(base.length).replace(/^\/+|\/+$/g, ""); // e.g. "field-notes/the-seam"
const essayDates = (dates as Record<string, { published: string; modified: string }>)[essayPath];
const tendedHuman = essayDates
  ? new Date(`${essayDates.modified}T00:00:00Z`).toLocaleDateString("en-GB", { month: "long", year: "numeric", timeZone: "UTC" })
  : undefined;

// the lexicon terms that cite this essay — cited by anchor id, so answer
// engines can walk from the essay to the term's source definition.
const aboutIds = (termAnchorsByHref[`/${essayPath}`] ?? []).map(
  (a) => `https://www.enkakanopi.world/lexicon#${a}`,
);

const rika = { "@type": "Person", name: "Fang Rika", alternateName: "Rika Fang", "@id": "https://www.enkakanopi.world/#rika" };

// citations → schema.org citation (CreativeWork the essay references at
// scholarly-source strength: papers, books). One entry per source the essay
// names in its own prose. Anthropic is treated as an Organization author;
// everything else is a Person.
const citationLd = (citations ?? []).map((c) => {
  const author = { "@type": c.name === "Anthropic" ? "Organization" : "Person", name: c.name };
  return {
    "@type": "CreativeWork",
    name: c.work ?? c.name,
    ...(c.work && { author }),
    ...(c.url && { url: c.url }),
  };
});

// mentionsWorks → schema.org mentions (a work referenced but not the subject).
const mentionsLd = (mentionsWorks ?? []).map((m) => ({
  "@type": "CreativeWork",
  name: m.name,
  ...(m.creator && { creator: { "@type": "Person", name: m.creator } }),
}));

const ldArticle = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: dek,
  ...(canonical && { url: canonical, mainEntityOfPage: canonical }),
  author: rika,
  publisher: rika,
  ...(essayDates && { datePublished: essayDates.published, dateModified: essayDates.modified }),
  ...(aboutIds.length > 0 && { about: aboutIds.map((id) => ({ "@id": id })) }),
  ...(citationLd.length > 0 && { citation: citationLd }),
  ...(mentionsLd.length > 0 && { mentions: mentionsLd }),
  ...(breath && { abstract: breath }),
  isPartOf: { "@type": "Blog", name: `Enka Kanopi · ${backLabel}` },
};

// BreadcrumbList JSON-LD — home → collection → essay. Machine-mirror only;
// the rendered breadcrumb is the small "← {backLabel}" link at page head.
const siteHref = Astro.site ? Astro.site.href.replace(/\/$/, "") : "https://www.enkakanopi.world";
const collectionHref = `${siteHref}${backHref}`;
const ldBreadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Enka Kanopi", item: siteHref + "/" },
    { "@type": "ListItem", position: 2, name: backLabel, item: collectionHref },
    ...(canonical ? [{ "@type": "ListItem", position: 3, name: title, item: canonical }] : []),
  ],
};
---
<Base title={title} description={description ?? dek}>
  <article class="page essay">
    <a class="back" href={base + backHref}>&larr; {backLabel}</a>
    <header class="head">
      <span class="g"><Glyph name={glyph} size={34} accent /></span>
      <h1>{title}</h1>
      <p class="dek">{dek}</p>
      <p class="metarow">
        <StageTag stage={stage} tended={tended} />
        <span class="status"><span class="pin">status:</span> {status}</span>
        {essayDates && tendedHuman && <time class="tended-note" datetime={essayDates.modified}>last tended · {tendedHuman.toLowerCase()}</time>}
      </p>
    </header>
    {breath && (
      <aside class="breath" id="in-one-breath">
        <p class="breath-k">in one breath</p>
        <p class="breath-line">{breath}</p>
        <p class="breath-echo">{status}</p>
      </aside>
    )}
    <div class="prose stack">
      <slot />
    </div>
    <footer class="end">
      {farewell && <p class="farewell">{farewell}</p>}
      {seal && (
        <div class="maker" aria-labelledby="maker-caption">
          <svg class="seal-mark" viewBox="0 0 40 40" width="28" height="28" aria-hidden="true">
            {/* hand-pressed wax mark — subtly irregular; the irregularity IS the handcraft */}
            <path
              d="M20 3.4
                 C 27.6 3.1, 36.9 8.2, 36.6 18.8
                 C 36.3 27.4, 30.4 36.2, 20.4 36.4
                 C 12.1 36.7, 3.6 30.9, 3.4 20.6
                 C 3.2 12.5, 8.9 4.6, 20 3.4 Z"
              fill="var(--seal)" opacity="0.92"
            />
            <path
              d="M14 12 C 17 10.8, 21 11.2, 23 13"
              stroke="var(--paper)" stroke-width="0.9" fill="none" opacity="0.28" stroke-linecap="round"
            />
          </svg>
          <p class="maker-caption" id="maker-caption">the garden · summer 07/ 2026 · tended by Fang Rika ·</p>
        </div>
      )}
      <p class="correspond">
        If something here found you — the garden keeps a line open — say{" "}
        <a href="mailto:hello@enkakanopi.world">hello@enkakanopi.world</a>.
      </p>
      <div class="endrow">
        <Glyph name="light" size={22} />
        <a class="more" href={base + backHref}>more from {backLabel.toLowerCase()}</a>
      </div>
    </footer>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />
  <script type="application/ld+json" set:html={JSON.stringify(ldBreadcrumbs)} />
</Base>
<style>
  .essay { max-width: 46rem; padding-top: 0.5rem; }
  .back { font-family: var(--sans); font-size: 0.8rem; letter-spacing: 0.02em; color: var(--ink-faint); text-decoration: none; }
  .back:hover { color: var(--poppy); }
  .head { margin: 1.6rem 0 2.2rem; }
  .head .g { line-height: 0; margin-bottom: 0.8rem; }
  .head h1 { max-width: 22ch; }
  .dek { font-size: 1.2rem; color: var(--ink-soft); margin-top: 0.9rem; max-width: 46ch; }
  .status .pin { font-family: var(--sans); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-faint); }
  .metarow { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; margin-top: 1rem; }
  .status { font-family: var(--hand); font-size: 1.1rem; color: var(--canopy-deep); }
  .tended-note { font-family: var(--hand); font-size: 1.05rem; color: var(--canopy-deep); opacity: 0.85; }
  .breath { margin: 0 0 2.2rem; padding: 1rem 0 1.1rem; border-top: 1.1px solid var(--paper-edge); border-bottom: 1.1px solid var(--paper-edge); }
  .breath-k { font-family: var(--sans); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-faint); }
  .breath-line { font-family: var(--serif); font-style: italic; font-size: 1.08rem; line-height: 1.6; color: var(--ink-soft); max-width: var(--measure); margin-top: 0.45rem; }
  .breath-echo { font-family: var(--hand); font-size: 1rem; color: var(--ink-faint); margin-top: 0.4rem; }
  .end { margin-top: 3rem; padding-top: 1.4rem; border-top: 1.1px solid var(--paper-edge); }
  .farewell { font-family: var(--hand); font-size: 1.3rem; color: var(--canopy-deep); line-height: 1.45; max-width: 42ch; margin: 0 0 1.1rem; }
  /* G4 · maker's-mark seal — one held gesture at essay foot, above the correspondence line */
  .maker { display: flex; flex-direction: column; align-items: center; gap: 0.55rem; margin: 0.4rem 0 1.4rem; }
  .seal-mark { display: block; line-height: 0; }
  .maker-caption { font-family: var(--serif); font-size: 0.82rem; letter-spacing: 0.02em; color: var(--ink-soft); margin: 0; text-align: center; max-width: 42ch; }
  /* G3 · foot-of-essay correspondence line — prose, not a button */
  .correspond { font-family: var(--serif); font-size: 1rem; color: var(--ink-soft); line-height: 1.55; max-width: 46ch; margin: 0 0 1.2rem; }
  .correspond a { color: var(--ink-soft); text-decoration-thickness: 1px; text-underline-offset: 3px; text-decoration-color: var(--poppy-soft); }
  .correspond a:hover { color: var(--poppy); text-decoration-color: var(--poppy); }
  .endrow { display: flex; align-items: center; gap: 0.7rem; }
  .more { font-family: var(--sans); font-size: 0.82rem; color: var(--ink-faint); text-decoration: none; }
  .more:hover { color: var(--poppy); }
</style>
